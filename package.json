{
  "name": "cabala-dos-caminhos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build --experimental-build-mode=compile && next build --experimental-build-mode=generate",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:community": "vitest run src/components/community/__tests__",
    "test:ssr": "vitest run __tests__/ssr",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "e2e:screenshots": "playwright test e2e/screenshots.spec.ts",
    "ci:local": "bash scripts/ci-local.sh",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "seed:posts": "tsx prisma/seed/posts.ts",
    "seed:articles": "tsx prisma/seed/articles.ts",
    "seed:articles:batch4": "tsx prisma/seed/articles-batch-4.ts",
    "seed:articles:all": "tsx prisma/seed/articles-root.ts",
    "embed:articles": "tsx scripts/embed-articles.ts",
    "verify:notifications-realtime": "tsx scripts/verify-notifications-realtime.ts",
    "check:bundle": "tsx scripts/check-bundle-size.ts",
    "analyze:bundle": "ANALYZE=true next build",
    "analyze:bundle:open": "ANALYZE=true next build --turbo",
    "quality": "tsx scripts/run-quality-eval.ts",
    "quality:evolve": "tsx scripts/run-evolution.ts",
    "postbuild": "next-sitemap",
    "sitemap": "next-sitemap"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ioredis": "^5.6.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "openai": "^6.39.0",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.8.2",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.9",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/glob": "^8.1.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "glob": "^13.0.6",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^4.1.7",
    "web-push": "^3.6.7"
  }
}
