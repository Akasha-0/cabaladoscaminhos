{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/akasha-portal/src/*"],
      "@akasha/types": ["./packages/types/src/index.ts"],
      "@akasha/core": ["./packages/akasha-core/src/index.ts"],
      "@akasha/core-astrology": ["./packages/core-astrology/src/index.ts"],
      "@akasha/core-cabala": ["./packages/core-cabala/src/index.ts"],
      "@akasha/core-odus": ["./packages/core-odus/src/index.ts"],
      "@akasha/core-tantra": ["./packages/core-tantra/src/index.ts"],
      "@akasha/core-iching": ["./packages/core-iching/src/index.ts"],
      "@akasha/core-pilar6": ["./packages/core-pilar6/src/index.ts"],
      "@akasha/core-pilar7": ["./packages/core-pilar7/src/index.ts"],
      "@akasha/tratamento": ["./packages/tratamento/src/index.ts"],
      "@akasha/mentor": ["./packages/mentor/src/index.ts"],
      "@akasha/mentor/*": ["./packages/mentor/src/*"],
      "@akasha/mcp": ["./packages/mcp/src/index.ts"]     
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    "apps/akasha-portal/.next/types/**/*.ts",
    "apps/akasha-portal/.next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "apps/akasha-portal/.next",
    "apps/akasha-portal/scripts",
    "tests",
    "apps/akasha-portal/src/lib/application/akasha/synthesis-engine.test.ts",
    "apps/akasha-portal/src/lib/quality/__evals_DISABLED__/**/*",
    "apps/**/node_modules",
    "packages/**/node_modules",
    "traducao-areas.ts",
    "docs-site"
  ]
}
