{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "types": []
  },
  "include": [
    "engines/**/*",
    "spec/**/*",
    "smoke/**/*",
    "globs.d.ts"
  ]
}