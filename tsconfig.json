{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./apps/akasha-portal/src/*"],
      "@akasha/types": ["./packages/types/src/index.ts"],
      "@akasha/core-astrology": ["./packages/core-astrology/src/index.ts"],
      "@akasha/core-cabala": ["./packages/core-cabala/src/index.ts"],
      "@akasha/core-odus": ["./packages/core-odus/src/index.ts"],
      "@akasha/core-tantra": ["./packages/core-tantra/src/index.ts"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    "apps/akasha-portal/.next/types/**/*.ts",
    "apps/akasha-portal/.next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "apps/akasha-portal/.next",
    "apps/akasha-portal/scripts",
    "tests",
    "apps/akasha-portal/src/lib/quality/__evals_DISABLED__/**/*",
    "apps/**/node_modules",
    "packages/**/node_modules"
  ]
}
