{
  "semi": true,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": true,
  "trailingComma": "es5",
  "endOfLine": "lf",
  "plugins": ["@trivago/prettier-plugin-sort-imports"],
  "importOrder": [
    "^react-native$",
    "^next/(.*)$",
    "^@/(.*)$",
    "^~/components/(.*)$",
    "^~/lib/(.*)$",
    "^[../]",
    "^[./]"
  ],
  "importOrderSortType": "natural"
}