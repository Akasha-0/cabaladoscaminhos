{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"],
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/lib/w91/reputation-leaderboard-engine.ts",
    "src/components/community/leaderboard/LeaderboardWidget.tsx",
    "src/components/community/leaderboard/LeaderboardTable.tsx",
    "src/app/(community)/community/leaderboard/page.tsx",
    "next-env.d.ts",
    "src/types/**/*.d.ts"
  ]
}