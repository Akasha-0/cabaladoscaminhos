{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [],
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "preserve"
  },
  "include": [
    "src/components/events/RSVPForm.ts",
    "src/components/events/RSVPForm.helpers.ts",
    "src/components/events/RSVPForm.spec.ts",
    "src/components/events/node-stubs.d.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
