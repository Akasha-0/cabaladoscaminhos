// ============================================================================
// AKASHA PORTAL — COMUNIDADE
// ============================================================================
// Modelos adicionados em 2026-06-26 para a nova visão:
//   - Comunidade viva de espiritualidade universalista + IA co-evoluindo
//   - Posts, comentários, grupos por tradição, biblioteca de artigos
//   - Perfil espiritual público, follows, likes
// ============================================================================
// Estes modelos são ADITIVOS ao schema.prisma existente.
// Quando rodar prisma generate, copie este bloco pro final do schema principal.
// ============================================================================

// ENUMS da comunidade

enum Visibility {
  PUBLIC       // qualquer pessoa vê (mesmo sem login)
  COMMUNITY    // só membros logados
  PRIVATE      // só o próprio dono
}

enum GroupRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum ArticleType {
  SCIENTIFIC_PAPER
  MAGAZINE_ARTICLE
  BOOK
  VIDEO
  PODCAST
  ESSAY
}

enum EvidenceLevel {
  ANECDOTAL
  OBSERVATIONAL
  PEER_REVIEWED
  META_ANALYSIS
}

enum PostType {
  TEXT
  LINK
  ARTICLE
  QUESTION
  EXPERIENCE
  PRACTICE
}

enum NotificationType {
  NEW_FOLLOWER
  NEW_COMMENT
  NEW_LIKE
  GROUP_INVITE
  NEW_POST_FROM_FOLLOWED
  ARTICLE_RECOMMENDATION
  MENTION
}

// ============================================================================
// PERFIL ESPIRITUAL (camada pessoal, compartilhável)
// ============================================================================
// Espelha o mapa espiritual do usuário mas com visibilidade configurável.
// Mantém o cache do cálculo pra não recalcular toda hora.

model SpiritualProfile {
  id     String @id @default(cuid())
  userId String @unique

  // Dados de nascimento
  birthName     String
  birthDate     DateTime
  birthTime     String?
  birthPlace    String?

  // Resultado calculado pelo motor espiritual (cache)
  caminhoDeVida    Int?
  numeroPessoal    Int?
  oduNascimento    String?   // ex: "Alafia"
  orixaRegente     String?   // ex: "Oxalá"
  signoSolar       String?   // ex: "Escorpião"
  ascendente       String?
  elementoDominante String?

  // Mapa completo (JSON) — gerado pelos engines
  mapaJson Json?

  // Visibilidade do mapa
  visibility Visibility @default(COMMUNITY)

  // Bio curta que aparece no perfil
  bio String?

  // Onboarding flag
  onboardedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caminhoDeVida])
  @@index([signoSolar])
  @@index([oduNascimento])
  @@index([orixaRegente])
  @@map("spiritual_profiles")
}

// ============================================================================
// POSTS DA COMUNIDADE
// ============================================================================

model Post {
  id String @id @default(cuid())

  authorId String
  content  String @db.Text

  type     PostType @default(TEXT)
  // Tags rápidas
  tradition String?  // "cabala", "ifa", "xamanismo", "tantra", "reiki", "ayurveda",...
  topic    String?  // sub-tema: "meditacao", "ervas", "sonhos", "rituais",...
  // Para posts de link ou compartilhamento de artigo
  mediaUrls String[]
  linkUrl   String?
  // Para citações a fontes científicas
  references Json?  // [{title, url, doi, year}]

  // Grupo ao qual pertence (opcional)
  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // Contadores denormalizados (atualizar via trigger ou app)
  likesCount    Int @default(0)
  commentsCount Int @default(0)
  sharesCount   Int @default(0)

  comments Comment[]
  likes    Like[]

  // Soft delete
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId, createdAt])
  @@index([groupId, createdAt])
  @@index([tradition])
  @@index([topic])
  @@index([createdAt])
  @@map("posts")
}

model Comment {
  id String @id @default(cuid())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId String
  content  String @db.Text

  // Threading
  parentId String?
  parent   Comment?  @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("replies")

  likesCount Int @default(0)
  likes      CommentLike[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

// ============================================================================
// GRUPOS POR TRADIÇÃO / LINHA ESPIRITUAL
// ============================================================================

model Group {
  id          String  @id @default(cuid())
  slug        String  @unique  // "cabala", "ifa", "xamanismo", "tantra", "reiki", "ayurveda"
  name        String
  description String  @db.Text
  iconUrl     String?
  bannerUrl   String?
  tradition   String  // linha espiritual

  // Configurações
  isPublic    Boolean @default(true)
  requireApproval Boolean @default(false)

  membersCount Int @default(0)

  members GroupMember[]
  posts   Post[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tradition])
  @@map("groups")
}

model GroupMember {
  groupId String
  group   Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  role    GroupRole @default(MEMBER)

  joinedAt DateTime @default(now())

  @@id([groupId, userId])
  @@index([userId])
  @@map("group_members")
}

// ============================================================================
// BIBLIOTECA COLETIVA — Artigos, papers, livros
// ============================================================================

model Article {
  id    String @id @default(cuid())
  slug  String @unique
  title String

  summary String @db.Text  // resumo curto (preview)
  body    String @db.Text  // conteúdo completo (markdown)

  type          ArticleType
  tradition     String?     // "cabala", "ifa",...
  topics        String[]    // ["meditacao", "neurociencia",...]
  evidenceLevel EvidenceLevel @default(ANECDOTAL)

  // Referências externas
  doi         String?  // digital object identifier
  externalUrl String?
  references  Json?    // [{title, url, doi, year}]

  // Autoria
  authorId    String?  // se for um membro da comunidade
  contributor String?  // se for um autor externo (nome)

  // Estatísticas
  viewsCount    Int @default(0)
  likesCount    Int @default(0)
  bookmarksCount Int @default(0)

  // Embeddings para busca semântica (Fase 3)
  // embedding Unsupported("vector(1536)")? -- quando ativar pgvector

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([tradition])
  @@index([evidenceLevel])
  @@index([publishedAt])
  @@index([topics])
  @@map("articles")
}

// ============================================================================
// SOCIAL GRAPH
// ============================================================================

model Follow {
  followerId String
  followedId String

  createdAt DateTime @default(now())

  @@id([followerId, followedId])
  @@index([followedId])
  @@map("follows")
}

model Like {
  userId String
  postId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, postId])
  @@index([postId])
  @@map("likes")
}

model CommentLike {
  userId    String
  commentId String

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, commentId])
  @@index([commentId])
  @@map("comment_likes")
}

model Bookmark {
  id     String @id @default(cuid())
  userId String
  articleId String

  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([userId])
  @@map("bookmarks")
}

// ============================================================================
// NOTIFICAÇÕES
// ============================================================================

model Notification {
  id     String @id @default(cuid())
  userId String  // destinatário
  type   NotificationType

  // Quem gerou (opcional)
  actorId String?

  // Referência ao objeto relacionado
  postId    String?
  commentId String?
  groupId   String?
  articleId String?

  // Conteúdo extra (texto, payload custom)
  payload Json?

  read Boolean @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================================
// CONTEÚDO CURADO POR IA (Fase 3 — IA Curadora)
// ============================================================================
// Histórico de respostas da IA, para co-evolução e feedback da comunidade.

model AiConversation {
  id     String @id @default(cuid())
  userId String

  title String?  // pode ser auto-gerado do primeiro prompt

  messages AiMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String  // "user" | "assistant" | "system"
  content String  @db.Text

  // Fontes que a IA usou pra responder (artigos da biblioteca)
  sources Json?  // [articleId, articleId, ...]

  // Feedback da comunidade (pra treinar/melhorar)
  helpful   Boolean?
  feedbackText String?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

// ============================================================================
// VIEW DO FEED (denormalizada para performance)
// ============================================================================
// Pré-computa o que aparece na timeline de cada usuário.
// Atualizada por triggers do Postgres ou via cron.

model FeedItem {
  id     String @id @default(cuid())
  userId String  // pra quem é esse item de feed

  // O que é esse item
  postId String?

  // Score (quanto maior, mais relevante)
  score Float

  // Razão ("followed_user_post", "group_post", "trending_topic", "article_recommendation")
  reason String

  seen Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, seen, createdAt])
  @@index([userId, createdAt])
  @@map("feed_items")
}
