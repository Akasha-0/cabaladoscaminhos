generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// AKASHA PORTAL — SCHEMA CONSOLIDADO (2026-06-27)
// ============================================================================
// Refs: ARCHITECTURE v3.0 §3 (Remove B2B/Zelador/Ferramentas pessoais)
// Refs: gap analysis 2026-06-27 P0 #1 (mesclar schema + remover B2B)
//
// Histórico:
//   - 2026-06-26: comunidade adicionada em prisma/community.prisma (18 modelos)
//   - 2026-06-27: community.prisma mesclado neste arquivo. 12 modelos B2B
//     legacy removidos (Operator, Client, Reading, Report, Assinatura,
//     Credito, TransacaoCredito, Empresa, Reminder, BirthChart,
//     SynastryResult, LeituraHistorico).
//
// Visão:
//   - Comunidade viva de espiritualidade universalista + IA co-evoluindo
//   - Posts, comentários, grupos por tradição, biblioteca de artigos
//   - Perfil espiritual público, follows, likes
//   - User é o agregado raiz; mapaNatal + spiritualProfile coexistem
// ============================================================================

// ============================================================================
// ENUMS — COMUNIDADE
// ============================================================================

enum Visibility {
  PUBLIC       // qualquer pessoa vê (mesmo sem login)
  COMMUNITY    // só membros logados
  PRIVATE      // só o próprio dono
}

enum GroupRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum ArticleType {
  SCIENTIFIC_PAPER
  MAGAZINE_ARTICLE
  BOOK
  VIDEO
  PODCAST
  ESSAY
}

// 2026-06-27 — alinhado com GRADE system para a Biblioteca Akasha
// HIGH        = revisões sistemáticas / meta-análises de RCTs
// MEDIUM      = RCTs individuais ou coortes bem desenhadas
// LOW         = observacionais pequenos / séries de casos
// ANECDOTAL   = ensaios, opinião de especialista, valor tradicional
enum EvidenceLevel {
  ANECDOTAL
  LOW
  MEDIUM
  HIGH
}

enum PostType {
  TEXT
  LINK
  ARTICLE
  QUESTION
  EXPERIENCE
  PRACTICE
}

// 2026-06-27 — Onda 14b Drafts & Scheduled Publishing
// DRAFT     → usuário está escrevendo (não aparece no feed)
// SCHEDULED → tem scheduledFor no futuro; cron publica ao chegar a hora
// PUBLISHED → publicado normalmente (default; comportamento legado)
// ARCHIVED  → oculto do feed, mantido para histórico do autor
enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  // Social graph
  LIKE
  COMMENT
  POST_REPLY
  FOLLOW
  MENTION
  // Community
  GROUP_INVITE
  GROUP_POST
  GROUP_ROLE_CHANGE
  // Content
  ARTICLE_RECOMMENDATION
  ARTICLE_PUBLISHED
  // System
  SYSTEM_ALERT
  MODERATION_ACTION
  // Meta
  DIGEST_WEEKLY
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum EntityType {
  POST
  COMMENT
  USER
  GROUP
  ARTICLE
  MENTION
  SYSTEM
}

enum GroupInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

// 2026-06-27 — Onda 13 Mentorship 1-on-1
// PENDING  = mentee solicitou, mentor ainda não aceitou
// ACTIVE   = mentor aceitou, em andamento
// COMPLETED = encerrado por qualquer das partes (endedAt preenchido)
enum MentorshipStatus {
  PENDING
  ACTIVE
  COMPLETED
}

// ============================================================================
// CURADOR / USER ROLES — Wave 35 (2026-07-01)
// ============================================================================
// Hierarquia de papéis do sistema (UserRole) + papéis específicos do
// subtree de curadores (CuratorRole) + ciclo de vida de convites.
//
// LGPD: dados de credenciais são opcionais e exigem consentimento
// explícito no aceite do convite (Art. 7º, I).
//
// Universalismo:
//  - Nenhuma tradição é superior; curadores representam com igualdade
//  - Curador pode revisar conteúdo de outras tradições via flag cruzada
//  - Iyá tem poder de veto + última palavra em conflito de revisão
//
// IMPORTANTE: estes enums são definidos aqui (antes do model User)
// porque Prisma exige resolução forward-free.
// ============================================================================

enum UserRole {
  USER           // membro regular da comunidade
  ADMIN          // admin operacional (escape hatch via ADMIN_EMAILS/planoAssinatura)
  IYA            // curadora-chefe (raiz do subtree Curator)
  CURATOR        // curador convidado (qualquer tradição, ativo)
  GUEST_CURATOR  // curador temporário (especialista convidado — prazo fixo)
}

enum CuratorRole {
  IYA                 // Iyá principal (curadora-chefe)
  CURATOR_CABALA      // curador convidado Cabala
  CURATOR_IFA         // curador convidado Ifá
  CURATOR_TANTRA      // curador convidado Tantra/Astrologia
  CURATOR_ASTROLOGIA  // curador convidado Astrologia (sub-trilha)
  GUEST_CURATOR       // curador temporário (especialista convidado)
}

enum CuratorInvitationStatus {
  PENDING   // convite enviado, ainda não aceito
  ACCEPTED  // curador aceitou e ativou perfil
  DECLINED  // recusa explícita
  EXPIRED   // passou do deadline (14d default)
  REVOKED   // Iyá/Admin cancelou manualmente
}

// ============================================================================
// MENTORSHIP V2 — Onda 35 (2026-07-01)
// Aplicação estruturada, matching automático, sessões agendadas, feedback.
// Universalismo: suporta todas as tradições canônicas (12 listadas em
// src/app/(community)/mentorship/page.tsx).
// LGPD Art. 7 (consentimento), Art. 18 (direitos do titular),
// Art. 37 (registro de operações) — bio/approach/availability são tratados
// como dados pessoais sensíveis (autoria declarada) e exigem base legal.
// ============================================================================

enum MentorApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  INACTIVE
}

enum MentorshipPairStatus {
  PROPOSED
  ACTIVE
  PAUSED
  COMPLETED
  ENDED
}

enum MentorshipSessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MentorshipSessionType {
  INTAKE
  REGULAR
  CHECK_IN
  CLOSING
}

// ============================================================================
// USER — agregado raiz
// ============================================================================
// Mantido do schema legacy. Removidas relações para modelos B2B deletados
// (assinatura, credito, empresas, historicoLeituras). Stripe fields
// preservados por ora (cleanup B2B completo é tarefa separada).
// ============================================================================

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String?
  nomeCompleto    String
  dataNascimento  DateTime
  horaNascimento  String?
  localNascimento String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  journalEntries JournalEntry[]
  mapaNatal      MapaNatal?
  temaPreferido  String        @default("mystical")

  supabaseUserId       String? @unique
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  planoAssinatura      String?

  // 2026-06-27 — Onda 13 Mentorship
  // Flag opcional: usuário pode oferecer mentoria na comunidade
  isMentor        Boolean   @default(false)
  // Tradições que o mentor pratica (slug canônico: cabala, ifa, tantra, ...)
  mentorTraditions String[] @default([])
  // Bio curta do mentor (até 500 chars)
  mentorBio       String?
  // Rating médio agregado (0.00–5.00, atualizado por trigger/event)
  mentorRating    Float     @default(0)
  // Total de mentorias já concluídas (denormalizado p/ ranking)
  mentorCompleted Int       @default(0)

  // 2026-06-27 — Wave 14 Newsletter
  // Inscrição em newsletter (opcional). Cada usuário pode ter no máximo uma.
  newsletterSubscription NewsletterSubscription?

  // 2026-06-27 — Wave 18 Akasha IA feedback
  // Histórico de 👍/👎 dados em respostas da Akasha (analytics + retreino).
  akashicFeedback AkashicFeedback[]

  // 2026-07-01 — Wave 35 Akasha Personalization
  // Memória de longo prazo do user (opt-in) + histórico de conversas
  akashaMemory               UserAkashaMemory?
  akashaConversationMemory   AkashaConversationMemory[]

  // 2026-06-30 — Wave 30 Stripe Connect marketplace
  connectAccount       ConnectAccount?
  paymentsAsReader     Payment[]       @relation("PaymentReader")
  paymentsAsClient     Payment[]       @relation("PaymentClient")
  paymentsAsAffiliate  Payment[]       @relation("PaymentAffiliate")
  payouts              Payout[]

  // 2026-06-30 — Wave 32 Beta Invite System
  // Convites que este usuário gerou (referral / admin) + convites que ele aceitou
  betaInvitesSent     BetaInvite[]    @relation("BetaInviteInviter")
  betaInvitesAccepted BetaInvite[]    @relation("BetaInviteAcceptor")

  // 2026-07-01 — Wave 35 Beta Onboarding (1/8)
  // Máquina de estados do primeiro acesso após convite beta (W32-2).
  // Default INVITED para usuários que vieram via convite; signup orgânico
  // começa em SIGNED_UP (skip welcome carousel).
  onboardingState        OnboardingState @default(INVITED)
  // Step atual dentro do welcome carousel (0..3). Persistido para
  // retomo entre devices (cookie + DB).
  onboardingWelcomeStep  Int             @default(0)
  // Tradição preferida selecionada no profile wizard (slug canônico).
  // nullable — usuário pode pular.
  preferredTradition     String?
  // Práticas preferidas (multi-select): meditation, prayer, ritual, study,
  // journaling, yoga, breathwork, divination.
  practicePreferences    String[]        @default([])
  // Email notification prefs (5 categorias booleanas). Default tudo OFF.
  emailPrefsNewContent   Boolean         @default(false)
  emailPrefsCommunity    Boolean         @default(false)
  emailPrefsMentorship   Boolean         @default(false)
  emailPrefsMarketing    Boolean         @default(false)
  emailPrefsNpsSurveys   Boolean         @default(true)
  // LGPD refresh timestamp — última vez que usuário confirmou consent
  // ativo na nova versão do privacy policy.
  lgpdRefreshedAt        DateTime?
  // Display name público (separado de nomeCompleto que é certidão).
  // Default = primeira parte de nomeCompleto.
  displayName            String?
  // Avatar URL (Cloudinary ou similar). Default = null (iniciais).
  avatarUrl              String?
  // Bio pública (max 280 chars enforced em validation layer).
  bioPublic              String?
  // Onboarding events (analytics + retomo). Append-only LGPD art. 37.
  onboardingEvents       OnboardingEvent[]
  // Skip-all flag — usuário pediu para nunca mais ver onboarding.
  onboardingSkippedAll   Boolean         @default(false)

  // 2026-07-01 — Wave 35 Marketplace Practitioner
  // Papel funcional (separado de planoAssinatura que é comercial):
  //   USER        → default; pode comprar e consumir
  //   PRACTITIONER → VERIFIED; pode publicar offerings e receber pagamentos
  //   ADMIN       → curador Iyá + ops
  // Transições controladas pelo admin verification dashboard.
  practitionerRole   String  @default("USER")
  // Status derivado da última verificação (cache p/ queries rápidas)
  practitionerStatus String  @default("NONE")
  // Média de reviews (0.00..5.00) — denormalizado
  practitionerAvgRating Float  @default(0)
  // Total de reviews recebidas
  practitionerReviewCount Int @default(0)

  // 2026-07-01 — Wave 35 reverse relations
  practitionerVerification PractitionerVerification?
  offeringsAsPractitioner  MarketplaceOffering[]   @relation("OfferingPractitioner")
  reviewsWritten           MarketplaceReview[]     @relation("ReviewAuthor")
  reviewsReceived          MarketplaceReview[]     @relation("ReviewPractitioner")
  escrowAsBuyer            EscrowTransaction[]     @relation("EscrowBuyer")
  escrowAsPractitioner     EscrowTransaction[]     @relation("EscrowPractitioner")

  // 2026-07-01 — Wave 35 Curator System
  // Papel do usuário na hierarquia. Default USER para novos signups.
  // ADMIN/Iyá continuam sendo resolvidos também via ADMIN_EMAILS/planoAssinatura
  // (defense-in-depth: a coluna aqui espelha o papel operacional).
  role                UserRole        @default(USER)
  curatorProfile      CuratorProfile?

  @@index([role])
  @@index([planoAssinatura])
  @@index([isMentor])
  @@index([createdAt])
  @@index([dataNascimento])
  @@index([stripeSubscriptionId])
  @@map("users")
}

// =====================
// MAPA NATAL (Cálculos)
// =====================

model MapaNatal {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  signoSolar String?
  signoLunar String?
  ascendente String?

  numeroCabalistico Int?
  numeroTantrico    Int?
  numeroPitagorico  Int?
  numeroCaldeu      Int?
  numeroCarmico     Int?

  oduPrincipal  String?
  oduSecundario String?

  arcanoPessoal Int?
  cartaCaminho  String?

  sefirotDominante String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([signoSolar])
  @@index([numeroPitagorico])
  @@index([arcanoPessoal])
  @@index([createdAt])
  @@map("mapa_natal")
}

// =====================
// BASE DE CONHECIMENTO
// =====================

model DiaSemana {
  id       String @id @default(cuid())
  nome     String @unique
  numero   Int    @unique
  planeta  String
  elemento String
  cor      String

  orixas Orixa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dias_semana")
}

model Orixa {
  id              String   @id @default(cuid())
  nome            String   @unique
  saudacao        String
  planeta         String
  elemento        String
  cores           String[]
  chakraPrincipal Int

  hierbas Erva[]

  quizilas String[]

  dias DiaSemana[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orixas")
}

model Chakra {
  id       String   @id @default(cuid())
  numero   Int      @unique
  nome     String   @unique
  cor      String
  elemento String
  glandula String?
  mantras  String[]
  funcoes  String[]

  sefirotId String?  @unique
  sefirot   Sefirot? @relation(fields: [sefirotId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chakras")
}

model Sefirot {
  id      String @id @default(cuid())
  numero  Int    @unique
  nome    String @unique
  caminho String
  aspecto String
  cor     String

  planeta String?

  chakra Chakra?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sefirots")
}

model Odú {
  id           String @id @default(cuid())
  numero       Int    @unique
  nome         String @unique
  significado  String
  elemento     String
  planeta      String
  orixaRegente String

  quizilas  String[]
  preceptos String[]
  ebos      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("odus")
}

model Erva {
  id   String   @id @default(cuid())
  nome String   @unique
  tipo String
  uso  String[]

  orixas Orixa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ervas")
}

model FaseLua {
  id      String   @id @default(cuid())
  nome    String   @unique
  energia String
  rituais String[]
  evitar  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fases_lua")
}

model Elemento {
  id         String   @id @default(cuid())
  nome       String   @unique
  simbolo    String
  qualidades String[]
  direcoes   String[]
  cores      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("elementos")
}

