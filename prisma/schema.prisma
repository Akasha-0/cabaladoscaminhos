generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AKASHA PORTAL — SCHEMA CONSOLIDADO (2026-06-27)
// ============================================================================
// Refs: ARCHITECTURE v3.0 §3 (Remove B2B/Zelador/Ferramentas pessoais)
// Refs: gap analysis 2026-06-27 P0 #1 (mesclar schema + remover B2B)
//
// Histórico:
//   - 2026-06-26: comunidade adicionada em prisma/community.prisma (18 modelos)
//   - 2026-06-27: community.prisma mesclado neste arquivo. 12 modelos B2B
//     legacy removidos (Operator, Client, Reading, Report, Assinatura,
//     Credito, TransacaoCredito, Empresa, Reminder, BirthChart,
//     SynastryResult, LeituraHistorico).
//
// Visão:
//   - Comunidade viva de espiritualidade universalista + IA co-evoluindo
//   - Posts, comentários, grupos por tradição, biblioteca de artigos
//   - Perfil espiritual público, follows, likes
//   - User é o agregado raiz; mapaNatal + spiritualProfile coexistem
// ============================================================================

// ============================================================================
// ENUMS — COMUNIDADE
// ============================================================================

enum Visibility {
  PUBLIC       // qualquer pessoa vê (mesmo sem login)
  COMMUNITY    // só membros logados
  PRIVATE      // só o próprio dono
}

enum GroupRole {
  MEMBER
  MODERATOR
  ADMIN
}

enum ArticleType {
  SCIENTIFIC_PAPER
  MAGAZINE_ARTICLE
  BOOK
  VIDEO
  PODCAST
  ESSAY
}

// 2026-06-27 — alinhado com GRADE system para a Biblioteca Akasha
// HIGH        = revisões sistemáticas / meta-análises de RCTs
// MEDIUM      = RCTs individuais ou coortes bem desenhadas
// LOW         = observacionais pequenos / séries de casos
// ANECDOTAL   = ensaios, opinião de especialista, valor tradicional
enum EvidenceLevel {
  ANECDOTAL
  LOW
  MEDIUM
  HIGH
}

enum PostType {
  TEXT
  LINK
  ARTICLE
  QUESTION
  EXPERIENCE
  PRACTICE
}

// 2026-06-27 — Onda 14b Drafts & Scheduled Publishing
// DRAFT     → usuário está escrevendo (não aparece no feed)
// SCHEDULED → tem scheduledFor no futuro; cron publica ao chegar a hora
// PUBLISHED → publicado normalmente (default; comportamento legado)
// ARCHIVED  → oculto do feed, mantido para histórico do autor
enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  // Social graph
  LIKE
  COMMENT
  POST_REPLY
  FOLLOW
  MENTION
  // Community
  GROUP_INVITE
  GROUP_POST
  GROUP_ROLE_CHANGE
  // Content
  ARTICLE_RECOMMENDATION
  ARTICLE_PUBLISHED
  // System
  SYSTEM_ALERT
  MODERATION_ACTION
  // Meta
  DIGEST_WEEKLY
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
}

enum EntityType {
  POST
  COMMENT
  USER
  GROUP
  ARTICLE
  MENTION
  SYSTEM
}

enum GroupInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  REVOKED
}

// 2026-06-27 — Onda 13 Mentorship 1-on-1
// PENDING  = mentee solicitou, mentor ainda não aceitou
// ACTIVE   = mentor aceitou, em andamento
// COMPLETED = encerrado por qualquer das partes (endedAt preenchido)
enum MentorshipStatus {
  PENDING
  ACTIVE
  COMPLETED
}

// ============================================================================
// USER — agregado raiz
// ============================================================================
// Mantido do schema legacy. Removidas relações para modelos B2B deletados
// (assinatura, credito, empresas, historicoLeituras). Stripe fields
// preservados por ora (cleanup B2B completo é tarefa separada).
// ============================================================================

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String?
  nomeCompleto    String
  dataNascimento  DateTime
  horaNascimento  String?
  localNascimento String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  journalEntries JournalEntry[]
  mapaNatal      MapaNatal?
  temaPreferido  String        @default("mystical")

  supabaseUserId       String? @unique
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  planoAssinatura      String?

  // 2026-06-27 — Onda 13 Mentorship
  // Flag opcional: usuário pode oferecer mentoria na comunidade
  isMentor        Boolean   @default(false)
  // Tradições que o mentor pratica (slug canônico: cabala, ifa, tantra, ...)
  mentorTraditions String[] @default([])
  // Bio curta do mentor (até 500 chars)
  mentorBio       String?
  // Rating médio agregado (0.00–5.00, atualizado por trigger/event)
  mentorRating    Float     @default(0)
  // Total de mentorias já concluídas (denormalizado p/ ranking)
  mentorCompleted Int       @default(0)

  // 2026-06-27 — Wave 14 Newsletter
  // Inscrição em newsletter (opcional). Cada usuário pode ter no máximo uma.
  newsletterSubscription NewsletterSubscription?

  // 2026-06-27 — Wave 18 Akasha IA feedback
  // Histórico de 👍/👎 dados em respostas da Akasha (analytics + retreino).
  akashicFeedback AkashicFeedback[]

  // 2026-06-30 — Wave 30 Stripe Connect marketplace
  connectAccount       ConnectAccount?
  paymentsAsReader     Payment[]       @relation("PaymentReader")
  paymentsAsClient     Payment[]       @relation("PaymentClient")
  paymentsAsAffiliate  Payment[]       @relation("PaymentAffiliate")
  payouts              Payout[]

  // 2026-06-30 — Wave 32 Beta Invite System
  // Convites que este usuário gerou (referral / admin) + convites que ele aceitou
  betaInvitesSent     BetaInvite[]    @relation("BetaInviteInviter")
  betaInvitesAccepted BetaInvite[]    @relation("BetaInviteAcceptor")

  @@index([planoAssinatura])
  @@index([isMentor])
  @@index([createdAt])
  @@index([dataNascimento])
  @@index([stripeSubscriptionId])
  @@map("users")
}

// =====================
// MAPA NATAL (Cálculos)
// =====================

model MapaNatal {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  signoSolar String?
  signoLunar String?
  ascendente String?

  numeroCabalistico Int?
  numeroTantrico    Int?
  numeroPitagorico  Int?
  numeroCaldeu      Int?
  numeroCarmico     Int?

  oduPrincipal  String?
  oduSecundario String?

  arcanoPessoal Int?
  cartaCaminho  String?

  sefirotDominante String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([signoSolar])
  @@index([numeroPitagorico])
  @@index([arcanoPessoal])
  @@index([createdAt])
  @@map("mapa_natal")
}

// =====================
// BASE DE CONHECIMENTO
// =====================

model DiaSemana {
  id       String @id @default(cuid())
  nome     String @unique
  numero   Int    @unique
  planeta  String
  elemento String
  cor      String

  orixas Orixa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dias_semana")
}

model Orixa {
  id              String   @id @default(cuid())
  nome            String   @unique
  saudacao        String
  planeta         String
  elemento        String
  cores           String[]
  chakraPrincipal Int

  hierbas Erva[]

  quizilas String[]

  dias DiaSemana[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orixas")
}

model Chakra {
  id       String   @id @default(cuid())
  numero   Int      @unique
  nome     String   @unique
  cor      String
  elemento String
  glandula String?
  mantras  String[]
  funcoes  String[]

  sefirotId String?  @unique
  sefirot   Sefirot? @relation(fields: [sefirotId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chakras")
}

model Sefirot {
  id      String @id @default(cuid())
  numero  Int    @unique
  nome    String @unique
  caminho String
  aspecto String
  cor     String

  planeta String?

  chakra Chakra?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sefirots")
}

model Odú {
  id           String @id @default(cuid())
  numero       Int    @unique
  nome         String @unique
  significado  String
  elemento     String
  planeta      String
  orixaRegente String

  quizilas  String[]
  preceptos String[]
  ebos      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("odus")
}

model Erva {
  id   String   @id @default(cuid())
  nome String   @unique
  tipo String
  uso  String[]

  orixas Orixa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ervas")
}

model FaseLua {
  id      String   @id @default(cuid())
  nome    String   @unique
  energia String
  rituais String[]
  evitar  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fases_lua")
}

model Elemento {
  id         String   @id @default(cuid())
  nome       String   @unique
  simbolo    String
  qualidades String[]
  direcoes   String[]
  cores      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("elementos")
}

// =====================
// INSIGHTS E CONVERSAS — REMOVIDOS Wave 21 (2026-06-28)
// =====================
// Models órfãos do schema B2B pré-v3.0. Substituídos por:
//   - AkashicFeedback (voto 👍/👎 em respostas da IA — Wave 18)
//   - MentorshipMessage (chat 1-on-1 de mentorias — Onda 13)
// Migration de drop: prisma/migrations/20260628_legacy_cleanup_w21/migration.sql
// Investigação completa: docs/LEGACY-CLEANUP-W21.md
// =====================
// (bloco intencionalmente vazio)

// =====================
// FAVORITOS — REMOVIDO Wave 21 (2026-06-28)
// =====================
// Substituído por Bookmark (articles) + PostBookmark (posts com collections),
// ambos adicionados em Onda 14 (2026-06-27). Cobertura completa em v3.0.
// Migration de drop: prisma/migrations/20260628_legacy_cleanup_w21/migration.sql
// Investigação completa: docs/LEGACY-CLEANUP-W21.md
// =====================
// (bloco intencionalmente vazio)

// =====================
// JOURNAL
// =====================

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  content   String
  mood      String?
  tags      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([mood])
  @@index([createdAt])
  @@map("journal_entries")
}

// ============================================================================
// COMUNIDADE — modelos adicionados em 2026-06-26 (mesclados em 2026-06-27)
// ============================================================================

// ============================================================================
// PERFIL ESPIRITUAL (camada pessoal, compartilhável)
// ============================================================================
// Espelha o mapa espiritual do usuário mas com visibilidade configurável.
// Mantém o cache do cálculo pra não recalcular toda hora.

model SpiritualProfile {
  id     String @id @default(cuid())
  userId String @unique

  // Dados de nascimento
  birthName     String
  birthDate     DateTime
  birthTime     String?
  birthPlace    String?

  // Resultado calculado pelo motor espiritual (cache)
  caminhoDeVida    Int?
  numeroPessoal    Int?
  oduNascimento    String?   // ex: "Alafia"
  orixaRegente     String?   // ex: "Oxalá"
  signoSolar       String?   // ex: "Escorpião"
  ascendente       String?
  elementoDominante String?

  // Mapa completo (JSON) — gerado pelos engines
  mapaJson Json?

  // Visibilidade do mapa
  visibility Visibility @default(COMMUNITY)

  // Bio curta que aparece no perfil
  bio String?

  // Onboarding flag
  onboardedAt DateTime?

  // 2026-06-27 — Onda 12 Search & Discovery
  searchVector Unsupported("tsvector")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caminhoDeVida])
  @@index([signoSolar])
  @@index([oduNascimento])
  @@index([orixaRegente])
  @@map("spiritual_profiles")
}

// ============================================================================
// POSTS DA COMUNIDADE
// ============================================================================

model Post {
  id String @id @default(cuid())

  authorId String
  content  String @db.Text

  type     PostType @default(TEXT)
  // Tags rápidas
  tradition String?  // "cabala", "ifa", "xamanismo", "tantra", "reiki", "ayurveda",...
  topic    String?  // sub-tema: "meditacao", "ervas", "sonhos", "rituais",...
  // Para posts de link ou compartilhamento de artigo
  mediaUrls String[]
  linkUrl   String?
  // Para citações a fontes científicas
  references Json?  // [{title, url, doi, year}]

  // Grupo ao qual pertence (opcional)
  groupId String?
  group   Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // Contadores denormalizados (atualizar via trigger ou app)
  likesCount    Int @default(0)
  commentsCount Int @default(0)
  sharesCount   Int @default(0)

  comments Comment[]
  likes    Like[]

  // Soft delete
  deletedAt DateTime?

  // 2026-06-27 — Onda 14b Drafts & Scheduled Publishing
  // status default PUBLISHED mantém compat com posts já criados antes da migration.
  // scheduledFor + status=SCHEDULED é o "agendado para publicar".
  // publishedAt é preenchido quando transita para PUBLISHED (imediato ou via cron).
  status        PostStatus  @default(PUBLISHED)
  scheduledFor  DateTime?
  publishedAt   DateTime?

  // 2026-06-27 — Onda 12 Search & Discovery
  // Coluna tsvector populada por trigger Postgres (ver migration search_discovery)
  // GIN index + pg_trgm index criados no SQL (não no Prisma)
  searchVector Unsupported("tsvector")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId, createdAt])
  @@index([groupId, createdAt])
  @@index([tradition])
  @@index([topic])
  @@index([createdAt])
  @@index([status, scheduledFor])
  @@index([authorId, status])
  @@map("posts")
}

model Comment {
  id String @id @default(cuid())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  authorId String
  content  String @db.Text

  // Threading
  parentId String?
  parent   Comment?  @relation("replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("replies")

  likesCount Int @default(0)
  likes      CommentLike[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, createdAt])
  @@index([authorId])
  @@index([parentId])
  @@map("comments")
}

// ============================================================================
// GRUPOS POR TRADIÇÃO / LINHA ESPIRITUAL
// ============================================================================
// Cada grupo representa uma sub-comunidade focada em uma tradição.
// Hierarquia de papéis: ADMIN (criador/promovido) > MODERATOR > MEMBER.
// ============================================================================

model Group {
  id          String  @id @default(cuid())
  slug        String  @unique  // "cabala", "ifa", "xamanismo", "tantra", "reiki", "ayurveda"
  name        String
  description String  @db.Text
  longDescription String? @db.Text  // descrição longa exibida na aba "Sobre"
  rules       String[]            // regras da comunidade (3-5 itens curtos)
  iconUrl     String?             // avatar (ícone/emoji)
  bannerUrl   String?             // cover image
  tradition   String              // linha espiritual (ex: "cabala", "ifa")

  // Configurações
  isPublic    Boolean @default(true)         // false = requer invite
  requireApproval Boolean @default(false)    // futuro: fila de aprovação

  // Quem criou o grupo (referência a User/Operator por id)
  createdBy   String?

  // Contadores denormalizados (atualizar via app)
  membersCount Int @default(0)
  postsCount   Int @default(0)

  members GroupMember[]
  invites GroupInvite[]
  posts   Post[]
  events  Event[]

  // 2026-06-27 — Onda 12 Search & Discovery
  searchVector Unsupported("tsvector")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tradition])
  @@index([isPublic])
  @@index([createdBy])
  @@map("groups")
}

model GroupMember {
  groupId String
  group   Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  role    GroupRole @default(MEMBER)

  // Quem convidou (opcional — audit trail)
  invitedBy String?

  joinedAt DateTime @default(now())

  @@id([groupId, userId])
  @@index([userId])
  @@index([role])
  @@map("group_members")
}

model GroupInvite {
  id        String   @id @default(cuid())
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  // Token único compartilhado no link de invite
  token     String   @unique

  // Quem convidou (moderador/admin)
  invitedBy String

  // Destinatário (id do usuário convidado, ou null se email-link)
  inviteeUserId String?
  inviteeEmail  String?

  // Quem aceitou (caso tenha sido por link com usuário)
  acceptedBy    String?
  acceptedAt    DateTime?

  status    GroupInviteStatus @default(PENDING)
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@index([groupId, status])
  @@index([inviteeUserId])
  @@map("group_invites")
}

// ============================================================================
// BIBLIOTECA COLETIVA — Artigos, papers, livros
// ============================================================================
// Atualizado em 2026-06-27 para a "Biblioteca Akasha Curada":
//   - Campos bibliográficos formais (authors[], journal, year, citations)
//   - Idioma e level de evidência GRADE-aligned
//   - Tags livres + tradition canônica
//   - Métricas (viewCount, bookmarkCount, citations) para ranking
// ============================================================================

model Article {
  id    String @id @default(cuid())
  slug  String @unique
  title String

  // Conteúdo
  summary String @db.Text  // resumo curto (~200 palavras, PT-BR) — preview
  content String @db.Text  // conteúdo completo (markdown PT-BR)

  // --- Bibliographic core ---
  // Autores estruturados como JSON para suportar "Lastname FM, Lastname FM" no citation
  // e futuro link a um Author canônico. Mantemos compat com o campo antigo `contributor`.
  authors   String[]  // ["Griffiths RR", "Johnson MW", ...]
  journal   String?   // "JAMA Psychiatry", "Cochrane Database Syst Rev", ...
  year      Int       // ano de publicação
  doi       String?   // DOI canônico (sem prefixo https://doi.org/)
  url       String?   // URL externa (DOI URL, PubMed, OpenAlex landing)

  // --- Tags / tradição ---
  tags      String[]    // ["meditacao", "neurociencia", "mbsr", ...]
  tradition String?     // "meditacao", "xamanismo", "cabala", "ifa", "tantra", "reiki", ...

  // --- Avaliação de evidência (GRADE-aligned) ---
  evidenceLevel EvidenceLevel @default(ANECDOTAL)

  // Idioma do paper original (article.language). O conteúdo do Akasha é sempre PT-BR.
  language  String  @default("en")  // "en" | "pt" | "es"

  // --- Mantidos por compat ---
  type          ArticleType     @default(SCIENTIFIC_PAPER)
  body          String?         @db.Text  // alias histórico de `content`
  topics        String[]                  // alias histórico de `tags` (mantido populado igual)
  externalUrl   String?                   // alias histórico de `url`
  references    Json?            // [{title, url, doi, year}]
  authorId      String?
  contributor   String?

  // --- Métricas ---
  citations      Int @default(0)  // citações externas (do Crossref/OpenAlex)
  viewCount      Int @default(0)  // visualizações no Akasha
  bookmarkCount  Int @default(0)  // saves dos usuários
  likesCount     Int @default(0)  // likes (mantido para compat)

  // Embeddings para recomendação semântica (Fase 3 — Akasha IA)
  // Ativado em 2026-06-27 — pgvector com dimensão 1536 (OpenAI text-embedding-3-small)
  // Migration: prisma/migrations/20260627_000000_pgvector_enable/migration.sql
  embedding Unsupported("vector(1536)")?

  // 2026-06-27 — Onda 12 Search & Discovery
  // Coluna tsvector populada por trigger Postgres (ver migration search_discovery)
  searchVector Unsupported("tsvector")?

  // --- Auditoria / proveniência ---
  // Quem inseriu (curador humano ou seed-bot)
  curatedBy  String?
  // Fonte de onde veio (openalex-id W..., pubmed-id PMID..., manual, ...)
  source     String?
  // Hash para detectar duplicatas em re-seed
  sourceHash String?

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([type])
  @@index([tradition])
  @@index([evidenceLevel])
  @@index([year])
  @@index([language])
  @@index([publishedAt])
  @@index([viewCount])
  @@index([bookmarkCount])
  @@index([citations])
  @@index([doi])
  @@index([topics])
  @@index([tags])
  @@map("articles")

  // Wave 21 — reading progress tracking
  readingProgress ArticleReadingProgress[]
}

// ============================================================================
// MENTORSHIP — 1-on-1 pairing (Onda 13, 2026-06-27)
// ============================================================================
// Praticantes mais experientes guiam novatos em uma tradição.
// Fluxo:
//   1. mentor marca isMentor=true no User
//   2. mentee solicita (status=PENDING)
//   3. mentor aceita (status=ACTIVE)
//   4. qualquer parte encerra (status=COMPLETED, endedAt=now)
// Mensagens do chat ficam em MentorshipMessage (1-on-1, sem realtime).
// ============================================================================

model Mentorship {
  id        String @id @default(cuid())
  mentorId  String
  menteeId  String

  // Tradição foco da mentoria (ex: "cabala", "ifa")
  tradition String

  // Status + timestamps
  status     MentorshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  acceptedAt DateTime?
  endedAt    DateTime?

  // Notas internas (audit/observabilidade)
  // Ex.: { requestMessage: "...", endReason: "completed" }
  metadata Json?

  messages MentorshipMessage[]

  // Um usuário só pode ter uma mentoria ATIVA com o mesmo mentor
  // (mas pode ter várias COMPLETED no histórico)
  @@unique([mentorId, menteeId, status])
  @@index([mentorId, status])
  @@index([menteeId, status])
  @@index([tradition])
  @@index([createdAt])
  @@map("mentorships")
}

// Mensagens simples do chat 1-on-1 (append-only, sem realtime)
// Reuso o envelope de Mensagem (existente) seria ideal, mas
// Mensagem depende de Conversa. Aqui temos escopo próprio para clareza.
model MentorshipMessage {
  id           String     @id @default(cuid())
  mentorshipId String
  mentorship   Mentorship @relation(fields: [mentorshipId], references: [id], onDelete: Cascade)

  // Autor (deve ser mentorId ou menteeId da Mentorship)
  authorId String
  content  String @db.Text

  createdAt DateTime @default(now())

  @@index([mentorshipId, createdAt])
  @@map("mentorship_messages")
}

// ============================================================================
// SOCIAL GRAPH
// ============================================================================

model Follow {
  followerId String
  followedId String

  createdAt DateTime @default(now())

  @@id([followerId, followedId])
  @@index([followedId])
  @@map("follows")
}

model Like {
  userId String
  postId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, postId])
  @@index([postId])
  @@map("likes")
}

model CommentLike {
  userId    String
  commentId String

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([userId, commentId])
  @@index([commentId])
  @@map("comment_likes")
}

// ============================================================================
// REACTIONS — Emoji universalista em posts e comments (Onda 14, 2026-06-27)
// ============================================================================
// Feedback positivo sem precisar escrever reply. Set curado de 8 emojis
// espiritualizados (gratidão, compaixão, transformação, insight, crescimento,
// paz, unidade, inspiração). Toggle: se já existe a (user, target, emoji),
// remove — senão cria.
//
// Diferente do Like binário (curtir genérico), Reaction carrega **emoção**.
// Mesma tabela para POST e COMMENT via targetType (polimórfico).
// ============================================================================

enum ReactionTargetType {
  POST
  COMMENT
}

model Reaction {
  id          String             @id @default(cuid())
  userId      String

  // Polimorfismo simples via (targetType, targetId). Não temos FK relacional
  // aqui porque o Prisma não suporta FK condicional ao enum — o app garante
  // integridade via checagem de existência antes do toggle.
  targetType  ReactionTargetType
  targetId    String

  // Emoji unicode (1-8 chars). Restrição de domínio é enforçada no app
  // (ALLOWED_EMOJIS) — não no DB — para permitir evolução do set sem migration.
  emoji       String

  createdAt   DateTime @default(now())

  @@unique([userId, targetType, targetId, emoji])
  @@index([targetType, targetId, emoji])
  @@index([userId, targetType])
  @@map("reactions")
}

model Bookmark {
  id     String @id @default(cuid())
  userId String
  articleId String

  createdAt DateTime @default(now())

  @@unique([userId, articleId])
  @@index([userId])
  @@map("bookmarks")
}

// ============================================================================
// ARTICLE READING PROGRESS — "Continue de onde parou" (Wave 21, 2026-06-28)
// ============================================================================
// Diferente do Bookmark (que é apenas "salvar"), este modelo registra
// o progresso de leitura pessoal por artigo. Permite:
//   - "Continue de onde parou" (lastPosition)
//   - Barra de progresso (percentRead)
//   - Histórico pessoal "O que estou lendo"
// Idempotente via @@unique(userId, articleId). Auto-upsert no client.
//
// Privacidade: percentRead e lastPosition são privados do usuário (LGPD).
// Apenas o próprio user lê/escreve nesta tabela.
// ============================================================================

model ArticleReadingProgress {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)

  // 0..100 (clamp na API). Monotônico crescente — não regredimos.
  percentRead Int @default(0)

  // Posição livre (ex: índice do parágrafo, scroll offset, etc).
  // Mantemos como string para flexibilidade (client define o formato).
  lastPosition String?

  // Quando terminou de ler (100%) — setado uma única vez
  completedAt DateTime?

  // Tracking
  readAt   DateTime  @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, articleId])
  @@index([userId, readAt])
  @@index([articleId])
  @@map("article_reading_progress")
}

// ============================================================================
// POST BOOKMARKS — "Salvar para ler depois" (Onda 14, 2026-06-27)
// ============================================================================
// Diferente do Bookmark (que é para Artigos da Biblioteca Akasha), este
// modelo cobre os Posts da comunidade. Suporta "collections" opcionais
// para o usuário organizar ("Favoritos", "Para Meditar", "Estudos", etc).
// Soft idempotente: o @@unique(userId, postId, collectionName) garante
// que não há duplicatas; toggle = delete + insert em uma transação.
// ============================================================================

model PostBookmark {
  id     String @id @default(cuid())
  userId String
  postId String

  // Coleção opcional (ex: "Favoritos", "Para Meditar"). Default = 'default'.
  // Vazio ou null também são aceitos e tratados como 'default' pela API.
  collectionName String @default("default")

  createdAt DateTime @default(now())

  @@unique([userId, postId, collectionName])
  @@index([userId, collectionName, createdAt])
  @@index([userId, createdAt])
  @@index([postId])
  @@map("post_bookmarks")
}

// ============================================================================
// READING HISTORY — Histórico pessoal de leitura (Onda 14, 2026-06-27)
// ============================================================================
// Cada vez que o usuário lê um post (chega a >= 50% de scroll, ou sai da
// página), registramos um evento. Mantemos o último por (userId, postId) via
// upsert, atualizando percentRead e readAt. O histórico pessoal é ordenado
// por readAt desc — "continue de onde parou".
//
// NÃO é analytics agregado; é histórico pessoal privado (LGPD-friendly).
// ============================================================================

model ReadingHistory {
  id     String @id @default(cuid())
  userId String
  postId String

  // Porcentagem lida (0..100). Default 0 — só registramos após o usuário
  // rolar a página, então a primeira escrita costuma ser > 0.
  percentRead Int    @default(0)

  readAt DateTime @default(now())
  createdAt DateTime @default(now())

  @@unique([userId, postId])
  @@index([userId, readAt])
  @@index([postId])
  @@map("reading_history")
}

// ============================================================================
// NOTIFICAÇÕES — Modelo consolidado (in-app + email + push)
// ============================================================================
// Adicionado em 2026-06-27 — Onda 3 (Sistema de notificações real).
// Suporta: tipos sociais (like/comment/follow/mention), grupos, artigos,
// alertas de sistema, moderação, e digest semanal.
//
// Batch: o campo `groupKey` permite agrupar várias notificações do mesmo
// tipo + entity em uma (ex: 5 likes → "+5 likes"). A aplicação usa
// upsert por (userId, type, groupKey) quando aplicável.
// ============================================================================

model Notification {
  id     String @id @default(cuid())
  userId String  // destinatário
  type   NotificationType

  // Quem gerou (opcional, null para SYSTEM_ALERT etc)
  actorId String?

  // Entidade alvo (polimórfica via entityType + entityId)
  entityType EntityType?
  entityId   String?

  // Referência direta (atalho para queries comuns — denormalizado)
  postId    String?
  commentId String?
  groupId   String?
  articleId String?

  // Chave de agrupamento para batch (ex: "post:<id>:LIKES")
  // Permite consolidar múltiplas notificações do mesmo tipo na mesma entidade
  groupKey String?

  // Contador quando batched (ex: 5 likes virou 1 notif com count=5)
  count Int @default(1)

  // Snapshot do ator mais recente (denormalizado p/ evitar joins no feed)
  // {id, displayName, handle, avatarUrl}
  actorSnapshot Json?

  // Conteúdo extra (preview, links, deep-link, etc)
  payload Json?

  read Boolean @default(false)
  readAt DateTime?

  // Rastreamento de canais entregues (multi-canal)
  emailedAt DateTime?  // quando foi enviado por email
  pushedAt  DateTime?  // quando foi entregue via push

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, groupKey])
  @@index([userId, read, createdAt])
  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
  @@index([groupKey])
  @@map("notifications")
}

// Preferências de notificação por usuário e tipo
// Quando ausente, default é: IN_APP=true, EMAIL=true, PUSH=false
model NotificationPreference {
  id     String @id @default(cuid())
  userId String
  type   NotificationType

  inApp Boolean @default(true)
  email Boolean @default(true)
  push  Boolean @default(false)

  // Digest semanal separado (se true, emails individuais são suprimidos)
  weeklyDigest Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@map("notification_preferences")
}

// Assinaturas de Web Push (opt-in, armazenadas para entrega de pushes)
model PushSubscription {
  id     String @id @default(cuid())
  userId String

  // Endpoint único por subscription (RFC 8030)
  endpoint String  @unique
  // Criptografia — p256dh + auth
  p256dh   String
  auth     String

  // Metadata
  userAgent String?
  ipAddress String?

  // Controle
  active     Boolean   @default(true)
  lastSentAt DateTime?
  lastError  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([active, userId])
  @@map("push_subscriptions")
}

// Tokens de unsubscribe (LGPD-friendly) — links assinados em emails
// Pra simplicidade, geramos tokens opacos (não JWT) armazenados no DB
model UnsubscribeToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  // null = unsubscribe de TODAS as notificações
  // string = apenas este tipo
  type      String?
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("unsubscribe_tokens")
}

// ============================================================================
// CONTEÚDO CURADO POR IA (Fase 3 — IA Curadora)
// ============================================================================
// Histórico de respostas da IA, para co-evolução e feedback da comunidade.

model AiConversation {
  id     String @id @default(cuid())
  userId String

  title String?  // pode ser auto-gerado do primeiro prompt

  messages AiMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, updatedAt])
  @@map("ai_conversations")
}

model AiMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String  // "user" | "assistant" | "system"
  content String  @db.Text

  // Fontes que a IA usou pra responder (artigos da biblioteca)
  sources Json?  // [articleId, articleId, ...]

  // Feedback da comunidade (pra treinar/melhorar)
  helpful   Boolean?
  feedbackText String?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
  @@map("ai_messages")
}

// ============================================================================
// VIEW DO FEED (denormalizada para performance)
// ============================================================================
// Pré-computa o que aparece na timeline de cada usuário.
// Atualizada por triggers do Postgres ou via cron.

model FeedItem {
  id     String @id @default(cuid())
  userId String  // pra quem é esse item de feed

  // O que é esse item
  postId String?

  // Score (quanto maior, mais relevante)
  score Float

  // Razão ("followed_user_post", "group_post", "trending_topic", "article_recommendation")
  reason String

  seen Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, seen, createdAt])
  @@index([userId, createdAt])
  @@map("feed_items")
}

// ============================================================================
// EVENTS — Círculos de Partilha Online (Wave 13, 2026-06-27)
// ============================================================================
// Eventos síncronos (workshops, rodas de conversa, meditações guiadas ao
// vivo). Diferente do feed assíncrono: aqui há data/hora marcada, número
// limitado de participantes e um host responsável. Suporta tanto eventos
// abertos (isPublic=true, qualquer logado participa) quanto eventos
// fechados do grupo (groupId opcional).
//
// Design minimal — sem videoconferência integrada nesta onda: o evento
// guarda um `meetingUrl` externo (Zoom, Google Meet, Jitsi...). Foco é
// discovery + RSVP + listagem de participantes.
// ============================================================================

model Event {
  id          String   @id @default(cuid())

  title       String
  description String   @db.Text

  // Tradição espiritual do círculo (mesmas chaves canônicas dos grupos)
  // ex: "cabala", "ifa", "astrologia", "tantra", "meditacao", "xamanismo"
  tradition   String

  // Host (quem está conduzindo)
  hostId      String

  // Quando acontece
  startsAt    DateTime

  // Duração estimada em minutos (mostrada na UI)
  durationMin Int      @default(60)

  // Capacidade máxima (0 = ilimitado)
  maxParticipants Int   @default(0)

  // Visibilidade: pública na lista de eventos vs restrita
  isPublic    Boolean  @default(true)

  // URL externa de reunião (Zoom, Meet, Jitsi...). Opcional — pode ser
  // revelada ao participante só após RSVP confirmado.
  meetingUrl  String?

  // Grupo opcional ao qual o evento pertence (círculo fechado)
  groupId     String?
  group       Group?   @relation(fields: [groupId], references: [id], onDelete: SetNull)

  // Contadores denormalizados (atualizar via app)
  participantsCount Int @default(0)

  participants EventParticipant[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([startsAt])
  @@index([tradition])
  @@index([hostId])
  @@index([groupId])
  @@index([isPublic, startsAt])
  @@map("events")
}

// RSVP — quem confirmou presença em qual evento
// 2026-06-28 — Wave 21: status expandido (going/maybe/declined).
// - going     → participante confirmado (incrementa participantsCount)
// - maybe     → marcou interesse mas não confirmou (não conta)
// - declined  → recusou (não conta)
//
// Mantemos joinedAt para audit de quando virou going pela primeira vez.
// event_participants_status_idx ajuda queries do tipo
// "listar RSVPs going de um host" no dashboard admin.
model EventParticipant {
  eventId String
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String

  status   EventRsvpStatus @default(GOING)
  joinedAt DateTime        @default(now())
  // Quando foi a última mudança de status (going→declined etc.)
  statusUpdatedAt DateTime @default(now())

  @@id([eventId, userId])
  @@index([userId])
  @@index([eventId])
  @@index([eventId, status])
  @@map("event_participants")
}

// 2026-06-28 — Wave 21: enum de status de RSVP.
// Substitui o boolean binário "está dentro / não está" por uma tríade
// que cobre o fluxo real de confirmações de eventos comunitários.
enum EventRsvpStatus {
  GOING       // confirmou presença
  MAYBE       // marcou interesse, sem confirmar
  DECLINED    // recusou explicitamente (host vê que recusou)
}

// ============================================================================
// AUDIT LOG — LGPD Art. 37 + Segurança (Wave 11)
// ============================================================================
// Registra ações sensíveis para auditoria e suporte a direitos do titular.
// Categorias: AUTH (login/logout/password), LGPD (export/delete/consent),
// CONTENT (post/comment/like/follow), ADMIN (moderação).
//
// Política de retenção: 12 meses para AUTH/CONTENT; 24 meses para LGPD.
// Após retenção, job cron deve purgar registros antigos.
//
// Hash do IP (sha256 + salt) para evitar armazenar IP cru em conformidade
// com LGPD art. 46 (dados de tráfego). Em caso de ordem judicial, é
// possível re-derivar via salt guardado fora do banco.
// ============================================================================

// 2026-06-27 — Frequência do digest semanal/mensal de newsletter
// WEEKLY = digest toda segunda 9h (default)
// MONTHLY = digest primeiro dia do mês
// NEVER = não envia (usuário continuou assinado mas silenciou)
enum NewsletterFrequency {
  WEEKLY
  MONTHLY
  NEVER
}

enum AuditAction {
  // Auth
  LOGIN_SUCCESS
  LOGIN_FAIL
  LOGOUT
  PASSWORD_RESET_REQUEST
  PASSWORD_RESET_SUCCESS
  ACCOUNT_DELETE_REQUEST
  ACCOUNT_DELETE_CONFIRMED
  // LGPD
  DATA_EXPORT_REQUEST
  DATA_EXPORT_DELIVERED
  CONSENT_GRANTED
  CONSENT_REVOKED
  // Content (sample; pode crescer)
  POST_CREATED
  POST_DELETED
  COMMENT_CREATED
  COMMENT_DELETED
  // Admin / moderação
  ADMIN_USER_BAN
  ADMIN_CONTENT_REMOVE
  // Beta invite (Wave 33)
  INVITE_EXPIRED_BATCH  // cron moveu convites vencidos para EXPIRED
  INVITE_REVOKED        // admin cancelou convite individual
}

// ============================================================================
// MODERAÇÃO — Flag/Report (Wave 14, 2026-06-27)
// ============================================================================
// Sistema transparente e respeitoso de denúncias. Membros sinalizam
// conteúdo problemático; admins revisam em uma fila e tomam ação
// (dismiss/hide/delete). Tudo auditado.
//
// Filosofia:
//  - Reporter nunca é exposto publicamente (anti-retaliação)
//  - Reporter vê status da própria denúncia no perfil
//  - Staff vê queue priorizada (PENDING + mais antiga primeiro)
//  - Toda ação é registrada em AuditLog (transparência interna)
// ============================================================================

enum FlagTargetType {
  POST
  COMMENT
  USER
  GROUP
}

enum FlagReason {
  SPAM
  HARASSMENT
  MISINFO
  OTHER
}

enum FlagStatus {
  PENDING       // novo, ainda não revisado
  REVIEWED      // admin viu, mas não agiu (ex: contexto ok)
  ACTIONED      // admin tomou ação (hide/delete)
  DISMISSED     // admin julgou improcedente
}

model Flag {
  id          String         @id @default(cuid())

  // O que foi sinalizado
  targetType  FlagTargetType
  targetId    String

  // Quem sinalizou
  reporterId  String

  // Por quê
  reason      FlagReason
  description String?        @db.Text  // contexto opcional (até 500 chars)

  // Workflow
  status      FlagStatus     @default(PENDING)
  createdAt   DateTime       @default(now())
  reviewedAt  DateTime?
  reviewerId  String?        // id do admin/moderador que resolveu

  // Ação tomada (quando status=ACTIONED). null quando não houve ação.
  // Valores: 'dismiss' | 'hide' | 'delete'
  actionTaken String?

  @@index([status, createdAt])
  @@index([reporterId, createdAt])
  @@index([targetType, targetId])
  @@index([reviewerId, reviewedAt])
  @@map("flags")
}

model AuditLog {
  id        String      @id @default(cuid())

  // Quem fez (subject) — opcional (eventos anônimos como login_fail sem userId)
  actorId   String?
  // Sobre quem (target) — útil para admin actions sobre outros
  targetId  String?

  // Categoria + ação específica
  action    AuditAction

  // Contexto extra (sem PII). Exemplos:
  //   { ipHash: "...", userAgent: "Chrome/120", metadata: { reason: "..." } }
  metadata  Json?

  // Hash da request-id + timestamp — útil pra deduplicação e correlação
  requestId String?

  createdAt DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([targetId, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================================================
// DRAFTS — Auto-save workspace separado do Post (2026-06-27)
// ==========================================================================
// Por que um modelo separado em vez de Post(status=DRAFT)?
//  - Auto-save escreve a cada 5s; mexer em Post.likesCount/commentsCount
//    e em likes[]/comments[] a cada save seria caro.
//  - Draft é 100% privado (visibility=PRIVATE + só o próprio autor).
//  - Quando o usuário "Publicar agora", copiamos conteúdo para Post e
//    deletamos o Draft (idempotente via deleteMany na transação).
//  - Permite multi-draft: usuário pode ter N rascunhos em paralelo.
// ============================================================================

model Draft {
  id        String   @id @default(cuid())

  // Autor
  authorId  String

  // Conteúdo do rascunho
  title     String?
  content   String   @db.Text  // markdown livre; vazio é ok (rascunho recém-criado)

  // Mesmos campos opcionais que Post (preview consistente)
  tradition String?  // "cabala", "ifa", "xamanismo", ...
  topic     String?
  tags      String[]

  // Estado do auto-save (timestamp do último save bem-sucedido)
  // Útil pro hook useAutoSave mostrar "salvo há 3s" sem bater no servidor.
  lastSavedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId, updatedAt])
  @@index([authorId, createdAt])
  @@map("drafts")
}

// ============================================================================
// NEWSLETTER — Newsletter semanal + Resend integration (Wave 14, 2026-06-27)
// ============================================================================
// Free-tier growth: manter engajamento da comunidade via digest semanal
// enviado a cada segunda-feira 9h (cron /api/cron/weekly-digest).
//
// Modelos:
//   - NewsletterSubscription — preferência do usuário (tradições + frequência)
//   - Newsletter              — edições enviadas (histórico para auditoria)
//
// Tradições armazenadas como slugs canônicos (cabala, ifa, tantra, ...) para
// cruzamento direto com Group.tradition, Article.traditions, Post.tags.
// ============================================================================

model NewsletterSubscription {
  id        String   @id @default(cuid())

  // Email é único por inscrito (mesmo anônimo sem user)
  email     String   @unique

  // Opcional: se o inscrito também é usuário autenticado, vincula
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Tradições de interesse (vazio = recebe tudo). Slugs canônicos.
  traditions String[] @default([])

  // Frequência do digest. WEEKLY = segunda 9h, MONTHLY = dia 1º, NEVER = silenciou
  frequency NewsletterFrequency @default(WEEKLY)

  // Quando foi desinscrito (soft-delete). null = ativo.
  unsubscribedAt DateTime?

  // Token único para unsubscribe sem login (enviado no rodapé do email)
  unsubscribeToken String @unique @default(cuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([frequency, unsubscribedAt])
  @@index([createdAt])
  @@map("newsletter_subscriptions")
}

model Newsletter {
  id        String   @id @default(cuid())

  // Assunto (subject do email)
  subject   String

  // Conteúdo em markdown (renderizado pra HTML inline no envio)
  contentMarkdown String @db.Text

  // Filtro de tradições enviado para esta edição (vazio = todos)
  traditionsFilter String[] @default([])

  // Quando foi efetivamente enviado. null = rascunho.
  sentAt    DateTime?

  // Quantos recipients receberam (denormalizado após envio)
  recipientCount Int @default(0)

  // Quem compôs (audit)
  composedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sentAt])
  @@index([createdAt])
  @@map("newsletters")
}

// ============================================================================
// AKASHIC FEEDBACK — Wave 18 (2026-06-27)
// ============================================================================
// Sinal 👍/👎 que o usuário dá em cada resposta da Akasha IA. Modelo
// separado da `Message` do chat porque:
//   - Permite analytics agregados sem precisar carregar histórico inteiro
//   - Permite auditoria ética (picos de 👎 disparam review)
//   - Permite retreino futuro do prompt quando houver volume
//
// Privacidade:
//   - messageId é um UUID gerado pelo client (não referenciamos ChatMessage
//     por FK porque o chat é em memória)
//   - userId é opcional (visitante anônimo pode dar feedback)
//   - NÃO salvamos o conteúdo da mensagem/resposta (LGPD minimization)
// ============================================================================

enum AkashicFeedbackVote {
  UP       // 👍
  DOWN     // 👎
}

model AkashicFeedback {
  id        String              @id @default(cuid())

  // Identificador da resposta avaliada (UUID v4 do client, no page.tsx)
  // Permite que o client faça match com a mensagem atual sem precisar de FK
  messageId String

  // Voto
  vote      AkashicFeedbackVote

  // Quem votou (opcional — visitante anônimo pode dar feedback)
  userId    String?
  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Contexto (para analytics, NÃO PII)
  tradition String?              // tradição efetiva da resposta (auto-detect ou explícita)
  deepMode  Boolean              @default(false)

  // Comentário opcional do usuário (ex: "faltou contraindicação")
  comment   String?              @db.Text

  createdAt DateTime            @default(now())

  @@index([messageId])
  @@index([userId, createdAt])
  @@index([vote, createdAt])
  @@index([tradition, vote])
  @@map("akashic_feedback")
}

// ============================================================================
// LIVING CONSCIOUSNESS — Feedback loop (Wave 29, 2026-06-28)
// ============================================================================
// Implementa o ciclo de "consciência viva" do Akasha Portal:
//   1. Cada interação da comunidade (post, reaction, comment, bookmark,
//      conversa Akasha, leitura, follow) gera um ConsciousnessEvent.
//   2. Um cron diário agrega os eventos e gera ConsciousnessInsight
//      via LLM (OpenAI) — identifica tradições ressonantes, perguntas
//      emergentes, content gaps e padrões de cura.
//   3. Insights alimentam o system prompt da Akasha (loop de evolução).
//
// LGPD:
//   - Todos os campos são agregados ou anonimizados (sem conteúdo cru)
//   - userId é opcional (visitante anônimo pode ser contado)
//   - sentiment é numérico agregado (-1..1), não texto
//   - metadata nunca deve carregar PII (sanitizado antes de gravar)
//   - Retenção: 12 meses para eventos, indefinida para insights aplicados
//
// Opt-in: o tracking é desligado por padrão e ativado apenas quando
// o usuário aceita explicitamente (User.consciousnessTrackingOptIn).
// ============================================================================

/// Tipos de eventos que alimentam a consciência coletiva.
/// Mantém o enum aberto (string) no banco para permitir evolução
/// sem migration. O TS define os valores canônicos.
enum ConsciousnessEventType {
  POST_CREATED
  REACTION_ADDED
  COMMENT_CREATED
  BOOKMARK_CREATED
  READING_PROGRESS
  AKASHIC_CONVERSATION
  AKASHIC_FEEDBACK
  USER_ONBOARDED
  GROUP_JOINED
}

/// Tipos de insights gerados pela análise periódica (LLM).
enum ConsciousnessInsightType {
  TRADITION_RESONANCE  // quais tradições ressoam mais
  EMERGING_QUESTION    // perguntas que estão surgindo
  CONTENT_GAP          // tópicos com pouca cobertura
  HEALING_PATTERN      // padrões de cura observados
  PROMPT_TWEAK         // sugestão de ajuste no prompt Akasha
}

model ConsciousnessEvent {
  id        String   @id @default(cuid())

  // Quem gerou (opcional — visitante anônimo)
  userId    String?

  // Tipo canônico (PostCreated, ReactionAdded, etc)
  type      ConsciousnessEventType

  // Contexto espiritual inferido (slugs canônicos)
  tradition String?
  topic     String?

  // Sentiment agregado -1..1 (de reaction emoji ou análise de texto curta)
  sentiment Float?

  // Metadados estruturados (NUNCA PII): { postId?, articleId?, emoji?, wordCount?, etc }
  metadata  Json?

  // Opt-in: evento só é gravado se o usuário consentiu.
  // Se false, conta como anônimo agregado (sem userId).
  optedIn   Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([tradition, createdAt])
  @@index([userId, createdAt])
  @@index([optedIn, createdAt])
  @@map("consciousness_events")
}

model ConsciousnessInsight {
  id          String   @id @default(cuid())

  // Tipo de insight
  type        ConsciousnessInsightType

  // Descrição legível (markdown leve)
  description String   @db.Text

  // Evidências: contagens, exemplos, top-N (sem PII)
  // Ex: { topTraditions: [{slug, count}], emergingTopics: ['sonhos', 'ayahuasca'], period: '24h' }
  evidence    Json

  // Ações sugeridas (texto livre)
  // Ex: ['Curadoria: artigo sobre "Cuidados pós-ritual xamânico"', 'Akasha: mencionar contraindicação na saudação']
  actionItems Json

  // Janela que o insight cobre (ex: 2026-06-27..2026-06-28)
  periodStart DateTime
  periodEnd   DateTime

  // Quando foi aplicado (prompt Akasha atualizado / artigo criado)
  appliedAt   DateTime?

  // Quem gerou (sempre 'system:llm' para insights automáticos)
  generatedBy String  @default("system:llm")

  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([periodStart, periodEnd])
  @@index([appliedAt])
  @@map("consciousness_insights")
}
// ============================================================================
// W30 — NOTIFICAÇÕES SAGRADAS (smart scheduling + LGPD-friendly)
// ============================================================================
// Três novos models complementam o sistema de notificações existente:
//
// 1. NotificationPreference — REFORÇO do existente com quietHours + sacredDays
//    + frequency + tone + ethicsAcknowledged. Mantém compat com tabela antiga.
// 2. NotificationEvent — log de auditoria (LGPD Art. 37) de cada tentativa
//    de envio, com decision (sent/deferred/skipped) e reason detalhado.
// 3. SacredCalendar — catálogo curado de datas sagradas (equinoxes, solstices,
//    luas cheias, dias de Orixá, etc) usado pelo smart-scheduler para detectar
//    "sacred days" e ajustar o tom/conteúdo.
// ============================================================================

// --- 1. NotificationPreference (reforço; @@map mantém compat) -------------
// O model original (id, userId, type, inApp, email, push, weeklyDigest)
// continua existindo; este é o "perfil geral" do user (one-to-one).

model NotificationProfile {
  id     String @id @default(cuid())
  userId String @unique

  // Quiet hours — período em que NADA é entregue (exceto CRITICAL_TYPES).
  // Time HH:MM (24h). Default: 22:00 → 07:00.
  quietHoursStart String  @default("22:00")
  quietHoursEnd   String  @default("07:00")

  // Dia(s) da semana OFF (0=Domingo, 6=Sábado). JSON array de inteiros.
  // Default: [0] (Domingo). Em tradição Candomblé/Ifá pode-se usar dia
  // específico da semana (ex: 4ª feira dia de Oxum).
  sacredDaysOff Json    @default("[]")

  // Frequência máxima — cap diário por canal.
  // Ex: { "EMAIL": 2, "PUSH": 4, "IN_APP": 10 }
  frequencyCap   Json    @default("{\"EMAIL\":2,\"PUSH\":4,\"IN_APP\":10}")

  // Tom preferido — afeta geração de copy pela AI personalization.
  // REVERENT (formal/cerimonioso), WARM (acolhedor/diálogo), NEUTRAL.
  tone           String  @default("WARM")

  // Timezone IANA do user (ex: "America/Sao_Paulo"). Usado pelo scheduler
  // para calcular janelas locais mesmo quando o servidor está em UTC.
  timezone       String  @default("America/Sao_Paulo")

  // LGPD Art. 8 — opt-in explícito para personalização via IA.
  // False = scheduler usa heurísticas simples; True = usa LLM pra timing/copy.
  aiPersonalizationEnabled Boolean @default(false)

  // LGPD Art. 9 — consentimento explícito p/ receber comunicações.
  // False = só transacionais (system alerts críticos).
  marketingConsent Boolean @default(false)

  // LGPD Art. 18 IX — revogação de consentimento ("apagar meus dados").
  // Quando true, scheduler NUNCA envia e criador de evento deve purgar logs.
  dataErasureRequested Boolean @default(false)

  // Ethics audit — user confirmou ter lido os 8 princípios sagrados.
  ethicsAcknowledgedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("notification_profiles")
}

// --- 2. NotificationEvent — log de auditoria (LGPD Art. 37) -------------

enum NotificationDecision {
  SENT          // entregue em pelo menos 1 canal
  DEFERRED      // adiado (quiet hours / sacred day / batch window)
  BATCHED       // agrupado com outras notificações
  SKIPPED_PREF  // user desabilitou este tipo
  SKIPPED_DND   // do-not-disturb / focus mode
  SKIPPED_SACRED // sacred day off
  SKIPPED_FREQ  // cap de frequência atingido
  SKIPPED_LGPD  // consent revogado / data erasure
  SKIPPED_ETHICS // ethics audit falhou
  FAILED        // erro técnico
}

model NotificationEvent {
  id     String @id @default(cuid())
  userId String
  type   NotificationType

  // Conteúdo (preview) — armazenado p/ auditoria e A/B test.
  payload Json

  // Decisão do scheduler.
  decision     NotificationDecision
  decisionReason String  // explicação human-readable

  // Canal tentado (IN_APP / EMAIL / PUSH / null se skip).
  channel      String?

  // Quando o scheduler decidiu (pode diferir de scheduledFor se deferred).
  scheduledFor DateTime

  // Quando foi efetivamente enviado (null se skip ou ainda pendente).
  sentAt       DateTime?

  // Quando foi lido (null se não lida).
  readAt       DateTime?

  // Tradição espiritual do user (pode afetar tom). Nullable.
  tradition    String?

  // Correlation IDs.
  correlationId String?  // agrupa eventos do mesmo fluxo
  sourceEvent   String?  // ex: "createNotification", "smart-send"

  // Variação A/B (tone, timing, frequency).
  experimentVariant String?

  // LGPD — auto-expira após 90 dias (logs de auditoria, não conteúdo).
  expiresAt    DateTime

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, decision])
  @@index([type, createdAt])
  @@index([scheduledFor])
  @@index([expiresAt])
  @@map("notification_events")
}

// --- 3. SacredCalendar — catálogo curado -------------------------------

enum SacredTradition {
  CANDOMBLE
  UMBANDA
  IFA
  ESOTERICA          // Cabala, Astrologia, Numerologia
  ECUMENICA          // Cristianismo, Budismo, Hinduísmo
  WICCA
  UNIVERSAL          // equinoxes/solstices/luas (todas as tradições)
}

model SacredCalendar {
  id        String @id @default(cuid())
  date      DateTime  // data local 00:00 (sem hora — datas sagradas são full-day)
  endDate   DateTime? // opcional, p/ períodos (ex: Semana Santa)

  name      String     // "Equinócio de Outono", "Dia de Iemanjá", "Lua Cheia de Junho"
  tradition SacredTradition

  // Tipo/peso — quanto mais alto, mais "sagrado".
  // 1 = leve (Lua Cheia comum); 5 = máximo (Equinócio, São Jorge, etc)
  weight    Int        @default(1)

  // Regiões em que se aplica (null = mundial). Ex: ["BR-SP", "BR-RJ"].
  regions   Json?

  // Descrição curta (mostrada no calendário do user).
  description String?

  // Sugestão de tom (REVERENT, WARM, NEUTRAL).
  suggestedTone String @default("REVERENT")

  // Mensagem-template opcional p/ gerar notif (AI pode reescrever).
  messageTemplate String?

  // Recorrente anualmente? Se true, gera ocorrência todo ano.
  recurring Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([date, name, tradition])
  @@index([date])
  @@index([tradition, date])
  @@index([weight])
  @@map("sacred_calendar")
}

// ============================================================================
// PAYMENTS — Wave 30 / Stripe Connect marketplace (2026-06-30)
// ============================================================================
// Refs: docs/STRIPE-PAYMENTS-W30.md
//
// Decisões:
//   - 3 modelos: ConnectAccount (1-1 com User), Payment (escrow ledger),
//     Payout (histórico de transferências da Stripe ao reader).
//   - ProcessedStripeEvent para idempotência de webhooks (UNIQUE por eventId).
//   - Reader.transactionsEncrypted: dados sensíveis (nunca PAN, mas PIX/
//     bank account tokens) cifrados em coluna BYTEA.
//   - Affiliate ledger via Payment.affiliateId (apenas 1 nível).
// ============================================================================

enum ConnectAccountStatus {
  PENDING        // onboarding link enviado, ainda não completou KYC
  ACTIVE         // charges_enabled && payouts_enabled === true
  RESTRICTED     // KYC parcial — payouts bloqueados, payments ok
  DISABLED       // suspenso por Stripe (fraude, dispute, etc)
}

model ConnectAccount {
  id                    String              @id @default(cuid())
  userId                String              @unique
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Stripe Connect Express account ID (acct_...)
  stripeAccountId       String              @unique

  // Snapshot do status retornado pela Stripe (sincronizado via webhook)
  status                ConnectAccountStatus @default(PENDING)
  chargesEnabled        Boolean             @default(false)
  payoutsEnabled        Boolean             @default(false)
  detailsSubmitted      Boolean             @default(false)

  // Requirements — informações pendentes (KYC, documentos, etc)
  requirementsDue       String[]            @default([])
  requirementsPastDue   String[]            @default([])
  requirementsPending   String[]            @default([])

  // Default currency da conta (BR=BRL, US=USD, ...)
  defaultCurrency       String              @default("brl")

  // Auditoria
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  onboardingCompletedAt DateTime?

  @@index([status])
  @@index([stripeAccountId])
  @@map("connect_accounts")
}

enum PaymentStatus {
  PENDING        // PaymentIntent criado, aguardando confirmação
  PROCESSING     // confirmação enviada, aguardando webhook
  SUCCEEDED      // payment_intent.succeeded → dinheiro em escrow
  RELEASED       // capturado + transferido ao reader (sessão confirmada)
  REFUNDED       // charge.refunded → reader não recebe
  DISPUTED       // charge.dispute.created → freeze até resolução
  FAILED         // payment_intent.payment_failed
  CANCELED       // payment_intent.canceled
}

enum PaymentServiceType {
  READING
  MENTORSHIP
  AFFILIATE
}

model Payment {
  id                    String              @id @default(cuid())
  // IDs internos (relacionamentos lógicos; FKs opcionais p/ flexibilidade)
  readerId              String
  reader                User                @relation("PaymentReader", fields: [readerId], references: [id], onDelete: Restrict)
  clientId              String
  client                User                @relation("PaymentClient", fields: [clientId], references: [id], onDelete: Restrict)

  // Stripe refs
  stripePaymentIntentId String              @unique
  stripeChargeId        String?             @unique
  stripeRefundId        String?             @unique

  // Valores (em smallest currency unit — centavos / cents)
  amount                Int
  currency              String              @default("brl")
  platformFee           Int                 @default(0)
  // Valor final líquido que o reader recebe após fees
  netAmount             Int

  // Affiliate (opcional, 1 nível)
  affiliateId           String?
  affiliate             User?               @relation("PaymentAffiliate", fields: [affiliateId], references: [id], onDelete: SetNull)
  affiliateFee          Int                 @default(0)

  status                PaymentStatus       @default(PENDING)
  serviceType           PaymentServiceType

  // Idempotency key da criação (debug + auditoria)
  idempotencyKey        String              @unique

  // Metadata livre (orderId, sessionId, etc) — NUNCA PAN/PII sensível
  metadata              Json                @default("{}")

  // Error info se status=FAILED
  failureCode           String?
  failureMessage        String?

  // Timestamps
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  succeededAt           DateTime?
  releasedAt            DateTime?
  refundedAt            DateTime?

  // Payouts derivados deste pagamento
  payouts               Payout[]

  @@index([readerId, status])
  @@index([clientId, status])
  @@index([status, createdAt])
  @@index([affiliateId])
  @@map("payments")
}

enum PayoutStatus {
  PENDING
  IN_TRANSIT
  PAID
  FAILED
  CANCELED
}

model Payout {
  id                String        @id @default(cuid())
  readerId          String
  reader            User          @relation(fields: [readerId], references: [id], onDelete: Restrict)
  paymentId         String?
  payment           Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  // Stripe refs
  stripePayoutId   String        @unique

  amount            Int
  currency          String        @default("brl")
  status            PayoutStatus  @default(PENDING)
  method            String        @default("standard") // standard | instant
  arrivalDate       DateTime
  destination       String        // last4 do bank account (LGPD-safe display)

  failureCode       String?
  failureMessage    String?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([readerId, status])
  @@index([arrivalDate])
  @@map("payouts")
}

// Idempotência de webhooks Stripe — UNIQUE por event.id garante dedupe
model ProcessedStripeEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique // Stripe event.id (evt_...)
  eventType   String
  processedAt DateTime @default(now())
  livemode    Boolean  @default(false)

  @@index([eventType])
  @@map("processed_stripe_events")
}

// ============================================================================
// WebhookEvent — log completo de eventos Stripe recebidos (Wave 33)
// ============================================================================
// Diferente de ProcessedStripeEvent (apenas idempotência), WebhookEvent guarda
// o payload COMPLETO de cada evento recebido — incluindo os que falharam,
// duplicados e desconhecidos — para auditoria LGPD Art. 37 (registro de
// operações de tratamento) e forense.
//
// LGPD: payload completo inclui email/PI do objeto `customer` etc. Para
// analytics, usar `metadata.lite` (PII-stripped). Para LGPD-DPO export,
// filtrar por userId via metadata.actorId quando aplicável.
// ============================================================================
model WebhookEvent {
  id          String    @id @default(cuid())
  // event.id da Stripe (evt_...). UNIQUE garante dedupe por evento bruto
  stripeId    String    @unique
  // event.type (payment_intent.succeeded, account.updated, etc)
  type        String
  // API version da Stripe que originou o evento
  apiVersion  String?
  // livemode (true = produção, false = test)
  livemode    Boolean   @default(false)
  // Evento foi processado com sucesso (side-effects aplicados)?
  processed   Boolean   @default(false)
  // Evento é duplicado de outro stripeId já visto (idempotência)
  duplicate   Boolean   @default(false)
  // Payload COMPLETO do evento (sem criptografia; restrito via RLS + logs)
  payload     Json
  // Versão PII-stripped para analytics (sem email/nome/phone do customer)
  metadata    Json?
  // Erro de processamento (se houver) — null em sucesso
  error       String?
  // Tempo total de processamento em ms (handler latency)
  durationMs  Int?
  // Origem do request (Connect account se Connect webhook)
  accountId   String?
  // Quando foi criado/recebido e quando foi processado
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([type, processed])
  @@index([processed, type])
  @@index([createdAt])
  @@index([duplicate])
  @@map("webhook_events")
}

// Audit log específico de operações financeiras (LGPD Art. 37 — registro de operações)
model PaymentAuditLog {
  id          String   @id @default(cuid())
  actorId     String?  // user que iniciou (null = webhook automático)
  action      String   // 'create_payment', 'refund', 'dispute_open', etc
  paymentId   String?
  metadata    Json     @default("{}")
  ipHash      String?  // SHA-256 do IP (LGPD-safe; sem PII reversível)
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([actorId, createdAt])
  @@index([action])
  @@index([paymentId])
  @@map("payment_audit_log")
}

// ============================================================================
// BETA INVITE SYSTEM — Wave 32 (2026-06-30)
// ============================================================================
// Convites beta fechados para as 3 ondas (50 vagas total, ~17 por onda).
// Tokens são HMAC-SHA256 (plaintext nunca persiste); single-use; expiração
// configurável por onda (default 7d). Auditoria via AuditLog + logAdmin.
//
// LGPD: e-mail e IP são PII; token plaintext nunca deve aparecer em logs.
// Tabela rastreia wave + status para dashboard admin sem expor identificador.
// ============================================================================

enum InviteStatus {
  PENDING    // gerado mas ainda não enviado (dry-run / batch aguardando)
  SENT       // email enviado; aguardando o destinatário abrir
  OPENED     // destinatário abriu o link (tracking pixel)
  ACCEPTED   // converteu em conta (token consumido; status final)
  EXPIRED    // passou expiresAt sem aceite
  REVOKED    // admin cancelou manualmente
}

model BetaInvite {
  id            String        @id @default(cuid())

  // Destinatário (PII — hash em analytics; nunca logar em plaintext)
  email         String

  // Token canônico (HMAC-SHA256). Único no DB; o plaintext só existe no
  // email enviado ao destinatário e nunca é logado.
  token         String        @unique

  // Wave 1 (founders), 2 (early community), 3 (public soft-launch)
  wave          Int

  // Máquina de estados do convite
  status        InviteStatus  @default(PENDING)

  // Timestamps de tracking (LGPD Art. 37 — registro de operações)
  sentAt        DateTime?
  openedAt      DateTime?
  acceptedAt    DateTime?

  // Expiração — configurável por onda (default 7 dias)
  expiresAt     DateTime

  // Origem: admin que gerou OU referral opcional
  inviterId     String?
  inviter       User?         @relation(fields: [inviterId], references: [id], onDelete: SetNull)

  // userId preenchido quando status=ACCEPTED (FK criada depois do signup)
  userId        String?       // relação declarada em User.betaInvite (logo abaixo)
  user          User?         @relation("BetaInviteAcceptor", fields: [userId], references: [id], onDelete: SetNull)

  // Contexto técnico (UTMs, IP hash do solicitante, batch id, etc) — sem PII cru
  metadata      Json?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([email, status])
  @@index([token])
  @@index([wave])
  @@index([status, expiresAt])
  @@index([inviterId])
  @@map("beta_invites")
}

// ============================================================================
// FeedbackSubmission — feedback in-app (Wave 33)
// ============================================================================
// Captura bug reports, feature requests, conteúdo e usabilidade de forma
// estruturada. Rate limit (3/dia/usuário) é enforced no endpoint.
//
// LGPD Art. 7: precisa de consentimento (analyticsConsent ou explicit
// submit). userId é opcional para permitir feedback anônimo de visitantes
// autenticados via cookie fingerprint (metadata.fingerprintHash).
//
// LGPD Art. 18: titular pode solicitar exclusão — endpoint admin ou
// self-service apaga + audit log.
// ============================================================================
model FeedbackSubmission {
  id          String          @id @default(cuid())
  userId      String?         // null = anônimo (fingerprint em metadata)
  type        FeedbackType
  category    String?         // sub-categoria livre (ex: "notifications", "ux")
  rating      Int?            // 1-5 (UX geral)
  nps         Int?            // 0-10 (snapshot no momento do submit)
  message     String          @db.Text
  metadata    Json?           // { url, userAgent, fingerprintHash, ... }
  status      FeedbackStatus  @default(NEW)
  priority    Int             @default(0) // 0=normal, 1=high, 2=urgent (admin manual)
  createdAt   DateTime        @default(now())
  reviewedAt  DateTime?
  reviewedBy  String?         // userId do admin
  reviewNote  String?         @db.Text

  @@index([userId, type])
  @@index([status, createdAt])
  @@index([type, createdAt])
  @@index([priority, createdAt])
  @@map("feedback_submissions")
}

// ============================================================================
// NpsResponse — respostas do NPS automatizado (Day 1/3/7/14/30)
// ============================================================================
// Uma linha por (userId, trigger) — upsert no cron de NPS. Score 0-10
// conforme metodologia Net Promoter Score. Trigger identifica o dia da
// jornada em que o prompt foi exibido.
//
// LGPD Art. 7: usuário pode recusar (skip = não criar row) ou aceitar
// anônimo (userId real + flag ANONYMOUS em metadata).
//
// Net Promoter, Net Promoter Score, NPS e os emojis relacionado são
// marcas registradas da Bain & Company, Inc., Fred Reichheld e Satmetrix.
// Implementação compatível com a metodologia, não afiliada.
// ============================================================================
model NpsResponse {
  id          String        @id @default(cuid())
  userId      String
  score       Int           // 0-10 (validado no endpoint, zod refine)
  reason      String?       @db.Text
  trigger     NpsTrigger
  triggerAt   DateTime      // quando o prompt foi exibido (cron)
  metadata    Json?         // { source: 'cron'|'manual', channel, ... }
  createdAt   DateTime      @default(now())

  @@unique([userId, trigger, triggerAt]) // 1 NPS por usuário por trigger por dia
  @@index([userId, trigger])
  @@index([trigger, createdAt])
  @@map("nps_responses")
}

// ============================================================================
// WeeklySurveyResponse — micro-survey semanal (Wave 33)
// ============================================================================
// Cada resposta captura uma única pergunta da survey. Permite granularidade
// temporal sem modelar JSON no banco — queries de tendência são triviais.
//
// Perguntas rotativas (3-5 por semana) vivem em código (WeeklySurvey.tsx)
// e são versionadas pelo campo `version`. Respostas antigas não são
// "deletadas" — apenas marcadas com `supersededAt` quando o tema muda.
// ============================================================================
model WeeklySurveyResponse {
  id          String    @id @default(cuid())
  userId      String
  weekIso     String    // ex: "2026-W27" (ISO week date)
  questionId  String    // ex: "satisfaction", "nps_alt", "feature_use"
  version     Int       @default(1) // version da survey
  answer      Json      // resposta (string, number, string[])
  metadata    Json?     // { durationMs, skipped, ... }
  createdAt   DateTime  @default(now())
  supersededAt DateTime?

  @@unique([userId, weekIso, questionId, version])
  @@index([userId, weekIso])
  @@index([questionId, weekIso])
  @@map("weekly_survey_responses")
}

// ============================================================================
// NpsPromptSchedule — controle de quando mostrar o NPS por usuário
// ============================================================================
// Cron job DAY_1/3/7/14/30 verifica User.createdAt e cria/atualiza
// a row. Next prompt é deduzido (createdAt + day_offset).
//
// Reset: usuário pode pedir reset (LGPD "right to be forgotten") —
// DELETE desta tabela + nps_responses.
// ============================================================================
model NpsPromptSchedule {
  id              String      @id @default(cuid())
  userId          String      @unique
  triggersShown   String[]    @default([]) // ["DAY_1", "DAY_3", ...]
  lastPromptedAt  DateTime?
  skippedAt       DateTime?
  pausedUntil     DateTime?   // opt-out temporário
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("nps_prompt_schedule")
}

