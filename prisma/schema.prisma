generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// ENUMS
// ============================================================================

enum TipoTransacao {
  CREDITO
  DEBITO
}

// ============================================================================
// ÉPICO A — AUTENTICAÇÃO (Doc 04 §1)
// ============================================================================

enum UserRole {
  OPERATOR
  ADMIN
}

/// Tipo de token de sessão (Fase 15 — refresh tokens).
/// ACCESS: token de curta duração (15min) usado em toda request.
/// REFRESH: token de longa duração (30d) usado SÓ no endpoint /refresh.
enum OperatorSessionType {
  ACCESS
  REFRESH
}

enum ReadingStatus {
  PENDING // Mesa preenchida, dossiê ainda não gerado
  GENERATING // IA processando
  COMPLETED // Dossiê gerado com sucesso
  ERROR // Falha na geração
}

// ============================================================================
// MODELOS CANÔNICOS (Doc 04 §1) — Client / Reading / Report
// ============================================================================

/// Usuário operador (terapeuta) — modelo canônico da Fase 1.
model Operator {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(OPERATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  readings      Reading[]
  consultations Consultation[]
  sessions      OperatorSession[]

  @@map("operators")
}

/// Sessão ativa do Operator (B2B) — Fase 13 + Fase 15 (refresh).
///
/// Cada login cria DUAS OperatorSession:
///   - type=ACCESS com hash do access token (15min, cookie `cockpit_session`)
///   - type=REFRESH com hash do refresh token (30d, cookie `cockpit_refresh`)
///
/// O endpoint /refresh faz rotação: revoga o refresh usado e emite um
/// novo par access+refresh. Detecção de reuso de refresh revogado →
/// revoga TODAS as sessões do operator (sinal de roubo de cookie).
///
/// Logout marca `revokedAt` (soft revoke) — permite auditoria de quem
/// logou de onde, sem expor credenciais.
///
/// Trade-off: 1 query extra em /api/operator/auth/me para verificar
/// não-revogação. Para o cockpit B2B (não high-traffic), é OK.
model OperatorSession {
  id String @id @default(cuid())

  /// Hash SHA-256 do JWT (NUNCA o token em si). 64 chars hex.
  tokenHash String @unique

  /// Tipo do token: ACCESS (curta duração) ou REFRESH (longa duração).
  /// Fase 15: substituiu o single-token por par access+refresh.
  type OperatorSessionType @default(ACCESS)

  /// Quando o JWT expira — usado para cleanup automático.
  /// Para type=ACCESS: ~15min. Para type=REFRESH: ~30d.
  expiresAt DateTime

  /// (Fase 15) Expiração específica do refresh, para o caso do
  /// access de 15min ser revogado/logout mantendo o refresh ativo.
  /// Default: igual a expiresAt (mantém compat com Fase 13).
  refreshExpiresAt DateTime?

  /// Soft revoke: se != null, sessão está revogada.
  /// Mantida para auditoria (quem logou de onde, quando foi revogada).
  revokedAt DateTime?

  /// Metadados de auditoria
  ipAddress String?
  userAgent String?

  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([operatorId])
  @@index([operatorId, type])
  @@index([expiresAt])
  @@index([type, revokedAt])
  @@map("operator_sessions")
}

/// Consulente — dados fixos do cliente. Os mapas calculados ficam
/// armazenados em JSON conforme estruturas do Doc 04 §2.
model Client {
  id String @id @default(cuid())

  // Identificação
  fullName     String
  birthDate    DateTime
  birthTime    String
  birthCity    String
  birthState   String
  birthCountry String

  // Coordenadas para cálculo astral
  birthLatitude  Float?
  birthLongitude Float?
  birthTimezone  String?

  // Mapas cacheados (calculados uma única vez no cadastro)
  astrologyMap  Json?
  kabalisticMap Json?
  tantricMap    Json?
  oduBirth      Json?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  readings Reading[]

  @@map("clients")
}

/// Leitura — uma sessão de Mesa Real.
model Reading {
  id     String        @id @default(cuid())
  date   DateTime      @default(now())
  status ReadingStatus @default(PENDING)
  notes  String?

  /// Matriz 9x4 salva como JSON. Estrutura: MatrixData
  matrixData Json

  // Relacionamentos
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])

  report        Report?
  consultations Consultation[] // Threads de Q&A ancoradas nesta leitura (Doc 12)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("readings")
}

/// Dossiê — relatório interpretativo gerado pelo LLM.
model Report {
  id String @id @default(cuid())

  /// Conteúdo gerado pelo LLM. Estrutura: ReportContent
  content Json

  llmModel   String?
  tokensUsed Int?
  pdfUrl     String?

  readingId String  @unique
  reading   Reading @relation(fields: [readingId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}

/// Consulta Interativa — thread de Q&A ancorada numa leitura (Doc 12 §3).
/// A conversa herda todo o contexto do Reading (e, por ele, do Client e do Report).
model Consultation {
  id    String  @id @default(cuid())
  title String? // Resumo opcional do tema dominante da conversa

  readingId String
  reading   Reading @relation(fields: [readingId], references: [id], onDelete: Cascade)

  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id])

  messages ChatMessage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([readingId])
  @@map("consultations")
}

/// Mensagem de uma consulta interativa (Doc 12 §3).
model ChatMessage {
  id      String   @id @default(cuid())
  role    ChatRole
  content String // Markdown da mensagem

  // Rastreabilidade do roteamento (somente mensagens do ORACLE)
  routedThemes String[] // Ex: ["amor", "decisao"]
  routedHouses Int[] // Ex: [24, 22]

  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([consultationId])
  @@map("chat_messages")
}

enum ChatRole {
  USER
  ORACLE
}

// =====================
// USUÁRIO E AUTENTICAÇÃO
// =====================

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String?
  nomeCompleto    String
  dataNascimento  DateTime
  horaNascimento  String?
  localNascimento String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  journalEntries  JournalEntry[]

  mapaNatal MapaNatal?

  assinatura Assinatura?

  credito           Credito?
  empresas          Empresa[]
  favoritos         Favorito[]
  historicoLeituras LeituraHistorico[]
  temaPreferido     String             @default("mystical")

  supabaseUserId String? @unique

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  planoAssinatura      String?

  @@index([planoAssinatura])
  @@index([createdAt])
  @@index([dataNascimento])
  @@index([stripeSubscriptionId])
  @@map("users")
}

// =====================
// MAPA NATAL (Cálculos)
// =====================

model MapaNatal {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  signoSolar String?
  signoLunar String?
  ascendente String?

  numeroCabalistico Int?
  numeroTantrico    Int?
  numeroPitagorico  Int?
  numeroCaldeu      Int?
  numeroCarmico     Int?

  oduPrincipal  String?
  oduSecundario String?

  arcanoPessoal Int?
  cartaCaminho  String?

  sefirotDominante String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([signoSolar])
  @@index([numeroPitagorico])
  @@index([arcanoPessoal])
  @@index([createdAt])
  @@map("mapa_natal")
}

// =====================
// ASSINATURA
// =====================

model Assinatura {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plano                String  @default("iniciante")
  status               String  @default("active")
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  dataInicio       DateTime  @default(now())
  dataProximoCobro DateTime?

  moduloPlanetas    Boolean @default(false)
  moduloLetras      Boolean @default(false)
  moduloGeometria   Boolean @default(false)
  moduloFrequencias Boolean @default(false)
  moduloEmpresa     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([dataProximoCobro])
  @@index([plano])
  @@map("assinaturas")
}

// =====================
// CRÉDITOS
// =====================

model Credito {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  saldo Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transacoes TransacaoCredito[]

  @@index([saldo])
  @@index([createdAt])
  @@map("creditos")
}

model TransacaoCredito {
  id         String        @id @default(cuid())
  creditoId  String
  credito    Credito       @relation(fields: [creditoId], references: [id], onDelete: Cascade)
  tipo       TipoTransacao
  quantidade Int
  descricao  String?
  operacao   String?
  createdAt  DateTime      @default(now())

  @@index([creditoId, createdAt])
  @@index([tipo])
  @@index([createdAt])
  @@map("transacoes_credito")
}

// =====================
// EMPRESA (FUTURO)
// =====================

model Empresa {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nomeFantasia String
  razaoSocial  String?
  cnpj         String?
  dataFundacao DateTime?

  numeroNome  Int?
  numeroRazao Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([cnpj])
  @@map("empresas")
}

// =====================
// BASE DE CONHECIMENTO
// =====================

model DiaSemana {
  id       String @id @default(cuid())
  nome     String @unique
  numero   Int    @unique
  planeta  String
  elemento String
  cor      String

  orixas Orixa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dias_semana")
}

model Orixa {
  id              String   @id @default(cuid())
  nome            String   @unique
  saudacao        String
  planeta         String
  elemento        String
  cores           String[]
  chakraPrincipal Int

  hierbas Erva[]

  quizilas String[]

  dias DiaSemana[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orixas")
}

model Chakra {
  id       String   @id @default(cuid())
  numero   Int      @unique
  nome     String   @unique
  cor      String
  elemento String
  glandula String?
  mantras  String[]
  funcoes  String[]

  sefirotId String?  @unique
  sefirot   Sefirot? @relation(fields: [sefirotId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chakras")
}

model Sefirot {
  id      String @id @default(cuid())
  numero  Int    @unique
  nome    String @unique
  caminho String
  aspecto String
  cor     String

  planeta String?

  chakra Chakra?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sefirots")
}

model Odú {
  id           String @id @default(cuid())
  numero       Int    @unique
  nome         String @unique
  significado  String
  elemento     String
  planeta      String
  orixaRegente String

  quizilas  String[]
  preceptos String[]
  ebos      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("odus")
}

model Erva {
  id   String   @id @default(cuid())
  nome String   @unique
  tipo String
  uso  String[]

  orixas Orixa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ervas")
}

model FaseLua {
  id      String   @id @default(cuid())
  nome    String   @unique
  energia String
  rituais String[]
  evitar  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fases_lua")
}

model Elemento {
  id         String   @id @default(cuid())
  nome       String   @unique
  simbolo    String
  qualidades String[]
  direcoes   String[]
  cores      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("elementos")
}

// =====================
// INSIGHTS E CONVERSAS
// =====================

model Insight {
  id     String @id @default(cuid())
  userId String

  titulo          String
  descricao       String
  acaoRecomendada String?
  mantra          String?

  diaSemana     String?
  faseLua       String?
  numeroPessoal Int?
  odu           String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([titulo])
  @@map("insights")
}

model Conversa {
  id     String @id @default(cuid())
  userId String
  tema   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mensagens Mensagem[]

  @@index([userId])
  @@index([updatedAt])
  @@map("conversas")
}

model Mensagem {
  id         String   @id @default(cuid())
  conversaId String
  conversa   Conversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  tipo     String
  conteudo String

  createdAt DateTime @default(now())

  @@index([conversaId, createdAt])
  @@index([conversaId])
  @@map("mensagens")
}

// =====================
// REMINDERS
// =====================

model Reminder {
  id              String    @id @default(cuid())
  userId          String
  type            String
  frequency       String
  title           String?
  message         String?
  time            String
  timezone        String?
  schedule        Json?
  enabled         Boolean   @default(true)
  lastTriggeredAt DateTime?
  nextTriggerAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([enabled])
  @@index([nextTriggerAt])
  @@map("reminders")
}

// =====================
// MAPA NATAL - GRAPHICS/STORAGE
// =====================

model BirthChart {
  id     String @id @default(cuid())
  userId String

  birthDate DateTime
  birthTime String?
  latitude  Float?
  longitude Float?
  chartData Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([birthDate])
  @@index([createdAt])
  @@map("birth_charts")
}

model SynastryResult {
  id        String  @id @default(cuid())
  userId    String
  partnerId String?

  chart1Id String?
  chart2Id String?

  resultData Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([partnerId])
  @@index([createdAt])
  @@map("synastry_results")
}

// =====================
// FAVORITOS
// =====================

model Favorito {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String
  referenceId String

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([referenceId])
  @@index([userId, type])
  @@map("favoritos")
}

// =====================
// LEITURA HISTÓRICO
// =====================

model LeituraHistorico {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type String
  data Json

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model JournalEntry {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title   String?
  content String
  mood    String?
  tags    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([mood])
  @@index([createdAt])
  @@map("journal_entries")
}
