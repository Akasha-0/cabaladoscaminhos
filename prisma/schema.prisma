generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum TipoTransacao {
  CREDITO
  DEBITO
}

// =====================
// USUÁRIO E AUTENTICAÇÃO
// =====================

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  passwordHash    String?
  nomeCompleto    String
  dataNascimento  DateTime
  horaNascimento  String?
  localNascimento String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  journalEntries    JournalEntry[]
  oraculista      Oraculista?

  mapaNatal MapaNatal?

  assinatura Assinatura?

  credito           Credito?
  empresas          Empresa[]
  favoritos         Favorito[]
  historicoLeituras LeituraHistorico[]
  temaPreferido     String             @default("mystical")

  supabaseUserId String? @unique

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  planoAssinatura      String?

  @@index([planoAssinatura])
  @@index([createdAt])
  @@index([dataNascimento])
  @@index([stripeSubscriptionId])
  @@map("users")
}

// =====================
// MAPA NATAL (Cálculos)
// =====================

model MapaNatal {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  signoSolar String?
  signoLunar String?
  ascendente String?

  numeroCabalistico Int?
  numeroTantrico    Int?
  numeroPitagorico  Int?
  numeroCaldeu      Int?
  numeroCarmico     Int?

  oduPrincipal  String?
  oduSecundario String?

  arcanoPessoal Int?
  cartaCaminho  String?

  sefirotDominante String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([signoSolar])
  @@index([numeroPitagorico])
  @@index([arcanoPessoal])
  @@index([createdAt])
  @@map("mapa_natal")
}

// =====================
// ASSINATURA
// =====================

model Assinatura {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  plano                String  @default("iniciante")
  status               String  @default("active")
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  dataInicio       DateTime  @default(now())
  dataProximoCobro DateTime?

  moduloPlanetas    Boolean @default(false)
  moduloLetras      Boolean @default(false)
  moduloGeometria   Boolean @default(false)
  moduloFrequencias Boolean @default(false)
  moduloEmpresa     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([dataProximoCobro])
  @@index([plano])
  @@map("assinaturas")
}

// =====================
// CRÉDITOS
// =====================

model Credito {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  saldo Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transacoes TransacaoCredito[]

  @@index([saldo])
  @@index([createdAt])
  @@map("creditos")
}

model TransacaoCredito {
  id         String        @id @default(cuid())
  creditoId  String
  credito    Credito       @relation(fields: [creditoId], references: [id], onDelete: Cascade)
  tipo       TipoTransacao
  quantidade Int
  descricao  String?
  operacao   String?
  createdAt  DateTime      @default(now())

  @@index([creditoId, createdAt])
  @@index([tipo])
  @@index([createdAt])
  @@map("transacoes_credito")
}

// =====================
// EMPRESA (FUTURO)
// =====================

model Empresa {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  nomeFantasia String
  razaoSocial  String?
  cnpj         String?
  dataFundacao DateTime?

  numeroNome  Int?
  numeroRazao Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([cnpj])
  @@map("empresas")
}

// =====================
// BASE DE CONHECIMENTO
// =====================

model DiaSemana {
  id       String @id @default(cuid())
  nome     String @unique
  numero   Int    @unique
  planeta  String
  elemento String
  cor      String

  orixas Orixa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("dias_semana")
}

model Orixa {
  id              String   @id @default(cuid())
  nome            String   @unique
  saudacao        String
  planeta         String
  elemento        String
  cores           String[]
  chakraPrincipal Int

  hierbas Erva[]

  quizilas String[]

  dias DiaSemana[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("orixas")
}

model Chakra {
  id       String   @id @default(cuid())
  numero   Int      @unique
  nome     String   @unique
  cor      String
  elemento String
  glandula String?
  mantras  String[]
  funcoes  String[]

  sefirotId String?  @unique
  sefirot   Sefirot? @relation(fields: [sefirotId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("chakras")
}

model Sefirot {
  id      String @id @default(cuid())
  numero  Int    @unique
  nome    String @unique
  caminho String
  aspecto String
  cor     String

  planeta String?

  chakra Chakra?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sefirots")
}

model Odú {
  id           String @id @default(cuid())
  numero       Int    @unique
  nome         String @unique
  significado  String
  elemento     String
  planeta      String
  orixaRegente String

  quizilas  String[]
  preceptos String[]
  ebos      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("odus")
}

model Erva {
  id   String   @id @default(cuid())
  nome String   @unique
  tipo String
  uso  String[]

  orixas Orixa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ervas")
}

model FaseLua {
  id      String   @id @default(cuid())
  nome    String   @unique
  energia String
  rituais String[]
  evitar  String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("fases_lua")
}

model Elemento {
  id         String   @id @default(cuid())
  nome       String   @unique
  simbolo    String
  qualidades String[]
  direcoes   String[]
  cores      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("elementos")
}

// =====================
// INSIGHTS E CONVERSAS
// =====================

model Insight {
  id     String @id @default(cuid())
  userId String

  titulo          String
  descricao       String
  acaoRecomendada String?
  mantra          String?

  diaSemana     String?
  faseLua       String?
  numeroPessoal Int?
  odu           String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([titulo])
  @@map("insights")
}

model Conversa {
  id     String @id @default(cuid())
  userId String
  tema   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mensagens Mensagem[]

  @@index([userId])
  @@index([updatedAt])
  @@map("conversas")
}

model Mensagem {
  id         String   @id @default(cuid())
  conversaId String
  conversa   Conversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  tipo     String
  conteudo String

  createdAt DateTime @default(now())

  @@index([conversaId, createdAt])
  @@index([conversaId])
  @@map("mensagens")
}

// =====================
// REMINDERS
// =====================

model Reminder {
  id              String    @id @default(cuid())
  userId          String
  type            String
  frequency       String
  title           String?
  message         String?
  time            String
  timezone        String?
  schedule        Json?
  enabled         Boolean   @default(true)
  lastTriggeredAt DateTime?
  nextTriggerAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([enabled])
  @@index([nextTriggerAt])
  @@map("reminders")
}

// =====================
// MAPA NATAL - GRAPHICS/STORAGE
// =====================

model BirthChart {
  id     String @id @default(cuid())
  userId String

  birthDate DateTime
  birthTime String?
  latitude  Float?
  longitude Float?
  chartData Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([birthDate])
  @@index([createdAt])
  @@map("birth_charts")
}

model SynastryResult {
  id        String  @id @default(cuid())
  userId    String
  partnerId String?

  chart1Id String?
  chart2Id String?

  resultData Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([partnerId])
  @@index([createdAt])
  @@map("synastry_results")
}

// =====================
// FAVORITOS
// =====================

model Favorito {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String
  referenceId String

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([referenceId])
  @@index([userId, type])
  @@map("favoritos")
}

// =====================
// LEITURA HISTÓRICO
// =====================

model LeituraHistorico {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type String
  data Json

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  content   String
  mood      String?
  tags      String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([mood])
  @@index([createdAt])
  @@map("journal_entries")
}
// ============================================================
// MESA REAL INTEGRADA — Modelos do Cockpit do Oraculista
// ============================================================

enum OraculistaRole {
  ADMIN
  ORACULISTA
  ASSISTENTE
}

enum TipoSpread {
  CASA_UNICA
  CRUZ_CIGANA
  GRANDE_CONSULTA
}

enum ReadingStatus {
  RASCUNHO
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

model Oraculista {
  id        String          @id @default(cuid())
  userId    String          @unique
  user      User            @relation(fields: [userId], references: [id], on_delete: Cascade)
  nome      String
  role      OraculistaRole  @default(ORACULISTA)
  biografia String?
  pix       String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  clientes  Client[]
  readings  Reading[]

  @@map("oraculistas")
}

model Client {
  id        String   @id @default(cuid())
  oraculistaId String
  oraculista Oraculista @relation(fields: [oraculistaId], references: [id], on_delete: Cascade)

  nomeCompleto    String
  dataNascimento  DateTime
  horaNascimento  String?
  localNascimento String?
  whatsapp        String?
  email           String?

  ascendente      String?
  solSigno        String?
  luaSigno        String?
  venusSigno      String?
  marteSigno      String?

  caminhoDeVida   Int?
  numeroAlma      Int?
  numeroMissao    Int?

  orixaRegente    String?
  observacoes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  readings  Reading[]

  @@index([oraculistaId])
  @@index([nomeCompleto])
  @@index([dataNascimento])
  @@map("clients")
}

model Reading {
  id           String        @id @default(cuid())
  oraculistaId String
  oraculista   Oraculista    @relation(fields: [oraculistaId], references: [id], on_delete: Cascade)
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id], on_delete: Cascade)

  spreadTipo   TipoSpread    @default(GRANDE_CONSULTA)
  status       ReadingStatus @default(RASCUNHO)

  mapaFixo     Json
  mesaReal     Json

  oduPrincipal String?
  oduComplementar String?
  refraoPrincipal String?

  perguntaCliente   String?
  notasOraculista   String?

  dossie            Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  finalizedAt DateTime?

  report Report?

  @@index([oraculistaId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
  @@map("readings")
}

model Report {
  id          String  @id @default(cuid())
  readingId   String  @unique
  reading     Reading @relation(fields: [readingId], references: [id], on_delete: Cascade)

  conteudoMd  String
  conteudoTxt String?
  interpretacoes Json
  sintesePilares Json

  totalCasas       Int
  totalPilares     Int     @default(4)
  modeloIA         String?
  tokensUsados     Int?
  custoCentavos    Int?

  pdfUrl       String?
  pdfGeradoEm  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}
