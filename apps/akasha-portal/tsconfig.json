{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@akasha/types": ["../../packages/types/src/index.ts"],
      "@akasha/core": ["../../packages/akasha-core/src/index.ts"],
      "@akasha/core-astrology": ["../../packages/core-astrology/src/index.ts"],
      "@akasha/core-cabala": ["../../packages/core-cabala/src/index.ts"],
      "@akasha/core-iching": ["../../packages/core-iching/src/index.ts"],
      "@akasha/core-odus": ["../../packages/core-odus/src/index.ts"],
      "@akasha/core-tantra": ["../../packages/core-tantra/src/index.ts"],
      "@akasha/mentor": ["../../packages/mentor/src/index.ts"],
      "@akasha/mentor/types": ["../../packages/mentor/src/types.ts"],
      "@akasha/mentor/maps": ["../../packages/mentor/src/maps.ts"],
      "@akasha/mentor/correlation": ["../../packages/mentor/src/correlation.ts"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "tests",
    "scripts",
    "src/lib/application/akasha/synthesis-engine.test.ts"
  ]
}
