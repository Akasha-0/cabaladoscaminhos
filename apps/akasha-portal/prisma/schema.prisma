generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  emailVerified Boolean  @default(false)
  passwordHash  String?
  name          String
  locale        String   @default("pt-BR")
  role          UserRole @default(MEMBER)

  // Wave 14.3 — Plan Management.
  // Nullable: null = plano FREEMIUM implícito (não persistido).
  // Plan é a "catálogo de planos" editável via /admin/plans; User.planId
  // é a atribuição (qual catálogo o usuário CONSOME). Subscription.plan
  // é o tier pago real (Stripe) — entidades distintas, ambas necessárias:
  // Subscription.plan = estado Stripe-pago, User.planId = plano atribuído
  // (manual, comp, gift, admin grant).
  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id], onDelete: SetNull)

  birthDate      DateTime?
  birthTime      String?
  birthCity      String?
  birthLatitude  Float?
  birthLongitude Float?
  birthTimezone  String?

  // v0.0.4 T10 (Doc 14 §2): I-Ching como 5º sistema opt-in.
  // Cached no cadastro (Doc 09 §5.3 — "calcule uma vez"); null até o
  // usuário solicitar a tiragem do hexagrama natal.
  ichingMap Json?

  // v0.0.5 T3 (Doc 14 §2): opt-in explícito para o sorteio de I-Ching
  // no oráculo. Sem flag = opt-out (LGPD). Default false para usuários
  // existentes; migração aplica @default(false) automaticamente.
  ichingEnabled Boolean @default(false)

  intentionProfile Json?

  consentAt DateTime? // AD-T5-C: LGPD consent timestamp (min. persistence)

  // T7: opt-in flag for daily Web Push notifications.
  // The actual endpoints live in `PushSubscription` (relation below).
  pushEnabled Boolean @default(false)

  // D-047 (Wave 14.2): admin-controlled account suspension flag.
  // When true, the user cannot authenticate or access any protected route
  // (enforced by `requireAkashaApi` — see `src/lib/application/auth/akasha-guard.ts`).
  // Migration NOT YET APPLIED — Gabriel runs `pnpm prisma migrate dev --name
  // 047_admin_user_disabled` after reviewing this proposal.
  // Before the migration, the column does not exist in `akasha_users` and
  // any read/write through Prisma's generated `User.disabled` field will
  // fail. The /admin/users UI ships a "suspend" action that writes through
  // this field; once the migration lands, the action is live end-to-end.
  disabled Boolean @default(false)

  birthChart             BirthChart?
  subscription           Subscription?
  creditLedger           CreditEntry[]
  manifesto              Manifesto?
  dailyReadings          DailyReading[]
  consultations          Consultation[]
  ritualLog              RitualCompletion[]
  pushSubscriptions      PushSubscription[]
  connections            Connection[]
  cycleSnapshots         CycleSnapshot[]
  areaHistory            AreaHistoryEntry[]
  exerciseCompletions    ExerciseCompletion[]
  // D-046 (Wave 13.3): In-app notifications inbox. Pending human approval of
  // proposal at apps/akasha-portal/prisma/proposals/D-046-notifications-in-app.md.
  notifications          Notification[]
  // D-041 (Caminhante + Caminhada) + D-XXX (Sessao, SessaoChunk, GrimorioPessoal, NotasConsulente, MapaCalculo)
  // + D-YYY/D-ZZZ (Wave 4 — Pilares 6 e 7)
  caminhantes            Caminhante[]         @relation("UserCaminhantes")
  caminhadas             Caminhada[]          @relation("UserCaminhadas")
  sessoes                Sessao[]             @relation("UserSessoes")
  sessaoChunks           SessaoChunk[]        @relation("UserSessaoChunks")
  grimorioPessoal        GrimorioPessoal?     @relation("UserGrimorioPessoal")
  notasConsulentes       NotasConsulente[]    @relation("UserNotasConsulentes")
  mapasCalculo           MapaCalculo[]        @relation("UserMapasCalculo")
  pilar6Calculos         Pilar6Calculo[]      @relation("UserPilar6Calculos")
  pilar7Calculos         Pilar7Calculo[]      @relation("UserPilar7Calculos")
  pilar7Estagios         Pilar7Estagio[]      @relation("UserPilar7Estagios")
  // Refresh token rotation — stores the jti of the current active refresh token.
  // When a refresh request arrives, its jti MUST match this field.
  // On successful refresh the old token's jti is replaced by the new one's — old token immediately invalid.
  // If jti doesn't match, the token has been rotated already → 401 (possible theft).
  currentRefreshTokenJti String?              @unique @map("current_refresh_token_jti")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("akasha_users")
}

enum UserRole {
  MEMBER
  ADMIN
}

model BirthChart {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  astrologyMap  Json
  kabalisticMap Json
  tantricMap    Json
  oduBirth      Json
  // v0.0.5 T3 (Doc 14 §2): I-Ching natal (5º pilar).
  // Computado automaticamente em /api/akasha/chart a partir dos dados
  // de nascimento — determinístico, sem dados pessoais adicionais.
  ichingMap     Json?

  incomplete Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("birth_charts")
}

model Subscription {
  id                   String               @id @default(cuid())
  userId               String               @unique
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 SubscriptionPlanTier @default(FREEMIUM)
  status               SubStatus            @default(ACTIVE)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  monthlyCreditQuota   Int                  @default(0)
  dashboardUntil       DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@map("subscriptions")
}

// Wave 14.3: enum renomeado de `Plan` → `SubscriptionPlanTier` para liberar
// o nome `Plan` para o novo model abaixo (catálogo editável de planos).
// Stripe webhook e tests usam strings literais 'FREEMIUM'/'AKASHA_PRO'
// (não tipos Prisma), portanto a renomeação é transparente para o código
// de aplicação. Migration `plans` deve rodar:
//   ALTER TYPE "Plan" RENAME TO "SubscriptionPlanTier";
//   ALTER TABLE "subscriptions" ALTER COLUMN "plan" DROP DEFAULT;
//   ALTER TABLE "subscriptions" ALTER COLUMN "plan" TYPE "SubscriptionPlanTier" USING "plan"::text::"SubscriptionPlanTier";
//   ALTER TABLE "subscriptions" ALTER COLUMN "plan" SET DEFAULT 'FREEMIUM';
enum SubscriptionPlanTier {
  FREEMIUM
  AKASHA_PRO
}

// Wave 14.3 — Plan (catálogo de planos).
//
// Model editável via /admin/plans (CRUD). Cada Plan representa um tier do
// produto (FREEMIUM, PRO, ENTERPRISE) com pricing + créditos mensais + features.
// Não confundir com SubscriptionPlanTier (enum fixo de Stripe) — Plan é a
// FONTE da verdade do catálogo; User.planId atribui qual catálogo o
// usuário CONSOME (admin grant, comp, gift).
model Plan {
  id              String  @id @default(cuid())
  // slug único, lowercase, sem espaços: 'freemium' | 'pro' | 'enterprise'.
  // Diferencia de SubscriptionPlanTier (enum) — aqui é string livre pra
  // permitir admin criar planos custom sem migration.
  name            String  @unique
  displayName     String
  priceCents      Int     @default(0)
  creditsPerMonth Int?
  features        Json    @default("[]")
  isActive        Boolean @default(true)
  sortOrder       Int     @default(0)

  // Back-relation ao User (1:N — vários usuários podem ter o mesmo plano).
  // User.planId nullable + onDelete: SetNull = deletar um plano só desassocia
  // os usuários (não cascateia delete). Soft-delete via isActive=false é
  // o caminho preferido; DELETE real é escape hatch.
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

enum SubStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

model CreditEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int
  reason    String
  balance   Int
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("credit_entries")
}

model Manifesto {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  content    Json
  pdfUrl     String?
  llmModel   String?
  tokensUsed Int?
  createdAt  DateTime @default(now())

  @@map("manifestos")
}

model DailyReading {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime @db.Date
  climate       String
  ritual        Json
  alert         String
  tensionPoint  Json
  llmModel      String?
  // v0.0.5 T3 (Doc 14 §2): hexagrama do dia persistido no cronjob
  // `cabala-transits.service`. Estrutura binária (6 linhas) em
  // `hexagramLines` para o `MandalaChart` e o `/daily` exibirem.
  hexagram      String?
  hexagramLines Json?
  createdAt     DateTime @default(now())

  @@unique([userId, date])
  @@map("daily_readings")
}

model RitualCompletion {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  grimoireId String
  date       DateTime @default(now())

  @@index([userId])
  @@map("ritual_completions")
}

model Consultation {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String?
  // v0.0.5 T3 (Doc 14 §2): hexagrama sorteado (quando `user.ichingEnabled = true`
  // e o consulente escolhe o pilar `iching` no /oraculo).
  hexagram  String?
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
  @@map("consultations")
}

model ChatMessage {
  id             String       @id @default(cuid())
  role           ChatRole
  content        String
  routedPillars  String[]     @default([])
  grimoireRefs   String[]     @default([])
  creditCost     Int          @default(0)
  consultationId String
  consultation   Consultation @relation(fields: [consultationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([consultationId])
  @@map("chat_messages")
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("push_subscriptions")
}

enum ChatRole {
  USER
  ORACLE
}

model GrimoireEntry {
  id         String                      @id @default(cuid())
  slug       String                      @unique
  categoria  String
  biblioteca String
  metadata   Json
  conteudo   String
  embedding  Unsupported("vector(768)")?
  sourcePath String
  updatedAt  DateTime                    @updatedAt

  @@index([categoria])
  @@index([biblioteca])
  @@map("grimoire")
}

model Connection {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  otherName           String
  otherBirthDate      DateTime
  otherBirthTime      String?
  otherBirthCity      String?
  otherBirthLatitude  Float?
  otherBirthLongitude Float?
  otherBirthTimezone  String?

  romanticScore    Int
  partnershipScore Int
  dominantType     String
  authorityMatch   String
  resultData       Json

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("connections")
}

// ─── Prioridade 6 (iter33): Agente Evolutivo — persistence layer ─────────────

model CycleSnapshot {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date

  personalDay     Json
  personalMonth   Json
  personalYear    Json
  universalYear   Json
  currentPinnacle Json
  challenges      Json
  karmicLessons   Json
  maturity        Json

  modulation Json

  synthesis     String?
  overallEnergy Int?
  exercisesJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@map("cycle_snapshots")
}

model AreaHistoryEntry {
  id     String   @id @default(cuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date

  area              String
  dominantFrequency String
  intensity         Int

  cycleBoost        String?
  alignmentScore    Int?
  dominantPillar    String?
  ritualTitle       String?
  ritualInstruction String?
  ritualDuration    String?
  ritualElement     String?
  ritualColor       String?

  createdAt DateTime @default(now())

  @@unique([userId, date, area])
  @@index([userId])
  @@index([userId, area])
  @@map("area_history")
}

model ExerciseCompletion {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  exerciseId String
  area       String
  title      String

  snapshotDate DateTime @db.Date
  snapshotId   String?

  completed   Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, completed])
  @@index([userId, area, completed])
  @@map("exercise_completions")
}

// =========================================================================
// D-041 + D-XXX — Multi-tenant Zelador-tool (Wave 3)
// Estende o schema canonico com Caminhante + Caminhada + 5 models novos
// para a visao Zelador-tool. Ver docs/25_visao-akasha.md e ADR 0004.
// =========================================================================

// D-041 (applied 2026-06-22 via 20260622000000_041_caminhante_caminhada)

model Caminhante {
  id                        String   @id @default(cuid())
  zeladorId                 String
  zelador                   User     @relation("UserCaminhantes", fields: [zeladorId], references: [id], onDelete: Cascade)
  nome                      String
  nomeLowercaseNormalized   String
  nomeCompleto              String?
  dataNascimento            DateTime
  horaNascimento            String?
  localNascimentoCidade     String
  localNascimentoEstado     String
  localNascimentoPais       String
  timezone                  String?
  contato                   String?
  saudeRelevante            String?
  caminhadaEspiritualPrevia String?
  observacoes               String?
  consentimentoPilar4Dados  Json?
  consentimentoLGPD         Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  caminhadas Caminhada[]

  @@unique([zeladorId, dataNascimento, nomeLowercaseNormalized])
  @@index([zeladorId])
  @@map("caminhantes")
}

model Caminhada {
  id                     String          @id @default(cuid())
  zeladorId              String
  zelador                User            @relation("UserCaminhadas", fields: [zeladorId], references: [id], onDelete: Cascade)
  caminhanteId           String
  caminhante             Caminhante      @relation(fields: [caminhanteId], references: [id], onDelete: Cascade)
  status                 CaminhadaStatus @default(aberta)
  intencaoInicial        String
  zeladorLinhagem        String
  consentimentoPilar4Uso Json?
  abertoEm               DateTime        @default(now())
  dataEncerramento       DateTime?
  motivo                 String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  sessoes          Sessao[]
  notasConsulentes NotasConsulente[]
  mapasCalculo     MapaCalculo[]
  // D-YYY/D-ZZZ (Wave 4 — Pilares 6 e 7)
  pilar6Calculos   Pilar6Calculo[]
  pilar7Calculos   Pilar7Calculo[]

  @@index([zeladorId, status])
  @@index([caminhanteId])
  @@map("caminhadas")
}

enum CaminhadaStatus {
  aberta
  em_encerramento
  encerrada
}

// D-XXX (Wave 3 — multi-tenant core)

model Sessao {
  id          String       @id @default(cuid())
  zeladorId   String
  zelador     User         @relation("UserSessoes", fields: [zeladorId], references: [id], onDelete: Cascade)
  caminhadaId String
  caminhada   Caminhada    @relation(fields: [caminhadaId], references: [id], onDelete: Cascade)
  tipo        TipoSessao
  status      StatusSessao @default(aberta)
  abertoEm    DateTime     @default(now())
  fechadoEm   DateTime?

  chunks SessaoChunk[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([zeladorId, caminhadaId, abertoEm])
  @@index([zeladorId, status])
  @@map("sessoes")
}

enum TipoSessao {
  Apresentacao
  Leitura
  Ritual
  Aconselhamento
  Integracao
}

enum StatusSessao {
  aberta
  fechada
}

model SessaoChunk {
  id        String                      @id @default(cuid())
  zeladorId String
  zelador   User                        @relation("UserSessaoChunks", fields: [zeladorId], references: [id], onDelete: Cascade)
  sessaoId  String
  sessao    Sessao                      @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  texto     String
  embedding Unsupported("vector(768)")?
  origem    String
  metadata  Json?
  createdAt DateTime                    @default(now())

  @@index([zeladorId, sessaoId])
  @@index([zeladorId])
  @@map("sessao_chunks")
}

model GrimorioPessoal {
  id            String   @id @default(cuid())
  zeladorId     String   @unique
  zelador       User     @relation("UserGrimorioPessoal", fields: [zeladorId], references: [id], onDelete: Cascade)
  prescricoes   String?
  notasInternas String?
  bibliografia  String?
  atualizadoEm  DateTime @updatedAt
  createdAt     DateTime @default(now())

  @@map("grimorios_pessoais")
}

model NotasConsulente {
  id           String        @id @default(cuid())
  zeladorId    String
  zelador      User          @relation("UserNotasConsulentes", fields: [zeladorId], references: [id], onDelete: Cascade)
  caminhadaId  String
  caminhada    Caminhada     @relation(fields: [caminhadaId], references: [id], onDelete: Cascade)
  categoria    CategoriaNota
  titulo       String
  conteudo     String
  contexto     Json?
  tags         String[]
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt

  @@index([zeladorId, caminhadaId, categoria])
  @@index([zeladorId, atualizadoEm])
  @@map("notas_consulentes")
}

enum CategoriaNota {
  observacao
  prescricao
  ritual
  firmeza
  intercorrencia
}

model MapaCalculo {
  id            String    @id @default(cuid())
  zeladorId     String
  zelador       User      @relation("UserMapasCalculo", fields: [zeladorId], references: [id], onDelete: Cascade)
  caminhadaId   String
  caminhada     Caminhada @relation(fields: [caminhadaId], references: [id], onDelete: Cascade)
  cabala        Json?
  astrologia    Json?
  tantra        Json?
  odu           Json?
  iching        Json?
  pilar6        Json?
  pilar7        Json?
  setores       Json?
  versaoCalculo String
  calculadoEm   DateTime  @default(now())
  atualizadoEm  DateTime  @updatedAt

  @@unique([zeladorId, caminhadaId])
  @@index([zeladorId, versaoCalculo])
  @@map("mapas_calculo")
}

// =========================================================================
// D-YYY + D-ZZZ — Pilares 6 e 7 (Wave 4)
// Adiciona Pilar 6 (Mapa Energetico Integrado — traducao universalista
// do Human Design) e Pilar 7 (Espectro de Transformacao — traducao
// universalista do Gene Keys). Ver docs/25_visao-akasha.md,
// docs/adrs/0002-pilares-6-7-human-design-gene-keys.md,
// apps/akasha-portal/prisma/designs/D-YYY-pilar-6-mapa-energetico-traduzido.md,
// apps/akasha-portal/prisma/designs/D-ZZZ-pilar-7-espectro-transformacao-traduzido.md.
// 4 guardrails do ADR 0002: renomear termos, textos do zero,
// visualizacao propria, disclaimer legal.
// =========================================================================

// D-YYY (Wave 4 — Pilar 6: Mapa Energetico Integrado)

model Pilar6Calculo {
  id String @id @default(cuid())

  // FKs (escopo multi-tenant — alinha D-XXX)
  zeladorId   String
  zelador     User      @relation("UserPilar6Calculos", fields: [zeladorId], references: [id], onDelete: Cascade)
  caminhadaId String
  caminhada   Caminhada @relation(fields: [caminhadaId], references: [id], onDelete: Cascade)

  // Pilar 6 calculation result (D-YYY §3.1)
  tipo             TipoEnergetico // 4 tipos (iniciador | guia | iniciador_aberto | refletor)
  estrategia       EstrategiaEnergetica // 4 estrategias
  autoridade       AutoridadeEnergetica? // 6 autoridades (nullable se inconclusivo)
  centrosDefinidos CentroEnergetico[] // subset dos 9 centros definidos

  // Auditoria
  versaoCalculo String // ex: "v1"
  calculadoEm   DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  @@unique([zeladorId, caminhadaId, versaoCalculo]) // cache: 1 calculo por versao
  @@index([zeladorId, caminhadaId, calculadoEm])
  @@index([zeladorId, versaoCalculo])
  @@map("pilar6_calculos")
}

// D-YYY §3.1: enums dos tipos renomeados (Guardrail 1 do ADR 0002).
enum TipoEnergetico {
  iniciador // ex-Human Design Generator
  guia // ex-Human Design Projector
  iniciador_aberto // ex-Human Design Manifestor
  refletor // ex-Human Design Reflector
}

// D-YYY §3.1: estrategias funcionais.
enum EstrategiaEnergetica {
  esperar_convite // ex-To Respond
  informar // ex-To Inform
  iniciar // ex-To Initiate
  esperar_ciclo_lunar // ex-To Wait (lunar)
}

// D-YYY §3.1: 6 autoridades internas. Reusa Emocional/Esplenica/Cardiaca de D-041.
enum AutoridadeEnergetica {
  emocional
  sacral
  esplenica
  cardiaca
  identidade
  lunar
}

// D-YYY §3.1: 9 centros energeticos baseados em I Ching + Cabala + Tantra
// (Guardrail 3 do ADR 0002: visualizacao propria).
enum CentroEnergetico {
  inspiracao // Cabala (Keter)
  mental // Cabala (Hokhmah/Binah)
  manifestacao // I Ching (canal de expressao)
  identidade // Astrologia (Ascendente)
  vontade // Tantra (Anahata)
  emocoes // Tantra (Manipura)
  vitalidade // Tantra (Svadhisthana)
  sobrevivencia // Tantra (Muladhara, instinto)
  fundamentacao // Tantra (Muladhara, base)
}

// D-ZZZ (Wave 4 — Pilar 7: Espectro de Transformacao)

model Pilar7Calculo {
  id String @id @default(cuid())

  // FKs (escopo multi-tenant — alinha D-XXX)
  zeladorId   String
  zelador     User      @relation("UserPilar7Calculos", fields: [zeladorId], references: [id], onDelete: Cascade)
  caminhadaId String
  caminhada   Caminhada @relation(fields: [caminhadaId], references: [id], onDelete: Cascade)

  // Pilar 7 calculation result (D-ZZZ §3.1)
  // 64 chaves (1-64 = I Ching) — cada uma com 3 estagios
  estagios     Pilar7Estagio[] // relation para os estagios desta chave
  chaveNumero  Int // 1-64 (I Ching gate)
  chaveNome    String // nome proprio (do zero — Guardrail 2)
  estagioAtual EstagioTransformacao // Sombra | Dom | Siddhi (onde esta HOJE)
  textoSombra  String // texto proprio (do zero — Guardrail 2)
  textoDom     String
  textoSiddhi  String

  // Auditoria
  versaoCalculo String // ex: "v1"
  calculadoEm   DateTime @default(now())
  atualizadoEm  DateTime @updatedAt

  @@unique([zeladorId, caminhadaId, versaoCalculo])
  @@index([zeladorId, caminhadaId, calculadoEm])
  @@index([zeladorId, versaoCalculo])
  @@map("pilar7_calculos")
}

// D-ZZZ §3.1: enum dos 3 estagios (Sombra → Dom → Siddhi).
// Termos sao tradicao antiga, nao-protegiveis (D-ZZZ.1).
enum EstagioTransformacao {
  sombra
  dom
  siddhi
}

// D-ZZZ §3.1: estagios de cada chave para cada consulente.
// N chaves × 3 estagios = N × 3 linhas por calculo (se aplicavel).
model Pilar7Estagio {
  id String @id @default(cuid())

  // FKs
  zeladorId String
  zelador   User          @relation("UserPilar7Estagios", fields: [zeladorId], references: [id], onDelete: Cascade)
  calculoId String
  calculo   Pilar7Calculo @relation(fields: [calculoId], references: [id], onDelete: Cascade)

  // Identificacao da chave
  chaveNumero Int // 1-64 (corresponde a hexagrama I Ching)
  chaveNome   String // nome proprio (do zero — Guardrail 2)
  estagio     EstagioTransformacao // qual dos 3 estagios esta chave representa no consulente
  texto       String // texto proprio (do zero — Guardrail 2)

  // Sequence position (D-ZZZ §3.1): Sequence Venusiana + Caminho Dourado renomeados
  sequencePosition Int? // 1-22 (Sequence Venusiana — 22 chaves)
  pathwayPosition  Int? // 1-11 (Caminho Dourado — 11 chaves)

  @@index([zeladorId, calculoId])
  @@index([zeladorId, chaveNumero])
  @@map("pilar7_estagios")
}

// ──────────────────────────────────────────────────────────────────────
// D-046 (Wave 13.3): In-app notifications inbox.
// Schema ONLY — migration NÃO foi aplicada. Gabriel precisa rodar:
//   pnpm exec prisma migrate dev --name notifications
// Ver PROPOSAL completo em apps/akasha-portal/prisma/proposals/D-046-notifications-in-app.md
// ──────────────────────────────────────────────────────────────────────

/// Categoria da notificação. Usado para ícone/cor no bell + filtragem
/// futura em preferences (Wave 14). NÃO enumera campos de negócio — só o
/// "tipo de evento" que gerou a notificação.
enum NotificationType {
  /// Novo Mandato do Dia disponível no /diario
  DIARIO
  /// Resposta assíncrona do Mentor chegou em /oraculo
  MENTOR
  /// Match em Conexões (compatibilidade alta) ou mensagem de outro usuário
  CONEXOES
  /// Saldo de créditos baixo (<5 créditos)
  CREDITS
  /// Aviso da plataforma (manutenção, atualização, etc) — sem CTA por default
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String // ≤120 chars (enforced em application layer)
  body      String // ≤500 chars (enforced em application layer)
  href      String? // deep link interno opcional (ex: /meu-dia, /diario/123)
  readAt    DateTime? // null = não lida (mostra no badge); set = timestamp de leitura
  createdAt DateTime         @default(now())

  // Query principal: "notificações não-lidas do user X ordenadas por mais recente"
  @@index([userId, readAt, createdAt])
  // Query "últimas N do user X (lidas + não-lidas) para o dropdown"
  @@index([userId, createdAt])
  @@map("notifications")
}

/// D-048 — User notification preferences (Wave 18.2).
///
/// Por que existe (vs. flag único no User):
///   - LGPD Art. 18 §VI (revogação granular): user pode desativar
///     DIARIO mas manter MENTOR + CONEXOES. Flag único não dá granularidade.
///   - UX: /conta/notifications mostra 5 toggles (um por tipo).
///   - Storage: tabela esparsa — só cria row quando user opt-out (default =
///     "all enabled" sem precisar de 5 rows por usuário novo).
///
/// Schema-decisions:
///   - SEM relation explícita para User — join feito via userId na query
///     (consistente com AuditLog que também opta por userId sem FK para
///     sobrevivência à exclusão; aqui Cascade seria OK mas mantemos simples).
///   - enabled @default(true) — opt-out model; "all on" é o default razoável.
///   - @@unique([userId, type]) impede duplicatas e suporta upsert (PATCH).
///   - Index em userId cobre a query principal ("todas prefs do user X").
///
/// Migration é aplicada por humano (per prisma/AGENTS.md D1):
///   pnpm exec prisma migrate dev --name notification_preferences
model NotificationPreference {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  enabled   Boolean          @default(true)
  updatedAt DateTime         @updatedAt

  @@unique([userId, type])
  @@index([userId])
  @@map("notification_preferences")
}

/// D-047 — AuditAction enum (Wave 14.5)
/// Movido de `lib/infrastructure/audit-log.ts` para o schema para que o DB
/// enforçe a integridade (não é possível gravar actions "fantasma").
/// Não é relacionado a nenhuma enum pré-existente — novo desde Wave 8.3.
enum AuditAction {
  /// Wave 8.3 — LGPD Art. 18 §V (direito ao esquecimento) — pedido recebido
  profile_delete_requested
  /// Wave 8.3 — LGPD Art. 18 §V — exclusão concluída (cascade Prisma)
  profile_delete_completed
  /// Wave 8.3 — LGPD Art. 18 §V — exclusão falhou (erro Prisma ou validação)
  profile_delete_failed
  /// Wave 8.3 — LGPD Art. 18 §IV (portabilidade) — export solicitado
  profile_export_requested
  /// Wave 8.3 — LGPD Art. 18 §IV — export concluído (PDF/JSON/CSV gerados)
  profile_export_completed
  /// Wave 8.3 — LGPD Art. 37 (uso compartilhado de dados com terceiros)
  conexao_third_party_consent_declarado
  /// Genérico — atualização de consentimento (LGPD Art. 8º)
  consent_updated
}

/// D-047 — Audit log persistente (Wave 14.5)
///
/// LGPD Art. 37: demonstração de operações com dados pessoais.
/// Armazena ações sensíveis para consulta pelo painel admin
/// (/admin/audit-logs) e respondibilidade Art. 18 §7
/// (informação sobre uso compartilhado de dados).
///
/// Decisões de design:
///  - SEM relation para `User` — entries devem SOBREVIVER à exclusão
///    do user (LGPD Art. 37 pede retenção; cascade apagaria o registro
///    da própria exclusão, que é justamente o evento mais crítico).
///  - `ipHash` é HMAC-SHA256(JWT_SECRET, IP) — NUNCA IP puro (LGPD Art. 33).
///  - `metadata` é Json livre — doc no JSDoc: "NUNCA conter PII direta".
///    Redaction acontece na camada de leitura (API /admin/audit-logs).
///  - Índices cobrem os 3 filtros admin mais comuns (data, user, action).
model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  /// userId do ator (ou null para operações anônimas).
  /// Intencionalmente SEM FK para User (sobrevivência ao delete — ver JSDoc).
  userId    String?
  /// SHA-256(IP) ou HMAC-SHA256(JWT_SECRET, IP). NUNCA IP em texto puro.
  ipHash    String?
  /// requestId correlaciona com structured logs (Wave 12.3) para tracing.
  requestId String?
  /// Metadata da ação. JSON estruturado. NÃO deve conter PII direta
  /// (email, telefone, birthDate, etc) — redaction na camada de leitura.
  metadata  Json?
  createdAt DateTime    @default(now())

  // Wave 14.5 — índices otimizados para o /admin/audit-logs viewer:
  // - query paginada ordenada por mais recente
  @@index([createdAt])
  // - filtro "ações de um usuário específico"
  @@index([userId, createdAt])
  // - filtro "todas as ações de um tipo" (LGPD Art. 18 — demonstrabilidade)
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ─── Wave 19.3 — Privacy Controls UI (LGPD Art. 7 / 8) ────────────────────
//
// Audit trail IMUTÁVEL das decisões de consentimento do usuário. Diferente
// de `NotificationPreference` (que é um upsert mutável), aqui cada decisão
// gera um NOVO registro. O histórico completo é preservado para fins de
// demonstrabilidade (LGPD Art. 37 — registro das operações de tratamento).
//
// LGPD:
//   - Art. 7º — consentimento deve ser livre, informado e inequívoco.
//   - Art. 8º — é vedado o tratamento de dados sem consentimento OU
//               mediante revogação. Cada decisão (grant ou revoke) precisa
//               ser registrada com timestamp + identificação do titular +
//               contexto da coleta (IP hash + user agent).
//   - Art. 37º — controlador deve manter registro das operações de
//               tratamento (audit trail).
//
// Wave 8.3 já persiste `User.consentAt` (timestamp mínimo). Wave 19.2
// adiciona o direito de eliminação (delete cascade). Wave 19.3 fecha o
// ciclo de LGPD self-service: o usuário pode consultar E REVOGAR cada
// categoria de consentimento individualmente, com trilha de auditoria.
//
// Decisões de design:
//   1. `userId` SEM FK para User — mesmo padrão de `AuditLog.userId` (LGPD
//      Art. 37: trilha precisa sobreviver ao delete do usuário).
//   2. `ipHash` (não IP puro) — `IpHash` tipo exportado por
//      `src/lib/infrastructure/security/ip-hash.ts` (HMAC-SHA256 com JWT_SECRET).
//      LGPD Art. 33: IP é PII; hash unidirecional é o mínimo necessário
//      para auditoria sem re-identificação.
//   3. `userAgent` é String (não enum) — diversidade legítima de browsers
//      e versões; capturar para evidência forense caso necessário.
//   4. SEM `updatedAt` — registros são append-only. Para "última decisão"
//      consultar `MAX(grantedAt)` por (userId, type).
//   5. SEM `@@unique([userId, type])` — múltiplas rows por type são
//      ESPERADAS (cada toggle = nova row). Mantemos apenas índice
//      `(userId, grantedAt)` para ordenação cronológica eficiente.
//
// `grantedAt` é obrigatório (sempre há um momento da decisão). Não há
// `revokedAt` separado: quando o usuário revoga, gravamos uma NOVA row
// com `granted = false`. O histórico completo (grants + revokes) é
// preservado.
//
// Migration é PROPOSAL (per prisma/AGENTS.md D1) — humano roda:
//   pnpm exec prisma migrate dev --name privacy_consent
model PrivacyConsent {
  id        String            @id @default(cuid())
  /// userId do titular. SEM FK para User (sobrevivência ao delete — ver JSDoc).
  userId    String
  /// Categoria de consentimento. Ver enum `PrivacyConsentType` abaixo.
  type      PrivacyConsentType
  /// Decisão do titular: `true` = concedeu, `false` = revogou.
  /// Para "última decisão", filtrar por `grantedAt` mais recente por (userId, type).
  granted   Boolean
  /// Momento da decisão. Sempre presente.
  grantedAt DateTime          @default(now())
  /// Contexto da coleta: IP hasheado (HMAC-SHA256, LGPD-compliant).
  /// Mesmo padrão de `AuditLog.ipHash`.
  ipHash    String
  /// User-Agent do browser no momento da decisão (evidência forense).
  userAgent String

  /// Índice principal: histórico cronológico por usuário. Cobertura da
  /// query "últimas N decisões do user X" (UI /conta/privacidade).
  @@index([userId, grantedAt])
  /// Índice secundário: filtro por categoria (admin reports).
  @@index([type, grantedAt])
  @@map("privacy_consents")
}

/// Categorias de consentimento suportadas (Wave 19.3).
///
/// 4 tipos — cada um com finalidade específica, base legal diferente
/// (LGPD Art. 7º, I — execução de contrato; II — tutela da saúde; etc).
///
/// Trade-offs de modelagem:
///   - Enum dedicado (vs Json livre) garante que a categoria é estável
///     e indexável. Adicionar uma categoria = migration.
///   - Mantemos os 4 tipos principais. Categorias mais granulares
///     (ex: marketing por canal) seriam Wave futuro.
///
/// Defaults no signup (LGPD Art. 7º, I — consentimento expresso):
///   - MARKETING = false           (opt-in obrigatório)
///   - ANALYTICS = true            (legítimo interesse, padrão de mercado)
///   - AI_TRAINING = false         (opt-in obrigatório — LGPD Art. 11)
///   - THIRD_PARTY_SHARING = false (opt-in obrigatório)
enum PrivacyConsentType {
  /// Newsletters, promoções, conteúdo de marketing geral.
  MARKETING
  /// Métricas agregadas anônimas para melhoria do produto
  /// (Plausible/PostHog-style, sem PII).
  ANALYTICS
  /// Uso de inputs do usuário (anonimizados ou não) para treinar /
  /// fine-tunar modelos de IA. LGPD Art. 11 (dados sensíveis) →
  /// opt-in estrito.
  AI_TRAINING
  /// Compartilhamento de dados com terceiros (parceiros, integrações,
  /// analytics vendors). Opt-in estrito.
  THIRD_PARTY_SHARING
}

// ─── Wave 23.1 — Literature Ingestion Cron (continuous scientific papers) ───
//
// ADR-013: Akasha Portal é uma **consciência viva** que evolui via chain
// of thought. Para que o RAG (Wave 21.1) não fique estagnado nos 15 papers
// hardcoded, este wave adiciona o cron semanal que busca papers novos sobre
// espiritualidade (ayahuasca, meditação, etc) na PubMed + arXiv e os
// ingere no modelo `LiteraturePaper`.
//
// Componentes do wave:
//   1. `LiteraturePaper` (referência ao schema Wave 21.1 — model vive no
//      branch `wave-21.1-literature-rag` ainda não merged em main).
//      Este comentário-documenta o contrato esperado pelo cron: papers
//      são identificados por DOI único (skip duplicates).
//   2. `CronLog` — tabela append-only de auditoria de jobs cron.
//      Inspirado em `PrivacyConsent` (Wave 19.3): sem FK para User,
//      sem updatedAt, sem delete. Cada execução do cron gera 1 row.
//
// LGPD:
//   - CronLog NÃO carrega PII. `errors` é JSON com mensagens técnicas
//     (sem userId, sem IP, sem abstracts).
//   - `jobName` é uma string livre ('literature-ingest', etc) — permite
//     que múltiplos crones compartilhem a tabela sem acoplamento.
//
// Schema diff Wave 23.1:
//   + model CronLog
//   + enum CronLogStatus
//
// Migration é PROPOSAL (per prisma/AGENTS.md D1) — humano roda:
//   pnpm exec prisma migrate dev --name cron_log
model CronLog {
  id         String        @id @default(cuid())
  /// Identificador semântico do job (ex: 'literature-ingest').
  /// String livre para evitar acoplamento entre crones.
  jobName    String
  /// Início da execução (UTC).
  startedAt  DateTime      @default(now())
  /// Fim da execução (UTC). NULL = ainda rodando (visível em dashboards).
  finishedAt DateTime?
  /// Estado final: success | partial_success | failed.
  status     CronLogStatus @default(RUNNING)
  /// Papers inseridos nesta execução (delta positivo).
  inserted   Int           @default(0)
  /// Papers pulados por duplicata (DOI já existia).
  skipped    Int           @default(0)
  /// Erros não-fatais acumulados (ex: 1 paper falhou ao gerar embedding).
  /// JSON com shape: { items: [{ pmid: string, stage: string, message: string }] }
  errors     Json          @default("{\"items\":[]}")

  /// Índice para queries do admin: últimas execuções de um job específico.
  @@index([jobName, startedAt])
  /// Índice secundário: filtro por status (admin alerts).
  @@index([status, startedAt])
  @@map("cron_logs")
}

/// Estados possíveis de uma execução de cron.
/// - RUNNING: job em andamento (finishedAt = null).
/// - SUCCESS: terminou sem erros (errors.items.length === 0).
/// - PARTIAL_SUCCESS: terminou com ≥1 erro não-fatal mas ≥1 inserção.
/// - FAILED: terminou sem inserções E com ≥1 erro fatal.
enum CronLogStatus {
  RUNNING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
}

// =========================================================================
// Wave 24.1 — InsightJob: log de execuções do cron de background insights.
//
// MOTIVAÇÃO (ADR-013 — consciencia viva):
//   O cron diário em /api/discoveries/cron gera 5-10 discoveries novas
//   toda madrugada, sem Zelador presente. Para auditoria (UI admin) e
//   para acompanhar o ritmo de evolução da consciência Akasha, cada
//   execução precisa ser persistida em uma tabela dedicada.
//
// DIFERENÇA vs CronLog (Wave 23.1):
//   - CronLog é genérico (1 tabela para todos os crones).
//   - InsightJob é específico do discovery cron: precisa de campos
//     semânticos (insightsGenerated, papersCited, windowSpec) que
//     CronLog não tem.
//
// LGPD by design:
//   - Sem FK para User (insights são globais — sem user attribution).
//   - Sem updatedAt (append-only).
//   - Sem PII em errors/windowSpec (puramente técnico).
//
// PROPOSAL ONLY (ver D-053) — humano aplica via
//   pnpm exec prisma migrate dev --name insight_job
// =========================================================================

enum InsightJobStatus {
  RUNNING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
}

model InsightJob {
  id                String           @id @default(cuid())
  /// Identificador semântico do job (ex: 'discoveries-cron').
  /// String livre para permitir múltiplos jobs de insights no futuro.
  jobName           String
  /// Início da execução (UTC).
  startedAt         DateTime         @default(now())
  /// Fim da execução (UTC). NULL = ainda rodando.
  finishedAt        DateTime?
  /// Estado final (mesmo enum semântico de CronLogStatus).
  status            InsightJobStatus @default(RUNNING)
  /// Quantos insights/discoveries esta execução persistiu no DB.
  /// Tipicamente 5-10 por dia (alvo do Wave 24.1).
  insightsGenerated Int              @default(0)
  /// Quantos papers foram citados como input desta execução.
  /// Janela: últimos 7 dias (Wave 23.1 cron rodou).
  papersCited       Int              @default(0)
  /// Erros não-fatais acumulados. Shape:
  /// { items: [{ stage: string, message: string, input?: string }] }
  errors            Json             @default("{\"items\":[]}")
  /// Janela temporal de inputs (ex: papers 7d, discoveries 30d, feedback 30d).
  /// Shape: { papersWindowDays: 7, discoveriesWindowDays: 30, feedbackWindowDays: 30 }
  windowSpec        Json             @default("{}")

  /// Índice: últimas execuções de um jobName específico (UI admin).
  @@index([jobName, startedAt])
  /// Índice secundário: filtro por status (admin alerts).
  @@index([status, startedAt])
  @@map("insight_jobs")
}
