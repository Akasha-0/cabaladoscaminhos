# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ... except the template (whitelisted so devs can `cp .env.example .env.local`)
!.env.example

# Supabase
.env.local
.env.*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma
# Local Pi runtime state
.atl/

# ================================
# Dev/Test/Prototype Cleanup
# Remove these paths after testing
# ================================
/src/app/debug/
/src/app/debug-auth/
/src/app/debug-login/
/src/app/simple-*/
/src/app/test-*/
/src/app/static-test.html
/src/app/api/chat.disabled/
/src/app/api/meditacao.disabled_BROKEN/
/src/app/api/spiritual.disabled_BROKEN/

# Skip/test disabled files
**/*.skip
**/*.test.disabled
**/*.disabled
**/*.bak
**/*.old
**/*.backup
**/*.tmp

# Runtime/agent state
/.mavis/
/.swarm/
/.hermes/

# Validation landing — waitlist captures (do NOT commit emails)
/data/
!/data/.gitkeep

# Local-only override
/.vscode/
/.idea/
