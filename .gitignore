/.claude/sessions/
/.claude/state/
/.claude/scripts/autonomous/
/.claude/memory/
/.claude/rules/
/.claude/scheduled_tasks.json
/.hermes/
/.remember/
/.mavis/plans.tmp/
/.omp/runtime/
/.omp/logs/
/.omp/state/
/.trae/documents/
/.trae/runtime/
/.trae/logs/
/.trae/state/
/.swarm/runtime/
/.swarm/logs/
.claude/

