/.claude/rules/
/.claude/scheduled_tasks.json
/.hermes/
/.remember/
/.mavis/plans.tmp/
/.omp/runtime/
/.omp/logs/
/.omp/state/
/.trae/documents/
/.trae/runtime/
/.trae/logs/
/.trae/state/
/.swarm/runtime/
/.swarm/logs/
.claude/

# Auto Claude generated files
.auto-claude/
.auto-claude-security.json
.auto-claude-status
.claude_settings.json
.worktrees/
.security-key
logs/security/

# Auto Claude data directory
.auto-claude/

