# ===========================================
# Akasha Portal — Environment Variables
# ===========================================
# Branch: feat/community-platform (comunidade + Akasha IA curadora)
# Copy to .env.local and fill in the values.
# NEVER commit actual secrets to version control.
#
# Estrutura por responsabilidade:
#   1. Database (PostgreSQL + pgvector)
#   2. Supabase (Auth + Storage + Realtime)
#   3. Cache / Rate-limit (Redis)
#   4. AI providers (OpenAI primário, MiniMax fallback, embeddings)
#   5. Web Push (VAPID) — notificações opt-in
#   6. Email (Resend) — notificações transacionais + LGPD
#   7. Observabilidade (PostHog + Sentry)
#   8. App config (URLs, feature flags)
#   9. CORS (production)
#  10. Development only (NUNCA em prod)
# ===========================================

# ===========================================
# 1. Database (PostgreSQL + pgvector)
# ===========================================
# Format: postgresql://user:password@host:port/database
# Em produção, use Supabase connection pooler (porta 6543) para serverless.
# Em dev, porta 5432 direta.
DATABASE_URL="postgresql://postgres:password@localhost:5432/akasha"

# ===========================================
# 2. Supabase (Auth + Storage + Realtime)
# ===========================================
# URL do projeto Supabase (anon-safe pra expor no client).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key — exposta no client; tem RLS como linha de defesa.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SOMENTE server-side; bypassa RLS. NUNCA expor no client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# 3. Cache / Rate-limit (Redis)
# ===========================================
# Upstash Redis, Vercel KV, ou Redis local.
# Usado pra: rate-limit de API, cache de feed, dedup de notificações.
REDIS_URL=redis://localhost:6379

# ===========================================
# 4. AI providers
# ===========================================
# OpenAI — síntese LLM primária (Akasha IA curadora na Fase 3).
OPENAI_API_KEY=sk-...
# Model default (pode ser sobrescrito em runtime por feature flag).
OPENAI_MODEL=gpt-4o
# Embeddings — usado no RAG da Fase 3 (pgvector).
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI resilience (circuit breaker + retry exponencial).
# Defaults razoáveis; ajustar só se tiver evidência empírica.
OPENAI_MAX_RETRIES=3
OPENAI_INITIAL_DELAY_MS=500
OPENAI_MAX_DELAY_MS=8000
OPENAI_RETRY_MULTIPLIER=2
OPENAI_CIRCUIT_THRESHOLD=5
OPENAI_CIRCUIT_TIMEOUT_MS=30000
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# MiniMax (recomendado em prod — raciocínio profundo, custo menor).
# Quando LLM_PROVIDER=minimax + MINIMAX_API_TOKEN setados, roteia via
# interface OpenAI-compatible do MiniMax.
MINIMAX_API_TOKEN=

# ─────────────────────────────────────────────────────────────
# MiniMax via interface Anthropic-compatible (RECOMENDADO)
# ─────────────────────────────────────────────────────────────
# Quando ANTHROPIC_AUTH_TOKEN + ANTHROPIC_BASE_URL estão setados,
# LLM_PROVIDER=anthropic redireciona o cliente Anthropic nativo para
# o endpoint MiniMax, mantendo o formato de mensagens Anthropic
# (mais rico em reasoning_content que a interface OpenAI-compatible).
#
# Models aceitos via interface Anthropic do MiniMax:
#   - MiniMax-M3 (recomendado — raciocínio profundo)
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# ANTHROPIC_AUTH_TOKEN=set via secret store (NEVER commit)
ANTHROPIC_MODEL=MiniMax-M3

# LLM provider default (auto-detectado se não setar).
# Opções: openai | minimax | anthropic | local | gemini | groq | deepseek | openrouter
# LLM_PROVIDER=anthropic

# ===========================================
# 5. Web Push (VAPID) — Notificações opt-in
# ===========================================
# Generate with: npx web-push generate-vapid-keys
# Public key is exposed to the client (NEXT_PUBLIC_*). Private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@akasha.local

# ===========================================
# 6. Email (Resend) — Notificações transacionais
# ===========================================
# Usado em src/lib/notifications/email.ts.
# Em dev, sem RESEND_API_KEY cai em console.log fallback.
RESEND_API_KEY=re_...
# Remetente padrão — DEVE ser domínio verificado no Resend.
NOTIFICATION_EMAIL_FROM=Akasha Portal <noreply@akasha.local>

# ===========================================
# 7. Observabilidade
# ===========================================
# PostHog — product analytics + feature flags.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Set 'true' pra desabilitar PostHog em dev local (evita ruído).
POSTHOG_DISABLED=false
POSTHOG_PROJECT_API_KEY=

# Sentry — error tracking (server + client).
SENTRY_DSN=

# Webhook pra PM feedback loop (feature requests, NPS).
PM_FEEDBACK_WEBHOOK_URL=

# ===========================================
# 8. App config
# ===========================================
# URL pública do app. Usado em emails, redirects de OAuth, manifest PWA.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Alias legado — alguns lugares ainda usam BASE_URL. Manter sincronizado.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# CDN customizada pra avatares/uploads (opcional — default Supabase Storage).
NEXT_PUBLIC_IMAGE_CDN=

# ===========================================
# 9. CORS (production)
# ===========================================
# Comma-separated list of allowed origins. NEVER use '*' em produção —
# o app rejeita explicitamente e exige origens declaradas.
# Exemplo: ALLOWED_ORIGINS=https://akasha.app,https://staging.akasha.app
ALLOWED_ORIGINS=

# ===========================================
# 10. Development only (NUNCA em prod)
# ===========================================
# Token de runtime do MiniMax agent (pra tasks automatizadas em dev).
MINIMAX_API_TOKEN=
# Set 'true' pra bypassar auth em dev local (header x-dev-operator-id).
# DEVE ficar unset em prod.
ALLOW_DEV_AUTH_BYPASS=
# Set 'true' pra permitir self-registration de operator em dev.
ALLOW_OPERATOR_REGISTRATION=
