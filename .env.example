# ===========================================
# Cabala dos Caminhos - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in the values.
# NEVER commit actual secrets to version control.

# ===========================================
# Supabase Configuration
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# Database (PostgreSQL)
# ===========================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:password@db.your-project.supabase.co:5432/postgres"

# ===========================================
# CORS Configuration
# ===========================================
# Required for production. Format: comma-separated list of allowed origins.
# IMPORTANT: In production, requests from origins not in this list will NOT receive
# CORS headers, preventing cross-origin API access from unauthorized domains.
#
# Examples:
#   ALLOWED_ORIGINS=https://cabala-dos-caminhos.vercel.app,https://staging.example.com
#   ALLOWED_ORIGINS=https://your-domain.com
#
# SECURITY: Do NOT use '*' in production. The app will reject '*' and require explicit origins.
ALLOWED_ORIGINS=

# ===========================================
# Feature Flags
# ===========================================
# LEGACY_B2C=on  → Enable legacy B2C platform (dashboard, mapa pessoal, rituais, billing)
# Not set        → B2C quarantined, only Cockpit (B2B) is accessible
# LEGACY_B2C=on

# ===========================================
# Stripe (Payments)
# ===========================================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# ===========================================
# Cockpit B2B Authentication
# ===========================================
# REQUIRED in production. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# REQUIRED in production. 32-byte hex key (64 hex chars) for MFA TOTP encryption.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=
# ===========================================
# Development / Testing Only
# ===========================================
# DO NOT set in production. Enables x-dev-operator-id header bypass for local dev.
# Set to 'true' only in .env.local for local development.
ALLOW_DEV_AUTH_BYPASS=
# DO NOT set in production. Enables operator self-registration endpoint.
# Set to 'true' only in .env.local for local development.
ALLOW_OPERATOR_REGISTRATION=
# ===========================================
# AI Services
# ===========================================
MINIMAX_API_TOKEN=
