# ===========================================
# Cabala dos Caminhos — Environment Variables (DEFINITIVO — Wave 27)
# ===========================================
# Branch: main @ 252d81c8
# Author: Coder + Caio (Wave 27 — DEPLOY 4/6)
#
# Copy to .env.local and fill in the values.
# NEVER commit actual secrets to version control.
# Em produção, TODAS as vars ficam em Vercel Project → Settings → Environment Variables
# (separadas por ambiente: Production / Preview / Development).
#
# Validação automática:
#   - src/lib/env.ts (Zod schema) roda no startup do server
#   - Em prod: falha rápida com mensagem clara se faltar var obrigatória
#   - Em dev: warning, mas `next dev` sobe mesmo assim
#   - Em test: skipped (Vitest seta vars per-test)
#
# Convenção:
#   - NEXT_PUBLIC_* → exposta ao client (anon-safe; RLS é a linha de defesa real)
#   - sem prefixo    → server-only (NUNCA bundled no client)
#   - # OPTIONAL    → marcados; app tem fallback razoável
#
# Estrutura por responsabilidade:
#   1.  Database (PostgreSQL + pgvector)
#   2.  Supabase (Auth + Storage + Realtime)
#   3.  Cache / Rate-limit (Redis)
#   4.  AI providers (OpenAI primário, MiniMax fallback, embeddings)
#   5.  Web Push (VAPID) — notificações opt-in
#   5b. Cron auth (Vercel Crons → rotas internas)
#   6.  Email (Resend) — notificações transacionais + LGPD
#   7.  Observabilidade (PostHog + Sentry)
#   8.  App config (URLs, feature flags)
#   9.  CORS (production)
#  10.  Admin (ADMIN_EMAILS, ADMIN_NEWSLETTER_SECRET)
#  11.  Development only (NUNCA em prod)
#  12.  Deploy runtime (Vercel injeta automaticamente)
#
# Verificação:
#   bash scripts/verify-env.sh              # checa todas as required vars + connectivity
#   bash scripts/pre-deploy-check.sh        # gate completo antes de deploy
# ===========================================

# ===========================================
# 1. Database (PostgreSQL + pgvector)
# ===========================================
# Format: postgresql://user:password@host:port/database
# Em produção, use Supabase connection pooler (porta 6543) para serverless.
# Em dev, porta 5432 direta.
DATABASE_URL="postgresql://postgres:password@localhost:5432/akasha"

# ===========================================
# 2. Supabase (Auth + Storage + Realtime)
# ===========================================
# URL do projeto Supabase (anon-safe pra expor no client).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Anon key — exposta no client; tem RLS como linha de defesa.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SOMENTE server-side; bypassa RLS. NUNCA expor no client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# 3. Cache / Rate-limit (Redis)
# ===========================================
# Upstash Redis, Vercel KV, ou Redis local.
# Usado pra: rate-limit de API, cache de feed, dedup de notificações.
# OPTIONAL — app cai pra in-memory fallback se ausente.
REDIS_URL=redis://localhost:6379

# ===========================================
# 4. AI providers
# ===========================================
# OpenAI — síntese LLM primária (Akasha IA curadora na Fase 3).
OPENAI_API_KEY=sk-...
# Model default (pode ser sobrescrito em runtime por feature flag).
OPENAI_MODEL=gpt-4o
# Embeddings — usado no RAG da Fase 3 (pgvector).
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI resilience (circuit breaker + retry exponencial).
# Defaults razoáveis; ajustar só se tiver evidência empírica.
OPENAI_MAX_RETRIES=3
OPENAI_INITIAL_DELAY_MS=500
OPENAI_MAX_DELAY_MS=8000
OPENAI_RETRY_MULTIPLIER=2
OPENAI_CIRCUIT_THRESHOLD=5
OPENAI_CIRCUIT_TIMEOUT_MS=30000
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────
# MiniMax via interface Anthropic-compatible (RECOMENDADO em prod)
# ─────────────────────────────────────────────────────────────
# Quando ANTHROPIC_AUTH_TOKEN + ANTHROPIC_BASE_URL estão setados,
# LLM_PROVIDER=anthropic redireciona o cliente Anthropic nativo para
# o endpoint MiniMax, mantendo o formato de mensagens Anthropic
# (mais rico em reasoning_content que a interface OpenAI-compatible).
#
# Models aceitos via interface Anthropic do MiniMax:
#   - MiniMax-M3 (recomendado — raciocínio profundo)
ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# ANTHROPIC_AUTH_TOKEN=set via secret store (NEVER commit)
ANTHROPIC_MODEL=MiniMax-M3

# ─────────────────────────────────────────────────────────────
# MiniMax via interface OpenAI-compatible (legacy fallback)
# ─────────────────────────────────────────────────────────────
# Quando LLM_PROVIDER=minimax + MINIMAX_API_TOKEN setados, roteia via
# interface OpenAI-compatible do MiniMax.
MINIMAX_API_TOKEN=
MINIMAX_BASE_URL=https://api.minimax.io/v1

# LLM provider default (auto-detectado se não setar).
# Opções: openai | minimax | anthropic | local | gemini | groq | deepseek | openrouter
LLM_PROVIDER=anthropic

# Anthropic nativo (opcional — usado se LLM_PROVIDER=anthropic sem MINIMAX)
ANTHROPIC_API_KEY=

# ===========================================
# 5. Web Push (VAPID) — Notificações opt-in
# ===========================================
# Generate with: npx web-push generate-vapid-keys
# Public key is exposed to the client (NEXT_PUBLIC_*). Private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@akasha.local

# ===========================================
# 5b. Cron auth (Vercel Crons → handlers internos)
# ===========================================
# Token que handlers em /api/cron/* validam via header
# `Authorization: Bearer ${CRON_SECRET}`. Vercel injeta automaticamente
# o header em chamadas de cron se você setar o "Authentication secret"
# no path do cron em Vercel Dashboard → Project → Settings → Cron Jobs.
# Este var é fallback pra testes locais via curl.
#
# Gerar com: openssl rand -hex 32
CRON_SECRET=

# ===========================================
# 6. Email (Resend) — Notificações transacionais
# ===========================================
# Usado em src/lib/notifications/email.ts e src/lib/email/.
# Em dev, sem RESEND_API_KEY cai em console.log fallback.
RESEND_API_KEY=re_...
# Remetente padrão — DEVE ser domínio verificado no Resend.
NOTIFICATION_EMAIL_FROM=Akasha Portal <noreply@akasha.local>
# Newsletter — sender específico para a sequência de boas-vindas.
NEWSLETTER_FROM_NAME=Akasha Portal
NEWSLETTER_FROM_EMAIL=Akasha Portal <noreply@akasha.local>
NEWSLETTER_REPLY_TO=contato@akasha.local

# ===========================================
# 7. Observabilidade
# ===========================================
# PostHog — product analytics + feature flags.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Set 'true' pra desabilitar PostHog em dev local (evita ruído).
POSTHOG_DISABLED=false
POSTHOG_PROJECT_API_KEY=
# PostHog sample rate 0..1 (default 1.0). Reduz volume em prod.
POSTHOG_SAMPLE_RATE=

# Sentry — error tracking (server + client).
SENTRY_DSN=
# Sentry release tag (matching git sha / vercel deploy id) para correlacionar
# source maps e eventos. Default: usa NEXT_PUBLIC_APP_VERSION.
SENTRY_RELEASE=
# Sentry server name (default: $HOSTNAME)
SENTRY_SERVER_NAME=
# Sentry sample rate 0..1 (default 1.0 prod, 0.0 dev)
SENTRY_SAMPLE_RATE=
# Sentry auth token (pra upload de source maps via @sentry/cli).
# NUNCA commit; manter em secret manager / CI vars.
SENTRY_AUTH_TOKEN=
# Sentry org/project slug (pra upload de source maps).
SENTRY_ORG=
SENTRY_PROJECT=

# Web Vitals auto-tracking (default true). Sentry + PostHog recebem LCP/CLS/INP.
NEXT_PUBLIC_WEB_VITALS=true

# Webhook pra PM feedback loop (feature requests, NPS).
PM_FEEDBACK_WEBHOOK_URL=

# Health endpoint — quando 'true', qualquer check falhando marca degraded (503).
# Default 'false': so' database/openai criticos derrubam.
HEALTH_REQUIRE_ALL=false

# ===========================================
# 8. App config
# ===========================================
# URL pública do app. Usado em emails, redirects de OAuth, manifest PWA.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Alias legado — alguns lugares ainda usam BASE_URL. Manter sincronizado.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Site URL (alias legacy usado em emails de auth). Manter sincronizado com APP_URL.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Versão do app (git sha / deploy id). Default: VERCEL_GIT_COMMIT_SHA.
NEXT_PUBLIC_APP_VERSION=
# CDN customizada pra avatares/uploads (opcional — default Supabase Storage).
NEXT_PUBLIC_IMAGE_CDN=
# APP_URL — server-only alias para NEXT_PUBLIC_APP_URL em contexts server-side.
APP_URL=http://localhost:3000

# ===========================================
# 9. CORS (production)
# ===========================================
# Comma-separated list of allowed origins. NEVER use '*' em produção —
# o app rejeita explicitamente e exige origens declaradas.
# Exemplo: ALLOWED_ORIGINS=https://akasha.app,https://staging.akasha.app
ALLOWED_ORIGINS=

# ===========================================
# 10. Admin (acesso restrito)
# ===========================================
# Comma-separated emails com permissão admin.
# Em prod, DEVE ser setado; sem isso, /admin retorna 404 em produção.
ADMIN_EMAILS=
# Secret para o endpoint /api/admin/newsletter/send (autenticação HMAC).
# Gerar com: openssl rand -hex 32
ADMIN_NEWSLETTER_SECRET=

# ===========================================
# 10b. Audit (LGPD)
# ===========================================
# Salt para hashing de IPs em audit logs (LGPD — não armazenar IP em plain).
# Gerar com: openssl rand -hex 16
# OPTIONAL — fallback para NODE_ENV no startup.
AUDIT_IP_SALT=

# ===========================================
# 11. Development only (NUNCA em prod)
# ===========================================
# Set 'true' pra bypassar auth em dev local (header x-dev-operator-id).
# DEVE ficar unset em prod.
ALLOW_DEV_AUTH_BYPASS=
# Set 'true' pra permitir self-registration de operator em dev.
ALLOW_OPERATOR_REGISTRATION=
# Skip env validation (usado em Vitest; NUNCA setar em prod).
SKIP_ENV_VALIDATION=

# ===========================================
# 12. Deploy runtime (Vercel injeta automaticamente)
# ===========================================
# Estas vars são setadas pela plataforma Vercel em runtime.
# Documentadas aqui só pra visibilidade — NÃO setar manualmente.
#
# VERCEL=1                              → ambiente Vercel detectado
# VERCEL_ENV=production|preview|development
# VERCEL_URL=*.vercel.app              → URL do deploy (preview)
# VERCEL_REGION=gru1                    → região do deploy
# VERCEL_GIT_PROVIDER=github
# VERCEL_GIT_REPO_SLUG=Akasha-0/cabaladoscaminhos
# VERCEL_GIT_REPO_OWNER=Akasha-0
# VERCEL_GIT_COMMIT_REF=
# VERCEL_GIT_COMMIT_SHA=
# VERCEL_GIT_COMMIT_MESSAGE=
# VERCEL_GIT_PREVIOUS_SHA=

# Node version (Vercel detecta do package.json ou .nvmrc; documentada pra clareza).
# Em package.json, dependências pedem Node 22+; CI roda Node 22.
# OPTIONAL — se não setar, Vercel usa 22.x default.
NODE_VERSION=22

# Build optimizations (Vercel Build Output API + Next.js experimental).
# ENABLE_EXPERIMENTAL_BUILD_OUTPUT=standalone → ativa compile + generate em 2 fases.
# OPTIONAL — sem isso, build cai no modo padrão (single pass, pode OOM).
ENABLE_EXPERIMENTAL_BUILD_OUTPUT=standalone

# ===========================================
# 13. (Reserved) NEXTAUTH_* / GITHUB_TOKEN
# ===========================================
# NEXTAUTH_SECRET, NEXTAUTH_URL — NÃO utilizados pelo app atual (auth via Supabase).
# Mantidos aqui apenas como histórico; remover se confirmado como dead vars.
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=
#
# GITHUB_TOKEN — gerado automaticamente por Vercel GitHub App para
# deployments via GitHub Actions. Não precisa setar manualmente.
# Em CI local (fork/sandbox), o workflow detecta ausência e skip.
# GITHUB_TOKEN=