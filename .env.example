# ===========================================
# Sistema Akasha — Environment Variables
# ===========================================
# Copy to .env.local and fill in the values.
# NEVER commit actual secrets to version control.

# ===========================================
# Database (PostgreSQL + pgvector)
# ===========================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:password@localhost:5432/akasha"

# ===========================================
# B2C Akasha Auth (JWT)
# ===========================================
# REQUIRED. Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AKASHA_JWT_SECRET=

# ===========================================
# B2B Cockpit Auth (JWT)
# ===========================================
# REQUIRED in production. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# REQUIRED in production.
MFA_ENCRYPTION_KEY=

# ===========================================
# Stripe — B2C Akasha
# ===========================================
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret for B2C Akasha Stripe events (meia-nota da assinatura, créditos, etc.)
STRIPE_AKASHA_WEBHOOK_SECRET=whsec_...

# Webhook secret for B2B cockpit Stripe events (legacy)
STRIPE_WEBHOOK_SECRET=whsec_...

# Pre-configured Stripe Price IDs (optional — app creates dynamic prices as fallback)
STRIPE_PRICE_AKASHA_MANIFESTO=price_...
STRIPE_PRICE_AKASHA_PRO=price_...
STRIPE_PRICE_AKASHA_CREDITS_10=price_...
STRIPE_PRICE_AKASHA_CREDITS_30=price_...
STRIPE_PRICE_AKASHA_CREDITS_60=price_...

# ===========================================
# Akasha Admin
# ===========================================
# Secret header for admin endpoints (POST /api/akasha/credits)
AKASHA_ADMIN_SECRET=

# ===========================================
# AI Services
# ===========================================
# OpenAI — Agente Oracular / Síntese LLM
OPENAI_API_KEY=sk-...

# Ollama — embeddings do Grimório (nomic-embed-text, local)
OLLAMA_BASE_URL=http://localhost:11434

# MiniMax (legacy B2B)
MINIMAX_API_TOKEN=

# ===========================================
# Redis (caching, rate-limit, daily transits)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# App
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# CORS (production)
# ===========================================
# Comma-separated list of allowed origins. NEVER use '*' in production.
ALLOWED_ORIGINS=

# ===========================================
# Web Push (VAPID) — Push Notifications
# ===========================================
# Generate with: npx web-push generate-vapid-keys
# Public key is exposed to the client (NEXT_PUBLIC_*). Private key is server-only.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:dev@akasha.local

# ===========================================
# Development Only
# ===========================================
# DO NOT set in production.
ALLOW_DEV_AUTH_BYPASS=
ALLOW_OPERATOR_REGISTRATION=
