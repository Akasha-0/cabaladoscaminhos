# ============================================================================
# .vercelignore — Arquivos excluídos do upload pro Vercel
# ============================================================================
# Reduz tamanho do upload (~80% menor) e tempo de build.
# Tudo aqui está fora do que o runtime de produção precisa.
#
# IMPORTANTE: NÃO excluir nada que o `next build` precisa. Em caso de dúvida
# sobre `src/`, deixar dentro (Next.js já filtra tree-shaking).
# ============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# Dependencies (NUNCA subir — Vercel instala via installCommand)
# ─────────────────────────────────────────────────────────────────────────────
node_modules
.pnpm-store

# ─────────────────────────────────────────────────────────────────────────────
# Build artifacts (Vercel gera o próprio)
# ─────────────────────────────────────────────────────────────────────────────
.next
out
build
dist
*.tsbuildinfo
next-env.d.ts

# ─────────────────────────────────────────────────────────────────────────────
# Testes (não rodam em prod)
# ─────────────────────────────────────────────────────────────────────────────
__tests__
tests
e2e
test-results
playwright-report
coverage
.vitest
.ci-logs
.screenshots

# ─────────────────────────────────────────────────────────────────────────────
# Documentation (pesado e inútil pro runtime)
# ─────────────────────────────────────────────────────────────────────────────
docs
*.md
!README.md
!LICENSE
CHANGELOG.md
ARCHITECTURE.md
CLAUDE.md
AGENTS.md

# ─────────────────────────────────────────────────────────────────────────────
# Local debug & test pages (NUNCA ir pra prod)
# ─────────────────────────────────────────────────────────────────────────────
src/app/debug
src/app/debug-auth
src/app/debug-login
src/app/simple-*
src/app/test-*
src/app/static-test.html
public/static-test.html
public/test.html
public/test-login.html
public/dashboard.html

# ─────────────────────────────────────────────────────────────────────────────
# Scripts locais e helpers de dev
# ─────────────────────────────────────────────────────────────────────────────
scripts/ci-local.sh
scripts/check-bundle-size.ts
scripts/run-evolution.ts
scripts/run-quality-eval.ts
scripts/test-browser.ts
scripts/verify-notifications-realtime.ts
scripts/postHog-funnels.yaml
scripts/migrations

# ─────────────────────────────────────────────────────────────────────────────
# Quality / evolution artifacts (auditoria interna, não runtime)
# ─────────────────────────────────────────────────────────────────────────────
quality-*.json
quality-*.yaml
report-*.json

# ─────────────────────────────────────────────────────────────────────────────
# Seeds (apenas dev local — production roda via migrations)
# ─────────────────────────────────────────────────────────────────────────────
prisma/seed
prisma/seed.ts

# ─────────────────────────────────────────────────────────────────────────────
# Agent / mavis state
# ─────────────────────────────────────────────────────────────────────────────
.mavis
.swarm
.trae
.claude
.omp
.atl
.agent-configs
.skills
attachments
logs

# ─────────────────────────────────────────────────────────────────────────────
# IDE / OS files
# ─────────────────────────────────────────────────────────────────────────────
.vscode
.idea
.DS_Store
*.swp
*.swo

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# ─────────────────────────────────────────────────────────────────────────────
# Env files (NUNCA subir secrets — só o template)
# ─────────────────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
.env.production
!.env.example

# ─────────────────────────────────────────────────────────────────────────────
# Vercel cache local (não confundir com .vercel deploy cache)
# ─────────────────────────────────────────────────────────────────────────────
.vercel
