{
  "compilerOptions": {
    "noEmit": true,
    "skipLibCheck": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "jsx": "preserve",
    "types": [],
    "strict": true,
    "allowImportingTsExtensions": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/components/mentorship/**/*",
    "src/lib/engines/mentorship-ui/**/*",
    "src/test/mentorship-ui.spec.ts",
    "src/test/mentorship-ui.smoke.ts",
    "src/test/node-stubs.d.ts",
    "react-stubs.d.ts"
  ]
}
