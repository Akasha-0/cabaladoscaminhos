{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "audit": {
    "gate": "all",
    "deadCodeBaseline": "./fallow-baseline-dead-code.json",
    "healthBaseline": "./fallow-baseline-health.json",
    "dupesBaseline": "./fallow-baseline-dupes.json"
  },
  "duplicates": {
    "enabled": false,
    "minOccurrences": 3,
    "ignore": [
      "tests*.test.ts"
    ]
  },
  "health": {
    "enabled": false
  },
  "rules": {
    "unused-dependencies": "warn"
  },
  "usedClassMembers": [
    "correlateChakraElement",
    "correlatePlanetOrixa",
    "getAllSystemCorrelations",
    "detectPatterns",
    "explainCorrelationPT",
    "generatePracticalAdvice",
    "toJSON"
  ],
  "entry": [
    "middleware.ts",
    "next.config.ts",
    "prisma/seed.ts",
    "prisma.config.ts",
    "src/apppage.tsx",
    "src/applayout.tsx",
    "src/approute.ts",
    "src/apploading.tsx",
    "src/apperror.tsx",
    "src/appnot-found.tsx",
    "src/apptemplate.tsx",
    "src/appdefault.tsx",
    "src/middleware.ts",
    "src/middleware/index.ts",
    "src/instrumentation.ts",
    "src/instrumentation-node.ts",
    "src/proxy.ts"
  ],
  "ignorePatterns": [
    "src/lib/orixa**",
    "src/lib/od***",
    "src/lib/os***",
    "src/lib/ik***",
    "src/lib/ir**.test.ts",
    "**/*.test.tsx"
  ],
  "ignoreUnresolvedImports": [
    "tests/lib/manifestation/**",
    "tests/lib/sacred-geometry/**",
    "tests/lib/transformation/**",
    "tests/lib/energy/**",
    "tests/lib/karma/**",
    "tests/lib/meditation/**",
    "tests/lib/sacred-texts/**",
    "tests/lib/auth-jwt.test.ts",
    "**/stats-visualization.ts"
  ],
  "ignoreExports": []
}