{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": [],
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": true,
    "exactOptionalPropertyTypes": false
  },
  "include": [
    "src/lib/w75/akashia-offering-tracking.ts",
    "src/lib/w75/akashia-offering-tracking.spec.ts",
    "src/lib/w75/akashia-offering-tracking.smoke.ts",
    "src/lib/w75/node-stubs.d.ts"
  ]
}
