import { describe, it, expect } from 'vitest';

describe('POST /api/correlation/diagnosis', () => {
 it.skip('should diagnose spiritual misalignment from symptoms', async () => {
    const res = await fetch('http://localhost:3000/api/correlation/diagnosis', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        symptoms: ['medo_crônico', 'ansiedade', 'insonia']
      })
    });
    const json = await res.json();
    expect(res.status).toBe(200);
    expect(json.success).toBe(true);
    expect(Array.isArray(json.data)).toBe(true);
    expect(json.data[0]).toHaveProperty('chakra');
    expect(json.data[0]).toHaveProperty('diagnosis');
    expect(json.data[0]).toHaveProperty('correctiveActions');
  });

 it.skip('should return herbs and frequencies in prescription', async () => {
    const res = await fetch('http://localhost:3000/api/correlation/diagnosis', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        symptoms: ['dor_cabeca', 'confusao_mental']
      })
    });
    const json = await res.json();
    expect(res.status).toBe(200);
    const prescription = json.data[0]?.correctiveActions;
    expect(prescription).toHaveProperty('herbs');
    expect(prescription).toHaveProperty('frequencies');
  });
});

describe('GET /api/correlation/diagnosis', () => {
 it.skip('should return available symptoms list', async () => {
    const res = await fetch('http://localhost:3000/api/correlation/diagnosis');
    const json = await res.json();
    expect(res.status).toBe(200);
    expect(json.success).toBe(true);
    expect(json.data).toHaveProperty('symptoms');
  });
});