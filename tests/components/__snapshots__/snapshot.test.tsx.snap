              class="grid grid-cols-2 gap-4"
            >
              <div
                aria-label="Mistério: Dia da fartura, da busca por conhecimento, da expansão e da cura através das matas."
                class="p-3 bg-secondary/50 rounded-lg"
              >
                <h5
                  class="text-sm font-medium mb-1"
