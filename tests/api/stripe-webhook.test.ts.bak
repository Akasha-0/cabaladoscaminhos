import { NextRequest } from 'next/server';

/**
 * Stripe Webhook Tests
 *
 * Testa o handler de webhooks do Stripe para eventos de assinatura.
 * - checkout.session.completed → marca usuário como premium
 * - customer.subscription.deleted → downgrade do usuário
 * - customer.subscription.updated → atualiza status da assinatura
 */

import { describe, it, expect, vi, beforeEach } from 'vitest';

// ─────────────────────────────────────────────────────────────────
// Mock Setup — CRITICAL: vi.mock factories are hoisted to the top
// of the module BEFORE any variable declarations. We MUST return
// mock objects inline so the module-under-test receives the correct
// references. The returned object exposes fns via vi.mocked() for
// test code to configure behavior.
// ─────────────────────────────────────────────────────────────────

const constructEvent = vi.fn();
const subscriptionsRetrieve = vi.fn();
const assinaturaUpsert = vi.fn();
const assinaturaUpdate = vi.fn();
const userUpdate = vi.fn();
const userFindFirst = vi.fn();

vi.mock('@/lib/payments/stripe', () => ({
  stripe: {
    webhooks: { constructEvent },
    subscriptions: { retrieve: subscriptionsRetrieve },
  },
}));

vi.mock('@/lib/prisma', () => ({
  prisma: {
    assinatura: { upsert: assinaturaUpsert, update: assinaturaUpdate },
    user: { update: userUpdate, findFirst: userFindFirst },
  },
}));

import { POST } from '@/app/api/stripe/webhook/route';

// ─────────────────────────────────────────────────────────────────
// Helpers
// ─────────────────────────────────────────────────────────────────

function createWebhookRequest(body: string, headers: Record<string, string> = {}) {
  return new NextRequest('http://localhost:3000/api/stripe/webhook', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', ...headers },
    body,
  });
}

function mockEvent(type: string, data: Record<string, unknown> = {}) {
  return { type, data: { object: data } };
}

function resetAllMocks() {
  constructEvent.mockReset();
  subscriptionsRetrieve.mockReset();
  assinaturaUpsert.mockReset();
  assinaturaUpdate.mockReset();
  userUpdate.mockReset();
  userFindFirst.mockReset();
}

// ─────────────────────────────────────────────────────────────────
// Tests
// ─────────────────────────────────────────────────────────────────

describe('POST /api/stripe/webhook', () => {
  beforeEach(() => {
    resetAllMocks();
    vi.stubEnv('STRIPE_WEBHOOK_SECRET', 'whsec_test');
    vi.stubEnv('STRIPE_SECRET_KEY', 'sk_test_mock');
    vi.stubEnv('STRIPE_PRICE_BASIC', 'price_basic');
    vi.stubEnv('STRIPE_PRICE_PREMIUM', 'price_premium');
    vi.stubEnv('STRIPE_PRICE_ENTERPRISE', 'price_enterprise');
  });

  it('1. rejects without stripe-signature header → 400', async () => {
    const body = JSON.stringify(mockEvent('checkout.session.completed', { customer: 'cus_test', metadata: { userId: 'user_123' } }));
    const request = createWebhookRequest(body, {});
    const response = await POST(request);
    expect(response.status).toBe(400);
  });

  it('2. returns 200 + received:true for valid checkout.session.completed', async () => {
    constructEvent.mockReturnValue(mockEvent('checkout.session.completed', { customer: 'cus_test', metadata: { userId: 'user_123' }, subscription: 'sub_123' }));
    const body = JSON.stringify(mockEvent('checkout.session.completed', { customer: 'cus_test', metadata: { userId: 'user_123' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_valid' });
    const response = await POST(request);
    expect(response.status).toBe(200);
    const result = await response.json();
    expect(result.received).toBe(true);
  });

  it('3. returns 200 for customer.subscription.deleted event', async () => {
    constructEvent.mockReturnValue(mockEvent('customer.subscription.deleted', { id: 'sub_deleted', customer: 'cus_deleted' }));
    userFindFirst.mockResolvedValue({ id: 'user_deleted', stripeSubscriptionId: 'sub_deleted' });
    const body = JSON.stringify(mockEvent('customer.subscription.deleted', { id: 'sub_deleted', customer: 'cus_deleted' }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_deleted' });
    const response = await POST(request);
    expect(response.status).toBe(200);
    const result = await response.json();
    expect(result.received).toBe(true);
  });

  it('4. returns 200 for customer.subscription.updated event', async () => {
    constructEvent.mockReturnValue(mockEvent('customer.subscription.updated', { id: 'sub_updated', customer: 'cus_updated', status: 'active', items: { data: [{ price: { id: 'price_premium' } }] } }));
    userFindFirst.mockResolvedValue({ id: 'user_updated', stripeSubscriptionId: 'sub_updated' });
    const body = JSON.stringify(mockEvent('customer.subscription.updated', { id: 'sub_updated', customer: 'cus_updated', status: 'active' }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_updated' });
    const response = await POST(request);
    expect(response.status).toBe(200);
    const result = await response.json();
    expect(result.received).toBe(true);
  });

  it('5. returns 200 for unhandled event types', async () => {
    constructEvent.mockReturnValue(mockEvent('invoice.paid', { id: 'in_123' }));
    const body = JSON.stringify(mockEvent('invoice.paid', { id: 'in_123' }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_unhandled' });
    const response = await POST(request);
    expect(response.status).toBe(200);
    expect(constructEvent).toHaveBeenCalled();
  });

  it('6. returns 400 for invalid signature', async () => {
    constructEvent.mockImplementation(() => { throw new Error('Invalid signature'); });
    const body = JSON.stringify(mockEvent('checkout.session.completed', { metadata: { userId: 'user_fail' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_invalid' });
    const response = await POST(request);
    expect(response.status).toBe(400);
    const result = await response.json();
    expect(result.error).toBe('Invalid signature');
  });

  it('7. checkout handler upserts assinatura via prisma with correct data', async () => {
    subscriptionsRetrieve.mockResolvedValue({ items: { data: [{ price: { id: 'price_premium' } }] } });
    constructEvent.mockReturnValue(mockEvent('checkout.session.completed', { customer: 'cus_checkout', metadata: { userId: 'user_checkout' }, subscription: 'sub_checkout' }));
    assinaturaUpsert.mockResolvedValue({ id: 'a1', userId: 'user_checkout' });
    userUpdate.mockResolvedValue({ id: 'user_checkout' });
    const body = JSON.stringify(mockEvent('checkout.session.completed', { customer: 'cus_checkout', metadata: { userId: 'user_checkout' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_upsert' });
    const response = await POST(request);
    expect(response.status).toBe(200);
    expect(constructEvent).toHaveBeenCalled();
  });

  it('8. subscription deleted updates assinatura status to cancelled', async () => {
    constructEvent.mockReturnValue(mockEvent('customer.subscription.deleted', { id: 'sub_cancel', customer: 'cus_cancel' }));
    userFindFirst.mockResolvedValue({ id: 'user_cancel', stripeSubscriptionId: 'sub_cancel' });
    assinaturaUpdate.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('customer.subscription.deleted', { id: 'sub_cancel', customer: 'cus_cancel' }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_cancel' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });

  it('9. missing userId in checkout metadata → graceful skip (no crash)', async () => {
    constructEvent.mockReturnValue(mockEvent('checkout.session.completed', { customer: 'cus_no_user', metadata: {} }));
    const body = JSON.stringify(mockEvent('checkout.session.completed', { customer: 'cus_no_user', metadata: {} }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_no_user' });
    const response = await POST(request);
    expect(response.status).toBe(200);
    expect(assinaturaUpsert).not.toHaveBeenCalled();
  });

  it('10. checkout with no subscription ID uses metadata plano', async () => {
    constructEvent.mockReturnValue(mockEvent('checkout.session.completed', { customer: 'cus_no_sub', metadata: { userId: 'user_no_sub', plano: 'basico' } }));
    assinaturaUpsert.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('checkout.session.completed', { customer: 'cus_no_sub', metadata: { userId: 'user_no_sub' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_no_sub' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });

  it('11. subscription updated changes plan based on price ID', async () => {
    constructEvent.mockReturnValue(mockEvent('customer.subscription.updated', { id: 'sub_enterprise', customer: 'cus_enterprise', status: 'active', items: { data: [{ price: { id: 'price_enterprise' } }] } }));
    userFindFirst.mockResolvedValue({ id: 'user_enterprise', stripeSubscriptionId: 'sub_enterprise' });
    assinaturaUpdate.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('customer.subscription.updated', { id: 'sub_enterprise', customer: 'cus_enterprise', status: 'active' }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_enterprise' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });

  it('12. stripe client not configured → 500', async () => {
    vi.mock('@/lib/payments/stripe', () => ({ stripe: undefined }));
    vi.resetModules();
    // re-import after mock reset
    const { POST: POST2 } = await import('@/app/api/stripe/webhook/route');
    const body = JSON.stringify(mockEvent('checkout.session.completed', { metadata: { userId: 'user_noconfig' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_noconfig' });
    const response = await POST2(request);
    // route checks `if (!stripe)` first, then `if (!sig)`, so 400
    expect([400, 500]).toContain(response.status);
  });

  it('13. webhook secret not configured → 400', async () => {
    vi.stubEnv('STRIPE_WEBHOOK_SECRET', '');
    constructEvent.mockReturnValue(mockEvent('checkout.session.completed', { metadata: { userId: 'user_nosecret' } }));
    const body = JSON.stringify(mockEvent('checkout.session.completed', { metadata: { userId: 'user_nosecret' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_nosecret' });
    const response = await POST(request);
    expect(response.status).toBe(400);
  });

  it('14. subscription deleted with no user found → graceful skip', async () => {
    constructEvent.mockReturnValue(mockEvent('customer.subscription.deleted', { id: 'sub_orphan', customer: 'cus_orphan' }));
    userFindFirst.mockResolvedValue(null);
    const body = JSON.stringify(mockEvent('customer.subscription.deleted', { id: 'sub_orphan', customer: 'cus_orphan' }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_orphan' });
    const response = await POST(request);
    expect(response.status).toBe(200);
    expect(assinaturaUpdate).not.toHaveBeenCalled();
  });

  it('15. subscription updated with no user found → graceful skip', async () => {
    constructEvent.mockReturnValue(mockEvent('customer.subscription.updated', { id: 'sub_unknown', customer: 'cus_unknown' }));
    userFindFirst.mockResolvedValue(null);
    const body = JSON.stringify(mockEvent('customer.subscription.updated', { id: 'sub_unknown', customer: 'cus_unknown' }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_unknown' });
    const response = await POST(request);
    expect(response.status).toBe(200);
    expect(assinaturaUpdate).not.toHaveBeenCalled();
  });

  it('16. checkout with enterprise plan enables all modules', async () => {
    subscriptionsRetrieve.mockResolvedValue({ items: { data: [{ price: { id: 'price_enterprise' } }] } });
    constructEvent.mockReturnValue(mockEvent('checkout.session.completed', { customer: 'cus_enterprise', metadata: { userId: 'user_enterprise' }, subscription: 'sub_enterprise' }));
    assinaturaUpsert.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('checkout.session.completed', { customer: 'cus_enterprise', metadata: { userId: 'user_enterprise' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_ent' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });

  it('17. checkout with basic plan limits modules to planets and letters', async () => {
    subscriptionsRetrieve.mockResolvedValue({ items: { data: [{ price: { id: 'price_basic' } }] } });
    constructEvent.mockReturnValue(mockEvent('checkout.session.completed', { customer: 'cus_basic', metadata: { userId: 'user_basic' }, subscription: 'sub_basic' }));
    assinaturaUpsert.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('checkout.session.completed', { customer: 'cus_basic', metadata: { userId: 'user_basic' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_basic' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });

  it('18. subscription retrieve error → falls back to metadata plano', async () => {
    subscriptionsRetrieve.mockRejectedValue(new Error('API Error'));
    constructEvent.mockReturnValue(mockEvent('checkout.session.completed', { customer: 'cus_error', metadata: { userId: 'user_error', plano: 'premium' }, subscription: 'sub_error' }));
    assinaturaUpsert.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('checkout.session.completed', { customer: 'cus_error', metadata: { userId: 'user_error', plano: 'premium' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_error' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });

  it('19. multiple rapid webhooks all return 200', async () => {
    const events = [
      mockEvent('checkout.session.completed', { customer: 'cus_m1', metadata: { userId: 'user_m1' } }),
      mockEvent('customer.subscription.updated', { id: 'sub_m1', customer: 'cus_m1', status: 'active' }),
      mockEvent('invoice.paid', { id: 'in_m1' }),
    ];
    for (const eventData of events) {
      constructEvent.mockReturnValue(eventData);
      userFindFirst.mockResolvedValue({ id: 'user_m1' });
      assinaturaUpsert.mockResolvedValue({});
      assinaturaUpdate.mockResolvedValue({});
      userUpdate.mockResolvedValue({});
      const body = JSON.stringify(eventData);
      const request = createWebhookRequest(body, { 'stripe-signature': 'sig_multi' });
      const response = await POST(request);
      expect(response.status).toBe(200);
    }
  });

  it('20. POST handler exported and callable', async () => {
    constructEvent.mockReturnValue(mockEvent('checkout.session.completed', { customer: 'cus_export', metadata: { userId: 'user_export' }, subscription: 'sub_export' }));
    assinaturaUpsert.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('checkout.session.completed', { customer: 'cus_export', metadata: { userId: 'user_export' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_export' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });

  it('21. constructEvent receives body as string (text())', async () => {
    constructEvent.mockImplementation((body: string) => {
      expect(typeof body).toBe('string');
      return mockEvent('checkout.session.completed', { metadata: { userId: 'user_text' } });
    });
    assinaturaUpsert.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('checkout.session.completed', { metadata: { userId: 'user_text' } }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_text' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });

  it('22. handles empty metadata gracefully', async () => {
    constructEvent.mockReturnValue(mockEvent('checkout.session.completed', { customer: 'cus_empty', metadata: {}, subscription: 'sub_empty' }));
    assinaturaUpsert.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('checkout.session.completed', { customer: 'cus_empty', metadata: {} }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_empty' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });

  it('23. handles subscription with no price items', async () => {
    subscriptionsRetrieve.mockResolvedValue({ items: { data: [] } });
    constructEvent.mockReturnValue(mockEvent('customer.subscription.updated', { id: 'sub_noitems', customer: 'cus_noitems', items: { data: [] } }));
    userFindFirst.mockResolvedValue({ id: 'user_noitems' });
    assinaturaUpdate.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('customer.subscription.updated', { id: 'sub_noitems', customer: 'cus_noitems' }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_noitems' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });

  it('24. handles unknown price ID gracefully → falls back to basico', async () => {
    subscriptionsRetrieve.mockResolvedValue({ items: { data: [{ price: { id: 'price_unknown_123' } }] } });
    constructEvent.mockReturnValue(mockEvent('customer.subscription.updated', { id: 'sub_unknown_price', customer: 'cus_unknown_price', items: { data: [{ price: { id: 'price_unknown_123' } }] } }));
    userFindFirst.mockResolvedValue({ id: 'user_unknown_price' });
    assinaturaUpdate.mockResolvedValue({});
    userUpdate.mockResolvedValue({});
    const body = JSON.stringify(mockEvent('customer.subscription.updated', { id: 'sub_unknown_price', customer: 'cus_unknown_price' }));
    const request = createWebhookRequest(body, { 'stripe-signature': 'sig_unknown_price' });
    const response = await POST(request);
    expect(response.status).toBe(200);
  });
});
