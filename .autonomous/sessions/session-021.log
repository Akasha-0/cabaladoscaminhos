{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_t1j9lhoj4m0o_1","type":"tool_result","content":"1\t/**\n2\t * @akasha/core — Akasha Core Algorithm v1 (R-030 prototype)\n3\t *\n4\t * Orquestrador puro (sem persistência, sem LLM).\n5\t * Recebe 1 pessoa → emite 5 saídas de Pilar + 1 Mandala (resumo)\n6\t * + 1 Mandato diário (esqueleto) + 1 hook de Mentor.\n7\t *\n8\t * Referência: .autonomous/research/synthesis/synthesis_v1.md §5\n9\t */\n10\t\n11\timport { z } from 'zod';\n12\t\n13\t// ─── Schemas Zod (R-030 spec) ───────────────────────────────────────────────\n14\t\n15\texport const AkashaInputSchema = z.object({\n16\t  nome: z.string().min(1, 'nome obrigatório'),\n17\t  data_nascimento: z.string().regex(/^\\d{4}-\\d{2}-\\d{2}$/, 'ISO YYYY-MM-DD'),\n18\t  hora_nascimento: z\n19\t    .string()\n20\t    .regex(/^\\d{2}:\\d{2}$/, 'ISO HH:MM')\n21\t    .optional(),\n22\t  local_nascimento: z.string().min(1, 'local obrigatório'),\n23\t  intencao_inicial: z.string().min(1, 'intenção obrigatória'),\n24\t});\n25\t\n26\texport type AkashaInput = z.infer<typeof AkashaInputSchema>;\n27\t\n28\t// ─── Tipos de saída por Pilar ────────────────────────────────────────────────\n29\t\n30\texport interface PilarCabala {\n31\t  life_path: number;\n32\t  birthday: number;\n33\t  expression: number;\n34\t  ano_pessoal: number;\n35\t}\n36\t\n37\texport interface PilarAstrologia {\n38\t  sol_signo: string;\n39\t  asc_signo: string | null;\n40\t  lua_signo: string;\n41\t  lua_fase: 'nova' | 'crescente' | 'cheia' | 'minguante';\n42\t  hora_desconhecida: boolean;\n43\t}\n44\t\n45\texport interface PilarTantrica {\n46\t  corpo_predominante: number;\n47\t  trigemeo: 'fisico' | 'astral' | 'mental';\n48\t  ciclo_anos: number;\n49\t}\n50\t\n51\texport interface PilarOdu {\n52\t  odu_principal: string;\n53\t  odu_secundario: string | null;\n54\t  fonte: 'Ifá' | 'Candomblé';\n55\t  aviso: 'requer consentimento + terreiro';\n56\t}\n57\t\n58\texport interface PilarIChing {\n59\t  hexagrama_natal: number;\n60\t  hexagrama_dia: number;\n61\t  level: 'shadow' | 'gift' | 'siddhi';\n62\t}\n63\t\n64\texport interface MandalaResumo {\n65\t  pilares_presentes: string[];\n66\t  pilares_ausentes: string[];\n67\t  camadas_temporais: ('D' | 'S' | 'Z' | 'V')[];\n68\t}\n69\t\n70\texport interface MandatoEsqueleto {\n71\t  escala: 'D' | 'S' | 'Z' | 'V';\n72\t  pilares_relevantes: string[];\n73\t  redacao_bruta: string;\n74\t  cita_fontes: string[];\n75\t}\n76\t\n77\texport interface AkashaLeitura {\n78\t  input_normalizado: AkashaInput;\n79\t  pilares: {\n80\t    cabala: PilarCabala;\n81\t    astrologia: PilarAstrologia;\n82\t    tantrica: PilarTantrica;\n83\t    odu: PilarOdu;\n84\t    iching: PilarIChing;\n85\t  };\n86\t  mandala: MandalaResumo;\n87\t  mandato: MandatoEsqueleto;\n88\t  mentor_hook: {\n89\t    intencao: string;\n90\t    crise_detectada: boolean;\n91\t    recurso: 'CVV-188' | 'mentor_normal' | null;\n92\t  };\n93\t}\n94\t\n95\t// ─── Limites éticos (R-022 §5.5-5.6) ─────────────────────────────────────────\n96\t\n97\tconst CRISE_REGEX = /\\b(suicid|morrer|matar|automutil|desesper[oa]|não aguento|não quero mais viver)\\b/i;\n98\t\n99\tfunction detectarCrise(intencao: string): boolean {\n100\t  return CRISE_REGEX.test(intencao);\n101\t}\n102\t\n103\t// ─── Engines reais (lazy import, Fase 6 integra) ────────────────────────────\n104\t\n105\tasync function loadEngines() {\n106\t  // Fase 6 integra engines reais; Fase 5 só valida o shape.\n107\t  // @ts-expect-error — engines workspace podem não estar linkados em dev\n108\t  const cabala = await import('@akasha/core-cabala').catch(() => null);\n109\t  // @ts-expect-error\n110\t  const astro = await import('@akasha/core-astrology').catch(() => null);\n111\t  // @ts-expect-error\n112\t  const tantra = await import('@akasha/core-tantra').catch(() => null);\n113\t  // @ts-expect-error\n114\t  const odu = await import('@akasha/core-odus').catch(() => null);\n115\t  // @ts-expect-error\n116\t  const iching = await import('@akasha/core-iching').catch(() => null);\n117\t  return { cabala, astro, tantra, odu, iching };\n118\t}\n119\t\n120\t// ─── Stubs determinísticos (Fase 5; reais na Fase 6) ────────────────────────\n121\t\n122\tfunction stubPilar1Cabala(input: AkashaInput): PilarCabala {\n123\t  const [y, m, d] = input.data_nascimento.split('-').map(Number);\n124\t  const reduzir = (n: number): number => {\n125\t    while (n > 9 && n !== 11 && n !== 22 && n !== 33) {\n126\t      n = String(n).split('').reduce((a, c) => a + Number(c), 0);\n127\t    }\n128\t    return n;\n129\t  };\n130\t  const anoBase = new Date().getFullYear();\n131\t  const aniversario = new Date(input.data_nascimento);\n132\t  const anoPessoalBase = anoBase + aniversario.getMonth() + aniversario.getDate();\n133\t  return {\n134\t    life_path: reduzir(y + m + d),\n135\t    birthday: reduzir(d),\n136\t    expression: reduzir(input.nome.replace(/\\s/g, '').length),\n137\t    ano_pessoal: reduzir(anoPessoalBase),\n138\t  };\n139\t}\n140\t\n141\tfunction stubPilar2Astrologia(input: AkashaInput): PilarAstrologia {\n142\t  const [, m, d] = input.data_nascimento.split('-').map(Number);\n143\t  const signos = [\n144\t    'capricornio', 'aquario', 'peixes', 'aries', 'touro', 'gemeos',\n145\t    'cancer', 'leao', 'virgem', 'libra', 'escorpiao', 'sagitario',\n146\t  ];\n147\t  const sol = signos[(m - 1) % 12];\n148\t  const base = new Date('2000-01-06').getTime();\n149\t  const dias = (new Date(input.data_nascimento).getTime() - base) / 86400000;\n150\t  const faseIdx = ((dias % 29.53) / 29.53) * 4;\n151\t  const fases: PilarAstrologia['lua_fase'][] = ['nova', 'crescente', 'cheia', 'minguante'];\n152\t  return {\n153\t    sol_signo: sol,\n154\t    asc_signo: input.hora_nascimento ? signos[(d - 1) % 12] : null,\n155\t    lua_signo: signos[Math.floor((d + 7) % 12)],\n156\t    lua_fase: fases[Math.floor(faseIdx) % 4],\n157\t    hora_desconhecida: !input.hora_nascimento,\n158\t  };\n159\t}\n160\t\n161\tfunction stubPilar3Tantrica(input: AkashaInput): PilarTantrica {\n162\t  const [y, m, d] = input.data_nascimento.split('-').map(Number);\n163\t  const corpo = (((y + m + d) % 11) + 1);\n164\t  const trigemeo: PilarTantrica['trigemeo'] =\n165\t    corpo <= 4 ? 'fisico' : corpo <= 8 ? 'astral' : 'mental';\n166\t  const idade = new Date().getFullYear() - y;\n167\t  const proximoCiclo = Math.ceil(idade / 7) * 7;\n168\t  return { corpo_predominante: corpo, trigemeo, ciclo_anos: proximoCiclo };\n169\t}\n170\t\n171\tfunction stubPilar4Odu(input: AkashaInput): PilarOdu {\n172\t  const odus16 = [\n173\t    'Ogbe', 'Oyeku', 'Iwori', 'Odi', 'Irosun', 'Owonrin',\n174\t    'Obara', 'Okanran', 'Ogunda', 'Osa', 'Ika', 'Oturupon',\n175\t    'Otura', 'Irete', 'Ofun', 'Ose',\n176\t  ];\n177\t  const [y, m, d] = input.data_nascimento.split('-').map(Number);\n178\t  const idx = (y + m + d) % 16;\n179\t  return {\n180\t    odu_principal: odus16[idx],\n181\t    odu_secundario: null,\n182\t    fonte: 'Ifá',\n183\t    aviso: 'requer consentimento + terreiro',\n184\t  };\n185\t}\n186\t\n187\tfunction stubPilar5IChing(_input: AkashaInput): PilarIChing {\n188\t  const hoje = new Date();\n189\t  const start = new Date(hoje.getFullYear(), 0, 0);\n190\t  const dia = Math.floor((hoje.getTime() - start.getTime()) / 86400000);\n191\t  return {\n192\t    hexagrama_natal: ((dia % 64) + 1),\n193\t    hexagrama_dia: (((dia + 1) % 64) + 1),\n194\t    level: 'gift',\n195\t  };\n196\t}\n197\t\n198\t// ─── Detectar escala temporal (D/S/Z/V) ─────────────────────────────────────\n199\t\n200\tfunction detectarEscala(agora: Date): 'D' | 'S' | 'Z' | 'V' {\n201\t  const hora = agora.getHours();\n202\t  const dia = agora.getDay();\n203\t  const m = agora.getMonth() + 1;\n204\t  const d = agora.getDate();\n205\t  if ((m === 3 && d >= 19 && d <= 22) || (m === 6 && d >= 20 && d <= 23) ||\n206\t      (m === 9 && d >= 21 && d <= 24) || (m === 12 && d >= 20 && d <= 23)) {\n207\t    return 'Z';\n208\t  }\n209\t  if (dia === 1 && hora < 8) return 'S';\n210\t  return 'D';\n211\t}\n212\t\n213\t// ─── Função pura principal: akasha.calcular() ────────────────────────────────\n214\t\n215\texport async function calcular(input: AkashaInput): Promise<AkashaLeitura> {\n216\t  const parsed = AkashaInputSchema.parse(input);\n217\t  await loadEngines();\n218\t  const cabala = stubPilar1Cabala(parsed);\n219\t  const astrologia = stubPilar2Astrologia(parsed);\n220\t  const tantrica = stubPilar3Tantrica(parsed);\n221\t  const odu = stubPilar4Odu(parsed);\n222\t  const iching = stubPilar5IChing(parsed);\n223\t  const mandala: MandalaResumo = {\n224\t    pilares_presentes: ['cabala', 'astrologia', 'tantrica', 'odu', 'iching'],\n225\t    pilares_ausentes: [],\n226\t    camadas_temporais: ['D', 'S', 'Z', 'V'],\n227\t  };\n228\t  const escala = detectarEscala(new Date());\n229\t  const relevantesPorEscala: Record<typeof escala, string[]> = {\n230\t    D: ['astrologia', 'iching', 'cabala'],\n231\t    S: ['astrologia', 'odu', 'tantrica'],\n232\t    Z: ['astrologia', 'tantrica', 'cabala'],\n233\t    V: ['cabala', 'astrologia', 'tantrica', 'odu', 'iching'],\n234\t  };\n235\t  const relevantes = relevantesPorEscala[escala];\n236\t  const citaFontes: Record<string, string> = {\n237\t    cabala: 'Pilar 1, Gematria (Sefer Yetzirah)',\n238\t    astrologia: 'Pilar 2, Astrologia (Whole Sign, Brennan 2017)',\n239\t    tantrica: 'Pilar 3, Tantra (tradição hindu, 11 corpos)',\n240\t    odu: 'Pilar 4, Ifá (axé/terreiro, 16 Odu)',\n241\t    iching: 'Pilar 5, I Ching (Wilhelm/Baynes 1950)',\n242\t  };\n243\t  const mandato: MandatoEsqueleto = {\n244\t    escala,\n245\t    pilares_relevantes: relevantes,\n246\t    redacao_bruta: `[${escala}] Pilares: ${relevantes.join(', ')}. ` +\n247\t      `Lua ${astrologia.lua_fase}, hex ${iching.hexagrama_dia}, ` +\n248\t      `vida ${cabala.life_path}. (LLM redige 3 frases + 1 pergunta + 1 micro-ritual.)`,\n249\t    cita_fontes: relevantes.map((p) => citaFontes[p] ?? p),\n250\t  };\n251\t  const crise = detectarCrise(parsed.intencao_inicial);\n252\t  return {\n253\t    input_normalizado: parsed,\n254\t    pilares: { cabala, astrologia, tantrica, odu, iching },\n255\t    mandala,\n256\t    mandato,\n257\t    mentor_hook: {\n258\t      intencao: parsed.intencao_inicial,\n259\t      crise_detectada: crise,\n260\t      recurso: crise ? 'CVV-188' : null,\n261\t    },\n262\t  };\n263\t}\n264\t"}]},"parent_tool_use_id":null,"session_id":"0b59d512-e0c2-43c6-b769-2249b6c9c290","uuid":"a2df4330-bcab-4b90-8158-3bede7c7309e","timestamp":"2026-06-11T10:21:36.491Z","tool_use_result":{"type":"text","file":{"filePath":"/home/skynet/cabala-dos-caminhos/packages/akasha-core/src/akasha-core.ts","content":"/**\n * @akasha/core — Akasha Core Algorithm v1 (R-030 prototype)\n *\n * Orquestrador puro (sem persistência, sem LLM).\n * Recebe 1 pessoa → emite 5 saídas de Pilar + 1 Mandala (resumo)\n * + 1 Mandato diário (esqueleto) + 1 hook de Mentor.\n *\n * Referência: .autonomous/research/synthesis/synthesis_v1.md §5\n */\n\nimport { z } from 'zod';\n\n// ─── Schemas Zod (R-030 spec) ───────────────────────────────────────────────\n\nexport const AkashaInputSchema = z.object({\n  nome: z.string().min(1, 'nome obrigatório'),\n  data_nascimento: z.string().regex(/^\\d{4}-\\d{2}-\\d{2}$/, 'ISO YYYY-MM-DD'),\n  hora_nascimento: z\n    .string()\n    .regex(/^\\d{2}:\\d{2}$/, 'ISO HH:MM')\n    .optional(),\n  local_nascimento: z.string().min(1, 'local obrigatório'),\n  intencao_inicial: z.string().min(1, 'intenção obrigatória'),\n});\n\nexport type AkashaInput = z.infer<typeof AkashaInputSchema>;\n\n// ─── Tipos de saída por Pilar ────────────────────────────────────────────────\n\nexport interface PilarCabala {\n  life_path: number;\n  birthday: number;\n  expression: number;\n  ano_pessoal: number;\n}\n\nexport interface PilarAstrologia {\n  sol_signo: string;\n  asc_signo: string | null;\n  lua_signo: string;\n  lua_fase: 'nova' | 'crescente' | 'cheia' | 'minguante';\n  hora_desconhecida: boolean;\n}\n\nexport interface PilarTantrica {\n  corpo_predominante: number;\n  trigemeo: 'fisico' | 'astral' | 'mental';\n  ciclo_anos: number;\n}\n\nexport interface PilarOdu {\n  odu_principal: string;\n  odu_secundario: string | null;\n  fonte: 'Ifá' | 'Candomblé';\n  aviso: 'requer consentimento + terreiro';\n}\n\nexport interface PilarIChing {\n  hexagrama_natal: number;\n  hexagrama_dia: number;\n  level: 'shadow' | 'gift' | 'siddhi';\n}\n\nexport interface MandalaResumo {\n  pilares_presentes: string[];\n  pilares_ausentes: string[];\n  camadas_temporais: ('D' | 'S' | 'Z' | 'V')[];\n}\n\nexport interface MandatoEsqueleto {\n  escala: 'D' | 'S' | 'Z' | 'V';\n  pilares_relevantes: string[];\n  redacao_bruta: string;\n  cita_fontes: string[];\n}\n\nexport interface AkashaLeitura {\n  input_normalizado: AkashaInput;\n  pilares: {\n    cabala: PilarCabala;\n    astrologia: PilarAstrologia;\n    tantrica: PilarTantrica;\n    odu: PilarOdu;\n    iching: PilarIChing;\n  };\n  mandala: MandalaResumo;\n  mandato: MandatoEsqueleto;\n  mentor_hook: {\n    intencao: string;\n    crise_detectada: boolean;\n    recurso: 'CVV-188' | 'mentor_normal' | null;\n  };\n}\n\n// ─── Limites éticos (R-022 §5.5-5.6) ─────────────────────────────────────────\n\nconst CRISE_REGEX = /\\b(suicid|morrer|matar|automutil|desesper[oa]|não aguento|não quero mais viver)\\b/i;\n\nfunction detectarCrise(intencao: string): boolean {\n  return CRISE_REGEX.test(intencao);\n}\n\n// ─── Engines reais (lazy import, Fase 6 integra) ────────────────────────────\n\nasync function loadEngines() {\n  // Fase 6 integra engines reais; Fase 5 só valida o shape.\n  // @ts-expect-error — engines workspace podem não estar linkados em dev\n  const cabala = await import('@akasha/core-cabala').catch(() => null);\n  // @ts-expect-error\n  const astro = await import('@akasha/core-astrology').catch(() => null);\n  // @ts-expect-error\n  const tantra = await import('@akasha/core-tantra').catch(() => null);\n  // @ts-expect-error\n  const odu = await import('@akasha/core-odus').catch(() => null);\n  // @ts-expect-error\n  const iching = await import('@akasha/core-iching').catch(() => null);\n  return { cabala, astro, tantra, odu, iching };\n}\n\n// ─── Stubs determinísticos (Fase 5; reais na Fase 6) ────────────────────────\n\nfunction stubPilar1Cabala(input: AkashaInput): PilarCabala {\n  const [y, m, d] = input.data_nascimento.split('-').map(Number);\n  const reduzir = (n: number): number => {\n    while (n > 9 && n !== 11 && n !== 22 && n !== 33) {\n      n = String(n).split('').reduce((a, c) => a + Number(c), 0);\n    }\n    return n;\n  };\n  const anoBase = new Date().getFullYear();\n  const aniversario = new Date(input.data_nascimento);\n  const anoPessoalBase = anoBase + aniversario.getMonth() + aniversario.getDate();\n  return {\n    life_path: reduzir(y + m + d),\n    birthday: reduzir(d),\n    expression: reduzir(input.nome.replace(/\\s/g, '').length),\n    ano_pessoal: reduzir(anoPessoalBase),\n  };\n}\n\nfunction stubPilar2Astrologia(input: AkashaInput): PilarAstrologia {\n  const [, m, d] = input.data_nascimento.split('-').map(Number);\n  const signos = [\n    'capricornio', 'aquario', 'peixes', 'aries', 'touro', 'gemeos',\n    'cancer', 'leao', 'virgem', 'libra', 'escorpiao', 'sagitario',\n  ];\n  const sol = signos[(m - 1) % 12];\n  const base = new Date('2000-01-06').getTime();\n  const dias = (new Date(input.data_nascimento).getTime() - base) / 86400000;\n  const faseIdx = ((dias % 29.53) / 29.53) * 4;\n  const fases: PilarAstrologia['lua_fase'][] = ['nova', 'crescente', 'cheia', 'minguante'];\n  return {\n    sol_signo: sol,\n    asc_signo: input.hora_nascimento ? signos[(d - 1) % 12] : null,\n    lua_signo: signos[Math.floor((d + 7) % 12)],\n    lua_fase: fases[Math.floor(faseIdx) % 4],\n    hora_desconhecida: !input.hora_nascimento,\n  };\n}\n\nfunction stubPilar3Tantrica(input: AkashaInput): PilarTantrica {\n  const [y, m, d] = input.data_nascimento.split('-').map(Number);\n  const corpo = (((y + m + d) % 11) + 1);\n  const trigemeo: PilarTantrica['trigemeo'] =\n    corpo <= 4 ? 'fisico' : corpo <= 8 ? 'astral' : 'mental';\n  const idade = new Date().getFullYear() - y;\n  const proximoCiclo = Math.ceil(idade / 7) * 7;\n  return { corpo_predominante: corpo, trigemeo, ciclo_anos: proximoCiclo };\n}\n\nfunction stubPilar4Odu(input: AkashaInput): PilarOdu {\n  const odus16 = [\n    'Ogbe', 'Oyeku', 'Iwori', 'Odi', 'Irosun', 'Owonrin',\n    'Obara', 'Okanran', 'Ogunda', 'Osa', 'Ika', 'Oturupon',\n    'Otura', 'Irete', 'Ofun', 'Ose',\n  ];\n  const [y, m, d] = input.data_nascimento.split('-').map(Number);\n  const idx = (y + m + d) % 16;\n  return {\n    odu_principal: odus16[idx],\n    odu_secundario: null,\n    fonte: 'Ifá',\n    aviso: 'requer consentimento + terreiro',\n  };\n}\n\nfunction stubPilar5IChing(_input: AkashaInput): PilarIChing {\n  const hoje = new Date();\n  const start = new Date(hoje.getFullYear(), 0, 0);\n  const dia = Math.floor((hoje.getTime() - start.getTime()) / 86400000);\n  return {\n    hexagrama_natal: ((dia % 64) + 1),\n    hexagrama_dia: (((dia + 1) % 64) + 1),\n    level: 'gift',\n  };\n}\n\n// ─── Detectar escala temporal (D/S/Z/V) ─────────────────────────────────────\n\nfunction detectarEscala(agora: Date): 'D' | 'S' | 'Z' | 'V' {\n  const hora = agora.getHours();\n  const dia = agora.getDay();\n  const m = agora.getMonth() + 1;\n  const d = agora.getDate();\n  if ((m === 3 && d >= 19 && d <= 22) || (m === 6 && d >= 20 && d <= 23) ||\n      (m === 9 && d >= 21 && d <= 24) || (m === 12 && d >= 20 && d <= 23)) {\n    return 'Z';\n  }\n  if (dia === 1 && hora < 8) return 'S';\n  return 'D';\n}\n\n// ─── Função pura principal: akasha.calcular() ────────────────────────────────\n\nexport async function calcular(input: AkashaInput): Promise<AkashaLeitura> {\n  const parsed = AkashaInputSchema.parse(input);\n  await loadEngines();\n  const cabala = stubPilar1Cabala(parsed);\n  const astrologia = stubPilar2Astrologia(parsed);\n  const tantrica = stubPilar3Tantrica(parsed);\n  const odu = stubPilar4Odu(parsed);\n  const iching = stubPilar5IChing(parsed);\n  const mandala: MandalaResumo = {\n    pilares_presentes: ['cabala', 'astrologia', 'tantrica', 'odu', 'iching'],\n    pilares_ausentes: [],\n    camadas_temporais: ['D', 'S', 'Z', 'V'],\n  };\n  const escala = detectarEscala(new Date());\n  const relevantesPorEscala: Record<typeof escala, string[]> = {\n    D: ['astrologia', 'iching', 'cabala'],\n    S: ['astrologia', 'odu', 'tantrica'],\n    Z: ['astrologia', 'tantrica', 'cabala'],\n    V: ['cabala', 'astrologia', 'tantrica', 'odu', 'iching'],\n  };\n  const relevantes = relevantesPorEscala[escala];\n  const citaFontes: Record<string, string> = {\n    cabala: 'Pilar 1, Gematria (Sefer Yetzirah)',\n    astrologia: 'Pilar 2, Astrologia (Whole Sign, Brennan 2017)',\n    tantrica: 'Pilar 3, Tantra (tradição hindu, 11 corpos)',\n    odu: 'Pilar 4, Ifá (axé/terreiro, 16 Odu)',\n    iching: 'Pilar 5, I Ching (Wilhelm/Baynes 1950)',\n  };\n  const mandato: MandatoEsqueleto = {\n    escala,\n    pilares_relevantes: relevantes,\n    redacao_bruta: `[${escala}] Pilares: ${relevantes.join(', ')}. ` +\n      `Lua ${astrologia.lua_fase}, hex ${iching.hexagrama_dia}, ` +\n      `vida ${cabala.life_path}. (LLM redige 3 frases + 1 pergunta + 1 micro-ritual.)`,\n    cita_fontes: relevantes.map((p) => citaFontes[p] ?? p),\n  };\n  const crise = detectarCrise(parsed.intencao_inicial);\n  return {\n    input_normalizado: parsed,\n    pilares: { cabala, astrologia, tantrica, odu, iching },\n    mandala,\n    mandato,\n    mentor_hook: {\n      intencao: parsed.intencao_inicial,\n      crise_detectada: crise,\n      recurso: crise ? 'CVV-188' : null,\n    },\n  };\n}\n","numLines":264,"startLine":1,"totalLines":264}}}
