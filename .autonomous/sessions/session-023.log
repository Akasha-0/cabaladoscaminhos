{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_bpiggx26cnxi_1","type":"tool_result","content":"1\t/**\n2\t * Mapa Insights Tests\n3\t * Tests parser and generator for AI-generated spiritual insights\n4\t */\n5\t\n6\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n7\timport { parseInsightResponse, extractJson, criarInsightFallback } from '@/lib/ai/mapa-insights/parser';\n8\timport { generateMapaInsights, gerarCacheKey } from '@/lib/ai/mapa-insights/generator';\n9\timport { Ope } from '@/lib/ifa/draw';\n10\t\n11\t// ============================================================\n12\t// HOISTED MOCKS (available during vi.mock factory evaluation)\n13\t// ============================================================\n14\t\n15\tconst { mockRedisGet, mockRedisSet, mockCreateChatCompletion } = vi.hoisted(() => ({\n16\t  mockRedisGet: vi.fn<() => Promise<string | null>>(),\n17\t  mockRedisSet: vi.fn<() => Promise<unknown>>(),\n18\t  mockCreateChatCompletion: vi.fn(),\n19\t}));\n20\t\n21\tvi.mock('@/lib/redis', () => ({\n22\t  getRedisClient: vi.fn(() =>\n23\t    Promise.resolve({\n24\t      get: mockRedisGet,\n25\t      set: mockRedisSet,\n26\t      incr: vi.fn(),\n27\t      expire: vi.fn(),\n28\t      ping: vi.fn(() => Promise.resolve('PONG')),\n29\t      quit: vi.fn(),\n30\t      disconnect: vi.fn(),\n31\t    })\n32\t  ),\n33\t  useMemory: false,\n34\t  inMemoryStore: new Map(),\n35\t}));\n36\t\n37\tvi.mock('@/lib/ai/openai', () => ({\n38\t  createChatCompletion: mockCreateChatCompletion,\n39\t}));\n40\t\n41\t// ============================================================\n42\t// SAMPLE DATA\n43\t// ============================================================\n44\t\n45\tconst SAMPLE_MAPA = {\n46\t  perfil: {\n47\t    nomeCompleto: 'João Silva',\n48\t    dataNascimento: '1990-05-15',\n49\t    hora: '10:00',\n50\t    cidade: 'Rio de Janeiro',\n51\t    estado: 'RJ',\n52\t    pais: 'BR',\n53\t  },\n54\t  numerologia: {\n55\t    vida: 5,\n56\t    expressao: 3,\n57\t    motivacao: 7,\n58\t    impressao: 2,\n59\t    destino: 1,\n60\t    cicloAtual: 8,"}]},"parent_tool_use_id":null,"session_id":"57d2ecb7-0101-4087-a0d9-0837b2dd3247","uuid":"034165ba-96c7-410a-b72f-3fcd63fe3f04","timestamp":"2026-06-11T11:03:53.884Z","tool_use_result":{"type":"text","file":{"filePath":"/home/skynet/cabala-dos-caminhos/tests/lib/ai/mapa-insights.test.ts","content":"/**\n * Mapa Insights Tests\n * Tests parser and generator for AI-generated spiritual insights\n */\n\nimport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\nimport { parseInsightResponse, extractJson, criarInsightFallback } from '@/lib/ai/mapa-insights/parser';\nimport { generateMapaInsights, gerarCacheKey } from '@/lib/ai/mapa-insights/generator';\nimport { Ope } from '@/lib/ifa/draw';\n\n// ============================================================\n// HOISTED MOCKS (available during vi.mock factory evaluation)\n// ============================================================\n\nconst { mockRedisGet, mockRedisSet, mockCreateChatCompletion } = vi.hoisted(() => ({\n  mockRedisGet: vi.fn<() => Promise<string | null>>(),\n  mockRedisSet: vi.fn<() => Promise<unknown>>(),\n  mockCreateChatCompletion: vi.fn(),\n}));\n\nvi.mock('@/lib/redis', () => ({\n  getRedisClient: vi.fn(() =>\n    Promise.resolve({\n      get: mockRedisGet,\n      set: mockRedisSet,\n      incr: vi.fn(),\n      expire: vi.fn(),\n      ping: vi.fn(() => Promise.resolve('PONG')),\n      quit: vi.fn(),\n      disconnect: vi.fn(),\n    })\n  ),\n  useMemory: false,\n  inMemoryStore: new Map(),\n}));\n\nvi.mock('@/lib/ai/openai', () => ({\n  createChatCompletion: mockCreateChatCompletion,\n}));\n\n// ============================================================\n// SAMPLE DATA\n// ============================================================\n\nconst SAMPLE_MAPA = {\n  perfil: {\n    nomeCompleto: 'João Silva',\n    dataNascimento: '1990-05-15',\n    hora: '10:00',\n    cidade: 'Rio de Janeiro',\n    estado: 'RJ',\n    pais: 'BR',\n  },\n  numerologia: {\n    vida: 5,\n    expressao: 3,\n    motivacao: 7,\n    impressao: 2,\n    destino: 1,\n    cicloAtual: 8,","numLines":60,"startLine":1,"totalLines":570}}}
