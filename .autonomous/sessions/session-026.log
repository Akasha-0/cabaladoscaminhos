{"type":"assistant","message":{"id":"0679f1eb92a6f1b10cde1315a9be8272","type":"message","role":"assistant","content":[{"type":"tool_use","id":"call_function_om5np8fvv3sq_1","name":"Edit","input":{"replace_all":false,"file_path":"/home/skynet/cabala-dos-caminhos/apps/akasha-portal/src/components/akasha/MandalaChart.tsx","old_string":"// Pilar colors — one unique color per Pilar (1..5), ordered by number.\n// P1 Cabala: indigo (distingue de P2 astrologia que usa roxo/ar).\n// P2 Astrologia: roxo (mantém afinidade com elemento Ar).\n// P3 Tantrica: teal (mantém afinidade com elemento Água).\n// P4 Odus: dourado (mantém afinidade com elemento Terra).\n// P5 I-Ching: cobre (canônico King Wen).\nconst PILAR_COLORS: Record<Layer, string> = {\n  1: '#F0B429', // P4 Odus (dourado)\n  2: '#7C5CFF', // P2 Astrologia (roxo)\n  3: '#2DD4BF', // P3 Tantrica (teal)\n  4: '#5C7CFF', // P1 Cabala (indigo)\n  5: '#A0763A', // P5 I-Ching (cobre)\n};\n\nconst PILAR_LABEL_BY_LAYER: Record<Layer, string> = {\n  1: 'Odus',\n  2: 'Astrologia',\n  3: 'Tântrica',\n  4: 'Cabala',\n  5: 'I-Ching',\n};","new_string":"// Pilar colors — keyed by VISUAL LAYER (1..5 inside-out).\n// Layer 1 = Odus core (Pilar 4)\n// Layer 2 = Cabala geometry (Pilar 1)\n// Layer 3 = Tantric web (Pilar 3)\n// Layer 4 = Astrological ring (Pilar 2)\n// Layer 5 = I-Ching node (Pilar 5)\n// Cabala usa indigo (distingue-se de Astrologia que usa roxo/ar).\nconst PILAR_COLORS: Record<Layer, string> = {\n  1: '#F0B429', // Layer 1 (P4 Odus) — dourado\n  2: '#5C7CFF', // Layer 2 (P1 Cabala) — indigo\n  3: '#2DD4BF', // Layer 3 (P3 Tantrica) — teal\n  4: '#7C5CFF', // Layer 4 (P2 Astrologia) — roxo\n  5: '#A0763A', // Layer 5 (P5 I-Ching) — cobre\n};\n\nconst PILAR_LABEL_BY_LAYER: Record<Layer, string> = {\n  1: 'Odus',\n  2: 'Cabala',\n  3: 'Tântrica',\n  4: 'Astrologia',\n  5: 'I-Ching',\n};"}}],"model":"MiniMax-M3","stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":0,"output_tokens":0,"service_tier":"standard"}