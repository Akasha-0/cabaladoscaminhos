     href={`/${locale}/conta`}\n          style={{\n            display: 'inline-block',\n            marginBottom: '1rem',\n            padding: '5px 14px',\n            borderRadius: '100px',\n            border: '1px solid rgba(251,87,129,0.4)',\n            background: 'rgba(251,87,129,0.08)',\n            color: '#FB5781',\n            fontSize: '0.75rem',\n            textDecoration: 'none',\n            letterSpacing: '0.03em',\n          }}\n        >\n          ⚠ Dados incompletos — complete seu perfil para uma leitura plena\n        </a>","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_35dcbeoze321_1","type":"tool_result","content":"1\t'use client';\n2\t\n3\timport { useState } from 'react';\n4\timport { MandalaAtmosphere } from '@/components/akasha/MandalaAtmosphere';\n5\timport { useCockpitStore } from '@/stores/cockpit-store';\n6\t\n7\tinterface MandalaData {\n8\t  incomplete: boolean;\n9\t  odus: {\n10\t    oduName: string;\n11\t    oduNumber: number | null;\n12\t    orixaRegency: string[];\n13\t    elementalForce: string | null;\n14\t    provisional: boolean;\n15\t    preceitos?: string[];\n16\t    quizilas?: string[];\n17\t  };\n18\t  kabala: {\n19\t    lifePath: number | null;\n20\t    lifePathMaster: boolean;\n21\t    expression: number | null;\n22\t    expressionMaster: boolean;\n23\t    motivation: number | null;\n24\t    personalYear: number | null;\n25\t  };\n26\t  tantra: {\n27\t    soul: number | null;\n28\t    karma: number | null;\n29\t    divineGift: number | null;\n30\t    destiny: number | null;\n31\t    tantricPath: number | null;\n32\t    bodies: Array<{ index: number; name: string; active: boolean }>;\n33\t  };\n34\t  astrology: {\n35\t    ascendant: string | null;\n36\t    midheaven: string | null;\n37\t    dominantPlanet: string | null;\n38\t    planets: Array<{ name: string; sign: string; degree: number; house: number }>;\n39\t    elementalBalance: { fire: number; earth: number; air: number; water: number };\n40\t  };\n41\t  iching: {\n42\t    hexagramNumber: number | null;\n43\t    hexagramName: string | null;\n44\t    hexagramChineseName: string | null;\n45\t    upperTrigram: number | null;\n46\t    lowerTrigram: number | null;\n47\t    upperTrigramName: string | null;\n48\t    lowerTrigramName: string | null;\n49\t    lines: boolean[];\n50\t    algorithm: string | null;\n51\t    provisional: boolean;\n52\t    birthDate: string | null;\n53\t    birthTime: string | null;\n54\t    available: boolean;\n55\t    error: string | null;\n56\t  };\n57\t  _user?: {\n58\t    birthDate: string | null;\n59\t    birthTime: string | null;\n60\t  };\n61\t}\n62\t\n63\tinterface Props {\n64\t  data: MandalaData;\n65\t}\n66\t\n67\ttype Layer = 1 | 2 | 3 | 4 | 5;\n68\t\n69\tconst toXY = (angleDeg: number, r: number, cx = 200, cy = 200) => ({\n70\t  x: cx + r * Math.cos((angleDeg - 90) * Math.PI / 180),\n71\t  y: cy + r * Math.sin((angleDeg - 90) * Math.PI / 180),\n72\t});\n73\t\n74\tconst ZODIAC_SIGNS = ['♈', '♉', '♊', '♋', '♌', '♍', '♎', '♏', '♐', '♑', '♒', '♓'];\n75\tconst ZODIAC_NAMES = ['Áries', 'Touro', 'Gêmeos', 'Câncer', 'Leão', 'Virgem', 'Libra', 'Escorpião', 'Sagitário', 'Capricórnio', 'Aquário', 'Peixes'];\n76\t\n77\tconst ELEMENT_COLORS: Record<string, string> = {\n78\t  fire: '#FB5781', earth: '#F0B429', air: '#7C5CFF', water: '#2DD4BF',\n79\t};\n80\tconst ELEMENT_LABELS: Record<string, string> = {\n81\t  fire: 'Fogo', earth: 'Terra', air: 'Ar', water: 'Água',\n82\t};\n83\tconst ELEMENT_GUIDANCE: Record<string, { balance: string; ritual: string }> = {\n84\t  fire: {\n85\t    balance: 'Elemento dominante Fogo — energia de ação, liderança e expansão. Para equilibrar: aterrar com práticas de Terra (corpo, natureza, alimentos raiz).',\n86\t    ritual: 'Ritual: banhos de ervas de terra (alecrim, patchouli), caminhar descalço, meditação com pedras.',\n87\t  },\n88\t  earth: {\n89\t    balance: 'Elemento dominante Terra — energia de estrutura, paciência e materialização. Para equilibrar: aquecer com Fogo (movimento, expressão, criatividade).',\n90\t    ritual: 'Ritual: dança livre, uso de cores vibrantes, incenso de canela ou cravo para ativar a chama interna.',\n91\t  },\n92\t  air: {\n93\t    balance: 'Elemento dominante Ar — energia mental, comunicação e movimento. Para equilibrar: ancorar com Água (emoção, intuição, descanso).',\n94\t    ritual: 'Ritual: banhos de água fria com pétalas de rosa, meditação aquática, chás calmantes.',\n95\t  },\n96\t  water: {\n97\t    balance: 'Elemento dominante Água — energia emocional, intuição e profundidade. Para equilibrar: estruturar com Terra (rotinas, corpo, alimentação consciente).',\n98\t    ritual: 'Ritual: caminhadas na natureza, dieta baseada em raízes e tubérculos, pedras de jaspe ou hematita.',\n99\t  },\n100\t};\n101\t\n102\tconst LIFE_PATH_MEANINGS: Record<number, string> = {\n103\t  1: 'Caminho do Pioneiro — sua missão é liderar e inaugurar novos caminhos. Aprenda a agir independentemente.',\n104\t  2: 'Caminho do Diplomata — cooperação, harmonia e parceria são seu veículo de crescimento.',\n105\t  3: 'Caminho do Criador — expressão, comunicação e criatividade são o seu propósito sagrado.',\n106\t  4: 'Caminho do Construtor — estrutura, disciplina e trabalho constante constroem seu legado.',\n107\t  5: 'Caminho da Liberdade — mudança, aventura e versatilidade são sua escola de vida.',\n108\t  6: 'Caminho do Guardião — responsabilidade, cuidado e serviço ao próximo definem sua essência.',\n109\t  7: 'Caminho do Buscador — introspecção, espiritualidade e sabedoria são seu norte.',\n110\t  8: 'Caminho do Realizador — poder, abundância e autoridade são os temas centrais da sua existência.',\n111\t  9: 'Caminho do Humanista — compaixão universal, conclusões e entrega ao coletivo.',\n112\t  11: 'Número Mestre 11 — Iluminador. Canal entre os planos, alta sensibilidade intuitiva e missão espiritual.',\n113\t  22: 'Número Mestre 22 — Construtor de Mundos. Capacidade de manifestar visões grandiosas na matéria.',\n114\t  33: 'Número Mestre 33 — Mestre Cósmico. Serviço incondicional, amor universal, cura e ensino.',\n115\t};\n116\t\n117\tconst TANTRIC_BODY_WISDOM: Record<number, { desc: string; challenge: string; activate: string }> = {\n118\t  1: { desc: 'Corpo da Alma', challenge: 'Encontrar propósito humilde', activate: 'Meditação Ong Namo' },\n119\t  2: { desc: 'Mente Negativa', challenge: 'Discernir sem paralisar', activate: 'Respiração de fogo' },\n120\t  3: { desc: 'Mente Positiva', challenge: 'Confiar no processo', activate: 'Sat Kriya — 3 min' },\n121\t  4: { desc: 'Mente Neutra', challenge: 'Observar sem reagir', activate: 'Meditação do coração' },\n122\t  5: { desc: 'Corpo Físico', challenge: 'Encarnar totalmente', activate: 'Movimento consciente' },\n123\t  6: { desc: 'Linha do Arco', challenge: 'Proteger o campo áurico', activate: 'Ser humano íntegro' },\n124\t  7: { desc: 'Aura', challenge: 'Expandir sem dissolver', activate: 'Projeção e Proteção' },\n125\t  8: { desc: 'Corpo Prânico', challenge: 'Sustentar a vitalidade', activate: 'Pranayama diário' },\n126\t  9: { desc: 'Corpo Sutil', challenge: 'Escutar o infinalível', activate: 'Escuta da intuição' },\n127\t  10: { desc: 'Corpo Radiante', challenge: 'Brilhar corajosamente', activate: 'Ação corajosa cotidiana' },\n128\t  11: { desc: 'Mente Divina', challenge: 'Manter-se aberto ao infinito', activate: 'Gratidão e rendição' },\n129\t};\n130\t\n131\t// Stars data — fixed positions seeded deterministically\n132\tconst STARS = Array.from({ length: 30 }, (_, i) => {\n133\t  const angle = (i * 137.508) % 360; // golden angle spacing\n134\t  const radius = 60 + (i * 47) % 130;\n135\t  const pos = toXY(angle, radius);\n136\t  const opacity = 0.08 + (i % 5) * 0.03;\n137\t  const delay = (i * 0.37) % 3;\n138\t  return { x: pos.x, y: pos.y, opacity, delay };\n139\t});\n140\t\n141\t// Particle dots on outer edge\n142\tconst PARTICLES = Array.from({ length: 12 }, (_, i) => {\n143\t  const angle = i * 30;\n144\t  const pos = toXY(angle, 198);\n145\t  const delay = (i * 0.4) % 4;\n146\t  return { x: pos.x, y: pos.y, delay };\n147\t});\n148\t\n149\tfunction describeArc(cx: number, cy: number, r: number, startDeg: number, endDeg: number): string {\n150\t  const start = toXY(startDeg, r, cx, cy);\n151\t  const end = toXY(endDeg, r, cx, cy);\n152\t  const largeArc = endDeg - startDeg > 180 ? 1 : 0;\n153\t  return `M ${start.x} ${start.y} A ${r} ${r} 0 ${largeArc} 1 ${end.x} ${end.y}`;\n154\t}\n155\t\n156\tfunction dominantElement(balance: { fire: number; earth: number; air: number; water: number }): string {\n157\t  const entries = Object.entries(balance) as [string, number][];\n158\t  const sorted = entries.sort((a, b) => b[1] - a[1]);\n159\t  return sorted[0][0];\n160\t}\n161\t\n162\texport default function MandalaChart({ data }: Props) {\n163\t  const [activeLayer, setActiveLayer] = useState<null | Layer>(null);\n164\t  const atmosphereIntensity = useCockpitStore((s) => s.atmosphereIntensity);\n165\t\n166\t  const opacity = (layer: Layer) =>\n167\t    activeLayer === null ? 1 : activeLayer === layer ? 1 : 0.3;\n168\t\n169\t  // Pause ring rotation when Layer 4 is selected\n170\t  const ringPaused = activeLayer === 4;\n171\t\n172\t  const astroSegments = ZODIAC_SIGNS.map((sym, i) => {\n173\t    const startDeg = i * 30;\n174\t    const endDeg = (i + 1) * 30;\n175\t    const midDeg = startDeg + 15;\n176\t    const labelPos = toXY(midDeg, 190);\n177\t    return { sym, name: ZODIAC_NAMES[i], startDeg, endDeg, midDeg, labelPos };\n178\t  });\n179\t\n180\t  const planetDots = data.astrology.planets.map((p) => ({\n181\t    ...p,\n182\t    pos: toXY((p.degree / 360) * 360, 178),\n183\t  }));\n184\t\n185\t  const tantricNodes = Array.from({ length: 11 }, (_, i) => {\n186\t    const angleDeg = i * (360 / 11);\n187\t    const pos = toXY(angleDeg, 138);\n188\t    const body = data.tantra.bodies.find((b) => b.index === i + 1);\n189\t    const wisdom = TANTRIC_BODY_WISDOM[i + 1];\n190\t    return { i, angleDeg, pos, active: body?.active ?? true, label: i + 1, name: wisdom?.desc ?? `Corpo ${i + 1}` };\n191\t  });\n192\t\n193\t  const kabVerts = [\n194\t    { angleDeg: 0, value: data.kabala.lifePath, master: data.kabala.lifePathMaster, label: 'VP' },\n195\t    { angleDeg: 120, value: data.kabala.expression, master: data.kabala.expressionMaster, label: 'EX' },\n196\t    { angleDeg: 240, value: data.kabala.motivation, master: false, label: 'MO' },\n197\t  ].map((v) => ({ ...v, pos: toXY(v.angleDeg, 80) }));\n198\t\n199\t  const trianglePath = `M ${kabVerts[0].pos.x} ${kabVerts[0].pos.y} L ${kabVerts[1].pos.x} ${kabVerts[1].pos.y} L ${kabVerts[2].pos.x} ${kabVerts[2].pos.y} Z`;\n200\t\n201\t  const elem = dominantElement(data.astrology.elementalBalance);\n202\t  const inactiveBodies = tantricNodes.filter((n) => !n.active);\n203\t  const lpMeaning = LIFE_PATH_MEANINGS[data.kabala.lifePath ?? 0] ?? null;\n204\t  const elemGuidance = ELEMENT_GUIDANCE[elem] ?? null;\n205\t\n206\t  return (\n207\t    <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '1.25rem', width: '100%', maxWidth: 460 }}>\n208\t      <style>{`\n209\t        @keyframes pulse-ori {\n210\t          0%, 100% { opacity: 0.65; }\n211\t          50% { opacity: 1; }\n212\t        }\n213\t        @keyframes ring-rotate {\n214\t          from { transform-origin: 200px 200px; transform: rotate(0deg); }\n215\t          to { transform-origin: 200px 200px; transform: rotate(360deg); }\n216\t        }\n217\t        @keyframes dash-flow {\n218\t          to { stroke-dashoffset: -20; }\n219\t        }\n220\t        @keyframes twinkle {\n221\t          0%, 100% { opacity: 0.08; }\n222\t          50% { opacity: 0.25; }\n223\t        }\n224\t        @keyframes particle-blink {\n225\t          0%, 100% { opacity: 0.1; }\n226\t          50% { opacity: 0.55; }\n227\t        }\n228\t        .mandala-pulse { animation: pulse-ori 3s ease-in-out infinite; }\n229\t        .mandala-pulse-2 { animation: pulse-ori 3s ease-in-out infinite; animation-delay: 0.5s; }\n230\t        .mandala-pulse-3 { animation: pulse-ori 3s ease-in-out infinite; animation-delay: 1s; }\n231\t        .ring-astrological { animation: ring-rotate 120s linear infinite; }\n232\t        .ring-astrological-paused { animation: ring-rotate 120s linear infinite; animation-play-state: paused; }\n233\t        .synergy-active { animation: dash-flow 3s linear infinite; }\n234\t        .synergy-alert { animation: dash-flow 1.5s linear infinite; }\n235\t        .star-twinkle { animation: twinkle 4s ease-in-out infinite; }\n236\t        .particle-blink { animation: particle-blink 2.5s ease-in-out infinite; }\n237\t        @media (prefers-reduced-motion: reduce) {\n238\t          * { animation: none !important; }\n239\t        }\n240\t      `}</style>\n241\t\n242\t      {/* Layer selector */}\n243\t      <div className=\"flex gap-2 flex-wrap justify-center\">\n244\t        {([\n245\t          { layer: 4 as Layer, label: 'Astrologia', color: '#7C5CFF' },\n246\t          { layer: 3 as Layer, label: 'Tântrica', color: '#2DD4BF' },\n247\t          { layer: 5 as Layer, label: 'I-Ching', color: '#A0763A' },\n248\t          { layer: 2 as Layer, label: 'Cabala', color: '#7C5CFF' },\n249\t          { layer: 1 as Layer, label: 'Odus', color: '#F0B429' },\n250\t        ] as const).map(({ layer, label, color }) => (\n251\t          <button\n252\t            key={layer}\n253\t            onClick={() => setActiveLayer(activeLayer === layer ? null : layer)}\n254\t            style={{\n255\t              fontSize: '0.75rem',\n256\t              padding: '4px 12px',\n257\t              borderRadius: '100px',\n258\t              border: `1px solid ${activeLayer === layer ? color : 'rgba(38,48,79,0.8)'}`,\n259\t              background: activeLayer === layer ? `${color}22` : 'rgba(11,14,28,0.5)',\n260\t              color: activeLayer === layer ? color : '#A7AECF',\n261\t              cursor: 'pointer',\n262\t              transition: 'all 0.2s',\n263\t            }}\n264\t          >\n265\t            {label}\n266\t          </button>\n267\t        ))}\n268\t      </div>\n269\t\n270\t      <div className=\"relative w-full\" style={{ maxWidth: 400 }}>\n271\t        <MandalaAtmosphere intensity={atmosphereIntensity} />\n272\t\n273\t        <svg\n274\t          viewBox=\"0 0 400 400\"\n275\t          width=\"100%\"\n276\t          style={{ maxWidth: 400, display: 'block', position: 'relative', zIndex: 1 }}\n277\t          aria-label=\"Mandala Akáshica Toroidal\"\n278\t        >\n279\t        {/* Deep space background */}\n280\t        <defs>\n281\t          <radialGradient id=\"bgGrad\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n282\t            <stop offset=\"0%\" stopColor=\"#0B0E1C\" />\n283\t            <stop offset=\"100%\" stopColor=\"#06070F\" />\n284\t          </radialGradient>\n285\t          <radialGradient id=\"oriGlow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n286\t            <stop offset=\"0%\" stopColor=\"#F0B429\" stopOpacity=\"0.3\" />\n287\t            <stop offset=\"100%\" stopColor=\"#F0B429\" stopOpacity=\"0\" />\n288\t          </radialGradient>\n289\t          <filter id=\"glow-akasha\">\n290\t            <feGaussianBlur stdDeviation=\"2\" result=\"blur\" />\n291\t            <feMerge><feMergeNode in=\"blur\" /><feMergeNode in=\"SourceGraphic\" /></feMerge>\n292\t          </filter>\n293\t        </defs>\n294\t        <circle cx=\"200\" cy=\"200\" r=\"200\" fill=\"url(#bgGrad)\" />\n295\t\n296\t        {/* ── E — Stars background ── */}\n297\t        {STARS.map((s, i) => (\n298\t          <circle\n299\t            key={`star-${i}`}\n300\t            cx={s.x}\n301\t            cy={s.y}\n302\t            r=\"1\"\n303\t            fill=\"white\"\n304\t            opacity={s.opacity}\n305\t            className=\"star-twinkle\"\n306\t            style={{ animationDelay: `${s.delay}s` }}\n307\t          />\n308\t        ))}\n309\t\n310\t        {/* Faint cross-layer synergy lines */}\n311\t        {[0, 72, 144, 216, 288].map((deg, i) => {\n312\t          const outer = toXY(deg, 178);\n313\t          const inner = toXY(deg, 80);\n314\t          return (\n315\t            <line\n316\t              key={i}\n317\t              x1={outer.x} y1={outer.y}\n318\t              x2={inner.x} y2={inner.y}\n319\t              stroke=\"rgba(45,212,191,0.08)\"\n320\t              strokeWidth=\"0.5\"\n321\t              strokeDasharray=\"3 5\"\n322\t            />\n323\t          );\n324\t        })}\n325\t\n326\t        {/* ── Layer 4 — Astrological Ring (rotating) ── */}\n327\t        <g\n328\t          opacity={opacity(4)}\n329\t          onClick={() => setActiveLayer(activeLayer === 4 ? null : 4)}\n330\t          style={{ cursor: 'pointer' }}\n331\t          className={ringPaused ? 'ring-astrological-paused' : 'ring-astrological'}\n332\t        >\n333\t          <circle cx=\"200\" cy=\"200\" r=\"196\" fill=\"none\" stroke=\"rgba(124,92,255,0.12)\" strokeWidth=\"0.5\" />\n334\t          <circle cx=\"200\" cy=\"200\" r=\"170\" fill=\"none\" stroke=\"rgba(124,92,255,0.12)\" strokeWidth=\"0.5\" />\n335\t          {astroSegments.map(({ startDeg, endDeg, sym, labelPos }, i) => (\n336\t            <g key={i}>\n337\t              <path\n338\t                d={describeArc(200, 200, 183, startDeg, endDeg)}\n339\t                fill=\"none\"\n340\t                stroke=\"rgba(38,48,79,0.7)\"\n341\t                strokeWidth=\"1\"\n342\t              />\n343\t              <text\n344\t                x={labelPos.x} y={labelPos.y}\n345\t                textAnchor=\"middle\"\n346\t                dominantBaseline=\"middle\"\n347\t                fontSize=\"9\"\n348\t                fill=\"#5C6691\"\n349\t              >\n350\t                {sym}\n351\t              </text>\n352\t            </g>\n353\t          ))}\n354\t          {/* Planet dots with tooltip */}\n355\t          {planetDots.map((p, i) => (\n356\t            <g key={i} filter=\"url(#glow-akasha)\">\n357\t              <circle cx={p.pos.x} cy={p.pos.y} r=\"3.5\" fill=\"#7C5CFF\" opacity=\"0.9\">\n358\t                <title>{p.name}: {p.sign} casa {p.house}</title>\n359\t              </circle>\n360\t            </g>\n361\t          ))}\n362\t          {/* Ring label */}\n363\t          <text x=\"200\" y=\"14\" textAnchor=\"middle\" fontSize=\"7\" fill=\"rgba(124,92,255,0.5)\" letterSpacing=\"2\">ASTROLOGIA</text>\n364\t\n365\t          {/* ── D — Particle dots on outer edge ── */}\n366\t          {PARTICLES.map((pt, i) => (\n367\t            <circle\n368\t              key={`particle-${i}`}\n369\t              cx={pt.x}\n370\t              cy={pt.y}\n371\t              r=\"1.5\"\n372\t              fill=\"white\"\n373\t              className=\"particle-blink\"\n374\t              style={{ animationDelay: `${pt.delay}s` }}\n375\t            />\n376\t          ))}\n377\t        </g>\n378\t\n379\t        {/* ── Layer 3 — Tantric Web ── */}\n380\t        <g opacity={opacity(3)} onClick={() => setActiveLayer(activeLayer === 3 ? null : 3)} style={{ cursor: 'pointer' }}>\n381\t          <circle cx=\"200\" cy=\"200\" r=\"138\" fill=\"none\" stroke=\"rgba(45,212,191,0.15)\" strokeWidth=\"1\" strokeDasharray=\"3 4\" />\n382\t          {/* Web lines between nodes */}\n383\t          {tantricNodes.map(({ pos }, i) => {\n384\t            const next = tantricNodes[(i + 1) % 11];\n385\t            return (\n386\t              <line\n387\t                key={i}\n388\t                x1={pos.x} y1={pos.y}\n389\t                x2={next.pos.x} y2={next.pos.y}\n390\t                stroke=\"rgba(45,212,191,0.1)\"\n391\t                strokeWidth=\"0.5\"\n392\t              />\n393\t            );\n394\t          })}\n395\t          {tantricNodes.map(({ pos, active, label }, i) => (\n396\t            <g key={i}>\n397\t              {!active && (\n398\t                <circle cx={pos.x} cy={pos.y} r=\"10\" fill=\"rgba(251,87,129,0.12)\" />\n399\t              )}\n400\t              <circle\n401\t                cx={pos.x} cy={pos.y} r={active ? 6 : 7}\n402\t                fill={active ? '#2DD4BF' : '#FB5781'}\n403\t                opacity={active ? 0.9 : 0.75}\n404\t              />\n405\t              <text\n406\t                x={pos.x} y={pos.y}\n407\t                textAnchor=\"middle\"\n408\t                dominantBaseline=\"middle\"\n409\t                fontSize=\"5\"\n410\t                fill=\"#06070F\"\n411\t                fontWeight=\"bold\"\n412\t              >\n413\t                {label}\n414\t              </text>\n415\t            </g>\n416\t          ))}\n417\t        </g>\n418\t\n419\t        {/* ── Layer 5 — I-Ching (5º sistema, v0.0.5 T6) ── */}\n420\t        <g opacity={opacity(5)} onClick={() => setActiveLayer(activeLayer === 5 ? null : 5)} style={{ cursor: 'pointer' }}>\n421\t          <circle cx=\"200\" cy=\"200\" r=\"110\" fill=\"none\" stroke=\"rgba(160,118,58,0.2)\" strokeWidth=\"1\" strokeDasharray=\"2 4\" />\n422\t          {/* I-Ching node at top (200, 110) */}\n423\t          <g>\n424\t            <circle cx=\"200\" cy=\"110\" r=\"20\" fill=\"rgba(160,118,58,0.12)\" />\n425\t            <circle\n426\t              cx=\"200\" cy=\"110\" r=\"13\"\n427\t              fill={data.iching.available ? '#A0763A' : 'rgba(160,118,58,0.35)'}\n428\t              opacity={data.iching.available ? 0.9 : 0.6}\n429\t              filter=\"url(#glow-akasha)\"\n430\t            >\n431\t              <title>\n432\t                {data.iching.available\n433\t                  ? `Hexagrama ${data.iching.hexagramNumber} — ${data.iching.hexagramName} (${data.iching.hexagramChineseName})`\n434\t                  : 'Hexagrama do Ori ainda não calculado'}\n435\t              </title>\n436\t            </circle>\n437\t            <text\n438\t              x=\"200\" y=\"110\"\n439\t              textAnchor=\"middle\"\n440\t              dominantBaseline=\"middle\"\n441\t              fontSize=\"9\"\n442\t              fill=\"#F4F5FF\"\n443\t              fontWeight=\"700\"\n444\t            >\n445\t              {data.iching.hexagramNumber ?? '?'}\n446\t            </text>\n447\t            <text\n448\t              x=\"200\" y=\"86\"\n449\t              textAnchor=\"middle\"\n450\t              fontSize=\"5.5\"\n451\t              fill=\"rgba(160,118,58,0.7)\"\n452\t              letterSpacing=\"1.5\"\n453\t            >\n454\t              I-CHING\n455\t            </text>\n456\t          </g>\n457\t        </g>\n458\t\n459\t        {/* ── B — Toroidal synergy lines (between Layer 3 and Layer 2) ── */}\n460\t        {tantricNodes.map(({ pos, active }, i) => (\n461\t          <line\n462\t            key={`synergy-${i}`}\n463\t            x1={pos.x} y1={pos.y}\n464\t            x2={200} y2={200}\n465\t            stroke={active ? '#2DD4BF' : '#FB5781'}\n466\t            strokeWidth=\"0.6\"\n467\t            strokeDasharray=\"4 6\"\n468\t            opacity={active ? 0.35 : 0.25}\n469\t            strokeDashoffset=\"0\"\n470\t            className={active ? 'synergy-active' : 'synergy-alert'}\n471\t            style={{ animationDelay: `${(i * 0.27) % 2}s` }}\n472\t          />\n473\t        ))}\n474\t\n475\t        {/* ── Layer 2 — Kabbalistic Geometry ── */}\n476\t        <g opacity={opacity(2)} onClick={() => setActiveLayer(activeLayer === 2 ? null : 2)} style={{ cursor: 'pointer' }}>\n477\t          <circle cx=\"200\" cy=\"200\" r=\"80\" fill=\"none\" stroke=\"rgba(124,92,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"2 3\" />\n478\t          <path\n479\t            d={trianglePath}\n480\t            fill=\"rgba(124,92,255,0.05)\"\n481\t            stroke=\"#7C5CFF\"\n482\t            strokeWidth=\"1.5\"\n483\t            opacity=\"0.8\"\n484\t          />\n485\t          {kabVerts.map(({ pos, value, master }, i) => (\n486\t            <g key={i}>\n487\t              {master && (\n488\t                <circle cx={pos.x} cy={pos.y} r=\"14\"\n489\t                  fill=\"none\" stroke=\"#9D86FF\" strokeWidth=\"0.75\" strokeDasharray=\"2 2\" opacity=\"0.6\" />\n490\t              )}\n491\t              <circle\n492\t                cx={pos.x} cy={pos.y} r=\"11\"\n493\t                fill=\"rgba(124,92,255,0.18)\"\n494\t                stroke=\"#7C5CFF\"\n495\t                strokeWidth=\"1.2\"\n496\t              />\n497\t              <text\n498\t                x={pos.x} y={pos.y}\n499\t                textAnchor=\"middle\"\n500\t                dominantBaseline=\"middle\"\n501\t                fontSize=\"8\"\n502\t                fill=\"#F4F5FF\"\n503\t                fontWeight=\"700\"\n504\t              >\n505\t                {value ?? '?'}\n506\t              </text>\n507\t            </g>\n508\t          ))}\n509\t        </g>\n510\t\n511\t        {/* ── Layer 1 — Odus Core ── */}\n512\t        <g opacity={opacity(1)} onClick={() => setActiveLayer(activeLayer === 1 ? null : 1)} style={{ cursor: 'pointer' }}>\n513\t          {/* ── C — Animated glow rings (3 concentric, phase-offset) ── */}\n514\t          <circle cx=\"200\" cy=\"200\" r=\"50\" fill=\"none\" stroke=\"#F0B429\" strokeWidth=\"0.5\" opacity=\"0.15\" className=\"mandala-pulse-3\" />\n515\t          <circle cx=\"200\" cy=\"200\" r=\"44\" fill=\"none\" stroke=\"#F0B429\" strokeWidth=\"0.75\" opacity=\"0.2\" className=\"mandala-pulse-2\" />\n516\t          {/* Ori glow */}\n517\t          <circle cx=\"200\" cy=\"200\" r=\"40\" fill=\"url(#oriGlow)\" className=\"mandala-pulse\" />\n518\t          <circle cx=\"200\" cy=\"200\" r=\"34\" fill=\"rgba(240,180,41,0.08)\" stroke=\"#F0B429\" strokeWidth=\"1.5\" className=\"mandala-pulse\" />\n519\t          <circle cx=\"200\" cy=\"200\" r=\"7\" fill=\"#F0B429\" filter=\"url(#glow-akasha)\" />\n520\t          <text x=\"200\" y=\"216\" textAnchor=\"middle\" fontSize=\"6.5\" fill=\"#F0B429\" fontWeight=\"600\">\n521\t            {data.odus.oduName.length > 16 ? data.odus.oduName.slice(0, 14) + '…' : data.odus.oduName}\n522\t          </text>\n523\t          {data.odus.orixaRegency[0] && (\n524\t            <text x=\"200\" y=\"226\" textAnchor=\"middle\" fontSize=\"5.5\" fill=\"rgba(240,180,41,0.65)\">\n525\t              {data.odus.orixaRegency[0]}\n526\t            </text>\n527\t          )}\n528\t        </g>\n529\t\n530\t        {/* ── F — Incomplete data badge ── */}\n531\t        {data.incomplete && (\n532\t          <text x=\"200\" y=\"390\" textAnchor=\"middle\" fontSize=\"7\" fill=\"#FB5781\" opacity=\"0.7\">\n533\t            * dados parciais — complete o perfil\n534\t          </text>\n535\t        )}\n536\t      </svg>\n537\t      </div>\n538\t\n539\t      {/* === Info Panels === */}\n540\t      {activeLayer === 4 && (\n541\t        <InfoPanel color=\"#7C5CFF\" title=\"Astrologia — O Céu\" subtitle=\"Anel Cósmico · Camada 4\">\n542\t          <Row label=\"Ascendente\" value={data.astrology.ascendant} />\n543\t          <Row label=\"Meio do Céu\" value={data.astrology.midheaven} />\n544\t          <Row label=\"Planeta dominante\" value={data.astrology.dominantPlanet} />\n545\t          {data.astrology.planets.slice(0, 5).map((p) => (\n546\t            <Row key={p.name} label={p.name} value={`${p.sign} — casa ${p.house}`} />\n547\t          ))}\n548\t          <Divider />\n549\t          <div style={{ display: 'flex', gap: '0.5rem', flexWrap: 'wrap' }}>\n550\t            {(Object.entries(data.astrology.elementalBalance) as [string, number][]).map(([el, val]) => (\n551\t              <span\n552\t                key={el}\n553\t                style={{\n554\t                  padding: '3px 10px',\n555\t                  borderRadius: '100px',\n556\t                  fontSize: '0.6875rem',\n557\t                  background: `${ELEMENT_COLORS[el]}18`,\n558\t                  border: `1px solid ${ELEMENT_COLORS[el]}44`,\n559\t                  color: ELEMENT_COLORS[el],\n560\t                }}\n561\t              >\n562\t                {ELEMENT_LABELS[el]} {val}%\n563\t              </span>\n564\t            ))}\n565\t          </div>\n566\t          {elemGuidance && (\n567\t            <>\n568\t              <Divider />\n569\t              <Insight color=\"#7C5CFF\">{elemGuidance.balance}</Insight>\n570\t              <Insight color=\"#2DD4BF\">{elemGuidance.ritual}</Insight>\n571\t            </>\n572\t          )}\n573\t        </InfoPanel>\n574\t      )}\n575\t\n576\t      {activeLayer === 3 && (\n577\t        <InfoPanel color=\"#2DD4BF\" title=\"Numerologia Tântrica — Os 11 Corpos\" subtitle=\"Teia de Conexão · Camada 3\">\n578\t          <Row label=\"Caminho Tântrico\" value={data.tantra.tantricPath} />\n579\t          <Row label=\"Alma\" value={data.tantra.soul} />\n580\t          <Row label=\"Karma\" value={data.tantra.karma} />\n581\t          <Row label=\"Dom Divino\" value={data.tantra.divineGift} />\n582\t          <Divider />\n583\t          {inactiveBodies.length === 0 ? (\n584\t            <Insight color=\"#2DD4BF\">Todos os 11 Corpos estão ativos — seu campo espiritual está em fluxo.</Insight>\n585\t          ) : (\n586\t            <>\n587\t              <p style={{ fontSize: '0.75rem', color: '#A7AECF', marginBottom: '0.5rem' }}>\n588\t                Corpos em tensão (indicados em magenta na Mandala):\n589\t              </p>\n590\t              {inactiveBodies.map((n) => {\n591\t                const w = TANTRIC_BODY_WISDOM[n.i + 1];\n592\t                return (\n593\t                  <div key={n.i} style={{ marginBottom: '0.5rem' }}>\n594\t                    <p style={{ fontSize: '0.8125rem', color: '#FB5781', fontWeight: 600 }}>\n595\t                      Corpo {n.i + 1} — {w?.desc}\n596\t                    </p>\n597\t                    <p style={{ fontSize: '0.75rem', color: '#A7AECF' }}>\n598\t                      Desafio: {w?.challenge} · Ativar: {w?.activate}\n599\t                    </p>\n600\t                  </div>\n601\t                );\n602\t              })}\n603\t            </>\n604\t          )}\n605\t        </InfoPanel>\n606\t      )}\n607\t\n608\t      {activeLayer === 2 && (\n609\t        <InfoPanel color=\"#7C5CFF\" title=\"Numerologia Cabalística — O Contrato de Alma\" subtitle=\"Geometria Interna · Camada 2\">\n610\t          <Row label=\"Caminho de Vida\" value={data.kabala.lifePath} master={data.kabala.lifePathMaster} />\n611\t          <Row label=\"Expressão\" value={data.kabala.expression} master={data.kabala.expressionMaster} />\n612\t          <Row label=\"Motivação\" value={data.kabala.motivation} />\n613\t          <Row label=\"Ano Pessoal\" value={data.kabala.personalYear} />\n614\t          {lpMeaning && (\n615\t            <>\n616\t              <Divider />\n617\t              <Insight color=\"#7C5CFF\">{lpMeaning}</Insight>\n618\t            </>\n619\t          )}\n620\t        </InfoPanel>\n621\t      )}\n622\t\n623\t      {activeLayer === 1 && (\n624\t        <InfoPanel color=\"#F0B429\" title={`Odu: ${data.odus.oduName}`} subtitle=\"Núcleo — Ori · Camada 1\">\n625\t          <Row label=\"Odu de Nascimento\" value={`${data.odus.oduName}${data.odus.oduNumber ? ` (${data.odus.oduNumber})` : ''}`} />\n626\t          <Row label=\"Orixá(s) regente(s)\" value={data.odus.orixaRegency.join(', ')} />\n627\t          <Row label=\"Força Elemental\" value={data.odus.elementalForce} />\n628\t          {data.odus.provisional && (\n629\t            <p style={{ fontSize: '0.6875rem', color: '#5C6691', marginTop: '0.25rem' }}>\n630\t              * Cálculo provisório — confirmar com linhagem de referência.\n631\t            </p>\n632\t          )}\n633\t          {data.odus.preceitos && data.odus.preceitos.length > 0 && (\n634\t            <>\n635\t              <Divider />\n636\t              <p style={{ fontSize: '0.75rem', color: '#F0B429', fontWeight: 600, marginBottom: '0.35rem' }}>\n637\t                Preceitos do Odu\n638\t              </p>\n639\t              {data.odus.preceitos.map((p, i) => (\n640\t                <p key={i} style={{ fontSize: '0.8125rem', color: '#A7AECF' }}>✦ {p}</p>\n641\t              ))}\n642\t            </>\n643\t          )}\n644\t          {data.odus.quizilas && data.odus.quizilas.length > 0 && (\n645\t            <>\n646\t              <Divider />\n647\t              <p style={{ fontSize: '0.75rem', color: '#FB5781', fontWeight: 600, marginBottom: '0.35rem' }}>\n648\t                Quizilás (evitar)\n649\t              </p>\n650\t              {data.odus.quizilas.map((q, i) => (\n651\t                <p key={i} style={{ fontSize: '0.8125rem', color: '#A7AECF' }}>⚠ {q}</p>\n652\t              ))}\n653\t            </>\n654\t          )}\n655\t          {(!data.odus.preceitos || data.odus.preceitos.length === 0) && (\n656\t            <Insight color=\"#F0B429\">\n657\t              As quizilás e preceitos específicos do seu Odu serão exibidos quando o Grimório for sincronizado.\n658\t              Consulte o Oráculo para orientação ancestral personalizada.\n659\t            </Insight>\n660\t          )}\n661\t        </InfoPanel>\n662\t      )}\n663\t\n664\t      {activeLayer === 5 && (\n665\t        <InfoPanel color=\"#A0763A\" title=\"I-Ching — O Hexagrama do Ori\" subtitle=\"Sabedoria Ancestral Chinesa · Camada 5\">\n666\t          {data.iching.available ? (\n667\t            <>\n668\t              <Row\n669\t                label=\"Hexagrama\"\n670\t                value={data.iching.hexagramChineseName\n671\t                  ? `${data.iching.hexagramNumber} — ${data.iching.hexagramName} (${data.iching.hexagramChineseName})`\n672\t                  : `${data.iching.hexagramNumber} — ${data.iching.hexagramName}`}\n673\t              />\n674\t              <Row\n675\t                label=\"Trigrama superior\"\n676\t                value={data.iching.upperTrigram != null && data.iching.upperTrigramName\n677\t                  ? `${data.iching.upperTrigram} — ${data.iching.upperTrigramName}`\n678\t                  : data.iching.upperTrigramName}\n679\t              />\n680\t              <Row\n681\t                label=\"Trigrama inferior\"\n682\t                value={data.iching.lowerTrigram != null && data.iching.lowerTrigramName\n683\t                  ? `${data.iching.lowerTrigram} — ${data.iching.lowerTrigramName}`\n684\t                  : data.iching.lowerTrigramName}\n685\t              />\n686\t              {Array.isArray(data.iching.lines) && data.iching.lines.length === 6 && (\n687\t                <>\n688\t                  <Divider />\n689\t                  <p style={{ fontSize: '0.75rem', color: '#A0763A', fontWeight: 600, marginBottom: '0.35rem' }}>\n690\t                    As 6 Linhas (de baixo para cima)\n691\t                  </p>\n692\t                  <div style={{ display: 'flex', flexDirection: 'column-reverse', gap: '4px', alignItems: 'center' }}>\n693\t                    {data.iching.lines.map((yang, i) => (\n694\t                      <span\n695\t                        key={i}\n696\t                        style={{\n697\t                          fontFamily: 'monospace',\n698\t                          fontSize: '0.875rem',\n699\t                          color: yang ? '#F4F5FF' : '#A0763A',\n700\t                          letterSpacing: '0.15em',\n701\t                        }}\n702\t                      >\n703\t                        {yang ? '———' : '— — —'}\n704\t                      </span>\n705\t                    ))}\n706\t                  </div>\n707\t                </>\n708\t              )}\n709\t              <Divider />\n710\t              <Row label=\"Data de nascimento\" value={data.iching.birthDate} />\n711\t              {data.iching.birthTime && <Row label=\"Hora\" value={data.iching.birthTime} />}\n712\t              {data.iching.provisional && (\n713\t                <p style={{ fontSize: '0.6875rem', color: '#5C6691', marginTop: '0.25rem' }}>\n714\t                  * Cálculo provisório — hora de nascimento não informada.\n715\t                </p>\n716\t              )}\n717\t            </>\n718\t          ) : (\n719\t            <Insight color=\"#A0763A\">\n720\t              O hexagrama do seu Ori será calculado quando você completar o perfil.\n721\t              Forneça data e hora de nascimento para que o algoritmo determinístico\n722\t              (akasha.v0.0.4.trigramas-mod8) revele o trigrama superior e inferior\n723\t              do seu nascimento.\n724\t            </Insight>\n725\t          )}\n726\t        </InfoPanel>\n727\t      )}\n728\t\n729\t      {activeLayer === null && (\n730\t        <p style={{ fontSize: '0.75rem', color: '#5C6691', textAlign: 'center' }}>\n731\t          Toque em uma camada para revelar seus dados e orientações práticas.\n732\t        </p>\n733\t      )}\n734\t    </div>\n735\t  );\n736\t}\n737\t\n738\tfunction InfoPanel({ color, title, subtitle, children }: {\n739\t  color: string; title: string; subtitle: string; children: React.ReactNode;\n740\t}) {\n741\t  return (\n742\t    <div\n743\t      style={{\n744\t        background: 'rgba(11,14,28,0.88)',\n745\t        border: `1px solid ${color}33`,\n746\t        backdropFilter: 'blur(12px)',\n747\t        borderRadius: '14px',\n748\t        padding: '1.25rem',\n749\t        width: '100%',\n750\t        maxWidth: 400,\n751\t      }}\n752\t    >\n753\t      <p style={{ fontSize: '0.6875rem', color, letterSpacing: '0.08em', marginBottom: '0.25rem', textTransform: 'uppercase' }}>\n754\t        {subtitle}\n755\t      </p>\n756\t      <p style={{ fontFamily: 'var(--font-cinzel), serif', fontSize: '0.9375rem', color: '#F4F5FF', fontWeight: 600, marginBottom: '0.75rem' }}>\n757\t        {title}\n758\t      </p>\n759\t      <div style={{ display: 'flex', flexDirection: 'column', gap: '0.35rem' }}>\n760\t        {children}\n761\t      </div>\n762\t    </div>\n763\t  );\n764\t}\n765\t\n766\tfunction Row({ label, value, master }: { label: string; value: string | number | null | undefined; master?: boolean }) {\n767\t  if (value === null || value === undefined) return null;\n768\t  return (\n769\t    <div style={{ display: 'flex', gap: '0.5rem', alignItems: 'baseline' }}>\n770\t      <span style={{ fontSize: '0.75rem', color: '#5C6691', minWidth: '120px', flexShrink: 0 }}>{label}</span>\n771\t      <span style={{ fontSize: '0.8125rem', color: '#F4F5FF' }}>\n772\t        {String(value)}{master && <span style={{ color: '#9D86FF', fontSize: '0.6875rem', marginLeft: 4 }}>★ Mestre</span>}\n773\t      </span>\n774\t    </div>\n775\t  );\n776\t}\n777\t\n778\tfunction Insight({ color, children }: { color: string; children: React.ReactNode }) {\n779\t  return (\n780\t    <p\n781\t      style={{\n782\t        fontSize: '0.8125rem',\n783\t        color: '#A7AECF',\n784\t        lineHeight: 1.6,\n785\t        borderLeft: `2px solid ${color}55`,\n786\t        paddingLeft: '0.75rem',\n787\t        marginTop: '0.25rem',\n788\t      }}\n789\t    >\n790\t      {children}\n791\t    </p>\n792\t  );\n793\t}\n794\t\n795\tfunction Divider() {\n796\t  return <hr style={{ border: 'none', borderTop: '1px solid rgba(38,48,79,0.6)', margin: '0.5rem 0' }} />;\n797\t}\n798\t"}]},"parent_tool_use_id":null,"session_id":"44a294c9-7ecf-4f85-9b61-8e5a12793e2c","uuid":"0fd07a30-cd0f-42d0-86ec-db65b198f672","timestamp":"2026-06-11T11:37:33.261Z","tool_use_result":{"type":"text","file":{"filePath":"/home/skynet/cabala-dos-caminhos/apps/akasha-portal/src/components/akasha/MandalaChart.tsx","content":"'use client';\n\nimport { useState } from 'react';\nimport { MandalaAtmosphere } from '@/components/akasha/MandalaAtmosphere';\nimport { useCockpitStore } from '@/stores/cockpit-store';\n\ninterface MandalaData {\n  incomplete: boolean;\n  odus: {\n    oduName: string;\n    oduNumber: number | null;\n    orixaRegency: string[];\n    elementalForce: string | null;\n    provisional: boolean;\n    preceitos?: string[];\n    quizilas?: string[];\n  };\n  kabala: {\n    lifePath: number | null;\n    lifePathMaster: boolean;\n    expression: number | null;\n    expressionMaster: boolean;\n    motivation: number | null;\n    personalYear: number | null;\n  };\n  tantra: {\n    soul: number | null;\n    karma: number | null;\n    divineGift: number | null;\n    destiny: number | null;\n    tantricPath: number | null;\n    bodies: Array<{ index: number; name: string; active: boolean }>;\n  };\n  astrology: {\n    ascendant: string | null;\n    midheaven: string | null;\n    dominantPlanet: string | null;\n    planets: Array<{ name: string; sign: string; degree: number; house: number }>;\n    elementalBalance: { fire: number; earth: number; air: number; water: number };\n  };\n  iching: {\n    hexagramNumber: number | null;\n    hexagramName: string | null;\n    hexagramChineseName: string | null;\n    upperTrigram: number | null;\n    lowerTrigram: number | null;\n    upperTrigramName: string | null;\n    lowerTrigramName: string | null;\n    lines: boolean[];\n    algorithm: string | null;\n    provisional: boolean;\n    birthDate: string | null;\n    birthTime: string | null;\n    available: boolean;\n    error: string | null;\n  };\n  _user?: {\n    birthDate: string | null;\n    birthTime: string | null;\n  };\n}\n\ninterface Props {\n  data: MandalaData;\n}\n\ntype Layer = 1 | 2 | 3 | 4 | 5;\n\nconst toXY = (angleDeg: number, r: number, cx = 200, cy = 200) => ({\n  x: cx + r * Math.cos((angleDeg - 90) * Math.PI / 180),\n  y: cy + r * Math.sin((angleDeg - 90) * Math.PI / 180),\n});\n\nconst ZODIAC_SIGNS = ['♈', '♉', '♊', '♋', '♌', '♍', '♎', '♏', '♐', '♑', '♒', '♓'];\nconst ZODIAC_NAMES = ['Áries', 'Touro', 'Gêmeos', 'Câncer', 'Leão', 'Virgem', 'Libra', 'Escorpião', 'Sagitário', 'Capricórnio', 'Aquário', 'Peixes'];\n\nconst ELEMENT_COLORS: Record<string, string> = {\n  fire: '#FB5781', earth: '#F0B429', air: '#7C5CFF', water: '#2DD4BF',\n};\nconst ELEMENT_LABELS: Record<string, string> = {\n  fire: 'Fogo', earth: 'Terra', air: 'Ar', water: 'Água',\n};\nconst ELEMENT_GUIDANCE: Record<string, { balance: string; ritual: string }> = {\n  fire: {\n    balance: 'Elemento dominante Fogo — energia de ação, liderança e expansão. Para equilibrar: aterrar com práticas de Terra (corpo, natureza, alimentos raiz).',\n    ritual: 'Ritual: banhos de ervas de terra (alecrim, patchouli), caminhar descalço, meditação com pedras.',\n  },\n  earth: {\n    balance: 'Elemento dominante Terra — energia de estrutura, paciência e materialização. Para equilibrar: aquecer com Fogo (movimento, expressão, criatividade).',\n    ritual: 'Ritual: dança livre, uso de cores vibrantes, incenso de canela ou cravo para ativar a chama interna.',\n  },\n  air: {\n    balance: 'Elemento dominante Ar — energia mental, comunicação e movimento. Para equilibrar: ancorar com Água (emoção, intuição, descanso).',\n    ritual: 'Ritual: banhos de água fria com pétalas de rosa, meditação aquática, chás calmantes.',\n  },\n  water: {\n    balance: 'Elemento dominante Água — energia emocional, intuição e profundidade. Para equilibrar: estruturar com Terra (rotinas, corpo, alimentação consciente).',\n    ritual: 'Ritual: caminhadas na natureza, dieta baseada em raízes e tubérculos, pedras de jaspe ou hematita.',\n  },\n};\n\nconst LIFE_PATH_MEANINGS: Record<number, string> = {\n  1: 'Caminho do Pioneiro — sua missão é liderar e inaugurar novos caminhos. Aprenda a agir independentemente.',\n  2: 'Caminho do Diplomata — cooperação, harmonia e parceria são seu veículo de crescimento.',\n  3: 'Caminho do Criador — expressão, comunicação e criatividade são o seu propósito sagrado.',\n  4: 'Caminho do Construtor — estrutura, disciplina e trabalho constante constroem seu legado.',\n  5: 'Caminho da Liberdade — mudança, aventura e versatilidade são sua escola de vida.',\n  6: 'Caminho do Guardião — responsabilidade, cuidado e serviço ao próximo definem sua essência.',\n  7: 'Caminho do Buscador — introspecção, espiritualidade e sabedoria são seu norte.',\n  8: 'Caminho do Realizador — poder, abundância e autoridade são os temas centrais da sua existência.',\n  9: 'Caminho do Humanista — compaixão universal, conclusões e entrega ao coletivo.',\n  11: 'Número Mestre 11 — Iluminador. Canal entre os planos, alta sensibilidade intuitiva e missão espiritual.',\n  22: 'Número Mestre 22 — Construtor de Mundos. Capacidade de manifestar visões grandiosas na matéria.',\n  33: 'Número Mestre 33 — Mestre Cósmico. Serviço incondicional, amor universal, cura e ensino.',\n};\n\nconst TANTRIC_BODY_WISDOM: Record<number, { desc: string; challenge: string; activate: string }> = {\n  1: { desc: 'Corpo da Alma', challenge: 'Encontrar propósito humilde', activate: 'Meditação Ong Namo' },\n  2: { desc: 'Mente Negativa', challenge: 'Discernir sem paralisar', activate: 'Respiração de fogo' },\n  3: { desc: 'Mente Positiva', challenge: 'Confiar no processo', activate: 'Sat Kriya — 3 min' },\n  4: { desc: 'Mente Neutra', challenge: 'Observar sem reagir', activate: 'Meditação do coração' },\n  5: { desc: 'Corpo Físico', challenge: 'Encarnar totalmente', activate: 'Movimento consciente' },\n  6: { desc: 'Linha do Arco', challenge: 'Proteger o campo áurico', activate: 'Ser humano íntegro' },\n  7: { desc: 'Aura', challenge: 'Expandir sem dissolver', activate: 'Projeção e Proteção' },\n  8: { desc: 'Corpo Prânico', challenge: 'Sustentar a vitalidade', activate: 'Pranayama diário' },\n  9: { desc: 'Corpo Sutil', challenge: 'Escutar o infinalível', activate: 'Escuta da intuição' },\n  10: { desc: 'Corpo Radiante', challenge: 'Brilhar corajosamente', activate: 'Ação corajosa cotidiana' },\n  11: { desc: 'Mente Divina', challenge: 'Manter-se aberto ao infinito', activate: 'Gratidão e rendição' },\n};\n\n// Stars data — fixed positions seeded deterministically\nconst STARS = Array.from({ length: 30 }, (_, i) => {\n  const angle = (i * 137.508) % 360; // golden angle spacing\n  const radius = 60 + (i * 47) % 130;\n  const pos = toXY(angle, radius);\n  const opacity = 0.08 + (i % 5) * 0.03;\n  const delay = (i * 0.37) % 3;\n  return { x: pos.x, y: pos.y, opacity, delay };\n});\n\n// Particle dots on outer edge\nconst PARTICLES = Array.from({ length: 12 }, (_, i) => {\n  const angle = i * 30;\n  const pos = toXY(angle, 198);\n  const delay = (i * 0.4) % 4;\n  return { x: pos.x, y: pos.y, delay };\n});\n\nfunction describeArc(cx: number, cy: number, r: number, startDeg: number, endDeg: number): string {\n  const start = toXY(startDeg, r, cx, cy);\n  const end = toXY(endDeg, r, cx, cy);\n  const largeArc = endDeg - startDeg > 180 ? 1 : 0;\n  return `M ${start.x} ${start.y} A ${r} ${r} 0 ${largeArc} 1 ${end.x} ${end.y}`;\n}\n\nfunction dominantElement(balance: { fire: number; earth: number; air: number; water: number }): string {\n  const entries = Object.entries(balance) as [string, number][];\n  const sorted = entries.sort((a, b) => b[1] - a[1]);\n  return sorted[0][0];\n}\n\nexport default function MandalaChart({ data }: Props) {\n  const [activeLayer, setActiveLayer] = useState<null | Layer>(null);\n  const atmosphereIntensity = useCockpitStore((s) => s.atmosphereIntensity);\n\n  const opacity = (layer: Layer) =>\n    activeLayer === null ? 1 : activeLayer === layer ? 1 : 0.3;\n\n  // Pause ring rotation when Layer 4 is selected\n  const ringPaused = activeLayer === 4;\n\n  const astroSegments = ZODIAC_SIGNS.map((sym, i) => {\n    const startDeg = i * 30;\n    const endDeg = (i + 1) * 30;\n    const midDeg = startDeg + 15;\n    const labelPos = toXY(midDeg, 190);\n    return { sym, name: ZODIAC_NAMES[i], startDeg, endDeg, midDeg, labelPos };\n  });\n\n  const planetDots = data.astrology.planets.map((p) => ({\n    ...p,\n    pos: toXY((p.degree / 360) * 360, 178),\n  }));\n\n  const tantricNodes = Array.from({ length: 11 }, (_, i) => {\n    const angleDeg = i * (360 / 11);\n    const pos = toXY(angleDeg, 138);\n    const body = data.tantra.bodies.find((b) => b.index === i + 1);\n    const wisdom = TANTRIC_BODY_WISDOM[i + 1];\n    return { i, angleDeg, pos, active: body?.active ?? true, label: i + 1, name: wisdom?.desc ?? `Corpo ${i + 1}` };\n  });\n\n  const kabVerts = [\n    { angleDeg: 0, value: data.kabala.lifePath, master: data.kabala.lifePathMaster, label: 'VP' },\n    { angleDeg: 120, value: data.kabala.expression, master: data.kabala.expressionMaster, label: 'EX' },\n    { angleDeg: 240, value: data.kabala.motivation, master: false, label: 'MO' },\n  ].map((v) => ({ ...v, pos: toXY(v.angleDeg, 80) }));\n\n  const trianglePath = `M ${kabVerts[0].pos.x} ${kabVerts[0].pos.y} L ${kabVerts[1].pos.x} ${kabVerts[1].pos.y} L ${kabVerts[2].pos.x} ${kabVerts[2].pos.y} Z`;\n\n  const elem = dominantElement(data.astrology.elementalBalance);\n  const inactiveBodies = tantricNodes.filter((n) => !n.active);\n  const lpMeaning = LIFE_PATH_MEANINGS[data.kabala.lifePath ?? 0] ?? null;\n  const elemGuidance = ELEMENT_GUIDANCE[elem] ?? null;\n\n  return (\n    <div style={{ display: 'flex', flexDirection: 'column', alignItems: 'center', gap: '1.25rem', width: '100%', maxWidth: 460 }}>\n      <style>{`\n        @keyframes pulse-ori {\n          0%, 100% { opacity: 0.65; }\n          50% { opacity: 1; }\n        }\n        @keyframes ring-rotate {\n          from { transform-origin: 200px 200px; transform: rotate(0deg); }\n          to { transform-origin: 200px 200px; transform: rotate(360deg); }\n        }\n        @keyframes dash-flow {\n          to { stroke-dashoffset: -20; }\n        }\n        @keyframes twinkle {\n          0%, 100% { opacity: 0.08; }\n          50% { opacity: 0.25; }\n        }\n        @keyframes particle-blink {\n          0%, 100% { opacity: 0.1; }\n          50% { opacity: 0.55; }\n        }\n        .mandala-pulse { animation: pulse-ori 3s ease-in-out infinite; }\n        .mandala-pulse-2 { animation: pulse-ori 3s ease-in-out infinite; animation-delay: 0.5s; }\n        .mandala-pulse-3 { animation: pulse-ori 3s ease-in-out infinite; animation-delay: 1s; }\n        .ring-astrological { animation: ring-rotate 120s linear infinite; }\n        .ring-astrological-paused { animation: ring-rotate 120s linear infinite; animation-play-state: paused; }\n        .synergy-active { animation: dash-flow 3s linear infinite; }\n        .synergy-alert { animation: dash-flow 1.5s linear infinite; }\n        .star-twinkle { animation: twinkle 4s ease-in-out infinite; }\n        .particle-blink { animation: particle-blink 2.5s ease-in-out infinite; }\n        @media (prefers-reduced-motion: reduce) {\n          * { animation: none !important; }\n        }\n      `}</style>\n\n      {/* Layer selector */}\n      <div className=\"flex gap-2 flex-wrap justify-center\">\n        {([\n          { layer: 4 as Layer, label: 'Astrologia', color: '#7C5CFF' },\n          { layer: 3 as Layer, label: 'Tântrica', color: '#2DD4BF' },\n          { layer: 5 as Layer, label: 'I-Ching', color: '#A0763A' },\n          { layer: 2 as Layer, label: 'Cabala', color: '#7C5CFF' },\n          { layer: 1 as Layer, label: 'Odus', color: '#F0B429' },\n        ] as const).map(({ layer, label, color }) => (\n          <button\n            key={layer}\n            onClick={() => setActiveLayer(activeLayer === layer ? null : layer)}\n            style={{\n              fontSize: '0.75rem',\n              padding: '4px 12px',\n              borderRadius: '100px',\n              border: `1px solid ${activeLayer === layer ? color : 'rgba(38,48,79,0.8)'}`,\n              background: activeLayer === layer ? `${color}22` : 'rgba(11,14,28,0.5)',\n              color: activeLayer === layer ? color : '#A7AECF',\n              cursor: 'pointer',\n              transition: 'all 0.2s',\n            }}\n          >\n            {label}\n          </button>\n        ))}\n      </div>\n\n      <div className=\"relative w-full\" style={{ maxWidth: 400 }}>\n        <MandalaAtmosphere intensity={atmosphereIntensity} />\n\n        <svg\n          viewBox=\"0 0 400 400\"\n          width=\"100%\"\n          style={{ maxWidth: 400, display: 'block', position: 'relative', zIndex: 1 }}\n          aria-label=\"Mandala Akáshica Toroidal\"\n        >\n        {/* Deep space background */}\n        <defs>\n          <radialGradient id=\"bgGrad\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stopColor=\"#0B0E1C\" />\n            <stop offset=\"100%\" stopColor=\"#06070F\" />\n          </radialGradient>\n          <radialGradient id=\"oriGlow\" cx=\"50%\" cy=\"50%\" r=\"50%\">\n            <stop offset=\"0%\" stopColor=\"#F0B429\" stopOpacity=\"0.3\" />\n            <stop offset=\"100%\" stopColor=\"#F0B429\" stopOpacity=\"0\" />\n          </radialGradient>\n          <filter id=\"glow-akasha\">\n            <feGaussianBlur stdDeviation=\"2\" result=\"blur\" />\n            <feMerge><feMergeNode in=\"blur\" /><feMergeNode in=\"SourceGraphic\" /></feMerge>\n          </filter>\n        </defs>\n        <circle cx=\"200\" cy=\"200\" r=\"200\" fill=\"url(#bgGrad)\" />\n\n        {/* ── E — Stars background ── */}\n        {STARS.map((s, i) => (\n          <circle\n            key={`star-${i}`}\n            cx={s.x}\n            cy={s.y}\n            r=\"1\"\n            fill=\"white\"\n            opacity={s.opacity}\n            className=\"star-twinkle\"\n            style={{ animationDelay: `${s.delay}s` }}\n          />\n        ))}\n\n        {/* Faint cross-layer synergy lines */}\n        {[0, 72, 144, 216, 288].map((deg, i) => {\n          const outer = toXY(deg, 178);\n          const inner = toXY(deg, 80);\n          return (\n            <line\n              key={i}\n              x1={outer.x} y1={outer.y}\n              x2={inner.x} y2={inner.y}\n              stroke=\"rgba(45,212,191,0.08)\"\n              strokeWidth=\"0.5\"\n              strokeDasharray=\"3 5\"\n            />\n          );\n        })}\n\n        {/* ── Layer 4 — Astrological Ring (rotating) ── */}\n        <g\n          opacity={opacity(4)}\n          onClick={() => setActiveLayer(activeLayer === 4 ? null : 4)}\n          style={{ cursor: 'pointer' }}\n          className={ringPaused ? 'ring-astrological-paused' : 'ring-astrological'}\n        >\n          <circle cx=\"200\" cy=\"200\" r=\"196\" fill=\"none\" stroke=\"rgba(124,92,255,0.12)\" strokeWidth=\"0.5\" />\n          <circle cx=\"200\" cy=\"200\" r=\"170\" fill=\"none\" stroke=\"rgba(124,92,255,0.12)\" strokeWidth=\"0.5\" />\n          {astroSegments.map(({ startDeg, endDeg, sym, labelPos }, i) => (\n            <g key={i}>\n              <path\n                d={describeArc(200, 200, 183, startDeg, endDeg)}\n                fill=\"none\"\n                stroke=\"rgba(38,48,79,0.7)\"\n                strokeWidth=\"1\"\n              />\n              <text\n                x={labelPos.x} y={labelPos.y}\n                textAnchor=\"middle\"\n                dominantBaseline=\"middle\"\n                fontSize=\"9\"\n                fill=\"#5C6691\"\n              >\n                {sym}\n              </text>\n            </g>\n          ))}\n          {/* Planet dots with tooltip */}\n          {planetDots.map((p, i) => (\n            <g key={i} filter=\"url(#glow-akasha)\">\n              <circle cx={p.pos.x} cy={p.pos.y} r=\"3.5\" fill=\"#7C5CFF\" opacity=\"0.9\">\n                <title>{p.name}: {p.sign} casa {p.house}</title>\n              </circle>\n            </g>\n          ))}\n          {/* Ring label */}\n          <text x=\"200\" y=\"14\" textAnchor=\"middle\" fontSize=\"7\" fill=\"rgba(124,92,255,0.5)\" letterSpacing=\"2\">ASTROLOGIA</text>\n\n          {/* ── D — Particle dots on outer edge ── */}\n          {PARTICLES.map((pt, i) => (\n            <circle\n              key={`particle-${i}`}\n              cx={pt.x}\n              cy={pt.y}\n              r=\"1.5\"\n              fill=\"white\"\n              className=\"particle-blink\"\n              style={{ animationDelay: `${pt.delay}s` }}\n            />\n          ))}\n        </g>\n\n        {/* ── Layer 3 — Tantric Web ── */}\n        <g opacity={opacity(3)} onClick={() => setActiveLayer(activeLayer === 3 ? null : 3)} style={{ cursor: 'pointer' }}>\n          <circle cx=\"200\" cy=\"200\" r=\"138\" fill=\"none\" stroke=\"rgba(45,212,191,0.15)\" strokeWidth=\"1\" strokeDasharray=\"3 4\" />\n          {/* Web lines between nodes */}\n          {tantricNodes.map(({ pos }, i) => {\n            const next = tantricNodes[(i + 1) % 11];\n            return (\n              <line\n                key={i}\n                x1={pos.x} y1={pos.y}\n                x2={next.pos.x} y2={next.pos.y}\n                stroke=\"rgba(45,212,191,0.1)\"\n                strokeWidth=\"0.5\"\n              />\n            );\n          })}\n          {tantricNodes.map(({ pos, active, label }, i) => (\n            <g key={i}>\n              {!active && (\n                <circle cx={pos.x} cy={pos.y} r=\"10\" fill=\"rgba(251,87,129,0.12)\" />\n              )}\n              <circle\n                cx={pos.x} cy={pos.y} r={active ? 6 : 7}\n                fill={active ? '#2DD4BF' : '#FB5781'}\n                opacity={active ? 0.9 : 0.75}\n              />\n              <text\n                x={pos.x} y={pos.y}\n                textAnchor=\"middle\"\n                dominantBaseline=\"middle\"\n                fontSize=\"5\"\n                fill=\"#06070F\"\n                fontWeight=\"bold\"\n              >\n                {label}\n              </text>\n            </g>\n          ))}\n        </g>\n\n        {/* ── Layer 5 — I-Ching (5º sistema, v0.0.5 T6) ── */}\n        <g opacity={opacity(5)} onClick={() => setActiveLayer(activeLayer === 5 ? null : 5)} style={{ cursor: 'pointer' }}>\n          <circle cx=\"200\" cy=\"200\" r=\"110\" fill=\"none\" stroke=\"rgba(160,118,58,0.2)\" strokeWidth=\"1\" strokeDasharray=\"2 4\" />\n          {/* I-Ching node at top (200, 110) */}\n          <g>\n            <circle cx=\"200\" cy=\"110\" r=\"20\" fill=\"rgba(160,118,58,0.12)\" />\n            <circle\n              cx=\"200\" cy=\"110\" r=\"13\"\n              fill={data.iching.available ? '#A0763A' : 'rgba(160,118,58,0.35)'}\n              opacity={data.iching.available ? 0.9 : 0.6}\n              filter=\"url(#glow-akasha)\"\n            >\n              <title>\n                {data.iching.available\n                  ? `Hexagrama ${data.iching.hexagramNumber} — ${data.iching.hexagramName} (${data.iching.hexagramChineseName})`\n                  : 'Hexagrama do Ori ainda não calculado'}\n              </title>\n            </circle>\n            <text\n              x=\"200\" y=\"110\"\n              textAnchor=\"middle\"\n              dominantBaseline=\"middle\"\n              fontSize=\"9\"\n              fill=\"#F4F5FF\"\n              fontWeight=\"700\"\n            >\n              {data.iching.hexagramNumber ?? '?'}\n            </text>\n            <text\n              x=\"200\" y=\"86\"\n              textAnchor=\"middle\"\n              fontSize=\"5.5\"\n              fill=\"rgba(160,118,58,0.7)\"\n              letterSpacing=\"1.5\"\n            >\n              I-CHING\n            </text>\n          </g>\n        </g>\n\n        {/* ── B — Toroidal synergy lines (between Layer 3 and Layer 2) ── */}\n        {tantricNodes.map(({ pos, active }, i) => (\n          <line\n            key={`synergy-${i}`}\n            x1={pos.x} y1={pos.y}\n            x2={200} y2={200}\n            stroke={active ? '#2DD4BF' : '#FB5781'}\n            strokeWidth=\"0.6\"\n            strokeDasharray=\"4 6\"\n            opacity={active ? 0.35 : 0.25}\n            strokeDashoffset=\"0\"\n            className={active ? 'synergy-active' : 'synergy-alert'}\n            style={{ animationDelay: `${(i * 0.27) % 2}s` }}\n          />\n        ))}\n\n        {/* ── Layer 2 — Kabbalistic Geometry ── */}\n        <g opacity={opacity(2)} onClick={() => setActiveLayer(activeLayer === 2 ? null : 2)} style={{ cursor: 'pointer' }}>\n          <circle cx=\"200\" cy=\"200\" r=\"80\" fill=\"none\" stroke=\"rgba(124,92,255,0.2)\" strokeWidth=\"1\" strokeDasharray=\"2 3\" />\n          <path\n            d={trianglePath}\n            fill=\"rgba(124,92,255,0.05)\"\n            stroke=\"#7C5CFF\"\n            strokeWidth=\"1.5\"\n            opacity=\"0.8\"\n          />\n          {kabVerts.map(({ pos, value, master }, i) => (\n            <g key={i}>\n              {master && (\n                <circle cx={pos.x} cy={pos.y} r=\"14\"\n                  fill=\"none\" stroke=\"#9D86FF\" strokeWidth=\"0.75\" strokeDasharray=\"2 2\" opacity=\"0.6\" />\n              )}\n              <circle\n                cx={pos.x} cy={pos.y} r=\"11\"\n                fill=\"rgba(124,92,255,0.18)\"\n                stroke=\"#7C5CFF\"\n                strokeWidth=\"1.2\"\n              />\n              <text\n                x={pos.x} y={pos.y}\n                textAnchor=\"middle\"\n                dominantBaseline=\"middle\"\n                fontSize=\"8\"\n                fill=\"#F4F5FF\"\n                fontWeight=\"700\"\n              >\n                {value ?? '?'}\n              </text>\n            </g>\n          ))}\n        </g>\n\n        {/* ── Layer 1 — Odus Core ── */}\n        <g opacity={opacity(1)} onClick={() => setActiveLayer(activeLayer === 1 ? null : 1)} style={{ cursor: 'pointer' }}>\n          {/* ── C — Animated glow rings (3 concentric, phase-offset) ── */}\n          <circle cx=\"200\" cy=\"200\" r=\"50\" fill=\"none\" stroke=\"#F0B429\" strokeWidth=\"0.5\" opacity=\"0.15\" className=\"mandala-pulse-3\" />\n          <circle cx=\"200\" cy=\"200\" r=\"44\" fill=\"none\" stroke=\"#F0B429\" strokeWidth=\"0.75\" opacity=\"0.2\" className=\"mandala-pulse-2\" />\n          {/* Ori glow */}\n          <circle cx=\"200\" cy=\"200\" r=\"40\" fill=\"url(#oriGlow)\" className=\"mandala-pulse\" />\n          <circle cx=\"200\" cy=\"200\" r=\"34\" fill=\"rgba(240,180,41,0.08)\" stroke=\"#F0B429\" strokeWidth=\"1.5\" className=\"mandala-pulse\" />\n          <circle cx=\"200\" cy=\"200\" r=\"7\" fill=\"#F0B429\" filter=\"url(#glow-akasha)\" />\n          <text x=\"200\" y=\"216\" textAnchor=\"middle\" fontSize=\"6.5\" fill=\"#F0B429\" fontWeight=\"600\">\n            {data.odus.oduName.length > 16 ? data.odus.oduName.slice(0, 14) + '…' : data.odus.oduName}\n          </text>\n          {data.odus.orixaRegency[0] && (\n            <text x=\"200\" y=\"226\" textAnchor=\"middle\" fontSize=\"5.5\" fill=\"rgba(240,180,41,0.65)\">\n              {data.odus.orixaRegency[0]}\n            </text>\n          )}\n        </g>\n\n        {/* ── F — Incomplete data badge ── */}\n        {data.incomplete && (\n          <text x=\"200\" y=\"390\" textAnchor=\"middle\" fontSize=\"7\" fill=\"#FB5781\" opacity=\"0.7\">\n            * dados parciais — complete o perfil\n          </text>\n        )}\n      </svg>\n      </div>\n\n      {/* === Info Panels === */}\n      {activeLayer === 4 && (\n        <InfoPanel color=\"#7C5CFF\" title=\"Astrologia — O Céu\" subtitle=\"Anel Cósmico · Camada 4\">\n          <Row label=\"Ascendente\" value={data.astrology.ascendant} />\n          <Row label=\"Meio do Céu\" value={data.astrology.midheaven} />\n          <Row label=\"Planeta dominante\" value={data.astrology.dominantPlanet} />\n          {data.astrology.planets.slice(0, 5).map((p) => (\n            <Row key={p.name} label={p.name} value={`${p.sign} — casa ${p.house}`} />\n          ))}\n          <Divider />\n          <div style={{ display: 'flex', gap: '0.5rem', flexWrap: 'wrap' }}>\n            {(Object.entries(data.astrology.elementalBalance) as [string, number][]).map(([el, val]) => (\n              <span\n                key={el}\n                style={{\n                  padding: '3px 10px',\n                  borderRadius: '100px',\n                  fontSize: '0.6875rem',\n                  background: `${ELEMENT_COLORS[el]}18`,\n                  border: `1px solid ${ELEMENT_COLORS[el]}44`,\n                  color: ELEMENT_COLORS[el],\n                }}\n              >\n                {ELEMENT_LABELS[el]} {val}%\n              </span>\n            ))}\n          </div>\n          {elemGuidance && (\n            <>\n              <Divider />\n              <Insight color=\"#7C5CFF\">{elemGuidance.balance}</Insight>\n              <Insight color=\"#2DD4BF\">{elemGuidance.ritual}</Insight>\n            </>\n          )}\n        </InfoPanel>\n      )}\n\n      {activeLayer === 3 && (\n        <InfoPanel color=\"#2DD4BF\" title=\"Numerologia Tântrica — Os 11 Corpos\" subtitle=\"Teia de Conexão · Camada 3\">\n          <Row label=\"Caminho Tântrico\" value={data.tantra.tantricPath} />\n          <Row label=\"Alma\" value={data.tantra.soul} />\n          <Row label=\"Karma\" value={data.tantra.karma} />\n          <Row label=\"Dom Divino\" value={data.tantra.divineGift} />\n          <Divider />\n          {inactiveBodies.length === 0 ? (\n            <Insight color=\"#2DD4BF\">Todos os 11 Corpos estão ativos — seu campo espiritual está em fluxo.</Insight>\n          ) : (\n            <>\n              <p style={{ fontSize: '0.75rem', color: '#A7AECF', marginBottom: '0.5rem' }}>\n                Corpos em tensão (indicados em magenta na Mandala):\n              </p>\n              {inactiveBodies.map((n) => {\n                const w = TANTRIC_BODY_WISDOM[n.i + 1];\n                return (\n                  <div key={n.i} style={{ marginBottom: '0.5rem' }}>\n                    <p style={{ fontSize: '0.8125rem', color: '#FB5781', fontWeight: 600 }}>\n                      Corpo {n.i + 1} — {w?.desc}\n                    </p>\n                    <p style={{ fontSize: '0.75rem', color: '#A7AECF' }}>\n                      Desafio: {w?.challenge} · Ativar: {w?.activate}\n                    </p>\n                  </div>\n                );\n              })}\n            </>\n          )}\n        </InfoPanel>\n      )}\n\n      {activeLayer === 2 && (\n        <InfoPanel color=\"#7C5CFF\" title=\"Numerologia Cabalística — O Contrato de Alma\" subtitle=\"Geometria Interna · Camada 2\">\n          <Row label=\"Caminho de Vida\" value={data.kabala.lifePath} master={data.kabala.lifePathMaster} />\n          <Row label=\"Expressão\" value={data.kabala.expression} master={data.kabala.expressionMaster} />\n          <Row label=\"Motivação\" value={data.kabala.motivation} />\n          <Row label=\"Ano Pessoal\" value={data.kabala.personalYear} />\n          {lpMeaning && (\n            <>\n              <Divider />\n              <Insight color=\"#7C5CFF\">{lpMeaning}</Insight>\n            </>\n          )}\n        </InfoPanel>\n      )}\n\n      {activeLayer === 1 && (\n        <InfoPanel color=\"#F0B429\" title={`Odu: ${data.odus.oduName}`} subtitle=\"Núcleo — Ori · Camada 1\">\n          <Row label=\"Odu de Nascimento\" value={`${data.odus.oduName}${data.odus.oduNumber ? ` (${data.odus.oduNumber})` : ''}`} />\n          <Row label=\"Orixá(s) regente(s)\" value={data.odus.orixaRegency.join(', ')} />\n          <Row label=\"Força Elemental\" value={data.odus.elementalForce} />\n          {data.odus.provisional && (\n            <p style={{ fontSize: '0.6875rem', color: '#5C6691', marginTop: '0.25rem' }}>\n              * Cálculo provisório — confirmar com linhagem de referência.\n            </p>\n          )}\n          {data.odus.preceitos && data.odus.preceitos.length > 0 && (\n            <>\n              <Divider />\n              <p style={{ fontSize: '0.75rem', color: '#F0B429', fontWeight: 600, marginBottom: '0.35rem' }}>\n                Preceitos do Odu\n              </p>\n              {data.odus.preceitos.map((p, i) => (\n                <p key={i} style={{ fontSize: '0.8125rem', color: '#A7AECF' }}>✦ {p}</p>\n              ))}\n            </>\n          )}\n          {data.odus.quizilas && data.odus.quizilas.length > 0 && (\n            <>\n              <Divider />\n              <p style={{ fontSize: '0.75rem', color: '#FB5781', fontWeight: 600, marginBottom: '0.35rem' }}>\n                Quizilás (evitar)\n              </p>\n              {data.odus.quizilas.map((q, i) => (\n                <p key={i} style={{ fontSize: '0.8125rem', color: '#A7AECF' }}>⚠ {q}</p>\n              ))}\n            </>\n          )}\n          {(!data.odus.preceitos || data.odus.preceitos.length === 0) && (\n            <Insight color=\"#F0B429\">\n              As quizilás e preceitos específicos do seu Odu serão exibidos quando o Grimório for sincronizado.\n              Consulte o Oráculo para orientação ancestral personalizada.\n            </Insight>\n          )}\n        </InfoPanel>\n      )}\n\n      {activeLayer === 5 && (\n        <InfoPanel color=\"#A0763A\" title=\"I-Ching — O Hexagrama do Ori\" subtitle=\"Sabedoria Ancestral Chinesa · Camada 5\">\n          {data.iching.available ? (\n            <>\n              <Row\n                label=\"Hexagrama\"\n                value={data.iching.hexagramChineseName\n                  ? `${data.iching.hexagramNumber} — ${data.iching.hexagramName} (${data.iching.hexagramChineseName})`\n                  : `${data.iching.hexagramNumber} — ${data.iching.hexagramName}`}\n              />\n              <Row\n                label=\"Trigrama superior\"\n                value={data.iching.upperTrigram != null && data.iching.upperTrigramName\n                  ? `${data.iching.upperTrigram} — ${data.iching.upperTrigramName}`\n                  : data.iching.upperTrigramName}\n              />\n              <Row\n                label=\"Trigrama inferior\"\n                value={data.iching.lowerTrigram != null && data.iching.lowerTrigramName\n                  ? `${data.iching.lowerTrigram} — ${data.iching.lowerTrigramName}`\n                  : data.iching.lowerTrigramName}\n              />\n              {Array.isArray(data.iching.lines) && data.iching.lines.length === 6 && (\n                <>\n                  <Divider />\n                  <p style={{ fontSize: '0.75rem', color: '#A0763A', fontWeight: 600, marginBottom: '0.35rem' }}>\n                    As 6 Linhas (de baixo para cima)\n                  </p>\n                  <div style={{ display: 'flex', flexDirection: 'column-reverse', gap: '4px', alignItems: 'center' }}>\n                    {data.iching.lines.map((yang, i) => (\n                      <span\n                        key={i}\n                        style={{\n                          fontFamily: 'monospace',\n                          fontSize: '0.875rem',\n                          color: yang ? '#F4F5FF' : '#A0763A',\n                          letterSpacing: '0.15em',\n                        }}\n                      >\n                        {yang ? '———' : '— — —'}\n                      </span>\n                    ))}\n                  </div>\n                </>\n              )}\n              <Divider />\n              <Row label=\"Data de nascimento\" value={data.iching.birthDate} />\n              {data.iching.birthTime && <Row label=\"Hora\" value={data.iching.birthTime} />}\n              {data.iching.provisional && (\n                <p style={{ fontSize: '0.6875rem', color: '#5C6691', marginTop: '0.25rem' }}>\n                  * Cálculo provisório — hora de nascimento não informada.\n                </p>\n              )}\n            </>\n          ) : (\n            <Insight color=\"#A0763A\">\n              O hexagrama do seu Ori será calculado quando você completar o perfil.\n              Forneça data e hora de nascimento para que o algoritmo determinístico\n              (akasha.v0.0.4.trigramas-mod8) revele o trigrama superior e inferior\n              do seu nascimento.\n            </Insight>\n          )}\n        </InfoPanel>\n      )}\n\n      {activeLayer === null && (\n        <p style={{ fontSize: '0.75rem', color: '#5C6691', textAlign: 'center' }}>\n          Toque em uma camada para revelar seus dados e orientações práticas.\n        </p>\n      )}\n    </div>\n  );\n}\n\nfunction InfoPanel({ color, title, subtitle, children }: {\n  color: string; title: string; subtitle: string; children: React.ReactNode;\n}) {\n  return (\n    <div\n      style={{\n        background: 'rgba(11,14,28,0.88)',\n        border: `1px solid ${color}33`,\n        backdropFilter: 'blur(12px)',\n        borderRadius: '14px',\n        padding: '1.25rem',\n        width: '100%',\n        maxWidth: 400,\n      }}\n    >\n      <p style={{ fontSize: '0.6875rem', color, letterSpacing: '0.08em', marginBottom: '0.25rem', textTransform: 'uppercase' }}>\n        {subtitle}\n      </p>\n      <p style={{ fontFamily: 'var(--font-cinzel), serif', fontSize: '0.9375rem', color: '#F4F5FF', fontWeight: 600, marginBottom: '0.75rem' }}>\n        {title}\n      </p>\n      <div style={{ display: 'flex', flexDirection: 'column', gap: '0.35rem' }}>\n        {children}\n      </div>\n    </div>\n  );\n}\n\nfunction Row({ label, value, master }: { label: string; value: string | number | null | undefined; master?: boolean }) {\n  if (value === null || value === undefined) return null;\n  return (\n    <div style={{ display: 'flex', gap: '0.5rem', alignItems: 'baseline' }}>\n      <span style={{ fontSize: '0.75rem', color: '#5C6691', minWidth: '120px', flexShrink: 0 }}>{label}</span>\n      <span style={{ fontSize: '0.8125rem', color: '#F4F5FF' }}>\n        {String(value)}{master && <span style={{ color: '#9D86FF', fontSize: '0.6875rem', marginLeft: 4 }}>★ Mestre</span>}\n      </span>\n    </div>\n  );\n}\n\nfunction Insight({ color, children }: { color: string; children: React.ReactNode }) {\n  return (\n    <p\n      style={{\n        fontSize: '0.8125rem',\n        color: '#A7AECF',\n        lineHeight: 1.6,\n        borderLeft: `2px solid ${color}55`,\n        paddingLeft: '0.75rem',\n        marginTop: '0.25rem',\n      }}\n    >\n      {children}\n    </p>\n  );\n}\n\nfunction Divider() {\n  return <hr style={{ border: 'none', borderTop: '1px solid rgba(38,48,79,0.6)', margin: '0.5rem 0' }} />;\n}\n","numLines":798,"startLine":1,"totalLines":798}}}
