{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_lclp6vq9d47c_1","type":"tool_result","content":"1\timport Link from 'next/link';\n2\t\n3\t/**\n4\t * (akasha) group layout inside the [locale] segment.\n5\t * Doc 25 §9 / v0.0.4-T9.8 — the previous `apps/akasha-portal/src/app/(akasha)/layout.tsx`\n6\t * lived at the route root; now it sits one level deeper so all nav links are\n7\t * locale-prefixed.\n8\t */\n9\texport default async function AkashaLayout({\n10\t  children,\n11\t  params,\n12\t}: {\n13\t  children: React.ReactNode;\n14\t  params: Promise<{ locale: string }>;\n15\t}) {\n16\t  const { locale } = await params;\n17\t\n18\t  return (\n19\t    <div\n20\t      className=\"min-h-screen flex flex-col antialiased\"\n21\t      style={{ background: '#06070F', color: '#F4F5FF' }}\n22\t    >\n23\t      <header\n24\t        style={{\n25\t          background: 'rgba(6, 7, 15, 0.88)',\n26\t          borderBottom: '1px solid rgba(124, 92, 255, 0.2)',\n27\t          backdropFilter: 'blur(12px)',\n28\t          position: 'sticky',\n29\t          top: 0,\n30\t          zIndex: 50,\n31\t        }}\n32\t      >\n33\t        <nav className=\"max-w-5xl mx-auto px-4 h-14 flex items-center justify-between\">\n34\t          <Link\n35\t            href={`/${locale}/mandala`}\n36\t            className=\"text-lg font-semibold\"\n37\t            style={{\n38\t              fontFamily: 'var(--font-cinzel), serif',\n39\t              color: '#7C5CFF',\n40\t              letterSpacing: '0.18em',\n41\t            }}\n42\t          >\n43\t            ✦ AKASHA\n44\t          </Link>\n45\t\n46\t          <ul className=\"flex items-center gap-5 text-sm\" style={{ fontFamily: 'var(--font-inter), sans-serif' }}>\n47\t            <li>\n48\t              <Link\n49\t                href={`/${locale}/mandala`}\n50\t                className=\"transition-colors\"\n51\t                style={{ color: '#A7AECF' }}\n52\t              >\n53\t                Mandala\n54\t              </Link>\n55\t            </li>\n56\t            <li>\n57\t              <Link\n58\t                href={`/${locale}/diario`}\n59\t                className=\"transition-colors\"\n60\t                style={{ color: '#A7AECF' }}\n61\t              >\n62\t                Diário\n63\t              </Link>\n64\t            </li>\n65\t            <li>\n66\t              <Link\n67\t                href={`/${locale}/oraculo`}\n68\t                className=\"transition-colors\"\n69\t                style={{ color: '#A7AECF' }}\n70\t              >\n71\t                Oráculo\n72\t              </Link>\n73\t            </li>\n74\t            <li>\n75\t              <Link\n76\t                href={`/${locale}/conta`}\n77\t                className=\"transition-colors\"\n78\t                style={{ color: '#A7AECF' }}\n79\t              >\n80\t                Conta\n81\t              </Link>\n82\t            </li>\n83\t          </ul>\n84\t        </nav>\n85\t      </header>\n86\t\n87\t      <main className=\"flex-1 w-full\">{children}</main>\n88\t\n89\t      <footer className=\"py-6 text-center text-xs\" style={{ color: '#5C6691' }}>\n90\t        Sistema Akasha · Cabala dos Caminhos · Tecnologia Espiritual Viva\n91\t      </footer>\n92\t    </div>\n93\t  );\n94\t}\n95\t"}]},"parent_tool_use_id":null,"session_id":"44a294c9-7ecf-4f85-9b61-8e5a12793e2c","uuid":"63741ac0-6e5e-4965-bad5-33d7f442404e","timestamp":"2026-06-11T11:38:28.518Z","tool_use_result":{"type":"text","file":{"filePath":"/home/skynet/cabala-dos-caminhos/apps/akasha-portal/src/app/[locale]/(akasha)/layout.tsx","content":"import Link from 'next/link';\n\n/**\n * (akasha) group layout inside the [locale] segment.\n * Doc 25 §9 / v0.0.4-T9.8 — the previous `apps/akasha-portal/src/app/(akasha)/layout.tsx`\n * lived at the route root; now it sits one level deeper so all nav links are\n * locale-prefixed.\n */\nexport default async function AkashaLayout({\n  children,\n  params,\n}: {\n  children: React.ReactNode;\n  params: Promise<{ locale: string }>;\n}) {\n  const { locale } = await params;\n\n  return (\n    <div\n      className=\"min-h-screen flex flex-col antialiased\"\n      style={{ background: '#06070F', color: '#F4F5FF' }}\n    >\n      <header\n        style={{\n          background: 'rgba(6, 7, 15, 0.88)',\n          borderBottom: '1px solid rgba(124, 92, 255, 0.2)',\n          backdropFilter: 'blur(12px)',\n          position: 'sticky',\n          top: 0,\n          zIndex: 50,\n        }}\n      >\n        <nav className=\"max-w-5xl mx-auto px-4 h-14 flex items-center justify-between\">\n          <Link\n            href={`/${locale}/mandala`}\n            className=\"text-lg font-semibold\"\n            style={{\n              fontFamily: 'var(--font-cinzel), serif',\n              color: '#7C5CFF',\n              letterSpacing: '0.18em',\n            }}\n          >\n            ✦ AKASHA\n          </Link>\n\n          <ul className=\"flex items-center gap-5 text-sm\" style={{ fontFamily: 'var(--font-inter), sans-serif' }}>\n            <li>\n              <Link\n                href={`/${locale}/mandala`}\n                className=\"transition-colors\"\n                style={{ color: '#A7AECF' }}\n              >\n                Mandala\n              </Link>\n            </li>\n            <li>\n              <Link\n                href={`/${locale}/diario`}\n                className=\"transition-colors\"\n                style={{ color: '#A7AECF' }}\n              >\n                Diário\n              </Link>\n            </li>\n            <li>\n              <Link\n                href={`/${locale}/oraculo`}\n                className=\"transition-colors\"\n                style={{ color: '#A7AECF' }}\n              >\n                Oráculo\n              </Link>\n            </li>\n            <li>\n              <Link\n                href={`/${locale}/conta`}\n                className=\"transition-colors\"\n                style={{ color: '#A7AECF' }}\n              >\n                Conta\n              </Link>\n            </li>\n          </ul>\n        </nav>\n      </header>\n\n      <main className=\"flex-1 w-full\">{children}</main>\n\n      <footer className=\"py-6 text-center text-xs\" style={{ color: '#5C6691' }}>\n        Sistema Akasha · Cabala dos Caminhos · Tecnologia Espiritual Viva\n      </footer>\n    </div>\n  );\n}\n","numLines":95,"startLine":1,"totalLines":95}}}
