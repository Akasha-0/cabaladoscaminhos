{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_0gpk2rona48b_1","type":"tool_result","content":"1\t/**\n2\t * Diário Energético — F-202 (Fase 6).\n3\t *\n4\t * Consome `GET /api/akasha/mandato-do-dia` (F-201) e renderiza o\n5\t * Mandato do Dia em 3 telas (Mandato · Pergunta · Micro-Ritual).\n6\t *\n7\t * Referências:\n8\t *   - VISION §4 — \"Mandato = 1 push/dia 06h, 3 frases + 1 pergunta + 1 micro-ritual\"\n9\t *   - synthesis_v1.md §5 — Mandato spec\n10\t *   - ethics_charter_v1.md §5 — Pilar 3 LGPD/crise: `mentor_hook.crise_detectada`\n11\t *     faz o cliente renderizar CVV-188 e suprimir `redacao_bruta`.\n12\t *\n13\t * F-204 (P2) substitui os stubs do `akasha-core` por `loadEngines()` real +\n14\t * redação LLM; o que o F-202 já trata como \"esqueleto\" será preenchido\n15\t * sem mudanças de UI.\n16\t */\n17\timport { cookies } from 'next/headers';\n18\timport Link from 'next/link';\n19\timport { redirect } from 'next/navigation';\n20\t\n21\ttype MandatoEsqueleto = {\n22\t  escala: 'D' | 'S' | 'Z' | 'V';\n23\t  pilares_relevantes: string[];\n24\t  redacao_bruta: string;\n25\t  cita_fontes: string[];\n26\t};\n27\t\n28\ttype MentorHook = {\n29\t  intencao: string;\n30\t  crise_detectada: boolean;\n31\t  recurso: string | null;\n32\t};\n33\t\n34\ttype MandatoDoDiaResponse = {\n35\t  date: string;\n36\t  mandato: MandatoEsqueleto;\n37\t  mentor_hook: MentorHook;\n38\t};\n39\t\n40\t// ── Paleta Akasha (alinhada com MandalaChart.tsx) ────────────────────────────\n41\tconst C = {\n42\t  violeta: '#7C5CFF',\n43\t  aurora: '#2DD4BF',\n44\t  dourado: '#F0B429',\n45\t  magenta: '#FB5781',\n46\t  bgVoid: '#06070F',\n47\t  bgDeep: '#0B0E1C',\n48\t  bgNeb: '#141A33',\n49\t  txtPri: '#F4F5FF',\n50\t  txtSec: '#A7AECF',\n51\t  txtMut: '#5C6691',\n52\t} as const;\n53\t\n54\t// ── Pilares (canônicos VISION §2 — ordem P1..P5) ─────────────────────────────\n55\tconst PILLAR_LABELS: Record<string, { nome: string; cor: string }> = {\n56\t  cabala: { nome: 'Numerologia Cabalística', cor: C.violeta },\n57\t  astrologia: { nome: 'Astrologia', cor: C.aurora },\n58\t  tantrica: { nome: 'Numerologia Tântrica', cor: C.dourado },\n59\t  odu: { nome: 'Odu de Nascimento', cor: C.magenta },\n60\t  iching: { nome: 'I Ching', cor: '#A0763A' },\n61\t};\n62\t\n63\tconst ESCALA_LABELS: Record<MandatoEsqueleto['escala'], string> = {\n64\t  D: 'Diário',\n65\t  S: 'Semanal',\n66\t  Z: 'Sazonal',\n67\t  V: 'Vida',\n68\t};\n69\t\n70\t// ── Estilos (mesma linguagem do MandalaChart.tsx) ───────────────────────────\n71\t\n72\tconst wrapStyle: React.CSSProperties = {\n73\t  background: C.bgVoid,\n74\t  minHeight: '100dvh',\n75\t  overflowY: 'scroll',\n76\t  scrollSnapType: 'y mandatory',\n77\t  WebkitOverflowScrolling: 'touch',\n78\t};\n79\t\n80\tconst screenStyle: React.CSSProperties = {\n81\t  scrollSnapAlign: 'start',\n82\t  minHeight: '100dvh',\n83\t  display: 'flex',\n84\t  flexDirection: 'column',\n85\t  justifyContent: 'center',\n86\t  padding: '48px 20px 64px',\n87\t};\n88\t\n89\tconst innerStyle: React.CSSProperties = {\n90\t  maxWidth: 560,\n91\t  margin: '0 auto',\n92\t  width: '100%',\n93\t};\n94\t\n95\tconst cardStyle = (borderColor: string): React.CSSProperties => ({\n96\t  background: 'rgba(11,14,28,0.72)',\n97\t  backdropFilter: 'blur(12px)',\n98\t  WebkitBackdropFilter: 'blur(12px)',\n99\t  border: `1px solid ${borderColor}44`,\n100\t  borderLeft: `3px solid ${borderColor}`,\n101\t  borderRadius: 14,\n102\t  padding: '24px 24px 20px',\n103\t  marginBottom: 16,\n104\t});\n105\t\n106\tconst labelStyle = (color: string): React.CSSProperties => ({\n107\t  fontSize: '0.62rem',\n108\t  fontFamily: 'var(--font-cinzel, serif)',\n109\t  letterSpacing: '0.2em',\n110\t  textTransform: 'uppercase',\n111\t  color,\n112\t  marginBottom: 12,\n113\t  display: 'block',\n114\t});\n115\t\n116\tconst headlineStyle: React.CSSProperties = {\n117\t  fontSize: '1.15rem',\n118\t  fontFamily: 'var(--font-cinzel, serif)',\n119\t  color: C.txtPri,\n120\t  marginBottom: 10,\n121\t  lineHeight: 1.4,\n122\t};\n123\t\n124\tconst bodyStyle: React.CSSProperties = {\n125\t  color: C.txtSec,\n126\t  fontSize: '0.9rem',\n127\t  lineHeight: 1.75,\n128\t};\n129\t\n130\tconst badgeStyle = (color: string): React.CSSProperties => ({\n131\t  display: 'inline-block',\n132\t  background: `${color}1A`,\n133\t  border: `1px solid ${color}55`,\n134\t  borderRadius: 20,\n135\t  padding: '3px 12px',\n136\t  fontSize: '0.72rem',\n137\t  letterSpacing: '0.08em',\n138\t  color,\n139\t  marginRight: 8,\n140\t  marginBottom: 8,\n141\t});\n142\t\n143\tconst dividerStyle: React.CSSProperties = {\n144\t  borderTop: `1px solid ${C.bgNeb}`,\n145\t  margin: '16px 0',\n146\t};\n147\t\n148\tconst btnStyle: React.CSSProperties = {\n149\t  display: 'block',\n150\t  width: '100%',\n151\t  textAlign: 'center',\n152\t  padding: '14px 0',\n153\t  borderRadius: 12,\n154\t  background: `linear-gradient(135deg, ${C.violeta}22 0%, ${C.aurora}14 100%)`,\n155\t  border: `1px solid ${C.violeta}55`,\n156\t  color: C.violeta,\n157\t  fontSize: '0.88rem',\n158\t  letterSpacing: '0.07em',\n159\t  fontFamily: 'var(--font-cinzel, serif)',\n160\t  textDecoration: 'none',\n161\t  cursor: 'pointer',\n162\t  marginTop: 8,\n163\t};\n164\t\n165\tconst screenNumStyle: React.CSSProperties = {\n166\t  fontSize: '0.6rem',\n167\t  color: C.txtMut,\n168\t  letterSpacing: '0.15em',\n169\t  textTransform: 'uppercase',\n170\t  marginBottom: 24,\n171\t};\n172\t\n173\tconst fonteStyle: React.CSSProperties = {\n174\t  marginTop: 14,\n175\t  paddingTop: 12,\n176\t  borderTop: `1px solid ${C.bgNeb}`,\n177\t  fontSize: '0.72rem',\n178\t  color: C.txtMut,\n179\t  lineHeight: 1.5,\n180\t};\n181\t\n182\tconst stubBadge: React.CSSProperties = {\n183\t  display: 'inline-block',\n184\t  marginLeft: 8,\n185\t  fontSize: '0.55rem',\n186\t  letterSpacing: '0.1em',\n187\t  padding: '2px 6px',\n188\t  borderRadius: 4,\n189\t  background: 'rgba(92,102,145,0.18)',\n190\t  border: '1px solid rgba(92,102,145,0.4)',\n191\t  color: C.txtMut,\n192\t  textTransform: 'uppercase',\n193\t};\n194\t\n195\t// ── Helpers ──────────────────────────────────────────────────────────────────\n196\t\n197\tfunction formatDate(iso: string): string {\n198\t  try {\n199\t    return new Date(iso + 'T12:00:00').toLocaleDateString('pt-BR', {\n200\t      weekday: 'long',\n201\t      day: 'numeric',\n202\t      month: 'long',\n203\t    });\n204\t  } catch {\n205\t    return iso;\n206\t  }\n207\t}\n208\t\n209\t/**\n210\t * Extrai 3 frases (heurística) da `redacao_bruta` para o Mandato.\n211\t * VISION §4 promete 3 frases; enquanto o LLM não redige (F-204),\n212\t * partimos no último ponto antes do parêntese de stub.\n213\t */\n214\tfunction extractFrases(redacao: string): string[] {\n215\t  const cleaned = redacao.replace(/\\s*\\(LLM redige.*?\\)\\.?\\s*$/i, '').trim();\n216\t  // Quebra em pontos finais que não sejam abreviação (sigla única).\n217\t  const raw = cleaned\n218\t    .split(/(?<=[.!?])\\s+(?=[A-ZÁÉÍÓÚÂÊÔÃÕÇ])/g)\n219\t    .map((s) => s.trim())\n220\t    .filter((s) => s.length > 0);\n221\t  if (raw.length >= 3) return raw.slice(0, 3);\n222\t  // Fallback: 1 frase só.\n223\t  return raw.length > 0 ? [cleaned] : ['(Mandato vazio — tente novamente em alguns instantes)'];\n224\t}\n225\t\n226\t/**\n227\t * Pergunta padrão derivada do Pilar principal.\n228\t * Quando o LLM (F-204) fornecer pergunta própria, esta vira fallback.\n229\t */\n230\tfunction perguntaPorPilar(pilarPrincipal: string): string {\n231\t  const mapa: Record<string, string> = {\n232\t    cabala: 'Qual decisão de vida o seu número-base está iluminando hoje?',\n233\t    astrologia: 'O que o céu de hoje está pedindo que você ouça em silêncio?',\n234\t    tantrica: 'Qual corpo sutil está pedindo atenção e cuidado agora?',\n235\t    odu: 'O que o seu Odu de nascimento está ensinando neste dia?',\n236\t    iching: 'Que mutação o seu hexagrama está convidando a atravessar?',\n237\t  };\n238\t  return mapa[pilarPrincipal] ?? 'O que seu Ori te pede para olhar com mais gentileza hoje?';\n239\t}\n240\t\n241\t/**\n242\t * Micro-ritual padrão (3 min) derivado do Pilar principal.\n243\t * F-204 substituirá por redação LLM com base em `pilares_relevantes` + escala.\n244\t */\n245\tfunction ritualPorPilar(pilarPrincipal: string): { titulo: string; instrucao: string } {\n246\t  const mapa: Record<string, { titulo: string; instrucao: string }> = {\n247\t    cabala: {\n248\t      titulo: 'Conta-Cantiga',\n249\t      instrucao:\n250\t        'Some os números do seu dia de nascimento e medite 3 minutos sobre o que esse número quer dizer na sua jornada.',\n251\t    },\n252\t    astrologia: {\n253\t      titulo: 'Respiração do Céu',\n254\t      instrucao:\n255\t        'Respire 4-4-4-4 olhando o horizonte. Deixe a Lua e o signo do dia embalarem o silêncio.',\n256\t    },\n257\t    tantrica: {\n258\t      titulo: 'Varredura dos 11',\n259\t      instrucao:\n260\t        'Passe 11 respirações por cada corpo sutil (alma → mente → corpo → aura). Anote o que pulsou.',\n261\t    },\n262\t    odu: {\n263\t      titulo: 'Oração ao Ori',\n264\t      instrucao:\n265\t        'Sente-se em terreiro (real ou mental). Agradeça ao seu Odu e peça uma orientação simples para o dia.',\n266\t    },\n267\t    iching: {\n268\t      titulo: 'Mutação em 3 Linhas',\n269\t      instrucao: 'Abra o hexagrama do dia. Leia as 3 linhas mutáveis. Escreva 1 palavra para cada.',\n270\t    },\n271\t  };\n272\t  return (\n273\t    mapa[pilarPrincipal] ?? {\n274\t      titulo: 'Silêncio de 3 min',\n275\t      instrucao: 'Sente-se, respire e anote o primeiro pensamento que surgir.',\n276\t    }\n277\t  );\n278\t}\n279\t\n280\t// ── Página ───────────────────────────────────────────────────────────────────\n281\t\n282\texport default async function DiarioPage({\n283\t  params,\n284\t  searchParams,\n285\t}: {\n286\t  params: Promise<{ locale: string }>;\n287\t  searchParams: Promise<{ intencao?: string }>;\n288\t}) {\n289\t  const { locale } = await params;\n290\t  const { intencao } = await searchParams;\n291\t  const cookieStore = await cookies();\n292\t  const token = cookieStore.get('akasha_session')?.value;\n293\t\n294\t  if (!token) redirect(`/${locale}/onboarding`);\n295\t\n296\t  const qs = intencao?.trim() ? `?intencao=${encodeURIComponent(intencao.trim())}` : '';\n297\t\n298\t  const res = await fetch(\n299\t    `${process.env.NEXT_PUBLIC_APP_URL ?? 'http://localhost:3000'}/api/akasha/mandato-do-dia${qs}`,\n300\t    {\n301\t      method: 'GET',\n302\t      headers: { Cookie: `akasha_session=${token}` },\n303\t      cache: 'no-store',\n304\t    }\n305\t  );\n306\t\n307\t  if (res.status === 401 || res.status === 404) redirect(`/${locale}/onboarding`);\n308\t  if (!res.ok) {\n309\t    return (\n310\t      <div style={{ ...wrapStyle, padding: '48px 20px' }}>\n311\t        <div style={innerStyle}>\n312\t          <div style={cardStyle(C.magenta)}>\n313\t            <span style={labelStyle(C.magenta)}>Mandato indisponível</span>\n314\t            <p style={bodyStyle}>\n315\t              Não conseguimos calcular o Mandato de hoje ({res.status}). Tente novamente em alguns\n316\t              instantes. Se o problema persistir, conclua o onboarding ou atualize seus dados\n317\t              natais.\n318\t            </p>\n319\t          </div>\n320\t        </div>\n321\t      </div>\n322\t    );\n323\t  }\n324\t\n325\t  const payload: MandatoDoDiaResponse = await res.json();\n326\t  const { date, mandato, mentor_hook } = payload;\n327\t  const pilarPrincipal = mandato.pilares_relevantes[0] ?? 'cabala';\n328\t  const pilarInfo = PILLAR_LABELS[pilarPrincipal] ?? { nome: pilarPrincipal, cor: C.txtMut };\n329\t  const crise = mentor_hook.crise_detectada;\n330\t  const frases = crise ? [] : extractFrases(mandato.redacao_bruta);\n331\t  const pergunta = perguntaPorPilar(pilarPrincipal);\n332\t  const ritual = ritualPorPilar(pilarPrincipal);\n333\t\n334\t  return (\n335\t    <div style={wrapStyle}>\n336\t      {/* ── Tela 1: O Mandato (3 frases) ─────────────────────────────────── */}\n337\t      <div style={screenStyle}>\n338\t        <div style={innerStyle}>\n339\t          <div style={screenNumStyle}>01 / 03 — Mandato</div>\n340\t\n341\t          {/* Cabeçalho: data + escala + intenção */}\n342\t          <div style={cardStyle(pilarInfo.cor)}>\n343\t            <span style={labelStyle(pilarInfo.cor)}>\n344\t              Mandato · Escala {mandato.escala} ({ESCALA_LABELS[mandato.escala]})\n345\t            </span>\n346\t            <p style={{ ...headlineStyle, color: pilarInfo.cor }}>{formatDate(date)}</p>\n347\t            <div style={{ marginTop: 10, fontSize: '0.78rem', color: C.txtMut }}>\n348\t              Intenção: <em style={{ color: C.txtSec }}>{mentor_hook.intencao}</em>\n349\t            </div>\n350\t          </div>\n351\t\n352\t          {/* Saudação do Akasha — 3 frases */}\n353\t          {crise ? (\n354\t            // Ethics Charter §5: suprimir `redacao_bruta` em crise; renderizar CVV-188.\n355\t            <div style={cardStyle(C.magenta)}>\n356\t              <span style={labelStyle(C.magenta)}>Recurso humano · CVV 188</span>\n357\t              <h2 style={{ ...headlineStyle, color: C.magenta }}>Você não está sozinho(a).</h2>\n358\t              <p style={bodyStyle}>\n359\t                O Mentor Akasha reconhece sinais de sofrimento emocional na sua intenção e, por\n360\t                design ético, se afasta. Fale agora com alguém treinado para ouvir, gratuitamente e\n361\t                24h:\n362\t              </p>\n363\t              <div\n364\t                style={{\n365\t                  marginTop: 16,\n366\t                  padding: 16,\n367\t                  borderRadius: 10,\n368\t                  background: 'rgba(251,87,129,0.08)',\n369\t                  border: '1px solid rgba(251,87,129,0.4)',\n370\t                }}\n371\t              >\n372\t                <p style={{ ...bodyStyle, color: C.txtPri, fontWeight: 600, marginBottom: 4 }}>\n373\t                  CVV — Centro de Valorização da Vida\n374\t                </p>\n375\t                <p\n376\t                  style={{\n377\t                    ...bodyStyle,\n378\t                    fontSize: '1.4rem',\n379\t                    fontFamily: 'var(--font-cinzel, serif)',\n380\t                    color: C.magenta,\n381\t                    letterSpacing: '0.08em',\n382\t                  }}\n383\t                >\n384\t                  ligue 188\n385\t                </p>\n386\t                <p style={{ ...bodyStyle, fontSize: '0.78rem', color: C.txtMut, marginTop: 6 }}>\n387\t                  chat também:{' '}\n388\t                  <a\n389\t                    href=\"https://cvv.org.br\"\n390\t                    target=\"_blank\"\n391\t                    rel=\"noopener\"\n392\t                    style={{ color: C.magenta }}\n393\t                  >\n394\t                    cvv.org.br\n395\t                  </a>\n396\t                </p>\n397\t              </div>\n398\t            </div>\n399\t          ) : (\n400\t            <div style={cardStyle(pilarInfo.cor)}>\n401\t              <span style={labelStyle(pilarInfo.cor)}>\n402\t                A Voz do Akasha <span style={stubBadge}>via {pilarInfo.nome}</span>\n403\t              </span>\n404\t              {frases.map((f, i) => (\n405\t                <p\n406\t                  key={i}\n407\t                  style={{\n408\t                    ...bodyStyle,\n409\t                    color: C.txtPri,\n410\t                    marginBottom: i < frases.length - 1 ? 14 : 0,\n411\t                  }}\n412\t                >\n413\t                  {f}\n414\t                </p>\n415\t              ))}\n416\t\n417\t              {/* Pilares relevantes como badges coloridos */}\n418\t              {mandato.pilares_relevantes.length > 0 && (\n419\t                <div style={{ marginTop: 16 }}>\n420\t                  {mandato.pilares_relevantes.map((p) => {\n421\t                    const info = PILLAR_LABELS[p];\n422\t                    return (\n423\t                      <span key={p} style={badgeStyle(info?.cor ?? C.txtMut)}>\n424\t                        {info?.nome ?? p}\n425\t                      </span>\n426\t                    );\n427\t                  })}\n428\t                </div>\n429\t              )}\n430\t\n431\t              {/* Fontes citadas — proveniência obrigatória (Ethics §1) */}\n432\t              {mandato.cita_fontes.length > 0 && (\n433\t                <div style={fonteStyle}>\n434\t                  <span style={{ ...labelStyle(C.txtMut), marginBottom: 6 }}>Citações</span>\n435\t                  {mandato.cita_fontes.map((c, i) => (\n436\t                    <div key={i}>· {c}</div>\n437\t                  ))}\n438\t                </div>\n439\t              )}\n440\t            </div>\n441\t          )}\n442\t\n443\t          <div style={{ textAlign: 'center', marginTop: 24, color: C.txtMut, fontSize: '0.7rem' }}>\n444\t            role para baixo ↓\n445\t          </div>\n446\t        </div>\n447\t      </div>\n448\t\n449\t      {/* ── Tela 2: A Pergunta do Dia ─────────────────────────────────────── */}\n450\t      <div style={screenStyle}>\n451\t        <div style={innerStyle}>\n452\t          <div style={screenNumStyle}>02 / 03 — Pergunta</div>\n453\t\n454\t          <div style={cardStyle(C.violeta)}>\n455\t            <span style={labelStyle(C.violeta)}>\n456\t              A Pergunta do Dia <span style={stubBadge}>template (F-204: LLM)</span>\n457\t            </span>\n458\t            <h2 style={{ ...headlineStyle, color: C.violeta, fontSize: '1.35rem' }}>{pergunta}</h2>\n459\t\n460\t            <div style={dividerStyle} />\n461\t\n462\t            <span style={labelStyle(C.txtMut)}>Por que esta pergunta?</span>\n463\t            <p style={bodyStyle}>\n464\t              A pergunta de hoje é ancorada em{' '}\n465\t              <strong style={{ color: pilarInfo.cor }}>{pilarInfo.nome}</strong>, o pilar principal\n466\t              da escala {mandato.escala}. A intenção de uma boa pergunta é abrir espaço de escuta —\n467\t              não de resposta apressada. Reserve 1 minuto para deixar a resposta emergir.\n468\t            </p>\n469\t          </div>\n470\t\n471\t          <div style={{ textAlign: 'center', marginTop: 24, color: C.txtMut, fontSize: '0.7rem' }}>\n472\t            role para baixo ↓\n473\t          </div>\n474\t        </div>\n475\t      </div>\n476\t\n477\t      {/* ── Tela 3: O Micro-Ritual ────────────────────────────────────────── */}\n478\t      <div style={screenStyle}>\n479\t        <div style={innerStyle}>\n480\t          <div style={screenNumStyle}>03 / 03 — Ritual</div>\n481\t\n482\t          <div style={cardStyle(C.aurora)}>\n483\t            <span style={labelStyle(C.aurora)}>\n484\t              O Micro-Ritual <span style={stubBadge}>template (F-204: LLM)</span>\n485\t            </span>\n486\t            <h2 style={{ ...headlineStyle, color: C.aurora }}>{ritual.titulo}</h2>\n487\t            <p style={bodyStyle}>{ritual.instrucao}</p>\n488\t\n489\t            <div style={{ marginTop: 14 }}>\n490\t              <span style={badgeStyle(pilarInfo.cor)}>via {pilarInfo.nome}</span>\n491\t              <span style={badgeStyle(C.aurora)}>~ 3 min</span>\n492\t            </div>\n493\t          </div>\n494\t\n495\t          {/* Link para o Oráculo (pode aprofundar no Mentor) */}\n496\t          <Link href={`/${locale}/oraculo`} style={btnStyle}>\n497\t            Consultar Oráculo →\n498\t          </Link>\n499\t        </div>\n500\t      </div>\n501\t    </div>\n502\t  );\n503\t}\n504\t"}]},"parent_tool_use_id":null,"session_id":"44a294c9-7ecf-4f85-9b61-8e5a12793e2c","uuid":"407da417-725b-4acd-87df-7ce82935948c","timestamp":"2026-06-11T11:38:17.790Z","tool_use_result":{"type":"text","file":{"filePath":"/home/skynet/cabala-dos-caminhos/apps/akasha-portal/src/app/[locale]/(akasha)/diario/page.tsx","content":"/**\n * Diário Energético — F-202 (Fase 6).\n *\n * Consome `GET /api/akasha/mandato-do-dia` (F-201) e renderiza o\n * Mandato do Dia em 3 telas (Mandato · Pergunta · Micro-Ritual).\n *\n * Referências:\n *   - VISION §4 — \"Mandato = 1 push/dia 06h, 3 frases + 1 pergunta + 1 micro-ritual\"\n *   - synthesis_v1.md §5 — Mandato spec\n *   - ethics_charter_v1.md §5 — Pilar 3 LGPD/crise: `mentor_hook.crise_detectada`\n *     faz o cliente renderizar CVV-188 e suprimir `redacao_bruta`.\n *\n * F-204 (P2) substitui os stubs do `akasha-core` por `loadEngines()` real +\n * redação LLM; o que o F-202 já trata como \"esqueleto\" será preenchido\n * sem mudanças de UI.\n */\nimport { cookies } from 'next/headers';\nimport Link from 'next/link';\nimport { redirect } from 'next/navigation';\n\ntype MandatoEsqueleto = {\n  escala: 'D' | 'S' | 'Z' | 'V';\n  pilares_relevantes: string[];\n  redacao_bruta: string;\n  cita_fontes: string[];\n};\n\ntype MentorHook = {\n  intencao: string;\n  crise_detectada: boolean;\n  recurso: string | null;\n};\n\ntype MandatoDoDiaResponse = {\n  date: string;\n  mandato: MandatoEsqueleto;\n  mentor_hook: MentorHook;\n};\n\n// ── Paleta Akasha (alinhada com MandalaChart.tsx) ────────────────────────────\nconst C = {\n  violeta: '#7C5CFF',\n  aurora: '#2DD4BF',\n  dourado: '#F0B429',\n  magenta: '#FB5781',\n  bgVoid: '#06070F',\n  bgDeep: '#0B0E1C',\n  bgNeb: '#141A33',\n  txtPri: '#F4F5FF',\n  txtSec: '#A7AECF',\n  txtMut: '#5C6691',\n} as const;\n\n// ── Pilares (canônicos VISION §2 — ordem P1..P5) ─────────────────────────────\nconst PILLAR_LABELS: Record<string, { nome: string; cor: string }> = {\n  cabala: { nome: 'Numerologia Cabalística', cor: C.violeta },\n  astrologia: { nome: 'Astrologia', cor: C.aurora },\n  tantrica: { nome: 'Numerologia Tântrica', cor: C.dourado },\n  odu: { nome: 'Odu de Nascimento', cor: C.magenta },\n  iching: { nome: 'I Ching', cor: '#A0763A' },\n};\n\nconst ESCALA_LABELS: Record<MandatoEsqueleto['escala'], string> = {\n  D: 'Diário',\n  S: 'Semanal',\n  Z: 'Sazonal',\n  V: 'Vida',\n};\n\n// ── Estilos (mesma linguagem do MandalaChart.tsx) ───────────────────────────\n\nconst wrapStyle: React.CSSProperties = {\n  background: C.bgVoid,\n  minHeight: '100dvh',\n  overflowY: 'scroll',\n  scrollSnapType: 'y mandatory',\n  WebkitOverflowScrolling: 'touch',\n};\n\nconst screenStyle: React.CSSProperties = {\n  scrollSnapAlign: 'start',\n  minHeight: '100dvh',\n  display: 'flex',\n  flexDirection: 'column',\n  justifyContent: 'center',\n  padding: '48px 20px 64px',\n};\n\nconst innerStyle: React.CSSProperties = {\n  maxWidth: 560,\n  margin: '0 auto',\n  width: '100%',\n};\n\nconst cardStyle = (borderColor: string): React.CSSProperties => ({\n  background: 'rgba(11,14,28,0.72)',\n  backdropFilter: 'blur(12px)',\n  WebkitBackdropFilter: 'blur(12px)',\n  border: `1px solid ${borderColor}44`,\n  borderLeft: `3px solid ${borderColor}`,\n  borderRadius: 14,\n  padding: '24px 24px 20px',\n  marginBottom: 16,\n});\n\nconst labelStyle = (color: string): React.CSSProperties => ({\n  fontSize: '0.62rem',\n  fontFamily: 'var(--font-cinzel, serif)',\n  letterSpacing: '0.2em',\n  textTransform: 'uppercase',\n  color,\n  marginBottom: 12,\n  display: 'block',\n});\n\nconst headlineStyle: React.CSSProperties = {\n  fontSize: '1.15rem',\n  fontFamily: 'var(--font-cinzel, serif)',\n  color: C.txtPri,\n  marginBottom: 10,\n  lineHeight: 1.4,\n};\n\nconst bodyStyle: React.CSSProperties = {\n  color: C.txtSec,\n  fontSize: '0.9rem',\n  lineHeight: 1.75,\n};\n\nconst badgeStyle = (color: string): React.CSSProperties => ({\n  display: 'inline-block',\n  background: `${color}1A`,\n  border: `1px solid ${color}55`,\n  borderRadius: 20,\n  padding: '3px 12px',\n  fontSize: '0.72rem',\n  letterSpacing: '0.08em',\n  color,\n  marginRight: 8,\n  marginBottom: 8,\n});\n\nconst dividerStyle: React.CSSProperties = {\n  borderTop: `1px solid ${C.bgNeb}`,\n  margin: '16px 0',\n};\n\nconst btnStyle: React.CSSProperties = {\n  display: 'block',\n  width: '100%',\n  textAlign: 'center',\n  padding: '14px 0',\n  borderRadius: 12,\n  background: `linear-gradient(135deg, ${C.violeta}22 0%, ${C.aurora}14 100%)`,\n  border: `1px solid ${C.violeta}55`,\n  color: C.violeta,\n  fontSize: '0.88rem',\n  letterSpacing: '0.07em',\n  fontFamily: 'var(--font-cinzel, serif)',\n  textDecoration: 'none',\n  cursor: 'pointer',\n  marginTop: 8,\n};\n\nconst screenNumStyle: React.CSSProperties = {\n  fontSize: '0.6rem',\n  color: C.txtMut,\n  letterSpacing: '0.15em',\n  textTransform: 'uppercase',\n  marginBottom: 24,\n};\n\nconst fonteStyle: React.CSSProperties = {\n  marginTop: 14,\n  paddingTop: 12,\n  borderTop: `1px solid ${C.bgNeb}`,\n  fontSize: '0.72rem',\n  color: C.txtMut,\n  lineHeight: 1.5,\n};\n\nconst stubBadge: React.CSSProperties = {\n  display: 'inline-block',\n  marginLeft: 8,\n  fontSize: '0.55rem',\n  letterSpacing: '0.1em',\n  padding: '2px 6px',\n  borderRadius: 4,\n  background: 'rgba(92,102,145,0.18)',\n  border: '1px solid rgba(92,102,145,0.4)',\n  color: C.txtMut,\n  textTransform: 'uppercase',\n};\n\n// ── Helpers ──────────────────────────────────────────────────────────────────\n\nfunction formatDate(iso: string): string {\n  try {\n    return new Date(iso + 'T12:00:00').toLocaleDateString('pt-BR', {\n      weekday: 'long',\n      day: 'numeric',\n      month: 'long',\n    });\n  } catch {\n    return iso;\n  }\n}\n\n/**\n * Extrai 3 frases (heurística) da `redacao_bruta` para o Mandato.\n * VISION §4 promete 3 frases; enquanto o LLM não redige (F-204),\n * partimos no último ponto antes do parêntese de stub.\n */\nfunction extractFrases(redacao: string): string[] {\n  const cleaned = redacao.replace(/\\s*\\(LLM redige.*?\\)\\.?\\s*$/i, '').trim();\n  // Quebra em pontos finais que não sejam abreviação (sigla única).\n  const raw = cleaned\n    .split(/(?<=[.!?])\\s+(?=[A-ZÁÉÍÓÚÂÊÔÃÕÇ])/g)\n    .map((s) => s.trim())\n    .filter((s) => s.length > 0);\n  if (raw.length >= 3) return raw.slice(0, 3);\n  // Fallback: 1 frase só.\n  return raw.length > 0 ? [cleaned] : ['(Mandato vazio — tente novamente em alguns instantes)'];\n}\n\n/**\n * Pergunta padrão derivada do Pilar principal.\n * Quando o LLM (F-204) fornecer pergunta própria, esta vira fallback.\n */\nfunction perguntaPorPilar(pilarPrincipal: string): string {\n  const mapa: Record<string, string> = {\n    cabala: 'Qual decisão de vida o seu número-base está iluminando hoje?',\n    astrologia: 'O que o céu de hoje está pedindo que você ouça em silêncio?',\n    tantrica: 'Qual corpo sutil está pedindo atenção e cuidado agora?',\n    odu: 'O que o seu Odu de nascimento está ensinando neste dia?',\n    iching: 'Que mutação o seu hexagrama está convidando a atravessar?',\n  };\n  return mapa[pilarPrincipal] ?? 'O que seu Ori te pede para olhar com mais gentileza hoje?';\n}\n\n/**\n * Micro-ritual padrão (3 min) derivado do Pilar principal.\n * F-204 substituirá por redação LLM com base em `pilares_relevantes` + escala.\n */\nfunction ritualPorPilar(pilarPrincipal: string): { titulo: string; instrucao: string } {\n  const mapa: Record<string, { titulo: string; instrucao: string }> = {\n    cabala: {\n      titulo: 'Conta-Cantiga',\n      instrucao:\n        'Some os números do seu dia de nascimento e medite 3 minutos sobre o que esse número quer dizer na sua jornada.',\n    },\n    astrologia: {\n      titulo: 'Respiração do Céu',\n      instrucao:\n        'Respire 4-4-4-4 olhando o horizonte. Deixe a Lua e o signo do dia embalarem o silêncio.',\n    },\n    tantrica: {\n      titulo: 'Varredura dos 11',\n      instrucao:\n        'Passe 11 respirações por cada corpo sutil (alma → mente → corpo → aura). Anote o que pulsou.',\n    },\n    odu: {\n      titulo: 'Oração ao Ori',\n      instrucao:\n        'Sente-se em terreiro (real ou mental). Agradeça ao seu Odu e peça uma orientação simples para o dia.',\n    },\n    iching: {\n      titulo: 'Mutação em 3 Linhas',\n      instrucao: 'Abra o hexagrama do dia. Leia as 3 linhas mutáveis. Escreva 1 palavra para cada.',\n    },\n  };\n  return (\n    mapa[pilarPrincipal] ?? {\n      titulo: 'Silêncio de 3 min',\n      instrucao: 'Sente-se, respire e anote o primeiro pensamento que surgir.',\n    }\n  );\n}\n\n// ── Página ───────────────────────────────────────────────────────────────────\n\nexport default async function DiarioPage({\n  params,\n  searchParams,\n}: {\n  params: Promise<{ locale: string }>;\n  searchParams: Promise<{ intencao?: string }>;\n}) {\n  const { locale } = await params;\n  const { intencao } = await searchParams;\n  const cookieStore = await cookies();\n  const token = cookieStore.get('akasha_session')?.value;\n\n  if (!token) redirect(`/${locale}/onboarding`);\n\n  const qs = intencao?.trim() ? `?intencao=${encodeURIComponent(intencao.trim())}` : '';\n\n  const res = await fetch(\n    `${process.env.NEXT_PUBLIC_APP_URL ?? 'http://localhost:3000'}/api/akasha/mandato-do-dia${qs}`,\n    {\n      method: 'GET',\n      headers: { Cookie: `akasha_session=${token}` },\n      cache: 'no-store',\n    }\n  );\n\n  if (res.status === 401 || res.status === 404) redirect(`/${locale}/onboarding`);\n  if (!res.ok) {\n    return (\n      <div style={{ ...wrapStyle, padding: '48px 20px' }}>\n        <div style={innerStyle}>\n          <div style={cardStyle(C.magenta)}>\n            <span style={labelStyle(C.magenta)}>Mandato indisponível</span>\n            <p style={bodyStyle}>\n              Não conseguimos calcular o Mandato de hoje ({res.status}). Tente novamente em alguns\n              instantes. Se o problema persistir, conclua o onboarding ou atualize seus dados\n              natais.\n            </p>\n          </div>\n        </div>\n      </div>\n    );\n  }\n\n  const payload: MandatoDoDiaResponse = await res.json();\n  const { date, mandato, mentor_hook } = payload;\n  const pilarPrincipal = mandato.pilares_relevantes[0] ?? 'cabala';\n  const pilarInfo = PILLAR_LABELS[pilarPrincipal] ?? { nome: pilarPrincipal, cor: C.txtMut };\n  const crise = mentor_hook.crise_detectada;\n  const frases = crise ? [] : extractFrases(mandato.redacao_bruta);\n  const pergunta = perguntaPorPilar(pilarPrincipal);\n  const ritual = ritualPorPilar(pilarPrincipal);\n\n  return (\n    <div style={wrapStyle}>\n      {/* ── Tela 1: O Mandato (3 frases) ─────────────────────────────────── */}\n      <div style={screenStyle}>\n        <div style={innerStyle}>\n          <div style={screenNumStyle}>01 / 03 — Mandato</div>\n\n          {/* Cabeçalho: data + escala + intenção */}\n          <div style={cardStyle(pilarInfo.cor)}>\n            <span style={labelStyle(pilarInfo.cor)}>\n              Mandato · Escala {mandato.escala} ({ESCALA_LABELS[mandato.escala]})\n            </span>\n            <p style={{ ...headlineStyle, color: pilarInfo.cor }}>{formatDate(date)}</p>\n            <div style={{ marginTop: 10, fontSize: '0.78rem', color: C.txtMut }}>\n              Intenção: <em style={{ color: C.txtSec }}>{mentor_hook.intencao}</em>\n            </div>\n          </div>\n\n          {/* Saudação do Akasha — 3 frases */}\n          {crise ? (\n            // Ethics Charter §5: suprimir `redacao_bruta` em crise; renderizar CVV-188.\n            <div style={cardStyle(C.magenta)}>\n              <span style={labelStyle(C.magenta)}>Recurso humano · CVV 188</span>\n              <h2 style={{ ...headlineStyle, color: C.magenta }}>Você não está sozinho(a).</h2>\n              <p style={bodyStyle}>\n                O Mentor Akasha reconhece sinais de sofrimento emocional na sua intenção e, por\n                design ético, se afasta. Fale agora com alguém treinado para ouvir, gratuitamente e\n                24h:\n              </p>\n              <div\n                style={{\n                  marginTop: 16,\n                  padding: 16,\n                  borderRadius: 10,\n                  background: 'rgba(251,87,129,0.08)',\n                  border: '1px solid rgba(251,87,129,0.4)',\n                }}\n              >\n                <p style={{ ...bodyStyle, color: C.txtPri, fontWeight: 600, marginBottom: 4 }}>\n                  CVV — Centro de Valorização da Vida\n                </p>\n                <p\n                  style={{\n                    ...bodyStyle,\n                    fontSize: '1.4rem',\n                    fontFamily: 'var(--font-cinzel, serif)',\n                    color: C.magenta,\n                    letterSpacing: '0.08em',\n                  }}\n                >\n                  ligue 188\n                </p>\n                <p style={{ ...bodyStyle, fontSize: '0.78rem', color: C.txtMut, marginTop: 6 }}>\n                  chat também:{' '}\n                  <a\n                    href=\"https://cvv.org.br\"\n                    target=\"_blank\"\n                    rel=\"noopener\"\n                    style={{ color: C.magenta }}\n                  >\n                    cvv.org.br\n                  </a>\n                </p>\n              </div>\n            </div>\n          ) : (\n            <div style={cardStyle(pilarInfo.cor)}>\n              <span style={labelStyle(pilarInfo.cor)}>\n                A Voz do Akasha <span style={stubBadge}>via {pilarInfo.nome}</span>\n              </span>\n              {frases.map((f, i) => (\n                <p\n                  key={i}\n                  style={{\n                    ...bodyStyle,\n                    color: C.txtPri,\n                    marginBottom: i < frases.length - 1 ? 14 : 0,\n                  }}\n                >\n                  {f}\n                </p>\n              ))}\n\n              {/* Pilares relevantes como badges coloridos */}\n              {mandato.pilares_relevantes.length > 0 && (\n                <div style={{ marginTop: 16 }}>\n                  {mandato.pilares_relevantes.map((p) => {\n                    const info = PILLAR_LABELS[p];\n                    return (\n                      <span key={p} style={badgeStyle(info?.cor ?? C.txtMut)}>\n                        {info?.nome ?? p}\n                      </span>\n                    );\n                  })}\n                </div>\n              )}\n\n              {/* Fontes citadas — proveniência obrigatória (Ethics §1) */}\n              {mandato.cita_fontes.length > 0 && (\n                <div style={fonteStyle}>\n                  <span style={{ ...labelStyle(C.txtMut), marginBottom: 6 }}>Citações</span>\n                  {mandato.cita_fontes.map((c, i) => (\n                    <div key={i}>· {c}</div>\n                  ))}\n                </div>\n              )}\n            </div>\n          )}\n\n          <div style={{ textAlign: 'center', marginTop: 24, color: C.txtMut, fontSize: '0.7rem' }}>\n            role para baixo ↓\n          </div>\n        </div>\n      </div>\n\n      {/* ── Tela 2: A Pergunta do Dia ─────────────────────────────────────── */}\n      <div style={screenStyle}>\n        <div style={innerStyle}>\n          <div style={screenNumStyle}>02 / 03 — Pergunta</div>\n\n          <div style={cardStyle(C.violeta)}>\n            <span style={labelStyle(C.violeta)}>\n              A Pergunta do Dia <span style={stubBadge}>template (F-204: LLM)</span>\n            </span>\n            <h2 style={{ ...headlineStyle, color: C.violeta, fontSize: '1.35rem' }}>{pergunta}</h2>\n\n            <div style={dividerStyle} />\n\n            <span style={labelStyle(C.txtMut)}>Por que esta pergunta?</span>\n            <p style={bodyStyle}>\n              A pergunta de hoje é ancorada em{' '}\n              <strong style={{ color: pilarInfo.cor }}>{pilarInfo.nome}</strong>, o pilar principal\n              da escala {mandato.escala}. A intenção de uma boa pergunta é abrir espaço de escuta —\n              não de resposta apressada. Reserve 1 minuto para deixar a resposta emergir.\n            </p>\n          </div>\n\n          <div style={{ textAlign: 'center', marginTop: 24, color: C.txtMut, fontSize: '0.7rem' }}>\n            role para baixo ↓\n          </div>\n        </div>\n      </div>\n\n      {/* ── Tela 3: O Micro-Ritual ────────────────────────────────────────── */}\n      <div style={screenStyle}>\n        <div style={innerStyle}>\n          <div style={screenNumStyle}>03 / 03 — Ritual</div>\n\n          <div style={cardStyle(C.aurora)}>\n            <span style={labelStyle(C.aurora)}>\n              O Micro-Ritual <span style={stubBadge}>template (F-204: LLM)</span>\n            </span>\n            <h2 style={{ ...headlineStyle, color: C.aurora }}>{ritual.titulo}</h2>\n            <p style={bodyStyle}>{ritual.instrucao}</p>\n\n            <div style={{ marginTop: 14 }}>\n              <span style={badgeStyle(pilarInfo.cor)}>via {pilarInfo.nome}</span>\n              <span style={badgeStyle(C.aurora)}>~ 3 min</span>\n            </div>\n          </div>\n\n          {/* Link para o Oráculo (pode aprofundar no Mentor) */}\n          <Link href={`/${locale}/oraculo`} style={btnStyle}>\n            Consultar Oráculo →\n          </Link>\n        </div>\n      </div>\n    </div>\n  );\n}\n","numLines":504,"startLine":1,"totalLines":504}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_0gpk2rona48b_2","type":"tool_result","content":"1\t'use client';\n2\t\n3\timport { useEffect, useState } from 'react';\n4\timport { useParams, useRouter } from 'next/navigation';\n5\t\n6\ttype ManifestoContent = {\n7\t  userName: string;\n8\t  generatedAt: string;\n9\t  synthesis: string;\n10\t  odus: {\n11\t    oduName: string;\n12\t    oduNumber: number | null;\n13\t    orixas: string[];\n14\t    elementalForce: string | null;\n15\t    description: string;\n16\t    preceitos?: string[];\n17\t    provisional: boolean;\n18\t  };\n19\t  kabala: {\n20\t    lifePath: number | null;\n21\t    lifePathMaster: boolean;\n22\t    expression: number | null;\n23\t    motivation: number | null;\n24\t    personalYear: number | null;\n25\t    description: string;\n26\t  };\n27\t  tantra: {\n28\t    soul: number | null;\n29\t    karma: number | null;\n30\t    divineGift: number | null;\n31\t    tantricPath: number | null;\n32\t    description: string;\n33\t  };\n34\t  astrology: {\n35\t    ascendant: string | null;\n36\t    dominantPlanet: string | null;\n37\t    mainPlanets: Array<{ name: string; sign: string }>;\n38\t    description: string;\n39\t  };\n40\t};\n41\t\n42\t// ─── Styles ────────────────────────────────────────────────────────────────\n43\t\n44\tconst glass: React.CSSProperties = {\n45\t  background: 'rgba(11,14,28,0.72)',\n46\t  backdropFilter: 'blur(16px)',\n47\t  WebkitBackdropFilter: 'blur(16px)',\n48\t  border: '1px solid rgba(38,48,79,0.7)',\n49\t  borderRadius: 16,\n50\t  padding: '24px 28px',\n51\t  marginBottom: 20,\n52\t};\n53\t\n54\tconst labelStyle: React.CSSProperties = {\n55\t  fontSize: '0.68rem',\n56\t  letterSpacing: '0.14em',\n57\t  textTransform: 'uppercase',\n58\t  color: 'rgba(244,245,255,0.38)',\n59\t  marginBottom: 3,\n60\t};\n61\t\n62\tconst valueStyle: React.CSSProperties = {\n63\t  color: '#F4F5FF',\n64\t  fontSize: '0.95rem',\n65\t};\n66\t\n67\tconst descriptionStyle: React.CSSProperties = {\n68\t  color: 'rgba(244,245,255,0.68)',\n69\t  fontSize: '0.875rem',\n70\t  lineHeight: 1.7,\n71\t  marginTop: 14,\n72\t};\n73\t\n74\tconst sectionTitleStyle = (color: string): React.CSSProperties => ({\n75\t  fontFamily: 'var(--font-cinzel, \"Cinzel\", serif)',\n76\t  color,\n77\t  fontSize: '0.78rem',\n78\t  letterSpacing: '0.16em',\n79\t  textTransform: 'uppercase',\n80\t  marginBottom: 18,\n81\t  paddingBottom: 12,\n82\t  borderBottom: `1px solid ${color}28`,\n83\t  display: 'flex',\n84\t  justifyContent: 'space-between',\n85\t  alignItems: 'center',\n86\t});\n87\t\n88\t// ─── Sub-components ─────────────────────────────────────────────────────────\n89\t\n90\tfunction DataPair({ label, value }: { label: string; value: React.ReactNode }) {\n91\t  if (value === null || value === undefined) return null;\n92\t  return (\n93\t    <div style={{ marginBottom: 10 }}>\n94\t      <div style={labelStyle}>{label}</div>\n95\t      <div style={valueStyle}>{value}</div>\n96\t    </div>\n97\t  );\n98\t}\n99\t\n100\tfunction DataRow({ pairs }: { pairs: Array<{ label: string; value: React.ReactNode }> }) {\n101\t  return (\n102\t    <div style={{ display: 'flex', gap: 24, flexWrap: 'wrap', marginBottom: 4 }}>\n103\t      {pairs.map((p) => (\n104\t        <DataPair key={p.label} label={p.label} value={p.value} />\n105\t      ))}\n106\t    </div>\n107\t  );\n108\t}\n109\t\n110\tfunction ExpandToggle({\n111\t  expanded,\n112\t  onToggle,\n113\t  color,\n114\t}: {\n115\t  expanded: boolean;\n116\t  onToggle: () => void;\n117\t  color: string;\n118\t}) {\n119\t  return (\n120\t    <button\n121\t      onClick={onToggle}\n122\t      style={{\n123\t        background: 'none',\n124\t        border: `1px solid ${color}44`,\n125\t        borderRadius: 6,\n126\t        color,\n127\t        fontSize: '0.65rem',\n128\t        letterSpacing: '0.1em',\n129\t        padding: '3px 10px',\n130\t        cursor: 'pointer',\n131\t        textTransform: 'uppercase',\n132\t        transition: 'border-color 0.2s',\n133\t      }}\n134\t    >\n135\t      {expanded ? 'Ver menos' : 'Ver mais'}\n136\t    </button>\n137\t  );\n138\t}\n139\t\n140\t// ─── Main Page ───────────────────────────────────────────────────────────────\n141\t\n142\texport default function ManifestoPage() {\n143\t  const router = useRouter();\n144\t  const params = useParams<{ locale: string }>();\n145\t  const locale = params?.locale ?? 'pt-BR';\n146\t  const [content, setContent] = useState<ManifestoContent | null>(null);\n147\t  const [incomplete, setIncomplete] = useState(false);\n148\t  const [loading, setLoading] = useState(true);\n149\t\n150\t  // Expandable section state\n151\t  const [expandedOdu, setExpandedOdu] = useState(false);\n152\t  const [expandedKabala, setExpandedKabala] = useState(false);\n153\t  const [expandedTantra, setExpandedTantra] = useState(false);\n154\t  const [expandedAstro, setExpandedAstro] = useState(false);\n155\t\n156\t  useEffect(() => {\n157\t    async function loadManifesto() {\n158\t      try {\n159\t        const res = await fetch('/api/akasha/manifesto/generate', {\n160\t          method: 'POST',\n161\t          headers: { 'Content-Type': 'application/json' },\n162\t          credentials: 'include',\n163\t        });\n164\t\n165\t        if (res.status === 401 || res.status === 403) {\n166\t          router.replace(`/${locale}/onboarding`);\n167\t          return;\n168\t        }\n169\t        if (res.status === 404) {\n170\t          router.replace(`/${locale}/onboarding`);\n171\t          return;\n172\t        }\n173\t\n174\t        const data: { manifestoId: string; content: ManifestoContent; incomplete?: boolean } =\n175\t          await res.json();\n176\t        setContent(data.content);\n177\t        setIncomplete(data.incomplete ?? false);\n178\t      } catch {\n179\t        router.replace(`/${locale}/onboarding`);\n180\t      } finally {\n181\t        setLoading(false);\n182\t      }\n183\t    }\n184\t    loadManifesto();\n185\t  }, [router, locale]);\n186\t\n187\t  if (loading) {\n188\t    return (\n189\t      <main\n190\t        style={{\n191\t          background: '#06070F',\n192\t          minHeight: 'calc(100vh - 56px)',\n193\t          display: 'flex',\n194\t          alignItems: 'center',\n195\t          justifyContent: 'center',\n196\t        }}\n197\t      >\n198\t        <div\n199\t          style={{\n200\t            textAlign: 'center',\n201\t            color: 'rgba(244,245,255,0.38)',\n202\t            fontFamily: 'var(--font-lora, \"Lora\", serif)',\n203\t            fontSize: '0.9rem',\n204\t            letterSpacing: '0.06em',\n205\t          }}\n206\t        >\n207\t          Tecendo seu mapa akáshico…\n208\t        </div>\n209\t      </main>\n210\t    );\n211\t  }\n212\t\n213\t  if (!content) return null;\n214\t\n215\t  const { userName, generatedAt, synthesis, odus, kabala, tantra, astrology } = content;\n216\t\n217\t  return (\n218\t    <main\n219\t      style={{ background: '#06070F', minHeight: 'calc(100vh - 56px)', paddingBottom: 100 }}\n220\t      className=\"flex flex-col items-center py-10 px-4\"\n221\t    >\n222\t\n223\t      {/* ── Header ─────────────────────────────────────────────── */}\n224\t      <div style={{ textAlign: 'center', marginBottom: 36, maxWidth: 700, width: '100%' }}>\n225\t        <h1\n226\t          style={{\n227\t            fontFamily: 'var(--font-cinzel, \"Cinzel\", serif)',\n228\t            color: '#F0B429',\n229\t            fontSize: 'clamp(1.05rem, 3vw, 1.45rem)',\n230\t            letterSpacing: '0.22em',\n231\t            textTransform: 'uppercase',\n232\t            marginBottom: 8,\n233\t          }}\n234\t        >\n235\t          Manifesto Akáshico\n236\t        </h1>\n237\t        <p\n238\t          style={{\n239\t            color: 'rgba(244,245,255,0.62)',\n240\t            fontSize: '0.88rem',\n241\t            letterSpacing: '0.06em',\n242\t            fontFamily: 'var(--font-lora, \"Lora\", serif)',\n243\t          }}\n244\t        >\n245\t          {userName}\n246\t        </p>\n247\t        <p\n248\t          style={{\n249\t            color: 'rgba(244,245,255,0.28)',\n250\t            fontSize: '0.72rem',\n251\t            letterSpacing: '0.08em',\n252\t            marginTop: 4,\n253\t          }}\n254\t        >\n255\t          Gerado em {generatedAt}\n256\t        </p>\n257\t      </div>\n258\t\n259\t      {/* ── Incomplete banner ──────────────────────────────────── */}\n260\t      {incomplete && (\n261\t        <div\n262\t          style={{\n263\t            maxWidth: 700,\n264\t            width: '100%',\n265\t            marginBottom: 20,\n266\t            background: 'rgba(240,180,41,0.08)',\n267\t            border: '1px solid rgba(240,180,41,0.4)',\n268\t            borderRadius: 10,\n269\t            padding: '12px 18px',\n270\t            display: 'flex',\n271\t            gap: 10,\n272\t            alignItems: 'flex-start',\n273\t          }}\n274\t        >\n275\t          <span style={{ color: '#F0B429', fontSize: '0.9rem' }}>⚠</span>\n276\t          <p\n277\t            style={{\n278\t              color: '#F0B429',\n279\t              fontSize: '0.8rem',\n280\t              lineHeight: 1.5,\n281\t              margin: 0,\n282\t            }}\n283\t          >\n284\t            Seu mapa está incompleto — alguns dados podem ser genéricos. Complete seu onboarding para\n285\t            uma leitura precisa.\n286\t          </p>\n287\t        </div>\n288\t      )}\n289\t\n290\t      {/* ── Sections ─────────────────────────────────────────── */}\n291\t      <div style={{ maxWidth: 700, width: '100%' }}>\n292\t\n293\t        {/* 0 — Síntese */}\n294\t        <div style={glass}>\n295\t          <div style={sectionTitleStyle('#FB5781')}>\n296\t            <span>Síntese dos 4 Pilares</span>\n297\t          </div>\n298\t          <p\n299\t            style={{\n300\t              ...descriptionStyle,\n301\t              marginTop: 0,\n302\t              color: 'rgba(244,245,255,0.82)',\n303\t              fontFamily: 'var(--font-lora, \"Lora\", serif)',\n304\t              fontSize: '0.9rem',\n305\t              lineHeight: 1.75,\n306\t            }}\n307\t          >\n308\t            {synthesis}\n309\t          </p>\n310\t        </div>\n311\t\n312\t        {/* I — Odus */}\n313\t        <div style={glass}>\n314\t          <div style={sectionTitleStyle('#F0B429')}>\n315\t            <span>I. Bússola Ancestral — Odus</span>\n316\t            <ExpandToggle expanded={expandedOdu} onToggle={() => setExpandedOdu(!expandedOdu)} color=\"#F0B429\" />\n317\t          </div>\n318\t\n319\t          <DataRow\n320\t            pairs={[\n321\t              { label: 'Odu', value: odus.oduName || '—' },\n322\t              ...(odus.oduNumber !== null ? [{ label: 'Número', value: String(odus.oduNumber) }] : []),\n323\t              ...(odus.elementalForce ? [{ label: 'Força Elemental', value: odus.elementalForce }] : []),\n324\t            ]}\n325\t          />\n326\t\n327\t          {odus.orixas.length > 0 && (\n328\t            <DataPair label=\"Orixás\" value={odus.orixas.join(' · ')} />\n329\t          )}\n330\t\n331\t          <p style={descriptionStyle}>{odus.description}</p>\n332\t\n333\t          {expandedOdu && odus.preceitos && odus.preceitos.length > 0 && (\n334\t            <div style={{ marginTop: 16 }}>\n335\t              <div style={labelStyle}>Preceitos</div>\n336\t              <ul style={{ margin: '8px 0 0', paddingLeft: 18 }}>\n337\t                {odus.preceitos.map((p, i) => (\n338\t                  <li\n339\t                    key={i}\n340\t                    style={{\n341\t                      color: 'rgba(244,245,255,0.6)',\n342\t                      fontSize: '0.83rem',\n343\t                      lineHeight: 1.6,\n344\t                      marginBottom: 4,\n345\t                    }}\n346\t                  >\n347\t                    {p}\n348\t                  </li>\n349\t                ))}\n350\t              </ul>\n351\t            </div>\n352\t          )}\n353\t\n354\t          {odus.provisional && (\n355\t            <div\n356\t              style={{\n357\t                display: 'inline-block',\n358\t                marginTop: 14,\n359\t                background: 'rgba(240,180,41,0.1)',\n360\t                border: '1px solid rgba(240,180,41,0.3)',\n361\t                borderRadius: 6,\n362\t                padding: '3px 10px',\n363\t                fontSize: '0.68rem',\n364\t                letterSpacing: '0.1em',\n365\t                color: '#F0B429',\n366\t                textTransform: 'uppercase',\n367\t              }}\n368\t            >\n369\t              Provisório\n370\t            </div>\n371\t          )}\n372\t        </div>\n373\t\n374\t        {/* II — Kabala */}\n375\t        <div style={glass}>\n376\t          <div style={sectionTitleStyle('#7C5CFF')}>\n377\t            <span>II. O Verbo — Numerologia Cabalística</span>\n378\t            <ExpandToggle expanded={expandedKabala} onToggle={() => setExpandedKabala(!expandedKabala)} color=\"#7C5CFF\" />\n379\t          </div>\n380\t\n381\t          <DataRow\n382\t            pairs={[\n383\t              {\n384\t                label: 'Caminho de Vida',\n385\t                value:\n386\t                  kabala.lifePath !== null\n387\t                    ? `${kabala.lifePath}${kabala.lifePathMaster ? ' ✦' : ''}`\n388\t                    : null,\n389\t              },\n390\t              { label: 'Expressão', value: kabala.expression },\n391\t              { label: 'Motivação', value: kabala.motivation },\n392\t              ...(kabala.personalYear !== null\n393\t                ? [{ label: 'Ano Pessoal', value: String(kabala.personalYear) }]\n394\t                : []),\n395\t            ]}\n396\t          />\n397\t\n398\t          <p style={descriptionStyle}>{kabala.description}</p>\n399\t        </div>\n400\t\n401\t        {/* III — Tantra */}\n402\t        <div style={glass}>\n403\t          <div style={sectionTitleStyle('#2DD4BF')}>\n404\t            <span>III. A Anatomia — Tantra</span>\n405\t            <ExpandToggle expanded={expandedTantra} onToggle={() => setExpandedTantra(!expandedTantra)} color=\"#2DD4BF\" />\n406\t          </div>\n407\t\n408\t          <DataRow\n409\t            pairs={[\n410\t              { label: 'Alma', value: tantra.soul },\n411\t              { label: 'Karma', value: tantra.karma },\n412\t              { label: 'Dádiva Divina', value: tantra.divineGift },\n413\t              { label: 'Caminho Tântrico', value: tantra.tantricPath },\n414\t            ]}\n415\t          />\n416\t\n417\t          <p style={descriptionStyle}>{tantra.description}</p>\n418\t        </div>\n419\t\n420\t        {/* IV — Astrologia */}\n421\t        <div style={glass}>\n422\t          <div style={sectionTitleStyle('#7C5CFF')}>\n423\t            <span>IV. O Céu — Astrologia</span>\n424\t            <ExpandToggle expanded={expandedAstro} onToggle={() => setExpandedAstro(!expandedAstro)} color=\"#7C5CFF\" />\n425\t          </div>\n426\t\n427\t          <DataRow\n428\t            pairs={[\n429\t              { label: 'Ascendente', value: astrology.ascendant },\n430\t              { label: 'Planeta Dominante', value: astrology.dominantPlanet },\n431\t            ]}\n432\t          />\n433\t\n434\t          {astrology.mainPlanets.length > 0 && (\n435\t            <div style={{ marginTop: 14 }}>\n436\t              <div style={labelStyle}>Posições Planetárias</div>\n437\t              <div style={{ display: 'flex', gap: 16, flexWrap: 'wrap' }}>\n438\t                {astrology.mainPlanets.map((p, i) => (\n439\t                  <div key={i} style={{ color: 'rgba(244,245,255,0.78)', fontSize: '0.85rem' }}>\n440\t                    <strong style={{ color: '#F4F5FF' }}>{p.name}</strong> em {p.sign}\n441\t                  </div>\n442\t                ))}\n443\t              </div>\n444\t            </div>\n445\t          )}\n446\t\n447\t          <p style={descriptionStyle}>{astrology.description}</p>\n448\t        </div>\n449\t\n450\t      </div>\n451\t\n452\t      {/* ── Floating PDF button ──────────────────────────────── */}\n453\t      <a\n454\t        href=\"/api/akasha/manifesto/pdf\"\n455\t        download\n456\t        style={{\n457\t          position: 'fixed',\n458\t          bottom: 28,\n459\t          right: 24,\n460\t          display: 'inline-flex',\n461\t          alignItems: 'center',\n462\t          gap: 8,\n463\t          background: 'linear-gradient(135deg, rgba(240,180,41,0.18) 0%, rgba(240,180,41,0.08) 100%)',\n464\t          backdropFilter: 'blur(12px)',\n465\t          WebkitBackdropFilter: 'blur(12px)',\n466\t          border: '1px solid rgba(240,180,41,0.5)',\n467\t          borderRadius: 12,\n468\t          padding: '11px 22px',\n469\t          color: '#F0B429',\n470\t          fontSize: '0.82rem',\n471\t          letterSpacing: '0.08em',\n472\t          textDecoration: 'none',\n473\t          boxShadow: '0 4px 24px rgba(240,180,41,0.15)',\n474\t          transition: 'box-shadow 0.2s, border-color 0.2s',\n475\t          zIndex: 50,\n476\t        }}\n477\t      >\n478\t        <span style={{ fontSize: '1rem' }}>⬇</span>\n479\t        <span>Exportar Manifesto</span>\n480\t      </a>\n481\t\n482\t    </main>\n483\t  );\n484\t}\n485\t"}]},"parent_tool_use_id":null,"session_id":"44a294c9-7ecf-4f85-9b61-8e5a12793e2c","uuid":"98d2ab78-3467-4649-b714-6941550f7375","timestamp":"2026-06-11T11:38:18.259Z","tool_use_result":{"type":"text","file":{"filePath":"/home/skynet/cabala-dos-caminhos/apps/akasha-portal/src/app/[locale]/(akasha)/manifesto/page.tsx","content":"'use client';\n\nimport { useEffect, useState } from 'react';\nimport { useParams, useRouter } from 'next/navigation';\n\ntype ManifestoContent = {\n  userName: string;\n  generatedAt: string;\n  synthesis: string;\n  odus: {\n    oduName: string;\n    oduNumber: number | null;\n    orixas: string[];\n    elementalForce: string | null;\n    description: string;\n    preceitos?: string[];\n    provisional: boolean;\n  };\n  kabala: {\n    lifePath: number | null;\n    lifePathMaster: boolean;\n    expression: number | null;\n    motivation: number | null;\n    personalYear: number | null;\n    description: string;\n  };\n  tantra: {\n    soul: number | null;\n    karma: number | null;\n    divineGift: number | null;\n    tantricPath: number | null;\n    description: string;\n  };\n  astrology: {\n    ascendant: string | null;\n    dominantPlanet: string | null;\n    mainPlanets: Array<{ name: string; sign: string }>;\n    description: string;\n  };\n};\n\n// ─── Styles ────────────────────────────────────────────────────────────────\n\nconst glass: React.CSSProperties = {\n  background: 'rgba(11,14,28,0.72)',\n  backdropFilter: 'blur(16px)',\n  WebkitBackdropFilter: 'blur(16px)',\n  border: '1px solid rgba(38,48,79,0.7)',\n  borderRadius: 16,\n  padding: '24px 28px',\n  marginBottom: 20,\n};\n\nconst labelStyle: React.CSSProperties = {\n  fontSize: '0.68rem',\n  letterSpacing: '0.14em',\n  textTransform: 'uppercase',\n  color: 'rgba(244,245,255,0.38)',\n  marginBottom: 3,\n};\n\nconst valueStyle: React.CSSProperties = {\n  color: '#F4F5FF',\n  fontSize: '0.95rem',\n};\n\nconst descriptionStyle: React.CSSProperties = {\n  color: 'rgba(244,245,255,0.68)',\n  fontSize: '0.875rem',\n  lineHeight: 1.7,\n  marginTop: 14,\n};\n\nconst sectionTitleStyle = (color: string): React.CSSProperties => ({\n  fontFamily: 'var(--font-cinzel, \"Cinzel\", serif)',\n  color,\n  fontSize: '0.78rem',\n  letterSpacing: '0.16em',\n  textTransform: 'uppercase',\n  marginBottom: 18,\n  paddingBottom: 12,\n  borderBottom: `1px solid ${color}28`,\n  display: 'flex',\n  justifyContent: 'space-between',\n  alignItems: 'center',\n});\n\n// ─── Sub-components ─────────────────────────────────────────────────────────\n\nfunction DataPair({ label, value }: { label: string; value: React.ReactNode }) {\n  if (value === null || value === undefined) return null;\n  return (\n    <div style={{ marginBottom: 10 }}>\n      <div style={labelStyle}>{label}</div>\n      <div style={valueStyle}>{value}</div>\n    </div>\n  );\n}\n\nfunction DataRow({ pairs }: { pairs: Array<{ label: string; value: React.ReactNode }> }) {\n  return (\n    <div style={{ display: 'flex', gap: 24, flexWrap: 'wrap', marginBottom: 4 }}>\n      {pairs.map((p) => (\n        <DataPair key={p.label} label={p.label} value={p.value} />\n      ))}\n    </div>\n  );\n}\n\nfunction ExpandToggle({\n  expanded,\n  onToggle,\n  color,\n}: {\n  expanded: boolean;\n  onToggle: () => void;\n  color: string;\n}) {\n  return (\n    <button\n      onClick={onToggle}\n      style={{\n        background: 'none',\n        border: `1px solid ${color}44`,\n        borderRadius: 6,\n        color,\n        fontSize: '0.65rem',\n        letterSpacing: '0.1em',\n        padding: '3px 10px',\n        cursor: 'pointer',\n        textTransform: 'uppercase',\n        transition: 'border-color 0.2s',\n      }}\n    >\n      {expanded ? 'Ver menos' : 'Ver mais'}\n    </button>\n  );\n}\n\n// ─── Main Page ───────────────────────────────────────────────────────────────\n\nexport default function ManifestoPage() {\n  const router = useRouter();\n  const params = useParams<{ locale: string }>();\n  const locale = params?.locale ?? 'pt-BR';\n  const [content, setContent] = useState<ManifestoContent | null>(null);\n  const [incomplete, setIncomplete] = useState(false);\n  const [loading, setLoading] = useState(true);\n\n  // Expandable section state\n  const [expandedOdu, setExpandedOdu] = useState(false);\n  const [expandedKabala, setExpandedKabala] = useState(false);\n  const [expandedTantra, setExpandedTantra] = useState(false);\n  const [expandedAstro, setExpandedAstro] = useState(false);\n\n  useEffect(() => {\n    async function loadManifesto() {\n      try {\n        const res = await fetch('/api/akasha/manifesto/generate', {\n          method: 'POST',\n          headers: { 'Content-Type': 'application/json' },\n          credentials: 'include',\n        });\n\n        if (res.status === 401 || res.status === 403) {\n          router.replace(`/${locale}/onboarding`);\n          return;\n        }\n        if (res.status === 404) {\n          router.replace(`/${locale}/onboarding`);\n          return;\n        }\n\n        const data: { manifestoId: string; content: ManifestoContent; incomplete?: boolean } =\n          await res.json();\n        setContent(data.content);\n        setIncomplete(data.incomplete ?? false);\n      } catch {\n        router.replace(`/${locale}/onboarding`);\n      } finally {\n        setLoading(false);\n      }\n    }\n    loadManifesto();\n  }, [router, locale]);\n\n  if (loading) {\n    return (\n      <main\n        style={{\n          background: '#06070F',\n          minHeight: 'calc(100vh - 56px)',\n          display: 'flex',\n          alignItems: 'center',\n          justifyContent: 'center',\n        }}\n      >\n        <div\n          style={{\n            textAlign: 'center',\n            color: 'rgba(244,245,255,0.38)',\n            fontFamily: 'var(--font-lora, \"Lora\", serif)',\n            fontSize: '0.9rem',\n            letterSpacing: '0.06em',\n          }}\n        >\n          Tecendo seu mapa akáshico…\n        </div>\n      </main>\n    );\n  }\n\n  if (!content) return null;\n\n  const { userName, generatedAt, synthesis, odus, kabala, tantra, astrology } = content;\n\n  return (\n    <main\n      style={{ background: '#06070F', minHeight: 'calc(100vh - 56px)', paddingBottom: 100 }}\n      className=\"flex flex-col items-center py-10 px-4\"\n    >\n\n      {/* ── Header ─────────────────────────────────────────────── */}\n      <div style={{ textAlign: 'center', marginBottom: 36, maxWidth: 700, width: '100%' }}>\n        <h1\n          style={{\n            fontFamily: 'var(--font-cinzel, \"Cinzel\", serif)',\n            color: '#F0B429',\n            fontSize: 'clamp(1.05rem, 3vw, 1.45rem)',\n            letterSpacing: '0.22em',\n            textTransform: 'uppercase',\n            marginBottom: 8,\n          }}\n        >\n          Manifesto Akáshico\n        </h1>\n        <p\n          style={{\n            color: 'rgba(244,245,255,0.62)',\n            fontSize: '0.88rem',\n            letterSpacing: '0.06em',\n            fontFamily: 'var(--font-lora, \"Lora\", serif)',\n          }}\n        >\n          {userName}\n        </p>\n        <p\n          style={{\n            color: 'rgba(244,245,255,0.28)',\n            fontSize: '0.72rem',\n            letterSpacing: '0.08em',\n            marginTop: 4,\n          }}\n        >\n          Gerado em {generatedAt}\n        </p>\n      </div>\n\n      {/* ── Incomplete banner ──────────────────────────────────── */}\n      {incomplete && (\n        <div\n          style={{\n            maxWidth: 700,\n            width: '100%',\n            marginBottom: 20,\n            background: 'rgba(240,180,41,0.08)',\n            border: '1px solid rgba(240,180,41,0.4)',\n            borderRadius: 10,\n            padding: '12px 18px',\n            display: 'flex',\n            gap: 10,\n            alignItems: 'flex-start',\n          }}\n        >\n          <span style={{ color: '#F0B429', fontSize: '0.9rem' }}>⚠</span>\n          <p\n            style={{\n              color: '#F0B429',\n              fontSize: '0.8rem',\n              lineHeight: 1.5,\n              margin: 0,\n            }}\n          >\n            Seu mapa está incompleto — alguns dados podem ser genéricos. Complete seu onboarding para\n            uma leitura precisa.\n          </p>\n        </div>\n      )}\n\n      {/* ── Sections ─────────────────────────────────────────── */}\n      <div style={{ maxWidth: 700, width: '100%' }}>\n\n        {/* 0 — Síntese */}\n        <div style={glass}>\n          <div style={sectionTitleStyle('#FB5781')}>\n            <span>Síntese dos 4 Pilares</span>\n          </div>\n          <p\n            style={{\n              ...descriptionStyle,\n              marginTop: 0,\n              color: 'rgba(244,245,255,0.82)',\n              fontFamily: 'var(--font-lora, \"Lora\", serif)',\n              fontSize: '0.9rem',\n              lineHeight: 1.75,\n            }}\n          >\n            {synthesis}\n          </p>\n        </div>\n\n        {/* I — Odus */}\n        <div style={glass}>\n          <div style={sectionTitleStyle('#F0B429')}>\n            <span>I. Bússola Ancestral — Odus</span>\n            <ExpandToggle expanded={expandedOdu} onToggle={() => setExpandedOdu(!expandedOdu)} color=\"#F0B429\" />\n          </div>\n\n          <DataRow\n            pairs={[\n              { label: 'Odu', value: odus.oduName || '—' },\n              ...(odus.oduNumber !== null ? [{ label: 'Número', value: String(odus.oduNumber) }] : []),\n              ...(odus.elementalForce ? [{ label: 'Força Elemental', value: odus.elementalForce }] : []),\n            ]}\n          />\n\n          {odus.orixas.length > 0 && (\n            <DataPair label=\"Orixás\" value={odus.orixas.join(' · ')} />\n          )}\n\n          <p style={descriptionStyle}>{odus.description}</p>\n\n          {expandedOdu && odus.preceitos && odus.preceitos.length > 0 && (\n            <div style={{ marginTop: 16 }}>\n              <div style={labelStyle}>Preceitos</div>\n              <ul style={{ margin: '8px 0 0', paddingLeft: 18 }}>\n                {odus.preceitos.map((p, i) => (\n                  <li\n                    key={i}\n                    style={{\n                      color: 'rgba(244,245,255,0.6)',\n                      fontSize: '0.83rem',\n                      lineHeight: 1.6,\n                      marginBottom: 4,\n                    }}\n                  >\n                    {p}\n                  </li>\n                ))}\n              </ul>\n            </div>\n          )}\n\n          {odus.provisional && (\n            <div\n              style={{\n                display: 'inline-block',\n                marginTop: 14,\n                background: 'rgba(240,180,41,0.1)',\n                border: '1px solid rgba(240,180,41,0.3)',\n                borderRadius: 6,\n                padding: '3px 10px',\n                fontSize: '0.68rem',\n                letterSpacing: '0.1em',\n                color: '#F0B429',\n                textTransform: 'uppercase',\n              }}\n            >\n              Provisório\n            </div>\n          )}\n        </div>\n\n        {/* II — Kabala */}\n        <div style={glass}>\n          <div style={sectionTitleStyle('#7C5CFF')}>\n            <span>II. O Verbo — Numerologia Cabalística</span>\n            <ExpandToggle expanded={expandedKabala} onToggle={() => setExpandedKabala(!expandedKabala)} color=\"#7C5CFF\" />\n          </div>\n\n          <DataRow\n            pairs={[\n              {\n                label: 'Caminho de Vida',\n                value:\n                  kabala.lifePath !== null\n                    ? `${kabala.lifePath}${kabala.lifePathMaster ? ' ✦' : ''}`\n                    : null,\n              },\n              { label: 'Expressão', value: kabala.expression },\n              { label: 'Motivação', value: kabala.motivation },\n              ...(kabala.personalYear !== null\n                ? [{ label: 'Ano Pessoal', value: String(kabala.personalYear) }]\n                : []),\n            ]}\n          />\n\n          <p style={descriptionStyle}>{kabala.description}</p>\n        </div>\n\n        {/* III — Tantra */}\n        <div style={glass}>\n          <div style={sectionTitleStyle('#2DD4BF')}>\n            <span>III. A Anatomia — Tantra</span>\n            <ExpandToggle expanded={expandedTantra} onToggle={() => setExpandedTantra(!expandedTantra)} color=\"#2DD4BF\" />\n          </div>\n\n          <DataRow\n            pairs={[\n              { label: 'Alma', value: tantra.soul },\n              { label: 'Karma', value: tantra.karma },\n              { label: 'Dádiva Divina', value: tantra.divineGift },\n              { label: 'Caminho Tântrico', value: tantra.tantricPath },\n            ]}\n          />\n\n          <p style={descriptionStyle}>{tantra.description}</p>\n        </div>\n\n        {/* IV — Astrologia */}\n        <div style={glass}>\n          <div style={sectionTitleStyle('#7C5CFF')}>\n            <span>IV. O Céu — Astrologia</span>\n            <ExpandToggle expanded={expandedAstro} onToggle={() => setExpandedAstro(!expandedAstro)} color=\"#7C5CFF\" />\n          </div>\n\n          <DataRow\n            pairs={[\n              { label: 'Ascendente', value: astrology.ascendant },\n              { label: 'Planeta Dominante', value: astrology.dominantPlanet },\n            ]}\n          />\n\n          {astrology.mainPlanets.length > 0 && (\n            <div style={{ marginTop: 14 }}>\n              <div style={labelStyle}>Posições Planetárias</div>\n              <div style={{ display: 'flex', gap: 16, flexWrap: 'wrap' }}>\n                {astrology.mainPlanets.map((p, i) => (\n                  <div key={i} style={{ color: 'rgba(244,245,255,0.78)', fontSize: '0.85rem' }}>\n                    <strong style={{ color: '#F4F5FF' }}>{p.name}</strong> em {p.sign}\n                  </div>\n                ))}\n              </div>\n            </div>\n          )}\n\n          <p style={descriptionStyle}>{astrology.description}</p>\n        </div>\n\n      </div>\n\n      {/* ── Floating PDF button ──────────────────────────────── */}\n      <a\n        href=\"/api/akasha/manifesto/pdf\"\n        download\n        style={{\n          position: 'fixed',\n          bottom: 28,\n          right: 24,\n          display: 'inline-flex',\n          alignItems: 'center',\n          gap: 8,\n          background: 'linear-gradient(135deg, rgba(240,180,41,0.18) 0%, rgba(240,180,41,0.08) 100%)',\n          backdropFilter: 'blur(12px)',\n          WebkitBackdropFilter: 'blur(12px)',\n          border: '1px solid rgba(240,180,41,0.5)',\n          borderRadius: 12,\n          padding: '11px 22px',\n          color: '#F0B429',\n          fontSize: '0.82rem',\n          letterSpacing: '0.08em',\n          textDecoration: 'none',\n          boxShadow: '0 4px 24px rgba(240,180,41,0.15)',\n          transition: 'box-shadow 0.2s, border-color 0.2s',\n          zIndex: 50,\n        }}\n      >\n        <span style={{ fontSize: '1rem' }}>⬇</span>\n        <span>Exportar Manifesto</span>\n      </a>\n\n    </main>\n  );\n}\n","numLines":485,"startLine":1,"totalLines":485}}}
