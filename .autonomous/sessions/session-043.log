{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_rlzb5jyqzwjg_1","type":"tool_result","content":"1\t/**\n2\t * i18n config — stub leve para migração futura ao next-intl\n3\t *\n4\t * Doc 25 §11 / Onda 3.5 — Roadmap de i18n.\n5\t *\n6\t * Por enquanto, este módulo provê:\n7\t * - Lista de locales suportados\n8\t * - Detecção de locale via header Accept-Language\n9\t * - Função `getMessages(locale)` que retorna o dicionário correto\n10\t *\n11\t * Para ativar next-intl 100%:\n12\t * 1. `npm install next-intl`\n13\t * 2. Mover `messages/` para `src/messages/` (estrutura do next-intl)\n14\t * 3. Adicionar `createNextIntlPlugin` em `next.config.js`\n15\t * 4. Criar `src/middleware.ts` para detectar locale via URL (`/pt-BR/...`, `/en/...`)\n16\t * 5. Refatorar componentes para usar `useTranslations` e `getTranslations`\n17\t *\n18\t * Já existem os dicionários `messages/pt-BR.json` e `messages/en.json` com\n19\t * as chaves canônicas. Esta configuração é compatível com next-intl quando\n20\t * instalado.\n21\t */\n22\t\n23\texport const SUPPORTED_LOCALES = ['pt-BR', 'en'] as const;\n24\texport type Locale = (typeof SUPPORTED_LOCALES)[number];\n25\texport const DEFAULT_LOCALE: Locale = 'pt-BR';\n26\t\n27\t/** Detecção simples de locale via Accept-Language. */\n28\texport function detectLocale(acceptLanguage: string | null | undefined): Locale {\n29\t  if (!acceptLanguage) return DEFAULT_LOCALE;\n30\t  // Suporta formatos: \"en\", \"en-US\", \"pt-BR\", \"pt\"\n31\t  const lower = acceptLanguage.toLowerCase();\n32\t  if (lower.includes('en') && !lower.includes('pt')) return 'en';\n33\t  return DEFAULT_LOCALE;\n34\t}\n35\t\n36\t/** Carrega o dicionário de mensagens do locale solicitado. */\n37\texport function getMessages(locale: Locale): Record<string, unknown> {\n38\t  // Esta função é substituível por `getMessages` do next-intl quando instalado.\n39\t  // Usa fs.readFileSync para evitar problemas de path resolution do `require()`\n40\t  // em diferentes bundlers (jest/vitest/Next).\n41\t  // eslint-disable-next-line @typescript-eslint/no-require-imports\n42\t  const fs = require('fs') as typeof import('fs');\n43\t  // eslint-disable-next-line @typescript-eslint/no-require-imports\n44\t  const path = require('path') as typeof import('path');\n45\t\n46\t  const rel = locale === 'en' ? 'messages/en.json' : 'messages/pt-BR.json';\n47\t  const fullPath = path.join(process.cwd(), rel);\n48\t\n49\t  try {\n50\t    const raw = fs.readFileSync(fullPath, 'utf8');\n51\t    return JSON.parse(raw) as Record<string, unknown>;\n52\t  } catch {\n53\t    // Fallback em memória mínima para evitar crash em build\n54\t    return { common: { appName: 'Cabala dos Caminhos' } };\n55\t  }\n56\t}\n57\t\n58\t/**\n59\t * Helper de tradução simples (use enquanto componentes não migram para\n60\t * `useTranslations`). Aceita dot-path: `t('nav.mandala')`.\n61\t */\n62\texport function makeT(messages: Record<string, unknown>) {\n63\t  return function t(key: string, vars?: Record<string, string | number>): string {\n64\t    const parts = key.split('.');\n65\t    let cur: unknown = messages;\n66\t    for (const part of parts) {\n67\t      if (cur && typeof cur === 'object' && part in (cur as object)) {\n68\t        cur = (cur as Record<string, unknown>)[part];\n69\t      } else {\n70\t        return key; // chave não encontrada — retorna o dot-path como fallback\n71\t      }\n72\t    }\n73\t    if (typeof cur !== 'string') return key;\n74\t    if (!vars) return cur;\n75\t    // Interpola {varName} (suporta ICU simples — não cobre plural/select)\n76\t    return cur.replace(/\\{(\\w+)\\}/g, (_, name) => String(vars[name] ?? `{${name}}`));\n77\t  };\n78\t}\n79\t"}]},"parent_tool_use_id":null,"session_id":"efa9633d-4bd4-4eaf-8cc7-696bf2eda76b","uuid":"2cf30fd3-ae90-4053-a6ba-a412e13422a9","timestamp":"2026-06-12T01:47:04.172Z","tool_use_result":{"type":"text","file":{"filePath":"/home/skynet/cabala-dos-caminhos/apps/akasha-portal/src/lib/domain/i18n/config.ts","content":"/**\n * i18n config — stub leve para migração futura ao next-intl\n *\n * Doc 25 §11 / Onda 3.5 — Roadmap de i18n.\n *\n * Por enquanto, este módulo provê:\n * - Lista de locales suportados\n * - Detecção de locale via header Accept-Language\n * - Função `getMessages(locale)` que retorna o dicionário correto\n *\n * Para ativar next-intl 100%:\n * 1. `npm install next-intl`\n * 2. Mover `messages/` para `src/messages/` (estrutura do next-intl)\n * 3. Adicionar `createNextIntlPlugin` em `next.config.js`\n * 4. Criar `src/middleware.ts` para detectar locale via URL (`/pt-BR/...`, `/en/...`)\n * 5. Refatorar componentes para usar `useTranslations` e `getTranslations`\n *\n * Já existem os dicionários `messages/pt-BR.json` e `messages/en.json` com\n * as chaves canônicas. Esta configuração é compatível com next-intl quando\n * instalado.\n */\n\nexport const SUPPORTED_LOCALES = ['pt-BR', 'en'] as const;\nexport type Locale = (typeof SUPPORTED_LOCALES)[number];\nexport const DEFAULT_LOCALE: Locale = 'pt-BR';\n\n/** Detecção simples de locale via Accept-Language. */\nexport function detectLocale(acceptLanguage: string | null | undefined): Locale {\n  if (!acceptLanguage) return DEFAULT_LOCALE;\n  // Suporta formatos: \"en\", \"en-US\", \"pt-BR\", \"pt\"\n  const lower = acceptLanguage.toLowerCase();\n  if (lower.includes('en') && !lower.includes('pt')) return 'en';\n  return DEFAULT_LOCALE;\n}\n\n/** Carrega o dicionário de mensagens do locale solicitado. */\nexport function getMessages(locale: Locale): Record<string, unknown> {\n  // Esta função é substituível por `getMessages` do next-intl quando instalado.\n  // Usa fs.readFileSync para evitar problemas de path resolution do `require()`\n  // em diferentes bundlers (jest/vitest/Next).\n  // eslint-disable-next-line @typescript-eslint/no-require-imports\n  const fs = require('fs') as typeof import('fs');\n  // eslint-disable-next-line @typescript-eslint/no-require-imports\n  const path = require('path') as typeof import('path');\n\n  const rel = locale === 'en' ? 'messages/en.json' : 'messages/pt-BR.json';\n  const fullPath = path.join(process.cwd(), rel);\n\n  try {\n    const raw = fs.readFileSync(fullPath, 'utf8');\n    return JSON.parse(raw) as Record<string, unknown>;\n  } catch {\n    // Fallback em memória mínima para evitar crash em build\n    return { common: { appName: 'Cabala dos Caminhos' } };\n  }\n}\n\n/**\n * Helper de tradução simples (use enquanto componentes não migram para\n * `useTranslations`). Aceita dot-path: `t('nav.mandala')`.\n */\nexport function makeT(messages: Record<string, unknown>) {\n  return function t(key: string, vars?: Record<string, string | number>): string {\n    const parts = key.split('.');\n    let cur: unknown = messages;\n    for (const part of parts) {\n      if (cur && typeof cur === 'object' && part in (cur as object)) {\n        cur = (cur as Record<string, unknown>)[part];\n      } else {\n        return key; // chave não encontrada — retorna o dot-path como fallback\n      }\n    }\n    if (typeof cur !== 'string') return key;\n    if (!vars) return cur;\n    // Interpola {varName} (suporta ICU simples — não cobre plural/select)\n    return cur.replace(/\\{(\\w+)\\}/g, (_, name) => String(vars[name] ?? `{${name}}`));\n  };\n}\n","numLines":79,"startLine":1,"totalLines":79}}}
