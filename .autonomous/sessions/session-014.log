sões arquiteturais\",\n    \"dependencies\": [\n      \"R-024\"\n    ],\n    \"questions\": [\n      \"Next.js 16 + Turbopack: confirmar?\",\n      \"pgvector para embeddings: sim?\",\n      \"LLM principal: gpt-4 ou opus 4.5? Minimax fallback?\",\n      \"Realtime: SSE ok ou WebSocket?\",\n      \"Auth: Supabase ou JWT próprio?\",\n      \"VPS ou Vercel edge?\"\n    ],\n    \"output\": \".autonomous/research/tech_decisions.md\",\n    \"passes\": false,\n    \"timebox\": \"45min\"\n  },\n  {\n    \"id\": \"R-030\",\n    \"phase\": 5,\n    \"category\": \"prototype\",\n    \"priority\": \"P0\",\n    \"description\": \"Akasha Core Algorithm — protótipo em TS puro (NÃO integrado)\",\n    \"dependencies\": [\n      \"R-022\"\n    ],\n    \"questions\": [\n      \"Tipos Zod para inputs (5 pilares)\",\n      \"Função pura akasha.calcular(pessoa) → Leitura\",\n      \"Validar com 3 perfis de teste\",\n      \"Sem persistência ainda — só tipos + lógica\"\n    ],\n    \"output\": \"packages/akasha-core/src/index.ts (skeleton)\",\n    \"passes\": false,\n    \"timebox\": \"90min\"\n  },\n  {\n    \"id\": \"F-100\",\n    \"phase\": 7,\n    \"category\": \"maintenance\",\n    \"priority\": \"P2\",\n    \"description\": \"Refactor — encontrar arquivos >500 linhas, funções >50 linhas, duplicação. Tooling: knip/ts-prune/manual grep.\",\n    \"output\": \".autonomous/research/maintenance/f100-refactor-<date>.md\",\n    \"passes\": false,\n    \"timebox\": \"30min\"\n  },\n  {\n    \"id\": \"F-101\",\n    \"phase\": 7,\n    \"category\": \"maintenance\",\n    \"priority\": \"P2\",\n    \"description\": \"Dead code — imports não usados, exports sem callers, branches mortos. Tool: pnpm fallow / ts-prune.\",\n    \"output\": \".autonomous/research/maintenance/f101-deadcode-<date>.md\",\n    \"passes\": false,\n    \"timebox\": \"20min\"\n  },\n  {\n    \"id\": \"F-102\",\n    \"phase\": 7,\n    \"category\": \"maintenance\",\n    \"priority\": \"P1\",\n    \"description\": \"Security review — OWASP top 10 nos endpoints novos. Skill: ecc:security-scan.\",\n    \"output\": \".autonomous/research/maintenance/f102-security-<date>.md\",\n    \"passes\": false,\n    \"timebox\": \"40min\"\n  },\n  {\n    \"id\": \"F-103\",\n    \"phase\": 7,\n    \"category\": \"maintenance\",\n    \"priority\": \"P2\",\n    \"description\": \"Performance — bundle size, TTFB, query N+1, LCP. Skill: vercel:performance-optimizer.\",\n    \"output\": \".autonomous/research/maintenance/f103-perf-<date>.md\",\n    \"passes\": false,\n    \"timebox\": \"40min\"\n  },\n  {\n    \"id\": \"F-104\",\n    \"phase\": 7,\n    \"category\": \"maintenance\",\n    \"priority\": \"P2\",\n    \"description\": \"Docs sync — código novo sem doc/README/AGENTS.md atualizado. Diff coverage.\",\n    \"output\": \".autonomous/research/maintenance/f104-docs-<date>.md\",\n    \"passes\": false,\n    \"timebox\": \"20min\"\n  },\n  {\n    \"id\": \"F-105\",\n    \"phase\": 7,\n    \"category\": \"maintenance\",\n    \"priority\": \"P0\",\n    \"description\": \"Meta-review perpétuo — quando fila vazia, ler git log -20, abrir 3-5 novos RQs Fase 7, reiniciar ciclo.\",\n    \"output\": \".autonomous/state/meta_review.signal + commits\",\n    \"passes\": true,\n    \"timebox\": \"perpétuo\"\n  }\n]","numLines":394,"startLine":1,"totalLines":394}}}
