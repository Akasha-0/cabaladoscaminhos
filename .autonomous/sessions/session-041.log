{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_59b3qficukof_1","type":"tool_result","content":"1\timport { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\n2\timport fs from 'fs';\n3\timport path from 'path';\n4\timport os from 'os';\n5\t\n6\t// ----------------------------------------------------------------------------\n7\t// Mocks\n8\t// ----------------------------------------------------------------------------\n9\t\n10\tconst mockRedisGet = vi.fn();\n11\tconst mockRedisPing = vi.fn();\n12\t\n13\tvi.mock('@/lib/redis', () => ({\n14\t  getRedisClient: () =>\n15\t    Promise.resolve({\n16\t      get: (...args: unknown[]) => mockRedisGet(...args),\n17\t      ping: () => mockRedisPing(),\n18\t    }),\n19\t}));\n20\t\n21\tbeforeEach(() => {\n22\t  vi.clearAllMocks();\n23\t  mockRedisPing.mockResolvedValue('PONG');\n24\t});\n25\t\n26\tafterEach(() => {\n27\t  // Limpa env vars temporárias\n28\t  delete process.env.TRANSITS_FALLBACK_PATH;\n29\t});\n30\t\n31\t// ----------------------------------------------------------------------------\n32\t// Tests\n33\t// ----------------------------------------------------------------------------\n34\t\n35\tdescribe('GET /api/akasha/transits/today', () => {\n36\t  it('retorna 200 com payload do Redis quando cache hit', async () => {\n37\t    const transits = { sun: 'Leão', moon: 'Escorpião' };\n38\t    mockRedisGet.mockResolvedValueOnce(JSON.stringify(transits));\n39\t\n40\t    const { GET } = await import('@/app/api/akasha/transits/today/route');\n41\t    const res = await GET();\n42\t\n43\t    expect(res.status).toBe(200);\n44\t    const body = await res.json();\n45\t    expect(body.source).toBe('redis');\n46\t    expect(body.transits).toEqual(transits);\n47\t    expect(body.date).toMatch(/^\\d{4}-\\d{2}-\\d{2}$/);\n48\t  });\n49\t\n50\t  it('retorna 200 com payload do fallback quando Redis nao tem a chave', async () => {\n51\t    // Cria arquivo de fallback temporário\n52\t    const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'transits-'));\n53\t    const fallbackPath = path.join(tmpDir, 'transits.json');\n54\t    const today = new Date().toISOString().split('T')[0];\n55\t    fs.writeFileSync(\n56\t      fallbackPath,\n57\t      JSON.stringify({\n58\t        [today]: { sun: 'Capricórnio' },\n59\t      })\n60\t    );\n61\t    process.env.TRANSITS_FALLBACK_PATH = fallbackPath;\n62\t\n63\t    mockRedisGet.mockResolvedValueOnce(null);\n64\t\n65\t    const { GET } = await import('@/app/api/akasha/transits/today/route');\n66\t    const res = await GET();\n67\t\n68\t    expect(res.status).toBe(200);\n69\t    const body = await res.json();\n70\t    expect(body.source).toBe('fallback');\n71\t    expect(body.transits).toEqual({ sun: 'Capricórnio' });\n72\t\n73\t    fs.rmSync(tmpDir, { recursive: true });\n74\t  });\n75\t\n76\t  it('retorna 503 com mensagem clara quando nem Redis nem fallback estao disponiveis', async () => {\n77\t    mockRedisGet.mockResolvedValueOnce(null);\n78\t    // Sem arquivo de fallback\n79\t    const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'transits-empty-'));\n80\t    process.env.TRANSITS_FALLBACK_PATH = path.join(tmpDir, 'nope.json');\n81\t\n82\t    const { GET } = await import('@/app/api/akasha/transits/today/route');\n83\t    const res = await GET();\n84\t\n85\t    expect(res.status).toBe(503);\n86\t    const body = await res.json();\n87\t    expect(body.source).toBe('none');\n88\t    expect(body.error).toBe('trânsitos_do_dia_indisponíveis');\n89\t    expect(body.message).toMatch(/meia-noite UTC/);\n90\t\n91\t    fs.rmSync(tmpDir, { recursive: true });\n92\t  });\n93\t\n94\t  it('inclui header Cache-Control para reduzir carga no Redis', async () => {\n95\t    mockRedisGet.mockResolvedValueOnce(JSON.stringify({ sun: 'Áries' }));\n96\t\n97\t    const { GET } = await import('@/app/api/akasha/transits/today/route');\n98\t    const res = await GET();\n99\t\n100\t    const cacheControl = res.headers.get('Cache-Control');\n101\t    expect(cacheControl).toMatch(/max-age=/);\n102\t  });\n103\t});\n104\t"}]},"parent_tool_use_id":null,"session_id":"b459875f-3ba4-4621-8745-06538d188ad4","uuid":"50c75681-5f73-4044-bc5b-95e82c5fbe72","timestamp":"2026-06-12T01:13:11.580Z","tool_use_result":{"type":"text","file":{"filePath":"/home/skynet/cabala-dos-caminhos/tests/api/akasha/transits/today.test.ts","content":"import { describe, it, expect, vi, beforeEach, afterEach } from 'vitest';\nimport fs from 'fs';\nimport path from 'path';\nimport os from 'os';\n\n// ----------------------------------------------------------------------------\n// Mocks\n// ----------------------------------------------------------------------------\n\nconst mockRedisGet = vi.fn();\nconst mockRedisPing = vi.fn();\n\nvi.mock('@/lib/redis', () => ({\n  getRedisClient: () =>\n    Promise.resolve({\n      get: (...args: unknown[]) => mockRedisGet(...args),\n      ping: () => mockRedisPing(),\n    }),\n}));\n\nbeforeEach(() => {\n  vi.clearAllMocks();\n  mockRedisPing.mockResolvedValue('PONG');\n});\n\nafterEach(() => {\n  // Limpa env vars temporárias\n  delete process.env.TRANSITS_FALLBACK_PATH;\n});\n\n// ----------------------------------------------------------------------------\n// Tests\n// ----------------------------------------------------------------------------\n\ndescribe('GET /api/akasha/transits/today', () => {\n  it('retorna 200 com payload do Redis quando cache hit', async () => {\n    const transits = { sun: 'Leão', moon: 'Escorpião' };\n    mockRedisGet.mockResolvedValueOnce(JSON.stringify(transits));\n\n    const { GET } = await import('@/app/api/akasha/transits/today/route');\n    const res = await GET();\n\n    expect(res.status).toBe(200);\n    const body = await res.json();\n    expect(body.source).toBe('redis');\n    expect(body.transits).toEqual(transits);\n    expect(body.date).toMatch(/^\\d{4}-\\d{2}-\\d{2}$/);\n  });\n\n  it('retorna 200 com payload do fallback quando Redis nao tem a chave', async () => {\n    // Cria arquivo de fallback temporário\n    const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'transits-'));\n    const fallbackPath = path.join(tmpDir, 'transits.json');\n    const today = new Date().toISOString().split('T')[0];\n    fs.writeFileSync(\n      fallbackPath,\n      JSON.stringify({\n        [today]: { sun: 'Capricórnio' },\n      })\n    );\n    process.env.TRANSITS_FALLBACK_PATH = fallbackPath;\n\n    mockRedisGet.mockResolvedValueOnce(null);\n\n    const { GET } = await import('@/app/api/akasha/transits/today/route');\n    const res = await GET();\n\n    expect(res.status).toBe(200);\n    const body = await res.json();\n    expect(body.source).toBe('fallback');\n    expect(body.transits).toEqual({ sun: 'Capricórnio' });\n\n    fs.rmSync(tmpDir, { recursive: true });\n  });\n\n  it('retorna 503 com mensagem clara quando nem Redis nem fallback estao disponiveis', async () => {\n    mockRedisGet.mockResolvedValueOnce(null);\n    // Sem arquivo de fallback\n    const tmpDir = fs.mkdtempSync(path.join(os.tmpdir(), 'transits-empty-'));\n    process.env.TRANSITS_FALLBACK_PATH = path.join(tmpDir, 'nope.json');\n\n    const { GET } = await import('@/app/api/akasha/transits/today/route');\n    const res = await GET();\n\n    expect(res.status).toBe(503);\n    const body = await res.json();\n    expect(body.source).toBe('none');\n    expect(body.error).toBe('trânsitos_do_dia_indisponíveis');\n    expect(body.message).toMatch(/meia-noite UTC/);\n\n    fs.rmSync(tmpDir, { recursive: true });\n  });\n\n  it('inclui header Cache-Control para reduzir carga no Redis', async () => {\n    mockRedisGet.mockResolvedValueOnce(JSON.stringify({ sun: 'Áries' }));\n\n    const { GET } = await import('@/app/api/akasha/transits/today/route');\n    const res = await GET();\n\n    const cacheControl = res.headers.get('Cache-Control');\n    expect(cacheControl).toMatch(/max-age=/);\n  });\n});\n","numLines":104,"startLine":1,"totalLines":104}}}
