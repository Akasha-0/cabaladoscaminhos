{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_w15vmacfs2lv_1","type":"tool_result","content":"1\timport { cookies } from 'next/headers';\n2\timport { redirect } from 'next/navigation';\n3\timport Link from 'next/link';\n4\t\n5\ttype Ritual = {\n6\t  titulo: string;\n7\t  instrucao: string;\n8\t  cor: string;\n9\t  elemento: string;\n10\t  herbs?: string[];\n11\t};\n12\t\n13\ttype TensionPoint = {\n14\t  pillar: string;\n15\t  theme: string;\n16\t  intensity: number;\n17\t  affectedBody?: number;\n18\t  affectedElement?: string;\n19\t};\n20\t\n21\ttype DailyReading = {\n22\t  date: string;\n23\t  climate: string;\n24\t  ritual: Ritual;\n25\t  alert: string;\n26\t  tensionPoint: TensionPoint;\n27\t  moonPhase?: string | null;\n28\t  overallTheme?: string | null;\n29\t};\n30\t\n31\t// ── Paleta Akasha ────────────────────────────────────────────────────────────\n32\tconst C = {\n33\t  violeta: '#7C5CFF',\n34\t  aurora:  '#2DD4BF',\n35\t  dourado: '#F0B429',\n36\t  magenta: '#FB5781',\n37\t  bgVoid:  '#06070F',\n38\t  bgDeep:  '#0B0E1C',\n39\t  bgNeb:   '#141A33',\n40\t  txtPri:  '#F4F5FF',\n41\t  txtSec:  '#A7AECF',\n42\t  txtMut:  '#5C6691',\n43\t} as const;\n44\t\n45\t// ── Nomes dos pilares ────────────────────────────────────────────────────────\n46\tconst PILLAR_LABELS: Record<string, string> = {\n47\t  astrology: 'Astrologia',\n48\t  kabala:    'Kabala',\n49\t  tantra:    'Tantra',\n50\t  odus:      'Odus do Ifá',\n51\t};\n52\t\n53\tconst TANTRIC_BODIES: Record<number, string> = {\n54\t  1:  'Alma (Atma)',\n55\t  2:  'Prânico',\n56\t  3:  'Negativo',\n57\t  4:  'Neutro',\n58\t  5:  'Físico',\n59\t  6:  'Arcline',\n60\t  7:  'Aura',\n61\t  8:  'Radiante',\n62\t  9:  'Sutil',\n63\t  10: 'Divino',\n64\t  11: 'Comando (Ajna)',\n65\t};\n66\t\n67\t// ── Estilos ──────────────────────────────────────────────────────────────────\n68\t\n69\tconst wrapStyle: React.CSSProperties = {\n70\t  background: C.bgVoid,\n71\t  minHeight: '100dvh',\n72\t  overflowY: 'scroll',\n73\t  scrollSnapType: 'y mandatory',\n74\t  WebkitOverflowScrolling: 'touch',\n75\t};\n76\t\n77\tconst screenStyle: React.CSSProperties = {\n78\t  scrollSnapAlign: 'start',\n79\t  minHeight: '100dvh',\n80\t  display: 'flex',\n81\t  flexDirection: 'column',\n82\t  justifyContent: 'center',\n83\t  padding: '48px 20px 64px',\n84\t};\n85\t\n86\tconst innerStyle: React.CSSProperties = {\n87\t  maxWidth: 560,\n88\t  margin: '0 auto',\n89\t  width: '100%',\n90\t};\n91\t\n92\tconst cardStyle = (borderColor: string): React.CSSProperties => ({\n93\t  background: 'rgba(11,14,28,0.72)',\n94\t  backdropFilter: 'blur(12px)',\n95\t  WebkitBackdropFilter: 'blur(12px)',\n96\t  border: `1px solid ${borderColor}44`,\n97\t  borderLeft: `3px solid ${borderColor}`,\n98\t  borderRadius: 14,\n99\t  padding: '24px 24px 20px',\n100\t  marginBottom: 16,\n101\t});\n102\t\n103\tconst labelStyle = (color: string): React.CSSProperties => ({\n104\t  fontSize: '0.62rem',\n105\t  fontFamily: 'var(--font-cinzel, serif)',\n106\t  letterSpacing: '0.2em',\n107\t  textTransform: 'uppercase',\n108\t  color,\n109\t  marginBottom: 12,\n110\t  display: 'block',\n111\t});\n112\t\n113\tconst headlineStyle: React.CSSProperties = {\n114\t  fontSize: '1.15rem',\n115\t  fontFamily: 'var(--font-cinzel, serif)',\n116\t  color: C.txtPri,\n117\t  marginBottom: 10,\n118\t  lineHeight: 1.4,\n119\t};\n120\t\n121\tconst bodyStyle: React.CSSProperties = {\n122\t  color: C.txtSec,\n123\t  fontSize: '0.9rem',\n124\t  lineHeight: 1.75,\n125\t};\n126\t\n127\tconst badgeStyle = (color: string): React.CSSProperties => ({\n128\t  display: 'inline-block',\n129\t  background: `${color}1A`,\n130\t  border: `1px solid ${color}55`,\n131\t  borderRadius: 20,\n132\t  padding: '3px 12px',\n133\t  fontSize: '0.72rem',\n134\t  letterSpacing: '0.08em',\n135\t  color,\n136\t  marginRight: 8,\n137\t  marginBottom: 8,\n138\t});\n139\t\n140\tconst pillStyle: React.CSSProperties = {\n141\t  display: 'inline-flex',\n142\t  alignItems: 'center',\n143\t  gap: 6,\n144\t  background: `${C.magenta}18`,\n145\t  border: `1px solid ${C.magenta}55`,\n146\t  borderRadius: 8,\n147\t  padding: '6px 14px',\n148\t  fontSize: '0.8rem',\n149\t  color: C.magenta,\n150\t  marginTop: 12,\n151\t  marginBottom: 4,\n152\t};\n153\t\n154\tconst mandalaStyle: React.CSSProperties = {\n155\t  display: 'flex',\n156\t  gap: 8,\n157\t  marginTop: 16,\n158\t  alignItems: 'center',\n159\t};\n160\t\n161\tconst dotStyle = (color: string, size = 10): React.CSSProperties => ({\n162\t  width: size,\n163\t  height: size,\n164\t  borderRadius: '50%',\n165\t  background: color,\n166\t  boxShadow: `0 0 8px ${color}99`,\n167\t  flexShrink: 0,\n168\t});\n169\t\n170\tconst dividerStyle: React.CSSProperties = {\n171\t  borderTop: `1px solid ${C.bgNeb}`,\n172\t  margin: '16px 0',\n173\t};\n174\t\n175\tconst btnStyle: React.CSSProperties = {\n176\t  display: 'block',\n177\t  width: '100%',\n178\t  textAlign: 'center',\n179\t  padding: '14px 0',\n180\t  borderRadius: 12,\n181\t  background: `linear-gradient(135deg, ${C.violeta}22 0%, ${C.aurora}14 100%)`,\n182\t  border: `1px solid ${C.violeta}55`,\n183\t  color: C.violeta,\n184\t  fontSize: '0.88rem',\n185\t  letterSpacing: '0.07em',\n186\t  fontFamily: 'var(--font-cinzel, serif)',\n187\t  textDecoration: 'none',\n188\t  cursor: 'pointer',\n189\t  marginTop: 8,\n190\t};\n191\t\n192\tconst stubBtnStyle: React.CSSProperties = {\n193\t  ...btnStyle,\n194\t  background: `linear-gradient(135deg, ${C.aurora}22 0%, ${C.dourado}14 100%)`,\n195\t  border: `1px solid ${C.aurora}55`,\n196\t  color: C.aurora,\n197\t};\n198\t\n199\tconst screenNumStyle: React.CSSProperties = {\n200\t  fontSize: '0.6rem',\n201\t  color: C.txtMut,\n202\t  letterSpacing: '0.15em',\n203\t  textTransform: 'uppercase',\n204\t  marginBottom: 24,\n205\t};\n206\t\n207\tconst herbsStyle: React.CSSProperties = {\n208\t  marginTop: 10,\n209\t  fontSize: '0.78rem',\n210\t  color: C.txtMut,\n211\t};\n212\t\n213\t// ── Helpers ──────────────────────────────────────────────────────────────────\n214\t\n215\tfunction formatDate(iso: string): string {\n216\t  try {\n217\t    return new Date(iso + 'T12:00:00').toLocaleDateString('pt-BR', {\n218\t      weekday: 'long',\n219\t      day: 'numeric',\n220\t      month: 'long',\n221\t    });\n222\t  } catch {\n223\t    return iso;\n224\t  }\n225\t}\n226\t\n227\tfunction buildGreeting(reading: DailyReading): string {\n228\t  const moon = reading.moonPhase ?? 'Lua';\n229\t  const theme = reading.overallTheme ?? 'Equilíbrio';\n230\t  return `As energias de ${moon} revelam o tema de ${theme} no campo de hoje.`;\n231\t}\n232\t\n233\t// ── Página ───────────────────────────────────────────────────────────────────\n234\t\n235\texport default async function DiarioPage({\n236\t  params,\n237\t}: {\n238\t  params: Promise<{ locale: string }>;\n239\t}) {\n240\t  const { locale } = await params;\n241\t  const cookieStore = await cookies();\n242\t  const token = cookieStore.get('akasha_session')?.value;\n243\t\n244\t  if (!token) redirect(`/${locale}/onboarding`);\n245\t\n246\t  const res = await fetch(\n247\t    `${process.env.NEXT_PUBLIC_APP_URL ?? 'http://localhost:3000'}/api/akasha/daily`,\n248\t    {\n249\t      method: 'GET',\n250\t      headers: { Cookie: `akasha_session=${token}` },\n251\t      cache: 'no-store',\n252\t    }\n253\t  );\n254\t\n255\t  if (res.status === 401 || res.status === 404) redirect(`/${locale}/onboarding`);\n256\t\n257\t  const reading: DailyReading = await res.json();\n258\t\n259\t  const ritual      = reading.ritual as Ritual;\n260\t  const tension     = reading.tensionPoint as TensionPoint;\n261\t  const pillarLabel = PILLAR_LABELS[tension.pillar] ?? tension.pillar;\n262\t  const bodyLabel   = tension.affectedBody ? TANTRIC_BODIES[tension.affectedBody] : null;\n263\t  const greeting    = buildGreeting(reading);\n264\t\n265\t  // Mini-mandala: 3 pontos representando Astrologia (Aurora), Odus (Dourado), Tantra (Violeta)\n266\t  const mandalaColors = [C.aurora, C.dourado, C.violeta];\n267\t\n268\t  return (\n269\t    <div style={wrapStyle}>\n270\t\n271\t      {/* ── Tela 1: Clima Energético ────────────────────────────────────────── */}\n272\t      <div style={screenStyle}>\n273\t        <div style={innerStyle}>\n274\t          <div style={screenNumStyle}>01 / 03 — Clima</div>\n275\t\n276\t          {/* Saudação magnética (Voz do Akasha) */}\n277\t          <div style={cardStyle(C.aurora)}>\n278\t            <span style={labelStyle(C.aurora)}>Voz do Akasha</span>\n279\t            <p style={{ ...bodyStyle, fontStyle: 'italic', color: C.txtPri, marginBottom: 10 }}>\n280\t              {greeting}\n281\t            </p>\n282\t            <div style={{ fontSize: '0.75rem', color: C.txtMut }}>\n283\t              {formatDate(reading.date)}\n284\t            </div>\n285\t          </div>\n286\t\n287\t          {/* Texto de clima */}\n288\t          <div style={cardStyle(C.violeta)}>\n289\t            <span style={labelStyle(C.violeta)}>Clima Energético</span>\n290\t            <p style={bodyStyle}>{reading.climate}</p>\n291\t\n292\t            {/* Badges: fase lunar + tema geral */}\n293\t            <div style={{ marginTop: 14 }}>\n294\t              {reading.moonPhase && (\n295\t                <span style={badgeStyle(C.aurora)}>{reading.moonPhase}</span>\n296\t              )}\n297\t              {reading.overallTheme && (\n298\t                <span style={badgeStyle(C.dourado)}>{reading.overallTheme}</span>\n299\t              )}\n300\t            </div>\n301\t\n302\t            {/* Mini-mandala */}\n303\t            <div style={mandalaStyle}>\n304\t              {mandalaColors.map((color, i) => (\n305\t                <span key={i} style={dotStyle(color)} title={['Astrologia', 'Odus', 'Tantra'][i]} />\n306\t              ))}\n307\t              <span style={{ fontSize: '0.65rem', color: C.txtMut, marginLeft: 4 }}>\n308\t                pilares ativos\n309\t              </span>\n310\t            </div>\n311\t          </div>\n312\t\n313\t          {/* Hint de scroll */}\n314\t          <div style={{ textAlign: 'center', marginTop: 24, color: C.txtMut, fontSize: '0.7rem' }}>\n315\t            role para baixo ↓\n316\t          </div>\n317\t        </div>\n318\t      </div>\n319\t\n320\t      {/* ── Tela 2: Desafio do Dia ──────────────────────────────────────────── */}\n321\t      <div style={screenStyle}>\n322\t        <div style={innerStyle}>\n323\t          <div style={screenNumStyle}>02 / 03 — Desafio</div>\n324\t\n325\t          <div style={cardStyle(C.magenta)}>\n326\t            <span style={labelStyle(C.magenta)}>Desafio do Dia</span>\n327\t            <h2 style={headlineStyle}>{tension.theme}</h2>\n328\t\n329\t            {/* Corpo tântrico afetado */}\n330\t            {bodyLabel && (\n331\t              <div style={pillStyle}>\n332\t                <span style={dotStyle(C.magenta, 8)} />\n333\t                Corpo tântrico em tensão: <strong style={{ marginLeft: 4 }}>{bodyLabel}</strong>\n334\t              </div>\n335\t            )}\n336\t\n337\t            {/* Pilar em tensão */}\n338\t            <div style={{ marginTop: 12, marginBottom: 4 }}>\n339\t              <span style={badgeStyle(C.magenta)}>Pilar: {pillarLabel}</span>\n340\t              <span style={badgeStyle(C.txtMut)}>\n341\t                Intensidade: {tension.intensity}/100\n342\t              </span>\n343\t            </div>\n344\t\n345\t            <div style={dividerStyle} />\n346\t\n347\t            {/* Orientação prática */}\n348\t            <span style={labelStyle(C.violeta)}>Orientação</span>\n349\t            <p style={bodyStyle}>{reading.alert}</p>\n350\t          </div>\n351\t\n352\t          <div style={{ textAlign: 'center', marginTop: 24, color: C.txtMut, fontSize: '0.7rem' }}>\n353\t            role para baixo ↓\n354\t          </div>\n355\t        </div>\n356\t      </div>\n357\t\n358\t      {/* ── Tela 3: A Prescrição ────────────────────────────────────────────── */}\n359\t      <div style={screenStyle}>\n360\t        <div style={innerStyle}>\n361\t          <div style={screenNumStyle}>03 / 03 — Prescrição</div>\n362\t\n363\t          <div style={cardStyle(C.dourado)}>\n364\t            <span style={labelStyle(C.dourado)}>A Prescrição do Dia</span>\n365\t            <h2 style={{ ...headlineStyle, color: C.dourado }}>{ritual.titulo}</h2>\n366\t            <p style={bodyStyle}>{ritual.instrucao}</p>\n367\t\n368\t            <div style={{ marginTop: 14 }}>\n369\t              <span style={badgeStyle(C.dourado)}>Cor: {ritual.cor}</span>\n370\t              <span style={badgeStyle(C.dourado)}>Elemento: {ritual.elemento}</span>\n371\t            </div>\n372\t\n373\t            {ritual.herbs && ritual.herbs.length > 0 && (\n374\t              <p style={herbsStyle}>\n375\t                Ervas sugeridas: {ritual.herbs.join(', ')}\n376\t              </p>\n377\t            )}\n378\t          </div>\n379\t\n380\t          {/* Botão stub \"Realizado\" */}\n381\t          <button\n382\t            style={stubBtnStyle}\n383\t            aria-label=\"Marcar ritual como realizado\"\n384\t            onClick={undefined /* stub — POST /api/akasha/ritual/complete */}\n385\t          >\n386\t            Realizado ✓\n387\t          </button>\n388\t\n389\t          {/* Link para o Oráculo */}\n390\t          <Link href={`/${locale}/oraculo`} style={btnStyle}>\n391\t            Consultar Oráculo →\n392\t          </Link>\n393\t        </div>\n394\t      </div>\n395\t\n396\t    </div>\n397\t  );\n398\t}\n399\t"}]},"parent_tool_use_id":null,"session_id":"d38a58d5-31a6-4161-80e1-d8d9df0b821e","uuid":"5ff3aefa-0c26-46fd-8765-fb1d05160c12","timestamp":"2026-06-11T11:25:55.998Z","tool_use_result":{"type":"text","file":{"filePath":"/home/skynet/cabala-dos-caminhos/apps/akasha-portal/src/app/[locale]/(akasha)/diario/page.tsx","content":"import { cookies } from 'next/headers';\nimport { redirect } from 'next/navigation';\nimport Link from