{"type":"user","message":{"role":"user","content":[{"tool_use_id":"call_function_2in1srgo82wl_2","type":"tool_result","content":"1\t/**\n2\t * GET /api/akasha/mandato-do-dia\n3\t * Retorna o Mandato do Dia (MandatoEsqueleto) calculado pelo\n4\t * @akasha/core `calcular()` para o usuário autenticado.\n5\t *\n6\t * Referência: .autonomous/research/synthesis/synthesis_v1.md §5 (Mandato)\n7\t * F-201 — P0 da Fase 6.\n8\t *\n9\t * Query params:\n10\t *   intencao?: string  (default: \"buscar clareza para o dia\")\n11\t *\n12\t * Response 200 (Mandato do Dia):\n13\t *   {\n14\t *     date: 'YYYY-MM-DD',\n15\t *     escala: 'D' | 'S' | 'Z' | 'V',\n16\t *     pilares_relevantes: string[],\n17\t *     redacao_bruta: string,\n18\t *     cita_fontes: string[],\n19\t *     mentor_hook: { intencao, crise_detectada, recurso }\n20\t *   }\n21\t *\n22\t * Erros:\n23\t *   400 — dados natais incompletos ou input inválido\n24\t *   401 — sem sessão\n25\t *   404 — sem Mapa Natal persistido (redireciona ao onboarding)\n26\t *   500 — falha inesperada de cálculo\n27\t *\n28\t * IMPORTANTE (Ethics Charter §5 — Pilar 3):\n29\t *   Se a intenção do usuário dispara o detector de crise, o endpoint\n30\t *   retorna 200 normalmente, mas o `mentor_hook.recurso` vem como\n31\t *   'CVV-188' e o cliente deve EXIBIR a sugestão de recurso humano\n32\t *   em vez de renderizar `redacao_bruta` no Mentor.\n33\t */\n34\timport { AkashaInputSchema, calcular, type MandatoEsqueleto } from '@akasha/core';\n35\timport { NextRequest, NextResponse } from 'next/server';\n36\timport { requireAkashaApi } from '@/lib/application/auth/akasha-guard';\n37\timport { prisma } from '@/lib/infrastructure/prisma';\n38\t\n39\t// Intent default — primeira chamada sem query param.\n40\tconst INTENCAO_DEFAULT = 'buscar clareza para o dia';\n41\t\n42\tfunction formatISODate(d: Date): string {\n43\t  return d.toISOString().split('T')[0];\n44\t}\n45\t\n46\tfunction parseHora(time: string | null | undefined): string | undefined {\n47\t  if (!time) return undefined;\n48\t  // Aceita \"HH:MM\" ou \"HH:MM:SS\"; normaliza para \"HH:MM\".\n49\t  const m = /^(\\d{2}):(\\d{2})(?::\\d{2})?$/.exec(time);\n50\t  if (!m) return undefined;\n51\t  return `${m[1]}:${m[2]}`;\n52\t}\n53\t\n54\texport async function GET(request: NextRequest) {\n55\t  // 1. Autenticar.\n56\t  const authResult = await requireAkashaApi(request);\n57\t  if (authResult instanceof NextResponse) return authResult;\n58\t  const { id: userId, name } = authResult;\n59\t\n60\t  // 2. Resolver intent (query param → default validado).\n61\t  const rawIntencao = request.nextUrl.searchParams.get('intencao')?.trim() ?? INTENCAO_DEFAULT;\n62\t\n63\t  // 3. Carregar birthChart + dados natais do usuário.\n64\t  const [birthChart, user] = await Promise.all([\n65\t    prisma.birthChart.findUnique({ where: { userId } }),\n66\t    prisma.user.findUnique({\n67\t      where: { id: userId },\n68\t      select: { birthDate: true, birthTime: true, birthCity: true },\n69\t    }),\n70\t  ]);\n71\t\n72\t  if (!birthChart) {\n73\t    return NextResponse.json(\n74\t      { error: 'Mapa natal não encontrado — conclua o onboarding' },\n75\t      { status: 404 }\n76\t    );\n77\t  }\n78\t\n79\t  if (!user?.birthDate) {\n80\t    return NextResponse.json(\n81\t      { error: 'Dados natais incompletos — atualize seu perfil' },\n82\t      { status: 400 }\n83\t    );\n84\t  }\n85\t\n86\t  // 4. Construir AkashaInput validado por Zod.\n87\t  const inputParse = AkashaInputSchema.safeParse({\n88\t    nome: name,\n89\t    data_nascimento: formatISODate(user.birthDate),\n90\t    hora_nascimento: parseHora(user.birthTime),\n91\t    local_nascimento: user.birthCity ?? 'local não informado',\n92\t    intencao_inicial: rawIntencao,\n93\t  });\n94\t\n95\t  if (!inputParse.success) {\n96\t    return NextResponse.json(\n97\t      { error: 'Entrada inválida para cálculo do Mandato', details: inputParse.error.flatten() },\n98\t      { status: 400 }\n99\t    );\n100\t  }\n101\t\n102\t  // 5. Calcular Mandato via orquestrador R-030.\n103\t  let leitura;\n104\t  try {\n105\t    leitura = await calcular(inputParse.data);\n106\t  } catch (err) {\n107\t    console.error('[mandato-do-dia] calcular() falhou', err);\n108\t    return NextResponse.json({ error: 'Falha ao calcular Mandato do Dia' }, { status: 500 });\n109\t  }\n110\t\n111\t  // 6. Devolver apenas o Mandato (PII mínima) + hook do Mentor.\n112\t  const { mandato, mentor_hook } = leitura;\n113\t  const date = formatISODate(new Date());\n114\t\n115\t  const response: {\n116\t    date: string;\n117\t    mandato: MandatoEsqueleto;\n118\t    mentor_hook: typeof mentor_hook;\n119\t  } = { date, mandato, mentor_hook };\n120\t\n121\t  return NextResponse.json(response);\n122\t}\n123\t"}]},"parent_tool_use_id":null,"session_id":"d38a58d5-31a6-4161-80e1-d8d9df0b821e","uuid":"52a9c5ee-572e-41ce-84a1-4060bcdf58be","timestamp":"2026-06-11T11:25:48.067Z","tool_use_result":{"type":"text","file":{"filePath":"/home/skynet/cabala-dos-caminhos/apps/akasha-portal/src/app/api/akasha/mandato-do-dia/route.ts","content":"/**\n * GET /api/akasha/mandato-do-dia\n * Retorna o Mandato do Dia (MandatoEsqueleto) calculado pelo\n * @akasha/core `calcular()` para o usuário autenticado.\n *\n * Referência: .autonomous/research/synthesis/synthesis_v1.md §5 (Mandato)\n * F-201 — P0 da Fase 6.\n *\n * Query params:\n *   intencao?: string  (default: \"buscar clareza para o dia\")\n *\n * Response 200 (Mandato do Dia):\n *   {\n *     date: 'YYYY-MM-DD',\n *     escala: 'D' | 'S' | 'Z' | 'V',\n *     pilares_relevantes: string[],\n *     redacao_bruta: string,\n *     cita_fontes: string[],\n *     mentor_hook: { intencao, crise_detectada, recurso }\n *   }\n *\n * Erros:\n *   400 — dados natais incompletos ou input inválido\n *   401 — sem sessão\n *   404 — sem Mapa Natal persistido (redireciona ao onboarding)\n *   500 — falha inesperada de cálculo\n *\n * IMPORTANTE (Ethics Charter §5 — Pilar 3):\n *   Se a intenção do usuário dispara o detector de crise, o endpoint\n *   retorna 200 normalmente, mas o `mentor_hook.recurso` vem como\n *   'CVV-188' e o cliente deve EXIBIR a sugestão de recurso humano\n *   em vez de renderizar `redacao_bruta` no Mentor.\n */\nimport { AkashaInputSchema, calcular, type MandatoEsqueleto } from '@akasha/core';\nimport { NextRequest, NextResponse } from 'next/server';\nimport { requireAkashaApi } from '@/lib/application/auth/akasha-guard';\nimport { prisma } from '@/lib/infrastructure/prisma';\n\n// Intent default — primeira chamada sem query param.\nconst INTENCAO_DEFAULT = 'buscar clareza para o dia';\n\nfunction formatISODate(d: Date): string {\n  return d.toISOString().split('T')[0];\n}\n\nfunction parseHora(time: string | null | undefined): string | undefined {\n  if (!time) return undefined;\n  // Aceita \"HH:MM\" ou \"HH:MM:SS\"; normaliza para \"HH:MM\".\n  const m = /^(\\d{2}):(\\d{2})(?::\\d{2})?$/.exec(time);\n  if (!m) return undefined;\n  return `${m[1]}:${m[2]}`;\n}\n\nexport async function GET(request: NextRequest) {\n  // 1. Autenticar.\n  const authResult = await requireAkashaApi(request);\n  if (authResult instanceof NextResponse) return authResult;\n  const { id: userId, name } = authResult;\n\n  // 2. Resolver intent (query param → default validado).\n  const rawIntencao = request.nextUrl.searchParams.get('intencao')?.trim() ?? INTENCAO_DEFAULT;\n\n  // 3. Carregar birthChart + dados natais do usuário.\n  const [birthChart, user] = await Promise.all([\n    prisma.birthChart.findUnique({ where: { userId } }),\n    prisma.user.findUnique({\n      where: { id: userId },\n      select: { birthDate: true, birthTime: true, birthCity: true },\n    }),\n  ]);\n\n  if (!birthChart) {\n    return NextResponse.json(\n      { error: 'Mapa natal não encontrado — conclua o onboarding' },\n      { status: 404 }\n    );\n  }\n\n  if (!user?.birthDate) {\n    return NextResponse.json(\n      { error: 'Dados natais incompletos — atualize seu perfil' },\n      { status: 400 }\n    );\n  }\n\n  // 4. Construir AkashaInput validado por Zod.\n  const inputParse = AkashaInputSchema.safeParse({\n    nome: name,\n    data_nascimento: formatISODate(user.birthDate),\n    hora_nascimento: parseHora(user.birthTime),\n    local_nascimento: user.birthCity ?? 'local não informado',\n    intencao_inicial: rawIntencao,\n  });\n\n  if (!inputParse.success) {\n    return NextResponse.json(\n      { error: 'Entrada inválida para cálculo do Mandato', details: inputParse.error.flatten() },\n      { status: 400 }\n    );\n  }\n\n  // 5. Calcular Mandato via orquestrador R-030.\n  let leitura;\n  try {\n    leitura = await calcular(inputParse.data);\n  } catch (err) {\n    console.error('[mandato-do-dia] calcular() falhou', err);\n    return NextResponse.json({ error: 'Falha ao calcular Mandato do Dia' }, { status: 500 });\n  }\n\n  // 6. Devolver apenas o Mandato (PII mínima) + hook do Mentor.\n  const { mandato, mentor_hook } = leitura;\n  const date = formatISODate(new Date());\n\n  const response: {\n    date: string;\n    mandato: MandatoEsqueleto;\n    mentor_hook: typeof mentor_hook;\n  } = { date, mandato, mentor_hook };\n\n  return NextResponse.json(response);\n}\n","numLines":123,"startLine":1,"totalLines":123}}}
