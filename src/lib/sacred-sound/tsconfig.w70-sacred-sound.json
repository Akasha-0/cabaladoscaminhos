{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": [],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "incremental": false,
    "allowImportingTsExtensions": true,
    "lib": ["ES2022", "DOM"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "frequencies.ts",
    "mantras.ts",
    "play-session.ts",
    "healing-protocol.ts",
    "index.ts",
    "globs.d.ts",
    "__tests__/**/*.ts"
  ],
  "exclude": ["node_modules", "__tests__/smoke/**"]
}