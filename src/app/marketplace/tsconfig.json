{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@/*": ["../../*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "../../lib/engines/marketplace/**/*.ts", "../../engine/marketplace/**/*.ts", "../../components/ui/*.tsx", "../../lib/utils.ts"]
}